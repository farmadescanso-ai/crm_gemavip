## Base
NODE_ENV=development

## MySQL (si aplica)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
# Debe coincidir con la BD donde están los datos (crm_gemavip o crm_farmadescanso)
DB_NAME=crm_gemavip
DB_SSL=false
# En Vercel/serverless se usa 3 por defecto; localmente 10. Sobrescribe si necesitas otro valor.
# DB_CONNECTION_LIMIT=3

# Índices: por defecto NO se crean en startup (evita bloqueo de tablas en producción).
# Solo desarrollo: ENABLE_INDEX_CREATION_ON_STARTUP=1 para crear índices al conectar.
# Producción: usar scripts/indices-migracion.sql o POST /api/db/ensure-indexes manualmente.
# ENABLE_INDEX_CREATION_ON_STARTUP=0

# Sesiones: intervalo de limpieza de sesiones expiradas (ms). Por defecto 900000 (15 min).
# SESSION_CHECK_EXPIRATION_MS=900000

## Seguridad (obligatorio en producción)
# SESSION_SECRET: obligatorio en producción. Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

## Seguridad API
# Si defines API_KEY en Vercel, la API exigirá el header X-API-Key
API_KEY=

## Fix FK notificaciones (ejecutar una vez y quitar)
# FIX_NOTIF_FK_ON_STARTUP=1

## Pool de clientes (pendientes de asignar)
# ID del comercial "pool": clientes con cli_com_id=26 están sin asignar. Los comerciales ven sus clientes + los del pool.
# Prioridad: COMERCIAL_POOL_ID > COMERCIAL_POOL_NAME. El comercial con este ID no puede iniciar sesión.
COMERCIAL_POOL_ID=26
# Alternativa: buscar por nombre (ej. "Paco Lara"). Solo si COMERCIAL_POOL_ID no está definido.
# COMERCIAL_POOL_NAME=Paco Lara

## Sesión (UI)
# Cierre automático por inactividad (minutos)
SESSION_IDLE_TIMEOUT_MINUTES=60

# (Compatibilidad) Si no defines SESSION_IDLE_TIMEOUT_MINUTES:
SESSION_MAX_AGE_DAYS=30

## Holded (sincronización de pedidos)
# API Key para scripts/sync-pedidos-holded.js (solo pedidos Provincia Murcia)
HOLDED_API_KEY=
# Emails con acceso a /admin/importar-holded (comma-separated). Por defecto: info@farmadescanso.com
# SYSTEM_ADMIN_EMAILS=info@farmadescanso.com,otro@email.com

## N8N (envío de pedidos)
# Webhook de N8N que recibirá el pedido y el Excel adjunto (multipart/form-data).
# Ejemplo: https://n8n.tu-dominio.com/webhook/gemavip-pedidos
N8N_PEDIDOS_WEBHOOK_URL=

## Web Push (notificaciones en el navegador)
# Generar con: node tools/generate-vapid-keys.js
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Webhook n8n que recibe todas las notificaciones (solicitud asignación, pedido especial). Por defecto: farmadescanso-n8n.
# NOTIF_WEBHOOK_URL=https://farmadescanso-n8n.6f4r35.easypanel.host/webhook/...

## Envío de pedidos por email (modo actual)
# Destinatario por defecto para el botón ENVIAR en /pedidos
PEDIDOS_MAIL_TO=p.lara@gemavip.com

## SMTP (recuperación de contraseña y envío de emails)
# Obligatorio para que funcione "¿Olvidaste tu contraseña?" y envío de pedidos por email.
# También puedes configurarlo en Admin → Configuración Email (variables_sistema).
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=noreply@tudominio.com
# SMTP_PASS=tu_contraseña_o_app_password
# MAIL_FROM=noreply@tudominio.com
# Si lo activas, además de enviar email intentará enviar a N8N (mantiene el código, desactivado por defecto)
N8N_PEDIDOS_ENABLED=0

