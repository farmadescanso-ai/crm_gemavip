{
  "name": "farmadescaso-crm",
  "version": "1.0.0",
  "description": "Portal CRM para comerciales de Farmadescaso 2021 SL",
  "main": "api/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node api/index.js",
    "dev": "nodemon api/index.js",
    "build": "echo \"no build step\"",
    "purge:youbelle:preview": "node tools/purge-youbelle.js --term \"Youbelle\"",
    "purge:youbelle:apply": "node tools/purge-youbelle.js --term \"Youbelle\" --apply",
    "copy-tarifa-mirafarma-to-pvl": "node tools/copy-tarifa-mirafarma-to-pvl.js",
    "fix-login": "node tools/fix-login-password.js",
    "hash-comerciales-passwords": "node scripts/hash-comerciales-passwords.js",
    "normalizar-clientes-espana": "node scripts/normalizar-clientes-espana.js",
    "sync:holded-pedidos": "node scripts/sync-pedidos-holded.js",
    "export:clientes-holded": "node scripts/export-clientes-holded-excel.js",
    "export:holded-contactos-crm": "node scripts/export-holded-contactos-crm-excel.js",
    "export:holded-contactos-crm:md": "node scripts/export-holded-contactos-crm-excel.js --md",
    "normalizar-clientes-espana:dry": "node scripts/normalizar-clientes-espana.js --dry-run",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ejs-xss-smoke": "jest --testPathPatterns=ejs-xss-smoke",
    "murciasalud:centros-sql": "node scripts/murciasalud-centros-prescriptores-sql.js"
  },
  "keywords": [
    "farmadescaso",
    "crm",
    "comerciales",
    "mysql"
  ],
  "author": "Farmadescaso 2021 SL",
  "license": "MIT",
  "dependencies": {
    "@vercel/speed-insights": "^1.2.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "googleapis": "^166.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.0",
    "mysql2": "^3.6.5",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.10",
    "pdf-parse": "^1.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
