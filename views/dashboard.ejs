<%- include('partials/header', { title: 'Dashboard' }) %>

<% const isAdmin = user && (user.roles || []).some((r) => String(r).toLowerCase().includes('admin')); %>
<% const errs = typeof dashboardErrors !== 'undefined' ? (dashboardErrors || {}) : {}; %>
<% const f = typeof filters !== 'undefined' ? filters : {}; %>
<% const periodOpts = typeof periodOptions !== 'undefined' ? periodOptions : []; %>
<% const zonasList = (typeof zonas !== 'undefined' && zonas) ? zonas : []; %>
<% const comercialesListSafe = (typeof comercialesList !== 'undefined' && comercialesList) ? comercialesList : []; %>
<% const marcasListSafe = (typeof marcasList !== 'undefined' && marcasList) ? marcasList : []; %>

<% if (isAdmin && (errs.clientes || errs.pedidos || errs.rankingComerciales || errs.rankingZona || errs.rankingProductos)) { %>
  <section class="card" style="margin-bottom: 16px; border-color: #dc2626;">
    <div class="card-hd" style="background: #fef2f2;">
      <h2 class="card-title" style="color: #dc2626;">Errores al cargar el Dashboard</h2>
    </div>
    <div class="card-bd" style="font-family: monospace; font-size: 13px; white-space: pre-wrap; word-break: break-word;">
      <% if (errs.clientes) { %><p><strong>Contactos:</strong> <%= errs.clientes %></p><% } %>
      <% if (errs.pedidos) { %><p><strong>Pedidos:</strong> <%= errs.pedidos %></p><% } %>
      <% if (errs.rankingComerciales) { %><p><strong>Ranking Comerciales:</strong> <%= errs.rankingComerciales %></p><% } %>
      <% if (errs.rankingZona) { %><p><strong>Desglose Zona:</strong> <%= errs.rankingZona %></p><% } %>
      <% if (errs.rankingProductos) { %><p><strong>Ranking Productos:</strong> <%= errs.rankingProductos %></p><% } %>
    </div>
  </section>
<% } %>

<section class="card">
  <div class="card-hd">
    <h1 class="card-title">Dashboard <%= isAdmin ? '· Vista ADMIN' : '· Vista COMERCIAL' %></h1>
    <p class="card-subtitle">
      <%= isAdmin ? 'Panel de control general' : 'Panel de gestión operativa' %>.
      Usuario: <strong><%= user?.nombre ?? user?.name ?? user?.email ?? '—' %></strong>
    </p>
  </div>
  <div class="card-bd">
    <form method="get" action="/dashboard" class="dash-filters" style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin: 0 0 16px 0;">
      <label for="year" style="font-weight:700; color: var(--gv-ink);">Año</label>
      <select id="year" name="year" class="gv-client-picker__q" style="width:auto; min-width: 120px;">
        <option value="all" <%= String(selectedYear || '') === 'all' ? 'selected' : '' %>>Todos</option>
        <% (years || []).forEach((y) => { %>
          <option value="<%= y %>" <%= Number(selectedYear) === Number(y) ? 'selected' : '' %>><%= y %></option>
        <% }) %>
      </select>
      <label for="period" style="font-weight:700; color: var(--gv-ink);">Periodo</label>
      <select id="period" name="period" class="gv-client-picker__q" style="width:auto; min-width: 160px;">
        <% (periodOpts || []).forEach((po) => { %>
          <option value="<%= po.value %>" <%= (f.period || 'acumulado') === po.value ? 'selected' : '' %>><%= po.label %></option>
        <% }) %>
      </select>
      <% if (isAdmin) { %>
        <label for="zone" style="font-weight:700; color: var(--gv-ink);">Zona (CCAA)</label>
        <select id="zone" name="zone" class="gv-client-picker__q" style="width:auto; min-width: 140px;">
          <option value="">Todas</option>
          <% (zonasList || []).forEach((z) => { %>
            <option value="<%= z.value ?? z.codpos_ComunidadAutonoma ?? '' %>" <%= (f.zone || '') === (z.value ?? z.codpos_ComunidadAutonoma ?? '') ? 'selected' : '' %>><%= z.value ?? z.codpos_ComunidadAutonoma ?? '' %></option>
          <% }) %>
        </select>
        <label for="comercial" style="font-weight:700; color: var(--gv-ink);">Comercial</label>
        <select id="comercial" name="comercial" class="gv-client-picker__q" style="width:auto; min-width: 140px;">
          <option value="">Todos</option>
          <% (comercialesListSafe || []).forEach((co) => { %>
            <option value="<%= co.id ?? co.com_id %>" <%= (f.comercial || '') === String(co.id ?? co.com_id ?? '') ? 'selected' : '' %>><%= co.nombre ?? co.com_nombre ?? '' %></option>
          <% }) %>
        </select>
      <% } %>
      <label for="marca" style="font-weight:700; color: var(--gv-ink);">Marca</label>
      <select id="marca" name="marca" class="gv-client-picker__q" style="width:auto; min-width: 120px;">
        <option value="">Todas</option>
        <% (marcasListSafe || []).forEach((m) => { %>
          <option value="<%= m.id ?? m.mar_id %>" <%= (f.marca || '') === String(m.id ?? m.mar_id ?? '') ? 'selected' : '' %>><%= m.nombre ?? m.mar_nombre ?? '' %></option>
        <% }) %>
      </select>
      <% if (!isAdmin) { %>
        <label for="pedidoEstado" style="font-weight:700; color: var(--gv-ink);">Estado pedidos</label>
        <select id="pedidoEstado" name="pedidoEstado" class="gv-client-picker__q" style="width:auto; min-width: 120px;">
          <option value="todos" <%= (f.pedidoEstado || 'todos') === 'todos' ? 'selected' : '' %>>Todos</option>
          <option value="pendiente" <%= (f.pedidoEstado || '') === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
          <option value="entregado" <%= (f.pedidoEstado || '') === 'entregado' ? 'selected' : '' %>>Entregado</option>
        </select>
      <% } %>
      <button class="btn" type="submit">Aplicar</button>
    </form>

    <div class="dash-stats" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap:12px;">
      <div class="dash-stat" data-variant="yellow">
        <div class="dash-stat-label">Ventas Totales</div>
        <div class="dash-stat-value"><%= stats.ventas != null ? fmtEurES(stats.ventas) : '—' %></div>
        <div class="dash-stat-foot"><%= isAdmin ? 'Total' : 'Tus ventas' %></div>
      </div>
      <div class="dash-stat" data-variant="navy">
        <div class="dash-stat-label">Nº Pedidos</div>
        <div class="dash-stat-value"><%= stats.pedidos ?? '—' %></div>
        <div class="dash-stat-foot">En periodo</div>
      </div>
      <div class="dash-stat" data-variant="blue">
        <div class="dash-stat-label">Ticket Medio</div>
        <div class="dash-stat-value"><%= stats.ticketMedio != null ? fmtEurES(stats.ticketMedio) : '—' %></div>
        <div class="dash-stat-foot">Ventas / Pedidos</div>
      </div>
      <div class="dash-stat" data-variant="green">
        <div class="dash-stat-label">Nº Visitas</div>
        <div class="dash-stat-value"><%= stats.visitas ?? '—' %></div>
        <div class="dash-stat-foot">Realizadas</div>
      </div>
      <% if (stats.contactosNuevos != null) { %>
        <div class="dash-stat" data-variant="blue">
          <div class="dash-stat-label">Contactos Nuevos</div>
          <div class="dash-stat-value"><%= stats.contactosNuevos %></div>
          <div class="dash-stat-foot">En periodo</div>
        </div>
      <% } %>
      <% if (isAdmin && stats.farmaciasActivas != null) { %>
        <div class="dash-stat" data-variant="navy">
          <div class="dash-stat-label">Farmacias Activas</div>
          <div class="dash-stat-value"><%= stats.farmaciasActivas %></div>
          <div class="dash-stat-foot">≥1 pedido</div>
        </div>
      <% } %>
      <% if (isAdmin && stats.coberturaCCAA != null) { %>
        <div class="dash-stat" data-variant="blue">
          <div class="dash-stat-label">CCAA Ventas</div>
          <div class="dash-stat-value"><%= stats.coberturaCCAA %></div>
          <div class="dash-stat-foot">Cobertura geográfica</div>
        </div>
      <% } %>
      <% if (!isAdmin && stats.clientesActivos != null) { %>
        <div class="dash-stat" data-variant="navy">
          <div class="dash-stat-label">Clientes Activos</div>
          <div class="dash-stat-value"><%= stats.clientesActivos %></div>
          <div class="dash-stat-foot">Cartera</div>
        </div>
      <% } %>
      <% if (isAdmin && stats.comerciales != null) { %>
        <div class="dash-stat" data-variant="navy">
          <div class="dash-stat-label">Comerciales</div>
          <div class="dash-stat-value"><%= stats.comerciales %></div>
          <div class="dash-stat-foot">Total en BD</div>
        </div>
      <% } %>
    </div>

    <div style="margin-top: 14px; display:flex; gap:10px; flex-wrap:wrap;">
      <a class="btn" href="/clientes">Contactos</a>
      <a class="btn secondary" href="/pedidos">Pedidos</a>
      <a class="btn secondary" href="/visitas">Visitas</a>
    </div>
  </div>
</section>

<% if (isAdmin) { %>
  <div class="dash-grid" style="margin-top: 16px; display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
    <% if ((rankingComerciales || []).length > 0) { %>
      <section class="card dash-card">
        <div class="card-hd">
          <h2 class="card-title">Rendimiento por Comercial</h2>
        </div>
        <div class="card-bd">
          <div class="table-wrap">
            <table class="dash-table">
              <thead><tr><th>Comercial</th><th>Zona</th><th>Ventas €</th><th>Pedidos</th><th>Ticket Medio</th></tr></thead>
              <tbody>
                <% (rankingComerciales || []).forEach((r) => { %>
                  <tr>
                    <td><%= r.Comercial ?? '' %></td>
                    <td><%= r.Zona ?? '—' %></td>
                    <td><%= fmtEurES(r.Ventas ?? 0) %></td>
                    <td><%= r.Pedidos ?? 0 %></td>
                    <td><%= fmtEurES(r.TicketMedio ?? 0) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    <% } %>
    <% if ((rankingZona || []).length > 0) { %>
      <section class="card dash-card">
        <div class="card-hd">
          <h2 class="card-title">Desglose por Zona</h2>
        </div>
        <div class="card-bd">
          <div class="table-wrap">
            <table class="dash-table">
              <thead><tr><th>Zona</th><th>Ventas €</th><th>Pedidos</th><th>Ticket Medio</th></tr></thead>
              <tbody>
                <% (rankingZona || []).forEach((r) => { %>
                  <tr>
                    <td><%= r.Zona ?? '' %></td>
                    <td><%= fmtEurES(r.Ventas ?? 0) %></td>
                    <td><%= r.Pedidos ?? 0 %></td>
                    <td><%= fmtEurES(r.TicketMedio ?? 0) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    <% } %>
  </div>

  <section class="card dash-card" style="margin-top: 16px;">
    <div class="card-hd">
      <h2 class="card-title">Ranking Productos</h2>
    </div>
    <div class="card-bd">
      <div class="table-wrap">
        <table class="dash-table">
          <thead><tr><th>Producto</th><th>Ventas €</th><th>Nº Unidades</th><th>% Total</th></tr></thead>
          <tbody>
            <% (rankingProductos || []).forEach((r) => { %>
              <tr>
                <td><%= r.Producto ?? r.art_nombre ?? '' %></td>
                <td><%= fmtEurES(r.Ventas ?? 0) %></td>
                <td><%= r.Unidades ?? 0 %></td>
                <td><%= (r.PctTotal ?? 0) %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="dash-grid" style="margin-top: 16px; display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
    <section class="card dash-card">
      <div class="card-hd">
        <h2 class="card-title">Contactos con más facturación</h2>
      </div>
      <div class="card-bd">
        <div class="table-wrap">
          <table class="dash-table">
            <thead>
              <tr>
                <th class="dash-th-actions">Acciones</th>
                <th>Nombre</th>
                <th>Población</th>
                <th>Facturación</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody>
              <% (latest.clientes || []).forEach((c) => { %>
                <% const cid = c.Id ?? c.id ?? c.cli_id; %>
                <tr>
                  <td class="dash-td-actions">
                    <a class="btn secondary icon" href="/clientes/<%= cid %>" title="Ver">Ver</a>
                  </td>
                  <td><%= c.Nombre_Razon_Social ?? '' %></td>
                  <td><%= c.Poblacion ?? '' %></td>
                  <td><%= fmtEurES(c.TotalFacturado ?? 0) %></td>
                  <td><span class="badge <%= (c.OK_KO ?? '').toString().toUpperCase() === 'OK' ? 'ok' : 'info' %>"><%= c.OK_KO ?? '—' %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <a class="btn secondary" href="/clientes" style="margin-top:10px; display:inline-block;">Ver todos</a>
      </div>
    </section>
    <section class="card dash-card">
      <div class="card-hd">
        <h2 class="card-title">Últimos pedidos</h2>
      </div>
      <div class="card-bd">
        <div class="table-wrap">
          <table class="dash-table">
            <thead><tr><th class="dash-th-actions">Acciones</th><th>NumPedido</th><th>Fecha</th><th>Total</th><th>Estado</th></tr></thead>
            <tbody>
              <% (latest.pedidos || []).forEach((p) => { %>
                <% const pid = p.Id ?? p.id ?? p.ped_id; %>
                <tr>
                  <td><a class="btn secondary icon" href="/pedidos/<%= pid %>" title="Ver">Ver</a></td>
                  <td><%= p.NumPedido ?? p.ped_numero ?? '' %></td>
                  <td><%= fmtDateES(p.FechaPedido ?? p.ped_fecha ?? '') %></td>
                  <td><%= fmtEurES(p.TotalPedido ?? p.ped_total ?? 0) %></td>
                  <td><%= p.EstadoPedido ?? p.ped_estado_txt ?? '' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <a class="btn secondary" href="/pedidos" style="margin-top:10px; display:inline-block;">Ver todos</a>
      </div>
    </section>
  </div>

  <% if ((latest.visitas || []).length > 0) { %>
  <section class="card dash-card" style="margin-top: 16px;">
    <div class="card-hd"><h2 class="card-title">Últimas visitas</h2></div>
    <div class="card-bd">
      <div class="table-wrap">
        <table class="dash-table">
          <thead><tr><th>Fecha</th><th>Tipo</th><th>Cliente</th><th>Comercial</th><th>Estado</th></tr></thead>
          <tbody>
            <% (latest.visitas || []).forEach((v) => { %>
              <tr>
                <td><%= fmtDateES(v.Fecha ?? '') %></td>
                <td><%= v.TipoVisita ?? '' %></td>
                <td><%= v.ClienteNombre ?? '' %></td>
                <td><%= v.ComercialNombre ?? '' %></td>
                <td><%= v.Estado ?? '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <% } %>

<% } else { %>
  <div class="dash-grid" style="margin-top: 16px; display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
    <section class="card dash-card">
      <div class="card-hd">
        <h2 class="card-title">Mis Clientes (Top Actividad)</h2>
      </div>
      <div class="card-bd">
        <div class="table-wrap">
          <table class="dash-table">
            <thead><tr><th>Cliente</th><th>Ventas €</th><th>Pedidos</th><th>Ticket Med.</th><th>Últ. Visita</th><th>Últ. Pedido</th></tr></thead>
            <tbody>
              <% (latest.clientes || []).forEach((c) => { %>
                <% const cid = c.Id ?? c.id ?? c.cli_id; %>
                <tr>
                  <td><a href="/clientes/<%= cid %>"><%= c.Nombre_Razon_Social ?? '' %></a></td>
                  <td><%= fmtEurES(c.TotalFacturado ?? 0) %></td>
                  <td><%= c.NumPedidos ?? 0 %></td>
                  <td><%= c.TicketMedio != null ? fmtEurES(c.TicketMedio) : '—' %></td>
                  <td><%= fmtDateES(c.UltimaVisita ?? '') %></td>
                  <td><%= fmtDateES(c.UltimoPedido ?? '') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <a class="btn secondary" href="/clientes" style="margin-top:10px; display:inline-block;">Ver todos</a>
      </div>
    </section>
    <section class="card dash-card">
      <div class="card-hd">
        <h2 class="card-title">Pedidos Recientes</h2>
      </div>
      <div class="card-bd">
        <div class="table-wrap">
          <table class="dash-table">
            <thead><tr><th>Fecha</th><th>Cliente</th><th>Nº Ped.</th><th>Importe</th><th>Estado</th></tr></thead>
            <tbody>
              <% (latest.pedidos || []).forEach((p) => { %>
                <% const pid = p.Id ?? p.id ?? p.ped_id; %>
                <tr>
                  <td><%= fmtDateES(p.FechaPedido ?? p.ped_fecha ?? '') %></td>
                  <td><%= p.ClienteNombre ?? '' %></td>
                  <td><a href="/pedidos/<%= pid %>"><%= p.NumPedido ?? p.ped_numero ?? '' %></a></td>
                  <td><%= fmtEurES(p.TotalPedido ?? p.ped_total ?? 0) %></td>
                  <td><%= p.EstadoPedido ?? p.ped_estado_txt ?? '' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <a class="btn secondary" href="/pedidos" style="margin-top:10px; display:inline-block;">Ver todos</a>
      </div>
    </section>
    <section class="card dash-card">
      <div class="card-hd">
        <h2 class="card-title">Ranking Productos</h2>
      </div>
      <div class="card-bd">
        <div class="table-wrap">
          <table class="dash-table">
            <thead><tr><th>Producto</th><th>Ventas €</th><th>Unidades</th></tr></thead>
            <tbody>
              <% (rankingProductos || []).forEach((r) => { %>
                <tr>
                  <td><%= r.Producto ?? '' %></td>
                  <td><%= fmtEurES(r.Ventas ?? 0) %></td>
                  <td><%= r.Unidades ?? 0 %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <section class="card dash-card">
      <div class="card-hd">
        <h2 class="card-title">Próximas Visitas</h2>
      </div>
      <div class="card-bd">
        <div class="table-wrap">
          <table class="dash-table">
            <thead><tr><th>Fecha</th><th>Cliente</th><th>Tipo</th><th>Estado</th></tr></thead>
            <tbody>
              <% (latest.proximasVisitas || []).forEach((v) => { %>
                <% const vid = v.Id ?? v.id ?? v.vis_id; %>
                <tr>
                  <td><%= fmtDateES(v.Fecha ?? '') %></td>
                  <td><a href="/visitas/<%= vid %>"><%= v.ClienteNombre ?? '' %></a></td>
                  <td><%= v.TipoVisita ?? '' %></td>
                  <td><%= v.Estado ?? '' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <a class="btn secondary" href="/visitas" style="margin-top:10px; display:inline-block;">Ver visitas</a>
      </div>
    </section>
  </div>
<% } %>

<%- include('partials/footer') %>
