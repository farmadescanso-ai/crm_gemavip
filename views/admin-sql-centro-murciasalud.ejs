<%- include('partials/header', { title: title || 'MurciaSalud → SQL centro' }) %>

<section class="card">
  <div class="card-hd">
    <h1 class="card-title"><%= title %></h1>
    <p class="card-subtitle"><%= subtitle %></p>
  </div>
  <div class="card-bd">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="gv-alert gv-alert--error" style="margin-bottom: 16px;" id="gv-ms-error"><%- escapeHtml(error) %></div>
    <% } %>

    <div id="gv-murcia-fetch-err" class="gv-alert gv-alert--error gv-murcia-fetch-err" role="alert" hidden></div>

    <p style="margin-bottom: 12px; color: var(--gv-muted); font-size: 14px;">
      <strong>Solo enlaces de ficha de centro</strong> (<code>op=mostrar_centro</code> e <code>id_centro</code>). No sirven listados de zona básica (<code>op=mostrar_zbs</code>), áreas u otros <code>op</code>.<br />
      Ejemplo válido:
      <code style="word-break: break-all;">https://www.murciasalud.es/caps.php?op=mostrar_centro&amp;id_centro=16&amp;idsec=6</code>
    </p>

    <form id="gv-murcia-sql-form" style="display: grid; gap: 14px; max-width: 720px;">
      <label style="display: grid; gap: 6px;">
        <span style="font-weight: 700;">URL de la ficha del centro <span style="font-weight: 400; color: var(--gv-muted);">(opcional si pegas HTML abajo)</span></span>
        <input
          type="url"
          name="url"
          id="gv-murcia-url"
          class="input"
          placeholder="https://www.murciasalud.es/caps.php?op=mostrar_centro&id_centro=…"
          value="<%= typeof lastUrl !== 'undefined' && lastUrl ? escapeHtml(String(lastUrl)) : '' %>"
          autocomplete="off"
          style="width: 100%;"
        />
      </label>
      <label style="display: grid; gap: 6px;">
        <span style="font-weight: 700;">cent_Id_Ruta <span style="font-weight: 400; color: var(--gv-muted);">(opcional)</span></span>
        <input type="number" name="cent_Id_Ruta" id="gv-murcia-ruta" class="input" placeholder="Dejar vacío = NULL" min="0" step="1" style="max-width: 220px;" />
      </label>
      <details class="gv-murcia-sql-details">
        <summary class="gv-murcia-sql-summary">Si obtienes error 422 / CAPTCHA desde el servidor (Vercel)</summary>
        <p class="gv-murcia-sql-details__p">
          Abre la misma URL en el navegador, <strong>Guardar como → Página web, solo HTML</strong>, abre el archivo en un editor, copia todo el contenido y pégalo aquí. Luego pulsa <strong>Generar SQL</strong> (la URL puede ir vacía si el HTML es completo). Si el pegado tiene al menos 400 caracteres, <strong>no se intenta descargar por URL</strong> (aunque el campo URL esté relleno).
        </p>
        <label style="display: grid; gap: 6px;">
          <span style="font-weight: 700;">HTML de la ficha</span>
          <textarea id="gv-murcia-html" class="input gv-murcia-html-ta" rows="6" placeholder="Pega aquí el HTML de la página de MurciaSalud…"></textarea>
        </label>
      </details>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center;">
        <button type="submit" class="btn" id="gv-murcia-submit">Generar SQL</button>
        <span id="gv-murcia-status" style="font-size: 14px; color: var(--gv-muted);" aria-live="polite"></span>
      </div>
    </form>

    <div id="gv-murcia-sql-panel" class="gv-murcia-sql-panel" hidden>
      <div class="gv-murcia-sql-panel__hd">
        <h2 class="gv-murcia-sql-panel__title">INSERT generado</h2>
        <p class="gv-murcia-sql-panel__hint">
          Copia el texto y ejecútalo en tu base de datos (phpMyAdmin, DBeaver, etc.). Puedes seguir editando la URL arriba y volver a generar.
        </p>
      </div>
      <textarea id="gv-murcia-sql-ta" readonly class="input gv-murcia-sql-panel__ta" rows="16"></textarea>
      <div class="gv-murcia-sql-panel__actions">
        <button type="button" class="btn secondary" id="gv-murcia-sql-hide">Ocultar resultado</button>
        <button type="button" class="btn" id="gv-murcia-sql-copy">Copiar al portapapeles</button>
      </div>
    </div>

    <% if (typeof generatedSql !== 'undefined' && generatedSql) { %>
      <div class="gv-alert gv-alert--success" style="margin-top: 20px;">SQL generado (también puedes volver a generar con el formulario).</div>
      <textarea class="input" readonly rows="18" style="margin-top: 12px; font-family: ui-monospace, monospace; font-size: 13px;"><%= generatedSql %></textarea>
    <% } %>
  </div>
</section>

<style nonce="<%= cspNonce %>">
  .gv-murcia-sql-panel {
    margin-top: 22px;
    max-width: min(920px, 100%);
    padding: 18px 20px 20px;
    border-radius: 12px;
    border: 1px solid rgba(15, 23, 42, 0.12);
    background: rgba(248, 250, 252, 0.95);
    box-shadow: 0 4px 24px rgba(15, 23, 42, 0.08);
  }
  .gv-murcia-sql-panel[hidden] {
    display: none !important;
  }
  .gv-murcia-sql-panel__hd {
    margin-bottom: 12px;
  }
  .gv-murcia-sql-panel__title {
    margin: 0 0 6px;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gv-ink, #0f172a);
  }
  .gv-murcia-sql-panel__hint {
    margin: 0;
    font-size: 14px;
    color: var(--gv-muted, #64748b);
    line-height: 1.45;
  }
  .gv-murcia-sql-panel__ta {
    width: 100%;
    box-sizing: border-box;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
    line-height: 1.45;
    resize: vertical;
    min-height: 200px;
  }
  .gv-murcia-sql-panel__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
    justify-content: flex-end;
  }
  .gv-murcia-fetch-err {
    margin-bottom: 14px;
    white-space: pre-wrap;
  }
  .gv-murcia-sql-details {
    border: 1px solid rgba(15, 23, 42, 0.12);
    border-radius: 10px;
    padding: 10px 14px;
    background: rgba(248, 250, 252, 0.6);
  }
  .gv-murcia-sql-summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--gv-ink, #0f172a);
  }
  .gv-murcia-sql-details__p {
    margin: 10px 0 12px;
    font-size: 14px;
    color: var(--gv-muted, #64748b);
    line-height: 1.5;
  }
  .gv-murcia-html-ta {
    width: 100%;
    box-sizing: border-box;
    font-family: ui-monospace, monospace;
    font-size: 12px;
  }
</style>

<script nonce="<%= cspNonce %>">
(function () {
  var MIN_HTML = 400;
  var form = document.getElementById('gv-murcia-sql-form');
  var urlIn = document.getElementById('gv-murcia-url');
  var htmlIn = document.getElementById('gv-murcia-html');
  var rutaIn = document.getElementById('gv-murcia-ruta');
  var btn = document.getElementById('gv-murcia-submit');
  var statusEl = document.getElementById('gv-murcia-status');
  var fetchErr = document.getElementById('gv-murcia-fetch-err');
  var panel = document.getElementById('gv-murcia-sql-panel');
  var ta = document.getElementById('gv-murcia-sql-ta');
  var btnCopy = document.getElementById('gv-murcia-sql-copy');
  var btnHide = document.getElementById('gv-murcia-sql-hide');
  if (!form || !urlIn || !panel || !ta) return;

  function esc(s) {
    var d = document.createElement('div');
    d.textContent = s == null ? '' : String(s);
    return d.innerHTML;
  }

  function showFetchErr(msg, hint) {
    if (!fetchErr) return;
    var h = hint ? '<br /><br /><strong>Qué hacer:</strong> ' + esc(hint) : '';
    fetchErr.innerHTML = esc(msg || 'Error') + h;
    fetchErr.hidden = false;
    fetchErr.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function clearFetchErr() {
    if (fetchErr) {
      fetchErr.hidden = true;
      fetchErr.textContent = '';
    }
  }

  function showPanelWithSql(sql) {
    ta.value = sql;
    panel.hidden = false;
    clearFetchErr();
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /**
   * Evita POST 400 en consola: mismas reglas que el servidor si solo se usa URL (sin HTML pegado).
   * @returns {{ msg: string, hint?: string }|null}
   */
  function clientValidateMurciaUrlForFetch(u, useHtml) {
    if (useHtml) return null;
    if (!u) return null;
    try {
      var parsed = new URL(u);
      var host = parsed.hostname.toLowerCase();
      if (host !== 'www.murciasalud.es' && host !== 'murciasalud.es') return null;
      var path = (parsed.pathname || '/').replace(/\/+$/, '') || '/';
      if (path !== '/caps.php') {
        return {
          msg: 'La ruta debe ser /caps.php.',
          hint: 'Ejemplo: https://www.murciasalud.es/caps.php?op=mostrar_centro&id_centro=16&idsec=6'
        };
      }
      var op = parsed.searchParams.get('op');
      if (op !== 'mostrar_centro') {
        if (op === 'mostrar_zbs') {
          return {
            msg:
              'Has indicado una URL de zona básica de salud (op=mostrar_zbs). Este generador solo admite la ficha de un centro (op=mostrar_centro e id_centro).',
            hint:
              'Abre un centro concreto desde MurciaSalud y copia su URL, o guarda la ficha del centro como HTML y pégala abajo (mín. ' + MIN_HTML + ' caracteres).'
          };
        }
        return {
          msg: 'La URL debe usar op=mostrar_centro (ficha de un centro). Ahora es: ' + (op ? 'op=' + op : 'sin parámetro op') + '.',
          hint: 'No valen enlaces de zona básica, área u otros listados; solo la página de un centro.'
        };
      }
      if (!parsed.searchParams.get('id_centro')) {
        return {
          msg: 'Falta el parámetro id_centro en la URL.',
          hint: 'Ejemplo: …&id_centro=16&…'
        };
      }
    } catch (e1) {
      return { msg: 'URL no válida (no se puede interpretar).', hint: 'Revisa que empiece por https:// y sea una dirección completa.' };
    }
    return null;
  }

  form.addEventListener('submit', function (ev) {
    ev.preventDefault();
    var u = (urlIn.value || '').trim();
    var html = htmlIn ? String(htmlIn.value || '').trim() : '';
    var useHtml = html.length >= MIN_HTML;
    if (!u && !useHtml) {
      showFetchErr('Indica la URL del centro o pega el HTML de la ficha (mínimo ' + MIN_HTML + ' caracteres).', null);
      return;
    }
    var bad = clientValidateMurciaUrlForFetch(u, useHtml);
    if (bad) {
      statusEl.textContent = '';
      showFetchErr(bad.msg, bad.hint || null);
      return;
    }
    clearFetchErr();
    statusEl.textContent = useHtml ? 'Parseando HTML…' : 'Descargando y parseando…';
    if (btn) btn.disabled = true;
    fetch('/admin/sql-centro-murciasalud/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({
        url: u,
        html: useHtml ? html : undefined,
        cent_Id_Ruta: (rutaIn && rutaIn.value && String(rutaIn.value).trim() !== '') ? rutaIn.value : null
      })
    })
      .then(function (r) {
        return r.json().then(function (j) {
          return { ok: r.ok, status: r.status, j: j };
        }).catch(function () {
          return { ok: false, status: r.status, j: { error: 'Respuesta no JSON (HTTP ' + r.status + ').' } };
        });
      })
      .then(function (x) {
        if (x.j && x.j.ok && x.j.sql) {
          if (typeof x.j.meta === 'object' && x.j.meta && x.j.meta.cent_Nombre_Centro) {
            statusEl.textContent =
              (x.j.source === 'html' ? 'Listo (HTML pegado): ' : 'Listo: ') +
              x.j.meta.cent_Nombre_Centro +
              ' (código ' +
              x.j.meta.cent_codigo +
              ')';
          } else {
            statusEl.textContent = 'Listo.';
          }
          showPanelWithSql(x.j.sql);
          return;
        }
        var err = (x.j && x.j.error) ? x.j.error : 'Error HTTP ' + x.status;
        var hint = x.j && x.j.hint ? x.j.hint : null;
        statusEl.textContent = '';
        showFetchErr(err, hint);
      })
      .catch(function () {
        statusEl.textContent = '';
        showFetchErr('No se pudo completar la petición. Revisa la conexión o recarga la página.', null);
      })
      .finally(function () {
        if (btn) btn.disabled = false;
      });
  });

  if (btnCopy) {
    btnCopy.addEventListener('click', function () {
      var txt = ta.value;
      var done = function () {
        btnCopy.textContent = 'Copiado';
        setTimeout(function () { btnCopy.textContent = 'Copiar al portapapeles'; }, 2000);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(txt).then(done).catch(function () {
          ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          done();
        });
      } else {
        ta.select();
        try { document.execCommand('copy'); } catch (e2) {}
        done();
      }
    });
  }
  if (btnHide) {
    btnHide.addEventListener('click', function () {
      panel.hidden = true;
    });
  }
})();
</script>

<%- include('partials/footer') %>
