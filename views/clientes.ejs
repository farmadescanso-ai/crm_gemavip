<%- include('partials/header', { title: 'Contactos' }) %>

<section class="card gv-contactos gv-vista">
  <div class="card-hd gv-vista-hd">
    <div class="gv-vista-hd__title-row">
      <h1 class="card-title gv-vista-hd__title">Contactos</h1>
      <button type="button" class="gv-vista-hd__info" aria-label="Información" title="Información" data-tooltip="Gestiona tus clientes y proveedores: empresas y personas. Solo los contactos con DNI/CIF y estado activo pueden recibir pedidos.">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
      </button>
      <span class="gv-vista-hd__tooltip" role="tooltip" id="contactos-tooltip">Gestiona tus clientes y proveedores: empresas y personas. Solo los contactos con DNI/CIF y estado activo pueden recibir pedidos.</span>
    </div>
    <div class="gv-vista-hd__bar">
      <nav class="gv-vista-tabs" aria-label="Filtrar por tipo">
        <a class="gv-vista-tab <%= (typeof tipoContacto === 'undefined' || tipoContacto === '') ? 'is-active' : '' %>" href="/clientes?<%= (typeof q !== 'undefined' && q) ? 'q=' + encodeURIComponent(q) + '&' : '' %>order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>">Todos</a>
        <% if (typeof admin !== 'undefined' && admin) { %><a class="gv-vista-tab" href="/clientes/duplicados" title="Ver grupos de contactos duplicados">Duplicados</a><% } %>
        <a class="gv-vista-tab <%= tipoContacto === 'Empresa' ? 'is-active' : '' %>" href="/clientes?tipo=Empresa&amp;order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %><%= (typeof q !== 'undefined' && q) ? '&q=' + encodeURIComponent(q) : '' %>">Empresas</a>
        <a class="gv-vista-tab <%= tipoContacto === 'Persona' ? 'is-active' : '' %>" href="/clientes?tipo=Persona&amp;order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %><%= (typeof q !== 'undefined' && q) ? '&q=' + encodeURIComponent(q) : '' %>">Personas</a>
        <a class="gv-vista-tab <%= tipoContacto === 'Otros' ? 'is-active' : '' %>" href="/clientes?tipo=Otros&amp;order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %><%= (typeof q !== 'undefined' && q) ? '&q=' + encodeURIComponent(q) : '' %>">Otros</a>
      </nav>
      <div class="gv-vista-hd__actions">
        <a class="gv-vista-order gv-vista-order-link" href="/clientes?<%= (typeof tipoContacto !== 'undefined' && tipoContacto) ? 'tipo=' + encodeURIComponent(tipoContacto) + '&' : '' %><%= (typeof q !== 'undefined' && q) ? 'q=' + encodeURIComponent(q) + '&' : '' %>order=<%= (typeof orderNombre !== 'undefined' && orderNombre === 'asc') ? 'desc' : 'asc' %>" title="Ordenar por nombre (clic para alternar A–Z / Z–A)"><%= (typeof orderNombre !== 'undefined' && orderNombre === 'desc') ? 'Contactos Z–A' : 'Contactos A–Z' %></a>
        <form method="get" action="/clientes" class="gv-vista-search">
          <% if (typeof tipoContacto !== 'undefined' && tipoContacto) { %><input type="hidden" name="tipo" value="<%= escapeHtml(String(tipoContacto)) %>" /><% } %>
          <input type="hidden" name="order" value="<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>" />
          <input type="search" name="q" placeholder="Ej: provincia:Murcia estado:activos tipo:Farmacia · o texto libre" value="<%= escapeHtml((typeof q !== 'undefined' && q) ? String(q) : '') %>" class="gv-vista-search__input" />
          <button class="btn secondary" type="submit">Buscar</button>
          <% if (typeof q !== 'undefined' && q) { %>
            <a class="btn secondary" href="/clientes?<%= (typeof tipoContacto !== 'undefined' && tipoContacto) ? 'tipo=' + encodeURIComponent(tipoContacto) + '&' : '' %>order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>" title="Limpiar búsqueda">✕</a>
          <% } %>
        </form>
        <a class="btn" href="/clientes/new">Nuevo contacto</a>
      </div>
    </div>
    <p class="gv-vista-hd__sub">
      Página <%= paging.page %> de <%= paging.totalPages || 1 %> · Mostrando <%= items.length %> de <%= paging.total %>
      <% if (typeof q !== 'undefined' && q) { %> · Buscando: "<%= escapeHtml(String(q)) %>"<% } %>
      <% if (typeof tipoContacto !== 'undefined' && tipoContacto) { %> · Tipo: <%= escapeHtml(String(tipoContacto)) %><% } %>
    </p>
  </div>
  <div class="card-bd">
    <% const qsBase = []; if (typeof q !== 'undefined' && q) qsBase.push('q=' + encodeURIComponent(q)); if (typeof tipoContacto !== 'undefined' && tipoContacto) qsBase.push('tipo=' + encodeURIComponent(tipoContacto)); qsBase.push('order=' + (typeof orderNombre !== 'undefined' ? orderNombre : 'asc')); const qsBaseStr = qsBase.join('&'); %>
    <div class="gv-vista-pagination">
      <% if (paging.page > 1) { %>
        <a class="btn secondary" href="/clientes?page=<%= paging.page - 1 %>&<%= qsBaseStr %>">← Anterior</a>
      <% } %>
      <span class="gv-vista-pagination__info">
        Página
        <form method="get" action="/clientes" class="gv-vista-pagination__goto" style="display:inline;">
          <input type="hidden" name="order" value="<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>" />
          <% if (typeof q !== 'undefined' && q) { %><input type="hidden" name="q" value="<%= escapeHtml(String(q)) %>" /><% } %>
          <% if (typeof tipoContacto !== 'undefined' && tipoContacto) { %><input type="hidden" name="tipo" value="<%= escapeHtml(String(tipoContacto)) %>" /><% } %>
          <input type="number" name="page" min="1" max="<%= paging.totalPages || 1 %>" value="<%= paging.page %>" class="gv-vista-pagination__input" aria-label="Ir a página" title="Ir a página" />
          <button type="submit" class="btn secondary icon gv-vista-pagination__btn">Ir</button>
        </form>
        de <%= paging.totalPages || 1 %>
      </span>
      <% if ((paging.page * paging.limit) < paging.total) { %>
        <a class="btn secondary" href="/clientes?page=<%= paging.page + 1 %>&<%= qsBaseStr %>">Siguiente →</a>
      <% } %>
    </div>

    <div class="table-wrap gv-contactos-table-wrap">
      <table class="gv-contactos-table">
        <colgroup>
          <col class="gv-contactos-col-acciones" />
          <col class="gv-contactos-col-nombre" />
          <col class="gv-contactos-col-tipo" />
          <col class="gv-contactos-col-relaciones" />
          <col class="gv-contactos-col-telefono" />
          <col class="gv-contactos-col-email" />
          <col class="gv-contactos-col-contacto" />
          <col class="gv-contactos-col-provincia" />
          <col class="gv-contactos-col-estado" />
        </colgroup>
        <thead>
          <tr>
            <th>Acciones</th>
            <th class="gv-contactos-col-nombre">Nombre / Razón Social</th>
            <th>Tipo</th>
            <th class="gv-contactos-col-relaciones" title="Contactos relacionados">Rel.</th>
            <th class="gv-contactos-col-telefono">Teléfono</th>
            <th class="gv-contactos-col-email">Email</th>
            <th class="gv-contactos-col-contacto">Contacto</th>
            <th>Provincia</th>
            <th class="gv-contactos-col-estado">Estado</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((c) => { %>
            <% const cid = c.id ?? c.Id ?? c.cli_id; %>
            <% const cial = Number(c.Id_Cial ?? c.id_cial ?? c.cli_com_id ?? 0) || 0; const uid = user && Number(user.id); const canEditRow = admin || (uid && (cial === uid || (poolId && cial === Number(poolId)))); %>
            <tr>
              <td>
                <div class="gv-actions">
                  <a class="btn secondary icon" href="/clientes/<%= cid %>" title="Ver" aria-label="Ver contacto <%= cid %>">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </a>
                  <% const relCount = Number(c.relaciones_count ?? 0) || 0; %>
                  <% if (relCount > 0) { %>
                    <a class="btn secondary icon" href="/clientes/<%= cid %>/edit#tab_relaciones" title="Ver contactos relacionados (<%= relCount %>)" aria-label="Ver relaciones de <%= cid %>">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                      </svg>
                    </a>
                  <% } else if (canEditRow) { %>
                    <button type="button" class="btn secondary icon gv-add-relacion-btn" data-cid="<%= cid %>" data-nombre="<%= (c.Nombre_Razon_Social ?? c.cli_nombre_razon_social ?? c.Nombre ?? '').replace(/"/g, '&quot;') %>" title="Añadir relación" aria-label="Añadir relación con este contacto">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                      </svg>
                    </button>
                  <% } %>
                  <% const solicRechazada = typeof solicitudRechazadaClienteIds !== 'undefined' && solicitudRechazadaClienteIds && solicitudRechazadaClienteIds.has && solicitudRechazadaClienteIds.has(cid); %>
                  <% const solicPendiente = typeof solicitudPendienteClienteIds !== 'undefined' && solicitudPendienteClienteIds && solicitudPendienteClienteIds.has && solicitudPendienteClienteIds.has(cid); %>
                  <% const puedeSolicitar = !admin && uid && !solicRechazada && (cial === 0 || (poolId && cial === Number(poolId))); %>
                  <% if (puedeSolicitar) { %>
                    <form method="post" action="/clientes/<%= cid %>/solicitar-asignacion" style="display:inline; margin:0;" class="gv-solicitar-asignacion-form" data-cid="<%= cid %>">
                      <%- include('partials/csrf-field') %>
                      <button class="btn icon" type="submit" title="<%= solicPendiente ? 'Solicitud pendiente de aprobación' : 'Solicitar asignación (el admin aprobará o denegará)' %>" aria-label="Solicitar que me asignen este cliente">
                        <span class="gv-btn-loading">
                          <span class="gv-spinner gv-solicitar-spinner" style="display:none;" aria-hidden="true"></span>
                          <svg class="gv-solicitar-icon <%= solicPendiente ? 'gv-solicitar-icon--pendiente' : '' %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="8.5" cy="7" r="4"></circle>
                            <line x1="20" y1="8" x2="20" y2="14"></line>
                            <line x1="23" y1="11" x2="17" y2="11"></line>
                          </svg>
                        </span>
                      </button>
                    </form>
                  <% } %>
                  <% if (canEditRow) { %>
                    <a class="btn secondary icon" href="/clientes/<%= cid %>/edit" title="Editar" aria-label="Editar contacto <%= cid %>">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
                      </svg>
                    </a>
                  <% } %>
                  <% if (admin) { %>
                    <form method="post" action="/clientes/<%= cid %>/delete" onsubmit="return confirm('¿Mover este contacto a la papelera?');">
                      <%- include('partials/csrf-field') %>
                      <button class="btn secondary icon danger" type="submit" title="Papelera" aria-label="Enviar contacto <%= cid %> a papelera">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M3 6h18"></path>
                          <path d="M8 6V4h8v2"></path>
                          <path d="M19 6l-1 14H6L5 6"></path>
                          <path d="M10 11v6"></path>
                          <path d="M14 11v6"></path>
                        </svg>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
              <td class="gv-contactos-col-nombre"><%= c.Nombre_Razon_Social ?? c.cli_nombre_razon_social ?? c.Nombre ?? '' %></td>
              <td><% const tipoClase = ((c.TipoContacto ?? c.cli_tipo_contacto ?? '').toLowerCase() === 'empresa') ? 'empresa' : ((c.TipoContacto ?? c.cli_tipo_contacto ?? '').toLowerCase() === 'persona') ? 'persona' : 'otros'; %><span class="gv-badge gv-badge--<%= tipoClase %>"><%= c.TipoContacto ?? c.cli_tipo_contacto ?? '—' %></span></td>
              <td class="gv-contactos-col-relaciones"><% if (relCount > 0) { %><a href="/clientes/<%= cid %>/edit#tab_relaciones" class="gv-relaciones-badge" title="<%= relCount %> contacto(s) relacionado(s)"><%= relCount %></a><% } else { %>—<% } %></td>
              <td class="gv-contactos-col-telefono"><% const tel = String(c.Telefono ?? c.cli_telefono ?? c.Movil ?? c.cli_movil ?? '').trim(); %><%- include('partials/telefono-display', { telefono: tel }) %></td>
              <td class="gv-contactos-col-email"><% const email = String(c.Email ?? c.cli_email ?? '').trim(); %><% if (email) { %><a href="mailto:<%= email %>" class="gv-contactos-link"><%= email %></a><% } else { %>—<% } %></td>
              <td class="gv-contactos-col-contacto"><%= (c.NomContacto || c.cli_nom_contacto || c.Nombre_Contacto) || '—' %></td>
              <td><%= c.ProvinciaNombre ?? (c.Id_Provincia ?? c.cli_prov_id ?? '') %></td>
              <td class="gv-contactos-col-estado"><% const estVal = c.EstadoClienteNombre ?? c.OK_KO ?? c.cli_ok_ko ?? ''; %><%= (estVal === 'OK' || estVal === 'ok') ? 'Activo' : estVal %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<div class="gv-modal-backdrop" id="gvAddRelModalBackdrop" hidden></div>
<div class="gv-modal" id="gvAddRelModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvAddRelModalTitle">
  <div class="gv-modal-card" style="max-width: 640px;">
    <div class="gv-modal-hd">
      <div class="gv-modal-title" id="gvAddRelModalTitle">Añadir relación</div>
      <div class="gv-modal-subtitle" id="gvAddRelModalSub">Vincula este contacto con otros. Escribe para buscar.</div>
    </div>
    <div class="gv-modal-bd" style="padding: 16px;">
      <input type="search" id="gvAddRelSearch" placeholder="Buscar por nombre, DNI, email..." style="width:100%; padding:10px 14px; margin-bottom:12px; border:1px solid var(--gv-border); border-radius:8px;" />
      <div id="gvAddRelResults" style="max-height: 280px; overflow-y: auto; display:grid; gap: 8px;"></div>
      <div id="gvAddRelSelected" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--gv-border);"></div>
    </div>
    <div class="gv-modal-actions" style="display:flex; gap:10px; justify-content:flex-end;">
      <button type="button" class="btn secondary" id="gvAddRelModalCerrar">Cancelar</button>
      <button type="button" class="btn" id="gvAddRelModalGuardar">Guardar seleccionados</button>
    </div>
  </div>
</div>

<script nonce="<%= cspNonce %>">
(function () {
  document.querySelectorAll('.gv-solicitar-asignacion-form').forEach(function (form) {
    form.addEventListener('submit', function () {
      var btn = form.querySelector('button[type="submit"]');
      var spinner = form.querySelector('.gv-solicitar-spinner');
      var icon = form.querySelector('.gv-solicitar-icon');
      if (btn) btn.disabled = true;
      if (spinner) spinner.style.display = 'inline-block';
      if (icon) icon.style.display = 'none';
    });
  });

  var addRelBackdrop = document.getElementById('gvAddRelModalBackdrop');
  var addRelModal = document.getElementById('gvAddRelModal');
  var addRelTitle = document.getElementById('gvAddRelModalTitle');
  var addRelSub = document.getElementById('gvAddRelModalSub');
  var addRelSearch = document.getElementById('gvAddRelSearch');
  var addRelResults = document.getElementById('gvAddRelResults');
  var addRelSelected = document.getElementById('gvAddRelSelected');
  var addRelCerrar = document.getElementById('gvAddRelModalCerrar');
  var addRelGuardar = document.getElementById('gvAddRelModalGuardar');
  var addRelCurrentCid = null;
  var addRelSelectedIds = {};
  var addRelSearchTimeout = null;
  function esc(s) {
    return String(s == null ? '' : s)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function hideAddRelModal() {
    if (addRelBackdrop) addRelBackdrop.hidden = true;
    if (addRelModal) addRelModal.hidden = true;
  }
  function showAddRelModal(cid, nombre) {
    addRelCurrentCid = cid;
    addRelSelectedIds = {};
    if (addRelTitle) addRelTitle.textContent = 'Añadir relación';
    if (addRelSub) addRelSub.textContent = 'Vincula "' + (nombre || 'este contacto') + '" con otros. Escribe para buscar.';
    if (addRelSearch) { addRelSearch.value = ''; addRelSearch.focus(); }
    if (addRelResults) addRelResults.innerHTML = '';
    if (addRelSelected) addRelSelected.innerHTML = '';
    if (addRelBackdrop) addRelBackdrop.hidden = false;
    if (addRelModal) addRelModal.hidden = false;
    if (addRelSearch) addRelSearch.dispatchEvent(new Event('input'));
  }
  function renderAddRelSelected() {
    if (!addRelSelected) return;
    var ids = Object.keys(addRelSelectedIds).filter(function(k){ return addRelSelectedIds[k]; });
    var html = ids.length ? '<div style="font-weight:800; margin-bottom:8px;">Seleccionados: ' + ids.length + '</div>' : '';
    addRelSelected.innerHTML = html;
  }
  function renderAddRelResults(items) {
    if (!addRelResults) return;
    if (!items || !items.length) {
      addRelResults.innerHTML = '<div style="color:var(--gv-muted); padding:12px;">Sin resultados. Escribe al menos 2 caracteres.</div>';
      return;
    }
    addRelResults.innerHTML = items.map(function(c) {
      var id = c.cli_id || c.Id || c.id;
      var nom = c.cli_nombre_razon_social || c.Nombre_Razon_Social || c.Nombre_Cial || '';
      var dni = c.cli_dni_cif || c.DNI_CIF || '';
      var email = c.cli_email || c.Email || '';
      var checked = addRelSelectedIds[id] ? 'checked' : '';
      var idEsc = esc(id);
      var nomEsc = esc(nom || ('Cliente ' + id));
      var metaEsc = esc([dni, email].filter(Boolean).join(' · '));
      return '<label style="display:flex; align-items:center; gap:10px; padding:10px; border:1px solid var(--gv-border); border-radius:8px; cursor:pointer;">' +
        '<input type="checkbox" class="gv-add-rel-check" data-id="' + idEsc + '" ' + checked + ' />' +
        '<div><div style="font-weight:800;">' + nomEsc + '</div>' +
        (metaEsc ? '<div style="font-size:12px; color:var(--gv-muted);">' + metaEsc + '</div>' : '') + '</div></label>';
    }).join('');
    addRelResults.querySelectorAll('.gv-add-rel-check').forEach(function(cb) {
      cb.addEventListener('change', function() {
        addRelSelectedIds[this.getAttribute('data-id')] = this.checked;
        renderAddRelSelected();
      });
    });
  }
  function doAddRelSearch() {
    var q = addRelSearch ? String(addRelSearch.value || '').trim() : '';
    if (q.length < 2) { renderAddRelResults([]); return; }
    var url = '/api/clientes/buscar?q=' + encodeURIComponent(q) + '&limit=20&exclude=' + encodeURIComponent(addRelCurrentCid || '') + '&scope=all';
    fetch(url, { headers: { Accept: 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(json) {
        if (json && json.ok && json.items) renderAddRelResults(json.items);
        else renderAddRelResults([]);
      })
      .catch(function() { renderAddRelResults([]); });
  }
  document.querySelectorAll('.gv-add-relacion-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var cid = this.getAttribute('data-cid');
      var nombre = this.getAttribute('data-nombre');
      if (cid) showAddRelModal(cid, nombre);
    });
  });
  if (addRelBackdrop) addRelBackdrop.addEventListener('click', hideAddRelModal);
  if (addRelCerrar) addRelCerrar.addEventListener('click', hideAddRelModal);
  if (addRelSearch) {
    addRelSearch.addEventListener('input', function() {
      if (addRelSearchTimeout) clearTimeout(addRelSearchTimeout);
      addRelSearchTimeout = setTimeout(doAddRelSearch, 300);
    });
  }
  if (addRelGuardar) {
    addRelGuardar.addEventListener('click', function() {
      var ids = Object.keys(addRelSelectedIds).filter(function(k){ return addRelSelectedIds[k]; });
      if (!ids.length || !addRelCurrentCid) { hideAddRelModal(); return; }
      var items = ids.map(function(id){ return { cliRelacionadoId: Number(id) }; });
      fetch('/api/clientes/' + addRelCurrentCid + '/relaciones/batch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ items: items })
      })
        .then(function(r) { return r.json().catch(function() { return { ok: false, error: 'Respuesta no válida' }; }); })
        .then(function(json) {
          if (json && json.ok) window.location.href = '/clientes/' + addRelCurrentCid + '/edit#tab_relaciones';
          else alert((json && json.error) ? json.error : 'Error al guardar.');
        })
        .catch(function() { alert('Error de conexión.'); });
    });
  }
})();
</script>

<%- include('partials/footer') %>
