<%- include('partials/header', { title: 'Contactos' }) %>

<section class="card gv-contactos">
  <div class="card-hd gv-contactos-hd">
    <div class="gv-contactos-hd__title-row">
      <h1 class="card-title gv-contactos-hd__title">Contactos</h1>
      <button type="button" class="gv-contactos-hd__info" aria-label="Información" title="Información" data-tooltip="Gestiona tus clientes y proveedores: empresas y personas. Solo los contactos con DNI/CIF y estado activo pueden recibir pedidos.">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
      </button>
      <span class="gv-contactos-hd__tooltip" role="tooltip" id="contactos-tooltip">Gestiona tus clientes y proveedores: empresas y personas. Solo los contactos con DNI/CIF y estado activo pueden recibir pedidos.</span>
    </div>
    <div class="gv-contactos-hd__bar">
      <nav class="gv-contactos-tabs" aria-label="Filtrar por tipo">
        <a class="gv-contactos-tab <%= (typeof tipoContacto === 'undefined' || tipoContacto === '') ? 'is-active' : '' %>" href="/clientes?<%= (typeof q !== 'undefined' && q) ? 'q=' + encodeURIComponent(q) + '&' : '' %>order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>&amp;limit=<%= paging.limit %>">Todos</a>
        <a class="gv-contactos-tab <%= tipoContacto === 'Empresa' ? 'is-active' : '' %>" href="/clientes?tipo=Empresa&amp;order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>&amp;limit=<%= paging.limit %><%= (typeof q !== 'undefined' && q) ? '&q=' + encodeURIComponent(q) : '' %>">Empresas</a>
        <a class="gv-contactos-tab <%= tipoContacto === 'Persona' ? 'is-active' : '' %>" href="/clientes?tipo=Persona&amp;order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>&amp;limit=<%= paging.limit %><%= (typeof q !== 'undefined' && q) ? '&q=' + encodeURIComponent(q) : '' %>">Personas</a>
        <a class="gv-contactos-tab <%= tipoContacto === 'Otros' ? 'is-active' : '' %>" href="/clientes?tipo=Otros&amp;order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>&amp;limit=<%= paging.limit %><%= (typeof q !== 'undefined' && q) ? '&q=' + encodeURIComponent(q) : '' %>">Otros</a>
      </nav>
      <div class="gv-contactos-hd__actions">
        <a class="gv-contactos-order gv-contactos-order-link" href="/clientes?<%= (typeof tipoContacto !== 'undefined' && tipoContacto) ? 'tipo=' + encodeURIComponent(tipoContacto) + '&' : '' %><%= (typeof q !== 'undefined' && q) ? 'q=' + encodeURIComponent(q) + '&' : '' %>order=<%= (typeof orderNombre !== 'undefined' && orderNombre === 'asc') ? 'desc' : 'asc' %>&amp;limit=<%= paging.limit %>" title="Ordenar por nombre (clic para alternar A–Z / Z–A)"><%= (typeof orderNombre !== 'undefined' && orderNombre === 'desc') ? 'Contactos Z–A' : 'Contactos A–Z' %></a>
        <form method="get" action="/clientes" class="gv-contactos-search">
          <% if (typeof tipoContacto !== 'undefined' && tipoContacto) { %><input type="hidden" name="tipo" value="<%= tipoContacto %>" /><% } %>
          <input type="hidden" name="order" value="<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %>" />
          <input type="hidden" name="limit" value="<%= paging.limit %>" />
          <input type="search" name="q" placeholder="Buscar..." value="<%= (typeof q !== 'undefined' && q) ? q : '' %>" class="gv-contactos-search__input" />
          <button class="btn secondary" type="submit">Buscar</button>
        </form>
        <a class="btn" href="/clientes/new">Nuevo contacto</a>
      </div>
    </div>
    <p class="gv-contactos-hd__sub">
      Página <%= paging.page %> · Mostrando <%= items.length %> de <%= paging.total %> (límite <%= paging.limit %>)
      <% if (typeof q !== 'undefined' && q) { %> · Buscando: "<%= q %>"<% } %>
      <% if (typeof tipoContacto !== 'undefined' && tipoContacto) { %> · Tipo: <%= tipoContacto %><% } %>
    </p>
  </div>
  <div class="card-bd">
    <div class="gv-contactos-pagination">
      <% if (paging.page > 1) { %>
        <a class="btn secondary" href="/clientes?page=<%= paging.page - 1 %>&limit=<%= paging.limit %>&order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %><%= (typeof q !== 'undefined' && q) ? ('&q=' + encodeURIComponent(q)) : '' %><%= (typeof tipoContacto !== 'undefined' && tipoContacto) ? ('&tipo=' + encodeURIComponent(tipoContacto)) : '' %>">Anterior</a>
      <% } %>
      <% if ((paging.page * paging.limit) < paging.total) { %>
        <a class="btn secondary" href="/clientes?page=<%= paging.page + 1 %>&limit=<%= paging.limit %>&order=<%= typeof orderNombre !== 'undefined' ? orderNombre : 'asc' %><%= (typeof q !== 'undefined' && q) ? ('&q=' + encodeURIComponent(q)) : '' %><%= (typeof tipoContacto !== 'undefined' && tipoContacto) ? ('&tipo=' + encodeURIComponent(tipoContacto)) : '' %>">Siguiente</a>
      <% } %>
    </div>

    <div class="table-wrap gv-contactos-table-wrap">
      <table class="gv-contactos-table">
        <colgroup>
          <col class="gv-contactos-col-acciones" />
          <col class="gv-contactos-col-nombre" />
          <col class="gv-contactos-col-tipo" />
          <col class="gv-contactos-col-relaciones" />
          <col class="gv-contactos-col-telefono" />
          <col class="gv-contactos-col-email" />
          <col class="gv-contactos-col-contacto" />
          <col class="gv-contactos-col-provincia" />
          <col class="gv-contactos-col-estado" />
        </colgroup>
        <thead>
          <tr>
            <th>Acciones</th>
            <th class="gv-contactos-col-nombre">Nombre / Razón Social</th>
            <th>Tipo</th>
            <th class="gv-contactos-col-relaciones" title="Contactos relacionados">Rel.</th>
            <th class="gv-contactos-col-telefono">Teléfono</th>
            <th class="gv-contactos-col-email">Email</th>
            <th class="gv-contactos-col-contacto">Contacto</th>
            <th>Provincia</th>
            <th class="gv-contactos-col-estado">Estado</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((c) => { %>
            <% const cid = c.id ?? c.Id ?? c.cli_id; %>
            <% const cial = Number(c.Id_Cial ?? c.id_cial ?? c.cli_com_id ?? 0) || 0; const uid = user && Number(user.id); const canEditRow = admin || (uid && (cial === uid || (poolId && cial === Number(poolId)))); %>
            <tr>
              <td>
                <div class="gv-actions">
                  <a class="btn secondary icon" href="/clientes/<%= cid %>" title="Ver" aria-label="Ver contacto <%= cid %>">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </a>
                  <% const relCount = Number(c.relaciones_count ?? 0) || 0; %>
                  <% if (relCount > 0) { %>
                    <a class="btn secondary icon" href="/clientes/<%= cid %>/edit#tab_relaciones" title="Ver contactos relacionados (<%= relCount %>)" aria-label="Ver relaciones de <%= cid %>">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                      </svg>
                    </a>
                  <% } else if (canEditRow) { %>
                    <button type="button" class="btn secondary icon gv-add-relacion-btn" data-cid="<%= cid %>" data-nombre="<%= (c.Nombre_Razon_Social ?? c.cli_nombre_razon_social ?? c.Nombre ?? '').replace(/"/g, '&quot;') %>" title="Añadir relación" aria-label="Añadir relación con este contacto">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                      </svg>
                    </button>
                  <% } %>
                  <% const puedeSolicitar = !admin && uid && (cial === 0 || (poolId && cial === Number(poolId))); %>
                  <% if (puedeSolicitar) { %>
                    <form method="post" action="/clientes/<%= cid %>/solicitar-asignacion" style="display:inline; margin:0;" class="gv-solicitar-asignacion-form" data-cid="<%= cid %>">
                      <button class="btn icon" type="submit" title="Solicitar asignación (el admin aprobará o denegará)" aria-label="Solicitar que me asignen este cliente">
                        <span class="gv-btn-loading">
                          <span class="gv-spinner gv-solicitar-spinner" style="display:none;" aria-hidden="true"></span>
                          <svg class="gv-solicitar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="8.5" cy="7" r="4"></circle>
                            <line x1="20" y1="8" x2="20" y2="14"></line>
                            <line x1="23" y1="11" x2="17" y2="11"></line>
                          </svg>
                        </span>
                      </button>
                    </form>
                  <% } %>
                  <% if (canEditRow) { %>
                    <a class="btn secondary icon" href="/clientes/<%= cid %>/edit" title="Editar" aria-label="Editar contacto <%= cid %>">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
                      </svg>
                    </a>
                  <% } %>
                  <% if (admin) { %>
                    <form method="post" action="/clientes/<%= cid %>/delete" onsubmit="return confirm('¿Mover este contacto a la papelera?');">
                      <button class="btn secondary icon danger" type="submit" title="Papelera" aria-label="Enviar contacto <%= cid %> a papelera">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M3 6h18"></path>
                          <path d="M8 6V4h8v2"></path>
                          <path d="M19 6l-1 14H6L5 6"></path>
                          <path d="M10 11v6"></path>
                          <path d="M14 11v6"></path>
                        </svg>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
              <td class="gv-contactos-col-nombre"><%= c.Nombre_Razon_Social ?? c.cli_nombre_razon_social ?? c.Nombre ?? '' %></td>
              <td><% const tipoClase = ((c.TipoContacto ?? c.cli_tipo_contacto ?? '').toLowerCase() === 'empresa') ? 'empresa' : ((c.TipoContacto ?? c.cli_tipo_contacto ?? '').toLowerCase() === 'persona') ? 'persona' : 'otros'; %><span class="gv-badge gv-badge--<%= tipoClase %>"><%= c.TipoContacto ?? c.cli_tipo_contacto ?? '—' %></span></td>
              <td class="gv-contactos-col-relaciones"><% if (relCount > 0) { %><a href="/clientes/<%= cid %>/edit#tab_relaciones" class="gv-relaciones-badge" title="<%= relCount %> contacto(s) relacionado(s)"><%= relCount %></a><% } else { %>—<% } %></td>
              <td class="gv-contactos-col-telefono"><% const tel = String(c.Telefono ?? c.cli_telefono ?? c.Movil ?? c.cli_movil ?? '').trim(); %><%- include('partials/telefono-display', { telefono: tel }) %></td>
              <td class="gv-contactos-col-email"><% const email = String(c.Email ?? c.cli_email ?? '').trim(); %><% if (email) { %><a href="mailto:<%= email %>" class="gv-contactos-link"><%= email %></a><% } else { %>—<% } %></td>
              <td class="gv-contactos-col-contacto"><%= (c.NomContacto || c.cli_nom_contacto || c.Nombre_Contacto) || '—' %></td>
              <td><%= c.ProvinciaNombre ?? (c.Id_Provincia ?? c.cli_prov_id ?? '') %></td>
              <td class="gv-contactos-col-estado"><%= c.EstadoClienteNombre ?? c.OK_KO ?? c.cli_ok_ko ?? '' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<div class="gv-modal-backdrop" id="gvAddRelModalBackdrop" hidden></div>
<div class="gv-modal" id="gvAddRelModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvAddRelModalTitle">
  <div class="gv-modal-card" style="max-width: 640px;">
    <div class="gv-modal-hd">
      <div class="gv-modal-title" id="gvAddRelModalTitle">Añadir relación</div>
      <div class="gv-modal-subtitle" id="gvAddRelModalSub">Vincula este contacto con otros. Escribe para buscar.</div>
    </div>
    <div class="gv-modal-bd" style="padding: 16px;">
      <input type="search" id="gvAddRelSearch" placeholder="Buscar por nombre, DNI, email..." style="width:100%; padding:10px 14px; margin-bottom:12px; border:1px solid var(--gv-border); border-radius:8px;" />
      <div id="gvAddRelResults" style="max-height: 280px; overflow-y: auto; display:grid; gap: 8px;"></div>
      <div id="gvAddRelSelected" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--gv-border);"></div>
    </div>
    <div class="gv-modal-actions" style="display:flex; gap:10px; justify-content:flex-end;">
      <button type="button" class="btn secondary" id="gvAddRelModalCerrar">Cancelar</button>
      <button type="button" class="btn" id="gvAddRelModalGuardar">Guardar seleccionados</button>
    </div>
  </div>
</div>

<style>
/* Vista Contactos – estilo Gemavip */
.gv-contactos .card-hd {
  background: linear-gradient(180deg, rgba(0,139,210,.06), transparent 70%);
  border-bottom: 1px solid rgba(229,229,229,.9);
}
.gv-contactos-hd { margin-bottom: 0; }
.gv-contactos-hd__title-row { display: flex; align-items: center; gap: 8px; position: relative; }
.gv-contactos-hd__title { margin: 0 0 6px 0; font-size: 18px; }
.gv-contactos-hd__info { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; padding: 0; border: none; border-radius: 50%; background: rgba(0,139,210,.12); color: var(--gv-primary); cursor: pointer; }
.gv-contactos-hd__info:hover { background: var(--gv-primary); color: #fff; }
.gv-contactos-hd__tooltip { position: absolute; left: 0; top: 100%; margin-top: 6px; padding: 10px 14px; max-width: 360px; font-size: 13px; line-height: 1.45; color: #fff; background: var(--gv-ink); border-radius: 10px; box-shadow: var(--gv-shadow); opacity: 0; visibility: hidden; pointer-events: none; z-index: 10; transition: opacity .15s, visibility .15s; }
.gv-contactos-hd__info:hover + .gv-contactos-hd__tooltip,
.gv-contactos-hd__info:focus + .gv-contactos-hd__tooltip { opacity: 1; visibility: visible; }
.gv-contactos-hd__bar { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px; margin-top: 14px; padding: 12px 5px 0; border-top: 1px solid var(--gv-border); }
.gv-contactos-tabs { display: flex; gap: 4px; }
.gv-contactos-tab { padding: 8px 14px; font-size: 14px; font-weight: 500; color: var(--gv-muted); text-decoration: none; border-radius: 10px; }
.gv-contactos-tab:hover { color: var(--gv-ink); background: rgba(0,139,210,.08); text-decoration: none; }
.gv-contactos-tab.is-active { color: var(--gv-primary); background: rgba(0,139,210,.12); font-weight: 600; }
.gv-contactos-hd__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
.gv-contactos-order { font-size: 13px; color: var(--gv-muted); }
.gv-contactos-order-link { text-decoration: none; font-weight: 500; color: var(--gv-primary); }
.gv-contactos-order-link:hover { color: var(--gv-primary-hover); text-decoration: underline; }
.gv-contactos-search { display: inline-flex; align-items: center; gap: 8px; }
.gv-contactos-search__input { min-width: 200px; padding: 8px 12px; border: 1px solid var(--gv-border); border-radius: 10px; font-size: 14px; }
.gv-contactos-search__input:focus { outline: none; border-color: var(--gv-primary); box-shadow: 0 0 0 2px rgba(0,139,210,.15); }
.gv-contactos-hd__sub { margin: 10px 0 0; padding: 0 5px; font-size: 13px; color: var(--gv-muted); }
.gv-contactos-pagination { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
.gv-badge { display: inline-block; padding: 4px 10px; font-size: 12px; font-weight: 600; border-radius: 8px; }
.gv-badge--empresa { background: rgba(0,139,210,.12); color: var(--gv-primary); }
.gv-badge--persona { background: rgba(143,174,27,.15); color: var(--gv-green); }
.gv-badge--otros { background: rgba(91,102,122,.15); color: var(--gv-muted); }
/* Tabla contactos: columnas ajustadas, iconos compactos */
.gv-contactos .gv-contactos-table-wrap { margin: 0 2px; }
.gv-contactos .gv-contactos-table { table-layout: fixed; width: 100%; border-collapse: separate; border-spacing: 6px 0; font-size: 0.8125rem; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-acciones { width: 13%; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-nombre { width: 19%; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-tipo { width: 8%; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-relaciones { width: 4%; text-align: center; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-telefono { width: 10%; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-email { width: 14%; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-contacto { width: 12%; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-provincia { width: 10%; }
.gv-contactos .gv-contactos-table col.gv-contactos-col-estado { width: 8%; }
.gv-contactos .gv-contactos-table th.gv-contactos-col-estado,
.gv-contactos .gv-contactos-table td.gv-contactos-col-estado { white-space: nowrap; }
.gv-contactos-link { color: var(--gv-primary); text-decoration: none; }
.gv-contactos-link:hover { color: var(--gv-primary-hover); text-decoration: underline; }
.gv-relaciones-badge {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 22px; height: 22px; padding: 0 6px;
  font-size: 12px; font-weight: 700;
  color: #fff; background: linear-gradient(135deg, var(--gv-primary), var(--gv-primary-2));
  border-radius: 10px; text-decoration: none;
  box-shadow: 0 2px 6px rgba(0,139,210,.25);
}
.gv-relaciones-badge:hover { filter: brightness(1.08); text-decoration: none; color: #fff; }
.gv-contactos .gv-contactos-table td.gv-contactos-col-relaciones { text-align: center; }
/* Cabecera tabla – estilo Gemavip */
.gv-contactos .gv-contactos-table thead th {
  background: linear-gradient(180deg, rgba(0,139,210,.04), transparent);
  color: var(--gv-ink);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: .4px;
  text-transform: uppercase;
  border-bottom: 1px solid var(--gv-border);
  padding: 12px 5px;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 1;
}
.gv-contactos .gv-contactos-table th,
.gv-contactos .gv-contactos-table td {
  word-wrap: break-word;
  overflow-wrap: break-word;
  min-width: 0;
  box-sizing: border-box;
  padding-left: 5px;
  padding-right: 5px;
}
.gv-contactos .gv-contactos-table tbody td {
  padding: 12px 5px;
  border-bottom: 1px solid var(--gv-border);
  color: var(--gv-text);
}
.gv-contactos .gv-contactos-table tbody tr:hover td {
  background: rgba(0,139,210,.03);
}
.gv-contactos .gv-contactos-table th:first-child,
.gv-contactos .gv-contactos-table td:first-child { padding-left: 0; padding-right: 4px; overflow: hidden; }
.gv-contactos .gv-contactos-table td:first-child .gv-actions {
  display: inline-flex;
  gap: 4px;
  flex-wrap: nowrap;
  max-width: 100%;
}
.gv-contactos .gv-contactos-table td:first-child .gv-actions .btn.icon {
  padding: 4px 6px;
  min-width: 28px;
}
.gv-contactos .gv-contactos-table td:first-child .gv-actions .btn.icon svg {
  width: 14px;
  height: 14px;
}
.gv-contactos .gv-contactos-table td.gv-contactos-col-nombre { white-space: normal; overflow-wrap: break-word; }
.gv-contactos .gv-contactos-table td { white-space: normal; }
</style>

<script>
(function () {
  document.querySelectorAll('.gv-solicitar-asignacion-form').forEach(function (form) {
    form.addEventListener('submit', function () {
      var btn = form.querySelector('button[type="submit"]');
      var spinner = form.querySelector('.gv-solicitar-spinner');
      var icon = form.querySelector('.gv-solicitar-icon');
      if (btn) btn.disabled = true;
      if (spinner) spinner.style.display = 'inline-block';
      if (icon) icon.style.display = 'none';
    });
  });

  var addRelBackdrop = document.getElementById('gvAddRelModalBackdrop');
  var addRelModal = document.getElementById('gvAddRelModal');
  var addRelTitle = document.getElementById('gvAddRelModalTitle');
  var addRelSub = document.getElementById('gvAddRelModalSub');
  var addRelSearch = document.getElementById('gvAddRelSearch');
  var addRelResults = document.getElementById('gvAddRelResults');
  var addRelSelected = document.getElementById('gvAddRelSelected');
  var addRelCerrar = document.getElementById('gvAddRelModalCerrar');
  var addRelGuardar = document.getElementById('gvAddRelModalGuardar');
  var addRelCurrentCid = null;
  var addRelSelectedIds = {};
  var addRelSearchTimeout = null;

  function hideAddRelModal() {
    if (addRelBackdrop) addRelBackdrop.hidden = true;
    if (addRelModal) addRelModal.hidden = true;
  }
  function showAddRelModal(cid, nombre) {
    addRelCurrentCid = cid;
    addRelSelectedIds = {};
    if (addRelTitle) addRelTitle.textContent = 'Añadir relación';
    if (addRelSub) addRelSub.textContent = 'Vincula "' + (nombre || 'este contacto') + '" con otros. Escribe para buscar.';
    if (addRelSearch) { addRelSearch.value = ''; addRelSearch.focus(); }
    if (addRelResults) addRelResults.innerHTML = '';
    if (addRelSelected) addRelSelected.innerHTML = '';
    if (addRelBackdrop) addRelBackdrop.hidden = false;
    if (addRelModal) addRelModal.hidden = false;
    if (addRelSearch) addRelSearch.dispatchEvent(new Event('input'));
  }
  function renderAddRelSelected() {
    if (!addRelSelected) return;
    var ids = Object.keys(addRelSelectedIds).filter(function(k){ return addRelSelectedIds[k]; });
    var html = ids.length ? '<div style="font-weight:800; margin-bottom:8px;">Seleccionados: ' + ids.length + '</div>' : '';
    addRelSelected.innerHTML = html;
  }
  function renderAddRelResults(items) {
    if (!addRelResults) return;
    if (!items || !items.length) {
      addRelResults.innerHTML = '<div style="color:var(--gv-muted); padding:12px;">Sin resultados. Escribe al menos 2 caracteres.</div>';
      return;
    }
    addRelResults.innerHTML = items.map(function(c) {
      var id = c.cli_id || c.Id || c.id;
      var nom = c.cli_nombre_razon_social || c.Nombre_Razon_Social || c.Nombre_Cial || '';
      var dni = c.cli_dni_cif || c.DNI_CIF || '';
      var email = c.cli_email || c.Email || '';
      var checked = addRelSelectedIds[id] ? 'checked' : '';
      return '<label style="display:flex; align-items:center; gap:10px; padding:10px; border:1px solid var(--gv-border); border-radius:8px; cursor:pointer;">' +
        '<input type="checkbox" class="gv-add-rel-check" data-id="' + id + '" ' + checked + ' />' +
        '<div><div style="font-weight:800;">' + (nom || 'Cliente ' + id) + '</div>' +
        (dni || email ? '<div style="font-size:12px; color:var(--gv-muted);">' + [dni, email].filter(Boolean).join(' · ') + '</div>' : '') + '</div></label>';
    }).join('');
    addRelResults.querySelectorAll('.gv-add-rel-check').forEach(function(cb) {
      cb.addEventListener('change', function() {
        addRelSelectedIds[this.getAttribute('data-id')] = this.checked;
        renderAddRelSelected();
      });
    });
  }
  function doAddRelSearch() {
    var q = addRelSearch ? String(addRelSearch.value || '').trim() : '';
    if (q.length < 2) { renderAddRelResults([]); return; }
    var url = '/api/clientes/buscar?q=' + encodeURIComponent(q) + '&limit=20&exclude=' + encodeURIComponent(addRelCurrentCid || '') + '&scope=all';
    fetch(url, { headers: { Accept: 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(json) {
        if (json && json.ok && json.items) renderAddRelResults(json.items);
        else renderAddRelResults([]);
      })
      .catch(function() { renderAddRelResults([]); });
  }
  document.querySelectorAll('.gv-add-relacion-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var cid = this.getAttribute('data-cid');
      var nombre = this.getAttribute('data-nombre');
      if (cid) showAddRelModal(cid, nombre);
    });
  });
  if (addRelBackdrop) addRelBackdrop.addEventListener('click', hideAddRelModal);
  if (addRelCerrar) addRelCerrar.addEventListener('click', hideAddRelModal);
  if (addRelSearch) {
    addRelSearch.addEventListener('input', function() {
      if (addRelSearchTimeout) clearTimeout(addRelSearchTimeout);
      addRelSearchTimeout = setTimeout(doAddRelSearch, 300);
    });
  }
  if (addRelGuardar) {
    addRelGuardar.addEventListener('click', function() {
      var ids = Object.keys(addRelSelectedIds).filter(function(k){ return addRelSelectedIds[k]; });
      if (!ids.length || !addRelCurrentCid) { hideAddRelModal(); return; }
      var items = ids.map(function(id){ return { cliRelacionadoId: Number(id) }; });
      fetch('/api/clientes/' + addRelCurrentCid + '/relaciones/batch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ items: items })
      })
        .then(function(r) { return r.json().catch(function() { return { ok: false, error: 'Respuesta no válida' }; }); })
        .then(function(json) {
          if (json && json.ok) window.location.href = '/clientes/' + addRelCurrentCid + '/edit#tab_relaciones';
          else alert((json && json.error) ? json.error : 'Error al guardar.');
        })
        .catch(function() { alert('Error de conexión.'); });
    });
  }
})();
</script>

<%- include('partials/footer') %>
