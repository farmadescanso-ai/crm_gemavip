<%- include('partials/header', { title: title || 'JSON Holded' }) %>
<style nonce="<%= cspNonce %>">
  .gv-holded-tab:hover{color:var(--gv-accent,#0d7377)!important;}
  .gv-json-wrap{ background:#1e1e1e; color:#d4d4d4; padding:16px; border-radius:8px; overflow-x:auto; font-family:'Consolas','Monaco','Courier New',monospace; font-size:13px; line-height:1.5; white-space:pre-wrap; word-break:break-all; }
  .gv-mapping-table{ width:100%; border-collapse:collapse; font-size:14px; }
  .gv-mapping-table th,.gv-mapping-table td{ padding:8px 12px; text-align:left; border-bottom:1px solid var(--gv-border,#ddd); }
  .gv-mapping-table th{ background:var(--gv-surface-2,#f5f5f5); font-weight:600; }
  .gv-mapping-table code{ font-size:12px; background:rgba(0,0,0,.06); padding:2px 6px; border-radius:4px; }
</style>

<section class="card">
  <div class="card-hd">
    <nav class="gv-holded-tabs" role="tablist" style="display: flex; gap: 0; margin-bottom: 16px; border-bottom: 1px solid var(--gv-border, #ddd);">
      <a href="/admin/importar-holded" role="tab" class="gv-holded-tab" style="padding: 10px 16px; color: var(--gv-muted, #666); text-decoration: none;">Importar</a>
      <a href="/admin/importar-holded?tab=json-holded&start=<%= start || '2026-01-01' %>&end=<%= end || '2026-12-31' %>" role="tab" class="gv-holded-tab gv-holded-tab--active" style="padding: 10px 16px; font-weight: 600; color: var(--gv-accent, #0d7377); border-bottom: 2px solid var(--gv-accent, #0d7377); margin-bottom: -1px; text-decoration: none;">JSON</a>
      <a href="/admin/importar-holded?tab=preview&start=<%= start || '2026-01-01' %>&end=<%= end || '2026-12-31' %>" role="tab" class="gv-holded-tab" style="padding: 10px 16px; color: var(--gv-muted, #666); text-decoration: none;">Vista previa</a>
      <a href="/admin/importar-holded?tab=relacion-codigos&start=2026-01-01&end=2026-01-31" role="tab" class="gv-holded-tab" style="padding: 10px 16px; color: var(--gv-muted, #666); text-decoration: none;">Relación códigos</a>
    </nav>
    <h1 class="card-title">JSON Holded — Estructura y mapeo</h1>
    <p class="card-subtitle">Período: <%= periodo || '2026-01-01 a 2026-12-31' %> — Texto plano para inspección.</p>
  </div>
  <div class="card-bd">
    <% if (typeof error === 'string' && error) { %>
      <div class="gv-alert error" role="alert"><strong>Error</strong><p style="margin: 8px 0 0 0;"><%= error %></p></div>
    <% } else { %>
      <form method="get" action="/admin/importar-holded" style="display: flex; gap: 12px; align-items: flex-end; margin-bottom: 20px; flex-wrap: wrap;">
        <input type="hidden" name="tab" value="json-holded" />
        <div class="form-group" style="margin: 0;">
          <label for="json-start">Fecha inicio</label>
          <input type="date" id="json-start" name="start" value="<%= start || '2026-01-01' %>" />
        </div>
        <div class="form-group" style="margin: 0;">
          <label for="json-end">Fecha fin</label>
          <input type="date" id="json-end" name="end" value="<%= end || '2026-12-31' %>" />
        </div>
        <button type="submit" class="btn primary">Actualizar</button>
      </form>

      <h3 style="margin: 8px 0 12px;">Mapeo Holded → BD</h3>
      <div style="overflow-x: auto; margin-bottom: 24px;">
        <table class="gv-mapping-table">
          <thead>
            <tr>
              <th>Origen</th>
              <th>Campo Holded</th>
              <th>→</th>
              <th>Tabla/Columna BD</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Documento</td><td><code>doc.id</code></td><td>→</td><td><code>pedidos.ped_id_holded</code></td></tr>
            <tr><td>Documento</td><td><code>doc.docNumber</code></td><td>→</td><td><code>pedidos.ped_numero</code></td></tr>
            <tr><td>Documento</td><td><code>doc.date</code></td><td>→</td><td><code>pedidos.ped_fecha</code></td></tr>
            <tr><td>Documento</td><td><code>doc.total</code></td><td>→</td><td><code>pedidos.ped_total</code></td></tr>
            <tr><td>Documento</td><td><code>doc.subtotal</code></td><td>→</td><td><code>pedidos.ped_base</code></td></tr>
            <tr><td>Documento</td><td><code>doc.tax</code></td><td>→</td><td><code>pedidos.ped_iva</code></td></tr>
            <tr><td>Documento</td><td><code>doc.docNumber</code></td><td>→</td><td><code>pedidos.ped_numero</code></td></tr>
            <tr><td>Contacto</td><td><code>contact.id</code></td><td>→</td><td><code>clientes.cli_Id_Holded</code></td></tr>
            <tr><td>Contacto</td><td><code>contact.name</code></td><td>→</td><td><code>clientes.cli_nombre_razon_social</code></td></tr>
            <tr><td>Contacto</td><td><code>contact.code</code></td><td>→</td><td><code>clientes.cli_dni_cif</code></td></tr>
            <tr><td>Contacto</td><td><code>contact.email</code></td><td>→</td><td><code>clientes.cli_email</code></td></tr>
            <tr><td>Contacto</td><td><code>contact.mobile</code></td><td>→</td><td><code>clientes.cli_movil</code></td></tr>
            <tr><td>Contacto</td><td><code>contact.phone</code></td><td>→</td><td><code>clientes.cli_telefono</code></td></tr>
            <tr><td>Contacto</td><td><code>billAddress.address</code></td><td>→</td><td><code>clientes.cli_direccion</code></td></tr>
            <tr><td>Contacto</td><td><code>billAddress.city</code></td><td>→</td><td><code>clientes.cli_poblacion</code></td></tr>
            <tr><td>Contacto</td><td><code>billAddress.postalCode</code></td><td>→</td><td><code>clientes.cli_codigo_postal</code></td></tr>
            <tr><td>Contacto</td><td><code>billAddress.province</code></td><td>→</td><td>Filtro: solo Murcia</td></tr>
            <tr><td>Producto</td><td><code>product.sku</code></td><td>→</td><td><code>articulos.art_sku</code> (búsqueda)</td></tr>
            <tr><td>Producto</td><td><code>product.code</code></td><td>→</td><td><code>articulos.art_codigo_interno</code></td></tr>
            <tr><td>Producto</td><td><code>product.name</code></td><td>→</td><td><code>pedidos_articulos.pedart_articulo_txt</code></td></tr>
            <tr><td>Producto</td><td><code>product.units</code></td><td>→</td><td><code>pedidos_articulos.pedart_cantidad</code></td></tr>
            <tr><td>Producto</td><td><code>product.price</code></td><td>→</td><td><code>pedidos_articulos.pedart_pvp</code></td></tr>
          </tbody>
        </table>
      </div>

      <h3 style="margin: 8px 0 12px;">JSON raw (estructura Holded)</h3>
      <pre class="gv-json-wrap" style="margin:0;"><%= jsonRaw %></pre>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
