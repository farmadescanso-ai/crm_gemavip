<%- include('partials/header', { title: 'Notificaciones' }) %>

<section class="card gv-notificaciones">
  <div class="card-hd gv-contactos-hd">
    <h1 class="card-title gv-contactos-hd__title">Notificaciones</h1>
    <p class="card-subtitle gv-contactos-hd__sub">Solicitudes pendientes (asignación de clientes y pedidos especiales). Puedes aprobar o rechazar.</p>
  </div>
  <div class="card-bd">
    <% if (typeof resuelto !== 'undefined' && resuelto) { %>
      <div class="gv-alert gv-alert--success" style="margin-bottom:12px;"><%= resuelto === 'aprobada' ? 'Solicitud aprobada.' : 'Solicitud rechazada.' %></div>
    <% } %>
    <% if (typeof borrado !== 'undefined' && borrado !== '' && borrado !== null) { %>
      <div class="gv-alert gv-alert--info" style="margin-bottom:12px;">Historial borrado: <strong><%= borrado %></strong> notificaciones eliminadas.</div>
    <% } %>
    <% if (typeof eliminada !== 'undefined' && eliminada) { %>
      <div class="gv-alert gv-alert--success" style="margin-bottom:12px;">Notificación eliminada.</div>
    <% } %>
    <p class="gv-contactos-hd__sub" style="margin-bottom: 16px; font-weight: 600; color: var(--gv-ink);">
      <span aria-hidden="true">🔔</span> Solicitudes pendientes: <strong><%= typeof paging !== 'undefined' ? paging.total : 0 %></strong>
      <form method="post" action="/notificaciones/borrar-historial" style="display:inline-block; margin-left:16px;">
        <%- include('partials/csrf-field') %>
        <button type="submit" class="btn secondary" onclick="return confirm('¿Borrar todo el historial de notificaciones? Esta acción no se puede deshacer.');">Borrar historial</button>
      </form>
    </p>
    <div class="table-wrap gv-notificaciones-table-wrap">
      <table class="gv-notificaciones-table">
        <colgroup>
          <col class="gv-notif-col-acciones" />
          <col class="gv-notif-col-fecha" />
          <col class="gv-notif-col-tipo" />
          <col class="gv-notif-col-referencia" />
          <col class="gv-notif-col-comercial" />
          <col class="gv-notif-col-estado" />
          <col class="gv-notif-col-fecha-resol" />
          <col />
        </colgroup>
        <thead>
          <tr>
            <th class="gv-notif-col-acciones">Acciones</th>
            <th class="gv-notif-col-fecha">Fecha</th>
            <th class="gv-notif-col-tipo">Tipo</th>
            <th class="gv-notif-col-referencia">Referencia</th>
            <th class="gv-notif-col-comercial">Comercial solicitante</th>
            <th class="gv-notif-col-estado">Estado</th>
            <th class="gv-notif-col-fecha-resol">Fecha<br>resolución</th>
            <th>Resuelto por</th>
          </tr>
        </thead>
        <tbody id="notif-tbody">
          <% if (!items || items.length === 0) { %>
            <tr id="notif-empty-row">
              <td colspan="8" style="text-align:center; color: var(--gv-muted); padding: 24px;">No hay notificaciones.</td>
            </tr>
          <% } else { %>
            <% items.forEach((n) => { %>
              <tr>
                <td class="gv-notif-col-acciones">
                  <div class="gv-actions">
                    <% if ((n.estado || '').toLowerCase() === 'pendiente') { %>
                      <form method="post" action="/notificaciones/<%= n.id %>/aprobar">
                        <%- include('partials/csrf-field') %>
                        <button class="btn secondary icon success" type="submit" title="Aprobar" aria-label="Aprobar">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        </button>
                      </form>
                      <form method="post" action="/notificaciones/<%= n.id %>/rechazar">
                        <%- include('partials/csrf-field') %>
                        <button class="btn secondary icon danger" type="submit" title="Rechazar" aria-label="Rechazar">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        </button>
                      </form>
                    <% } %>
                    <form method="post" action="/notificaciones/<%= n.id %>/eliminar" style="display:inline;">
                      <%- include('partials/csrf-field') %>
                      <button class="btn secondary icon" type="submit" title="Eliminar" aria-label="Eliminar notificación" onclick="return confirm('¿Eliminar esta notificación?');" style="color:#6c757d;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                      </button>
                    </form>
                  </div>
                </td>
                <td class="gv-notif-col-fecha"><%= typeof fmtDateES !== 'undefined' ? fmtDateES(n.fecha_creacion) : (n.fecha_creacion || '') %></td>
                <td class="gv-notif-col-tipo">
                  <%= (n.tipo || '').toLowerCase() === 'pedido_especial' ? 'Pedido especial' : 'Asignación cliente' %>
                </td>
                <td class="gv-notif-col-referencia">
                  <% const tipoN = (n.tipo || '').toLowerCase(); %>
                  <% const pidFromNotas = (() => { const m = String(n.notas || '').match(/pedidoId\s*=\s*(\d+)/i); return m && m[1] ? Number(m[1]) : null; })(); %>
                  <% const pid = (n.id_pedido != null ? Number(n.id_pedido) : null) || pidFromNotas; %>
                  <% if (tipoN === 'pedido_especial' && pid) { %>
                    <% const clienteName = String(n.contacto_nombre || '').trim(); %>
                    <a href="/pedidos/<%= pid %>/edit" title="<%= n.pedido_num ? String(n.pedido_num) : ('Pedido #' + pid) %>"><%= clienteName || 'Cliente' %></a>
                  <% } else { %>
                    <a href="/clientes/<%= n.id_contacto %>"><%= n.contacto_nombre || 'Cliente' %></a>
                  <% } %>
                </td>
                <td class="gv-notif-col-comercial"><%= n.comercial_nombre || 'Comercial #' + n.id_comercial_solicitante %></td>
                <td class="gv-notif-col-estado">
                  <span class="gv-badge gv-badge--<%= (n.estado || '').toLowerCase() === 'pendiente' ? 'otros' : ((n.estado || '').toLowerCase() === 'aprobada' ? 'persona' : 'empresa') %>">
                    <%= (n.estado || '').toLowerCase() === 'pendiente' ? 'Pendiente' : ((n.estado || '').toLowerCase() === 'aprobada' ? 'Aprobada' : 'Rechazada') %>
                  </span>
                </td>
                <td class="gv-notif-col-fecha-resol"><%= (n.estado || '').toLowerCase() !== 'pendiente' && n.fecha_resolucion ? (typeof fmtDateES !== 'undefined' ? fmtDateES(n.fecha_resolucion) : n.fecha_resolucion) : '—' %></td>
                <td><%= (n.estado || '').toLowerCase() !== 'pendiente' ? (n.admin_nombre || 'Enlace email') : '—' %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>
<script nonce="<%= cspNonce %>">
(function() {
  var emptyRow = document.getElementById('notif-empty-row');
  var total = <%= (typeof paging !== 'undefined' && paging && paging.total) ? paging.total : 0 %>;
  if (!emptyRow || total === 0) return;
  var csrfMeta = document.querySelector('meta[name="csrf-token"]');
  var csrfToken = csrfMeta && csrfMeta.getAttribute('content') ? String(csrfMeta.getAttribute('content')) : '';
  var csrfHidden = csrfToken ? ('<input type="hidden" name="_csrf" value="' + csrfToken.replace(/"/g, '&quot;') + '" />') : '';
  fetch('/api/notificaciones?limit=10')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.ok || !data.items || data.items.length === 0) return;
      var tbody = document.getElementById('notif-tbody');
      emptyRow.remove();
      var esc = function (s) {
        return String(s == null ? '' : s)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      };
      var fmtDate = function(d) {
        if (!d) return '';
        var s = String(d);
        var m = s.match(/^(\d{4})-(\d{2})-(\d{2})/);
        if (m) return m[3] + '/' + m[2] + '/' + m[1];
        return s;
      };
      data.items.forEach(function(n) {
        var estado = (n.estado || '').toLowerCase();
        var estadoLabel = estado === 'pendiente' ? 'Pendiente' : (estado === 'aprobada' ? 'Aprobada' : 'Rechazada');
        var badgeClass = estado === 'pendiente' ? 'otros' : (estado === 'aprobada' ? 'persona' : 'empresa');
        var tipo = (n.tipo || '').toLowerCase();
        var tipoLabel = tipo === 'pedido_especial' ? 'Pedido especial' : 'Asignación cliente';
        var pid = n.id_pedido;
        if (!pid && tipo === 'pedido_especial' && n.notas) {
          var mm = String(n.notas).match(/pedidoId\s*=\s*(\d+)/i);
          if (mm && mm[1]) pid = parseInt(mm[1], 10) || null;
        }
        var pedidoLabel = (n.pedido_num ? String(n.pedido_num) : ('Pedido #' + pid));
        var clienteLabel = (n.contacto_nombre ? String(n.contacto_nombre) : 'Cliente');
        var pedidoLabelEsc = esc(pedidoLabel);
        var clienteLabelEsc = esc(clienteLabel);
        var ref = (tipo === 'pedido_especial' && pid)
          ? ('<a href="/pedidos/' + encodeURIComponent(pid) + '/edit" title="' + pedidoLabelEsc + '">' + clienteLabelEsc + '</a>')
          : ('<a href="/clientes/' + encodeURIComponent(n.id_contacto || '') + '">' + clienteLabelEsc + '</a>');
        var tr = document.createElement('tr');
        var acc = '<div class="gv-actions">';
        if (estado === 'pendiente') {
          acc += '<form method="post" action="/notificaciones/' + encodeURIComponent(n.id || '') + '/aprobar">' + csrfHidden + '<button class="btn secondary icon success" type="submit" title="Aprobar" aria-label="Aprobar"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg></button></form><form method="post" action="/notificaciones/' + encodeURIComponent(n.id || '') + '/rechazar">' + csrfHidden + '<button class="btn secondary icon danger" type="submit" title="Rechazar" aria-label="Rechazar"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button></form>';
        }
        acc += '<form method="post" action="/notificaciones/' + encodeURIComponent(n.id || '') + '/eliminar" style="display:inline;">' + csrfHidden + '<button class="btn secondary icon" type="submit" title="Eliminar" aria-label="Eliminar notificación" onclick="return confirm(\\'¿Eliminar esta notificación?\\');" style="color:#6c757d;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg></button></form></div>';
        var fechaResol = (estado !== 'pendiente' && n.fecha_resolucion) ? fmtDate(n.fecha_resolucion) : '—';
        var adminNombre = (estado !== 'pendiente') ? (n.admin_nombre || 'Enlace email') : '—';
        var comercialNombre = n.comercial_nombre || ('Comercial #' + n.id_comercial_solicitante);
        tr.innerHTML =
          '<td class="gv-notif-col-acciones">' + acc + '</td>' +
          '<td class="gv-notif-col-fecha">' + esc(fmtDate(n.fecha_creacion)) + '</td>' +
          '<td class="gv-notif-col-tipo">' + esc(tipoLabel) + '</td>' +
          '<td class="gv-notif-col-referencia">' + ref + '</td>' +
          '<td class="gv-notif-col-comercial">' + esc(comercialNombre) + '</td>' +
          '<td class="gv-notif-col-estado"><span class="gv-badge gv-badge--' + esc(badgeClass) + '">' + esc(estadoLabel) + '</span></td>' +
          '<td class="gv-notif-col-fecha-resol">' + esc(fechaResol) + '</td>' +
          '<td>' + esc(adminNombre) + '</td>';
        tbody.appendChild(tr);
      });
    })
    .catch(function() {});
})();
</script>
<%- include('partials/footer') %>
