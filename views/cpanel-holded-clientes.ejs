<%- include('partials/header', { title: title || 'Holded clientes' }) %>

<% const sel = Array.isArray(selectedTags) ? selectedTags : []; %>
<% const selSet = new Set(sel.map((t) => String(t).toLowerCase())); %>
<% const vp = typeof vistaPreview === 'string' ? vistaPreview : 'todos'; %>
<% const baseQs = sel.length ? sel.map(function(t){ return 'tags=' + encodeURIComponent(t); }).join('&') : ''; %>
<% const vistaLink = function(v) {
  if (v === 'todos') return baseQs ? '/cpanel/holded-clientes?' + baseQs : '/cpanel/holded-clientes';
  return '/cpanel/holded-clientes?' + (baseQs ? baseQs + '&' : '') + 'vista=' + encodeURIComponent(v);
}; %>

<section class="card gv-vista">
  <div class="card-hd gv-vista-hd">
    <div class="gv-vista-hd__title-row">
      <h1 class="card-title gv-vista-hd__title"><%= title || 'Importar clientes Holded' %></h1>
    </div>
    <p class="gv-vista-hd__sub" style="margin-top:0;">
      Elige una o más <strong>tags</strong> de Holded (coincidencia sin distinguir mayúsculas). Se importan contactos que tengan <strong>al menos una</strong> de las elegidas, <strong>CIF/NIF informado</strong> en Holded (campo <code>code</code>, no vacío) y provincia mapeada en <code>provincias</code> con <code>prov_codigo_pais = 'ES'</code>. Tras importar, en Holded se añade la tag <code>crm</code> al contacto (si aún no la tenía); en el CRM se guarda el ID en <code>cli_Id_Holded</code> y el máximo de campos disponibles desde Holded.
    </p>
    <p style="margin-top: 10px;">
      <a class="btn secondary" href="/cpanel">← CPanel</a>
    </p>
  </div>
  <div class="card-bd">
    <% if (typeof error === 'string' && error) { %>
      <div class="gv-alert error" role="alert" style="margin-bottom: 16px;">
        <strong>Error</strong>
        <p style="margin: 8px 0 0 0;"><%= error %></p>
      </div>
    <% } %>
    <% if (typeof success === 'string' && success) { %>
      <div class="gv-alert success" role="status" style="margin-bottom: 16px;">
        <strong>Completado</strong>
        <p style="margin: 8px 0 0 0;"><%= success %></p>
      </div>
    <% } %>

    <% const s = stats || {}; %>
    <% const allTagsList = Array.isArray(allTags) ? allTags : []; %>
    <% const rowsSafe = Array.isArray(rows) ? rows : []; %>

    <details class="gv-holded-tags-accordion" style="margin-bottom: 18px; border: 1px solid var(--gv-border, rgba(0,0,0,.12)); border-radius: 10px; background: var(--gv-card-bg, #fff);">
      <summary style="cursor: pointer; list-style: none; padding: 14px 16px; font-weight: 700; font-size: 16px; display: flex; align-items: center; justify-content: space-between; gap: 12px;">
        <span>Tags en Holded <span style="color: var(--gv-muted); font-weight: 600; font-size: 13px;">(<%= allTagsList.length %> etiquetas)</span></span>
        <span style="font-size: 12px; font-weight: 600; color: var(--gv-muted);">Mostrar / ocultar</span>
      </summary>
      <div class="card-bd" style="padding: 0 16px 16px 16px; border-top: 1px solid var(--gv-border, rgba(0,0,0,.08));">
        <p class="card-subtitle" style="margin: 12px 0 10px 0;">Marca las que quieras usar como filtro y pulsa «Aplicar filtro».</p>
        <% if (!allTagsList.length) { %>
          <p style="margin:0; color: var(--gv-muted);">Sin datos de tags (o API sin contactos).</p>
        <% } else { %>
          <form method="get" action="/cpanel/holded-clientes" id="gv-holded-tags-filter" style="margin-bottom: 0;">
            <% if (vp !== 'todos') { %>
              <input type="hidden" name="vista" value="<%= vp %>" />
            <% } %>
            <div style="display: flex; flex-wrap: wrap; gap: 10px 18px; align-items: flex-start; max-height: 280px; overflow-y: auto; padding: 4px 0;">
              <% allTagsList.forEach((t) => { %>
                <% const checked = selSet.has(String(t.key).toLowerCase()); %>
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px;">
                  <input type="checkbox" name="tags" value="<%= t.key %>" <%= checked ? 'checked' : '' %> />
                  <span><code><%= t.display %></code> <span style="color: var(--gv-muted);">(<%= t.count %>)</span></span>
                </label>
              <% }) %>
            </div>
            <div style="margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap;">
              <button type="submit" class="btn">Aplicar filtro</button>
              <a class="btn secondary" href="/cpanel/holded-clientes">Quitar selección</a>
            </div>
          </form>
        <% } %>
      </div>
    </details>
    <style>.gv-holded-tags-accordion summary::-webkit-details-marker { display: none; }</style>

    <p style="margin: 0 0 10px 0; font-size: 13px; color: var(--gv-muted);">
      <strong>Resumen:</strong> solo contactos Holded con <code>type</code> <strong>client</strong> o <strong>lead</strong> (API: <a href="https://developers.holded.com/reference/list-contacts-1" target="_blank" rel="noopener">List Contacts</a>).
      Se excluyen proveedores (<code>supplier</code>), acreedores (<code>creditor</code>), deudores (<code>debtor</code>), etc.
      <% if (s.totalHoldedApi != null && s.holdedExcluidosTipo != null && s.holdedExcluidosTipo > 0) { %>
        En la API hay <strong><%= s.totalHoldedApi %></strong> contactos; <strong><%= s.holdedExcluidosTipo %></strong> no son cliente/lead.
      <% } %>
      Con tag + CIF + provincia ES: <strong>Pendientes alta CRM</strong> = en Holded y aún sin fila en clientes;
      <strong>Datos distintos</strong> = ya en CRM pero Holded y BD no coinciden en los campos sincronizados.
    </p>
    <div class="dash-stats" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap:12px; margin-bottom: 14px;">
      <div class="dash-stat" data-variant="navy">
        <div class="dash-stat-label" title="Contactos tipo client o lead (filtro Holded)">Holded (cliente / lead)</div>
        <div class="dash-stat-value"><%= s.totalHolded != null ? s.totalHolded : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="green">
        <div class="dash-stat-label" title="Con tag + reglas: ya existe cliente en CRM">En CRM (BD)</div>
        <div class="dash-stat-value"><%= s.crmClientesEnBd != null ? s.crmClientesEnBd : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="yellow">
        <div class="dash-stat-label" title="En Holded con tag y reglas, aún sin alta en tabla clientes">Pendientes alta CRM</div>
        <div class="dash-stat-value"><%= s.crmClientesPendientesAlta != null ? s.crmClientesPendientesAlta : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="blue">
        <div class="dash-stat-label" title="Holded y CRM difieren en al menos un campo comparable">Datos distintos (sync)</div>
        <div class="dash-stat-value"><%= s.syncDatosDistintos != null ? s.syncDatosDistintos : '—' %></div>
      </div>
    </div>

    <div class="dash-stats" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap:12px; margin-bottom: 18px;">
      <% if (s.holdedExcluidosTipo != null && s.holdedExcluidosTipo > 0) { %>
      <div class="dash-stat" data-variant="blue">
        <div class="dash-stat-label" title="Contactos en API con otro type (supplier, creditor…)">Excl. por tipo</div>
        <div class="dash-stat-value"><%= s.holdedExcluidosTipo %></div>
      </div>
      <% } %>
      <div class="dash-stat" data-variant="green">
        <div class="dash-stat-label">Con tag elegida</div>
        <div class="dash-stat-value"><%= s.conTagSeleccionada != null ? s.conTagSeleccionada : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="yellow">
        <div class="dash-stat-label">Importables</div>
        <div class="dash-stat-value"><%= s.importables != null ? s.importables : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="blue">
        <div class="dash-stat-label">Sin tag elegida</div>
        <div class="dash-stat-value"><%= s.omitSinTag != null ? s.omitSinTag : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="blue">
        <div class="dash-stat-label">Sin CIF (Holded)</div>
        <div class="dash-stat-value"><%= s.omitSinCif != null ? s.omitSinCif : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="blue">
        <div class="dash-stat-label">Sin prov. ES (BD)</div>
        <div class="dash-stat-value"><%= s.omitSinProvinciaEs != null ? s.omitSinProvinciaEs : '—' %></div>
      </div>
    </div>

    <p style="margin: -6px 0 14px 0; font-size: 12px; color: var(--gv-muted);">
      Detalle sync (solo filas con tag + CIF + provincia ES). «En CRM» / pendientes según vinculación en base (ref / Holded / CIF).
    </p>
    <div class="dash-stats" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap:12px; margin-bottom: 18px;">
      <div class="dash-stat" data-variant="green">
        <div class="dash-stat-label">Importados (al día)</div>
        <div class="dash-stat-value"><%= s.syncImportados != null ? s.syncImportados : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="yellow">
        <div class="dash-stat-label">Pte. importar</div>
        <div class="dash-stat-value"><%= s.syncPteImportar != null ? s.syncPteImportar : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="blue">
        <div class="dash-stat-label" title="CRM enlazado a Holded pero datos distintos; hay que volcar cambios del CRM a Holded">Sincronizar</div>
        <div class="dash-stat-value"><%= s.syncPteExportar != null ? s.syncPteExportar : '—' %></div>
      </div>
      <div class="dash-stat" data-variant="blue">
        <div class="dash-stat-label">Desincronizado</div>
        <div class="dash-stat-value"><%= s.syncDesincronizado != null ? s.syncDesincronizado : '—' %></div>
      </div>
    </div>

    <div style="display:flex; gap: 12px; flex-wrap: wrap; margin-bottom: 18px;">
      <form method="post" action="/cpanel/holded-clientes/import" style="display:inline;">
        <input type="hidden" name="dryRun" value="1" />
        <% sel.forEach(function(t) { %>
          <input type="hidden" name="tags" value="<%= t %>" />
        <% }) %>
        <% if (vp !== 'todos') { %>
          <input type="hidden" name="vista" value="<%= vp %>" />
        <% } %>
        <button type="submit" class="btn secondary" <%= sel.length ? '' : 'disabled title="Selecciona al menos una tag"' %>>Simular importación</button>
      </form>
      <form method="post" action="/cpanel/holded-clientes/import" style="display:inline;">
        <% sel.forEach(function(t) { %>
          <input type="hidden" name="tags" value="<%= t %>" />
        <% }) %>
        <% if (vp !== 'todos') { %>
          <input type="hidden" name="vista" value="<%= vp %>" />
        <% } %>
        <button type="submit" class="btn" <%= sel.length ? '' : 'disabled title="Selecciona al menos una tag"' %>>Importar ahora</button>
      </form>
      <a class="btn secondary" href="<%= vistaLink(vp) %>">Actualizar vista previa</a>
    </div>

    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin-bottom: 12px;">
      <h2 class="card-title" style="margin:0;">Vista previa</h2>
      <span style="font-size: 12px; font-weight: 700; color: var(--gv-muted);">Mostrar:</span>
      <a href="<%= vistaLink('todos') %>" class="badge <%= vp === 'todos' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;">Todos</a>
      <a href="<%= vistaLink('importables') %>" class="badge <%= vp === 'importables' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;" title="Nueva importación o reimportar desde Holded">Importar / reimportar</a>
      <a href="<%= vistaLink('importados') %>" class="badge <%= vp === 'importados' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;" title="Con la etiqueta elegida y ya existe fila en clientes (CRM)">Importados</a>
      <a href="<%= vistaLink('pendientes_importar') %>" class="badge <%= vp === 'pendientes_importar' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;" title="Con la etiqueta elegida y aún no hay cliente en la base">Pendientes de importar</a>
      <a href="<%= vistaLink('errores') %>" class="badge <%= vp === 'errores' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;" title="Tienen la etiqueta elegida pero no son importables (diferencia entre «con tag» e «importables»); motivo en la última columna">Errores</a>
      <a href="<%= vistaLink('omitidos') %>" class="badge <%= vp === 'omitidos' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;">Solo omitidos</a>
    </div>
    <% const previewList = Array.isArray(previewRows) ? previewRows : rowsSafe; %>
    <% const motivoSinCif = typeof motivoSinCifHolded === 'string' ? motivoSinCifHolded : ''; %>
    <% const sinCifEnErrores = (vp === 'errores' && motivoSinCif) ? previewList.filter(function(r) { return String(r.motivo || '') === motivoSinCif; }) : []; %>
    <p style="margin: 0 0 10px 0; font-size: 13px; color: var(--gv-muted);">
      Mostrando <strong><%= previewList.length %></strong> fila(s)<% if (vp !== 'todos') { %> (filtro activo; el total en Holded no cambia)<% } %>.
    </p>
    <% if (vp === 'errores' && s.conTagSeleccionada != null && s.importables != null) { %>
    <p style="margin: -6px 0 12px 0; font-size: 12px; color: var(--gv-muted);">
      Lista = <strong>con tag elegida</strong> (<%= s.conTagSeleccionada %>) − <strong>importables</strong> (<%= s.importables %>) = contactos con etiqueta pero que no cumplen reglas de importación; el motivo está en la columna «Motivo».
    </p>
    <% } %>
    <% if (vp === 'errores' && sinCifEnErrores.length > 0 && sel.length) { %>
    <div style="margin-bottom: 14px; display: flex; flex-wrap: wrap; align-items: center; gap: 12px;">
      <form method="post" action="/cpanel/holded-clientes/alta-leads-sin-cif" style="display: inline;">
        <% sel.forEach(function(t) { %>
          <input type="hidden" name="tags" value="<%= t %>" />
        <% }) %>
        <input type="hidden" name="vista" value="errores" />
        <button type="submit" class="btn">Dar de alta como Lead (<%= sinCifEnErrores.length %> sin CIF en Holded)</button>
      </form>
      <span style="font-size: 12px; color: var(--gv-muted); max-width: 560px;">Crea clientes en estado Lead, CIF «Pendiente», vincula ID Holded y sincroniza tag <code>crm</code> en Holded si no la tenían.</span>
    </div>
    <% } %>
    <div class="table-wrap" style="max-height: 70vh; overflow: auto;">
      <table class="dash-table">
        <thead>
          <tr>
            <th title="Nombre del estado del cliente en el CRM (estdoClientes) y estado de alineación Holded ↔ BD">Estado (BD / sync)</th>
            <th>ID Holded</th>
            <th>Nombre</th>
            <th>CIF</th>
            <th>Prov. Holded</th>
            <th>Prov. CRM</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th>Tags</th>
            <th title="Fecha de última modificación en Holded (API) y en CRM si la columna existe">Últ. modificación</th>
            <th title="Campos comparables distintos entre Holded y CRM">Campos distintos</th>
            <th>Motivo</th>
          </tr>
        </thead>
        <tbody>
          <% previewList.forEach((r) => { %>
            <tr>
              <td>
                <% if (r.estadoBase === 'omitido' || r.estado === 'omitido') { %>
                  <span class="badge danger">omitido</span>
                <% } else { %>
                  <div style="font-weight:600; font-size:13px; color: var(--gv-text, #1a1a1a);">
                    <%= (r.crmEstadoClienteNombre && String(r.crmEstadoClienteNombre).trim()) ? String(r.crmEstadoClienteNombre).trim() : (r.crmVinculado ? '—' : 'Sin cliente en CRM') %>
                  </div>
                  <div style="font-size:11px; margin-top:5px; line-height:1.35;">
                    <% if (r.estado === 'importable') { %>
                      <span class="badge ok">Pendiente alta CRM</span>
                    <% } else if (r.estado === 'importado') { %>
                      <span class="badge ok">Al día (Holded ↔ BD)</span>
                    <% } else if (r.estado === 'pte_importar') { %>
                      <span class="badge warn">Pte. importar</span>
                    <% } else if (r.estado === 'pte_exportar') { %>
                      <span class="badge info">Sincronizar</span>
                    <% } else if (r.estado === 'desincronizado') { %>
                      <span class="badge danger">Desincronizado</span>
                    <% } else { %>
                      <span class="badge info"><%= r.estado || '—' %></span>
                    <% } %>
                  </div>
                <% } %>
              </td>
              <td style="font-size: 11px; font-family: monospace;"><%= r.holdedId || r.cli_Id_Holded || '—' %></td>
              <td><%= r.nombre || '—' %></td>
              <td><%= r.cif || '—' %></td>
              <td><%= r.provinciaHolded || '—' %></td>
              <td title="<%= r.estado === 'importado' ? 'Provincia CRM oculta: contacto ya importado' : '' %>"><% if (r.estado === 'importado') { %>—<% } else { %><%= r.provinciaCrm || '—' %><% } %></td>
              <td><%= r.email || '—' %></td>
              <td><%= r.telefono || r.movil || '—' %></td>
              <td style="max-width: 180px; word-break: break-word; font-size: 12px;"><%= r.tags || '—' %></td>
              <td style="font-size: 11px; line-height: 1.35; max-width: 160px;">
                <% if (r.estadoBase === 'omitido' || r.estado === 'omitido') { %>—<% } else { %>
                  <span style="color: var(--gv-muted);">Holded:</span> <%= r.holdedFechaModTexto || '—' %><br />
                  <span style="color: var(--gv-muted);">CRM:</span> <%= r.crmFechaModTexto || '—' %>
                <% } %>
              </td>
              <td style="font-size: 11px; max-width: 220px; line-height: 1.35;">
                <% if (r.estadoBase === 'omitido' || r.estado === 'omitido') { %>—<% } else if (Array.isArray(r.syncCamposDiferentes) && r.syncCamposDiferentes.length) { %>
                  <%= r.syncCamposDiferentes.join(', ') %>
                <% } else { %>—<% } %>
              </td>
              <td style="font-size: 12px;"><%= r.motivo || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
