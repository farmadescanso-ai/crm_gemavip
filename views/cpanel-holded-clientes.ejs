<%- include('partials/header', { title: title || 'Holded clientes' }) %>

<% const sel = Array.isArray(selectedTags) ? selectedTags : []; %>
<% const vp = typeof vistaPreview === 'string' ? vistaPreview : 'todos'; %>
<% const seg = typeof segment === 'string' ? segment : ''; %>
<% const baseQs = sel.length ? sel.map(function(t){ return 'tags=' + encodeURIComponent(t); }).join('&') : ''; %>
<% const vistaLink = function(v) {
  if (v === 'todos') return baseQs ? '/cpanel/holded-clientes?' + baseQs : '/cpanel/holded-clientes';
  return '/cpanel/holded-clientes?' + (baseQs ? baseQs + '&' : '') + 'vista=' + encodeURIComponent(v);
}; %>
<% const segmentLink = function(s) {
  var q = baseQs ? baseQs + '&' : '';
  q += 'vista=todos&segment=' + encodeURIComponent(s);
  return '/cpanel/holded-clientes?' + q;
}; %>
<% const kpiClearLink = baseQs ? ('/cpanel/holded-clientes?' + baseQs) : '/cpanel/holded-clientes?tags=crm'; %>
<% const excelSinTagHref = baseQs ? ('/cpanel/holded-clientes/sin-tag-filtro.xlsx?' + baseQs) : '/cpanel/holded-clientes/sin-tag-filtro.xlsx?tags=crm'; %>

<section class="card gv-vista">
  <div class="card-hd gv-vista-hd">
    <div class="gv-vista-hd__title-row">
      <h1 class="card-title gv-vista-hd__title"><%= title || 'Importar clientes Holded' %></h1>
    </div>
    <% const ts = typeof tagScope === 'object' && tagScope && tagScope.effectiveTagsDisplay ? tagScope : { mode: 'filter', effectiveTagsDisplay: ['crm'] }; %>
    <p class="gv-vista-hd__sub" style="margin-top:0;">
      Se listan contactos Holded tipo <code>client</code> / <code>lead</code> con la tag <strong>crm</strong> (y opcionalmente las de <code>SYNC_HOLDED_DEFAULT_TAGS</code> en el servidor) que además cumplan <strong>CIF/NIF</strong> en Holded y <strong>provincia española</strong> mapeada en BD. La columna Tags solo muestra <code>crm</code> (no el resto de etiquetas del contacto). La comparación Holded ↔ CRM ignora IDs de enlace, número interno y tags: solo datos de contacto.
    </p>
    <% if (Array.isArray(ts.effectiveTagsDisplay) && ts.effectiveTagsDisplay.length) { %>
      <p style="margin: 10px 0 0 0; font-size: 13px; color: var(--gv-muted);"><strong>Tags en filtro (OR):</strong> <%= ts.effectiveTagsDisplay.map(function(t){ return t; }).join(', ') %></p>
    <% } %>
    <p style="margin-top: 10px;">
      <a class="btn secondary" href="/cpanel">← CPanel</a>
    </p>
  </div>
  <div class="card-bd">
    <% if (typeof error === 'string' && error) { %>
      <div class="gv-alert error" role="alert" style="margin-bottom: 16px;">
        <strong>Error</strong>
        <p style="margin: 8px 0 0 0;"><%= error %></p>
      </div>
    <% } %>
    <% if (typeof success === 'string' && success) { %>
      <div class="gv-alert success" role="status" style="margin-bottom: 16px;">
        <strong>Completado</strong>
        <p style="margin: 8px 0 0 0;"><%= success %></p>
      </div>
    <% } %>

    <% const s = stats || {}; %>
    <% const allTagsList = Array.isArray(allTags) ? allTags : []; %>
    <% const rowsSafe = Array.isArray(rows) ? rows : []; %>

    <details class="gv-holded-tags-accordion" style="margin-bottom: 18px; border: 1px solid var(--gv-border, rgba(0,0,0,.12)); border-radius: 10px; background: var(--gv-card-bg, #fff);">
      <summary style="cursor: pointer; list-style: none; padding: 14px 16px; font-weight: 700; font-size: 16px; display: flex; align-items: center; justify-content: space-between; gap: 12px;">
        <span>Tag de alcance <span style="color: var(--gv-muted); font-weight: 600; font-size: 13px;">(siempre <code>crm</code>)</span></span>
        <span style="font-size: 12px; font-weight: 600; color: var(--gv-muted);">Mostrar / ocultar</span>
      </summary>
      <div class="card-bd" style="padding: 0 16px 16px 16px; border-top: 1px solid var(--gv-border, rgba(0,0,0,.08));">
        <p class="card-subtitle" style="margin: 12px 0 10px 0;">El filtro incluye siempre la tag <code>crm</code>. Otras etiquetas del mismo contacto no se muestran aquí ni en la tabla. Para más criterios usa <code>SYNC_HOLDED_DEFAULT_TAGS</code> en el servidor.</p>
        <form method="get" action="/cpanel/holded-clientes" id="gv-holded-tags-filter" style="margin-bottom: 0;">
          <% if (vp !== 'todos') { %>
            <input type="hidden" name="vista" value="<%= vp %>" />
          <% } %>
          <input type="hidden" name="tags" value="crm" />
          <label style="display: flex; align-items: center; gap: 8px; font-size: 13px;">
            <input type="checkbox" checked disabled />
            <span><code>crm</code> <span style="color: var(--gv-muted);">(<%= allTagsList.length && allTagsList[0] ? allTagsList[0].count : 0 %> contactos con esta tag)</span></span>
          </label>
          <div style="margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap;">
            <button type="submit" class="btn">Aplicar / actualizar</button>
            <a class="btn secondary" href="/cpanel/holded-clientes?tags=crm">Solo tag crm</a>
          </div>
        </form>
      </div>
    </details>
    <style>
      .gv-holded-tags-accordion summary::-webkit-details-marker { display: none; }
      /* Solo omitidos: revisar en CRM (no son el bloque «sin CIF → Lead») */
      .dash-table tbody tr.gv-holded-omitidos-revisar td:first-child {
        border-left: 4px solid #ec4899;
        background: linear-gradient(90deg, rgba(236, 72, 153, 0.14) 0%, rgba(236, 72, 153, 0.02) 100%);
      }
    </style>

    <p style="margin: 0 0 12px 0; font-size: 13px; color: var(--gv-muted); line-height: 1.5;">
      Solo contactos Holded <code>client</code>/<code>lead</code>. Clic en una tarjeta abre el listado filtrado (vista «Todos» + segmento).
      <% if (s.totalHoldedApi != null && s.holdedExcluidosTipo != null && s.holdedExcluidosTipo > 0) { %>
        API total <strong><%= s.totalHoldedApi %></strong>, excluidos por tipo <strong><%= s.holdedExcluidosTipo %></strong>.
      <% } %>
      <% if (s.omitidosYaEnCrm != null && s.omitidosYaEnCrm > 0) { %>
        <strong><%= s.omitidosYaEnCrm %></strong> omitido(s) ya estaban en CRM (no se listan en «Solo omitidos»).
      <% } %>
    </p>
    <% if (seg) { %>
    <p style="margin: 0 0 12px 0; font-size: 13px;">
      <span class="badge info">Filtro KPI: <code><%= seg %></code></span>
      <a href="<%= kpiClearLink %>" style="margin-left:10px; font-weight:700;">Quitar filtro</a>
    </p>
    <% } %>

    <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(152px, 1fr)); gap: 12px; margin-bottom: 16px;">
      <a href="<%= segmentLink('con_tag') %>" class="dash-stat gv-holded-kpi" data-variant="green" style="text-decoration:none; color:inherit; display:block; border-radius:12px; transition: transform .12s, box-shadow .12s;" title="Listado: tienen al menos una tag del filtro">
        <div class="dash-stat-label">Con tag de filtro</div>
        <div class="dash-stat-value"><%= s.conTagSeleccionada != null ? s.conTagSeleccionada : '—' %></div>
      </a>
      <a href="<%= segmentLink('importables') %>" class="dash-stat gv-holded-kpi" data-variant="yellow" style="text-decoration:none; color:inherit; display:block; border-radius:12px;" title="CIF + provincia ES: listos para import / sync">
        <div class="dash-stat-label">Cumplen reglas (import.)</div>
        <div class="dash-stat-value"><%= s.importables != null ? s.importables : '—' %></div>
      </a>
      <a href="<%= segmentLink('importados_vista') %>" class="dash-stat gv-holded-kpi" data-variant="navy" style="text-decoration:none; color:inherit; display:block; border-radius:12px;" title="Importables con fila en clientes CRM">
        <div class="dash-stat-label">En CRM (importables)</div>
        <div class="dash-stat-value"><%= s.crmClientesEnBd != null ? s.crmClientesEnBd : '—' %></div>
      </a>
      <a href="<%= segmentLink('pendientes_alta') %>" class="dash-stat gv-holded-kpi" data-variant="yellow" style="text-decoration:none; color:inherit; display:block; border-radius:12px;" title="Aún sin cliente en BD">
        <div class="dash-stat-label">Pendientes alta CRM</div>
        <div class="dash-stat-value"><%= s.crmClientesPendientesAlta != null ? s.crmClientesPendientesAlta : '—' %></div>
      </a>
      <div class="dash-stat" data-variant="navy" title="Todos los client/lead en esta vista">
        <div class="dash-stat-label">Holded (cliente / lead)</div>
        <div class="dash-stat-value"><%= s.totalHolded != null ? s.totalHolded : '—' %></div>
      </div>
    </div>

    <p style="margin: 0 0 8px 0; font-size: 12px; font-weight: 700; color: var(--gv-muted); text-transform: uppercase; letter-spacing: .04em;">Omitidos que requieren acción <span style="font-weight:600; text-transform:none;">(sin fila CRM o sin coincidencia por ref/CIF)</span></p>
    <% const nSinTagKpi = (s.omitSinTagAccion != null) ? Number(s.omitSinTagAccion) : (s.omitSinTag != null ? Number(s.omitSinTag) : 0); %>
    <% if (nSinTagKpi > 0) { %>
    <p style="margin: 0 0 12px 0; font-size: 13px; display: flex; flex-wrap: wrap; align-items: center; gap: 10px;">
      <a href="<%= excelSinTagHref %>" class="btn secondary" style="display:inline-block;">Descargar Excel — sin tag de filtro (<%= nSinTagKpi %>)</a>
      <span style="font-size: 12px; color: var(--gv-muted); max-width: 560px;">Incluye columnas <strong>Alcance CRM (OR)</strong> y <strong>Faltan añadir</strong> (<code>crm</code> más las de <code>SYNC_HOLDED_DEFAULT_TAGS</code>, p. ej. <code>sepa</code>). No se listan contactos sin ninguna etiqueta en Holded (—).</span>
    </p>
    <% } %>
    <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(148px, 1fr)); gap: 12px; margin-bottom: 16px;">
      <a href="<%= segmentLink('omit_sin_tag') %>" class="dash-stat gv-holded-kpi" data-variant="blue" style="text-decoration:none; color:inherit; display:block; border-radius:12px;">
        <div class="dash-stat-label">Sin tag de filtro</div>
        <div class="dash-stat-value"><%= s.omitSinTagAccion != null ? s.omitSinTagAccion : (s.omitSinTag != null ? s.omitSinTag : '—') %></div>
      </a>
      <a href="<%= segmentLink('omit_sin_cif') %>" class="dash-stat gv-holded-kpi" data-variant="blue" style="text-decoration:none; color:inherit; display:block; border-radius:12px;">
        <div class="dash-stat-label">Sin CIF (Holded)</div>
        <div class="dash-stat-value"><%= s.omitSinCifAccion != null ? s.omitSinCifAccion : (s.omitSinCif != null ? s.omitSinCif : '—') %></div>
      </a>
      <a href="<%= segmentLink('omit_sin_prov') %>" class="dash-stat gv-holded-kpi" data-variant="blue" style="text-decoration:none; color:inherit; display:block; border-radius:12px;">
        <div class="dash-stat-label">Sin prov. ES (BD)</div>
        <div class="dash-stat-value"><%= s.omitSinProvAccion != null ? s.omitSinProvAccion : (s.omitSinProvinciaEs != null ? s.omitSinProvinciaEs : '—') %></div>
      </a>
      <a href="<%= vistaLink('omitidos') %>" class="dash-stat gv-holded-kpi" data-variant="blue" style="text-decoration:none; color:inherit; display:block; border-radius:12px;" title="Todos los omitidos operativos">
        <div class="dash-stat-label">Total omitidos (acción)</div>
        <div class="dash-stat-value"><%= s.omitidosAccion != null ? s.omitidosAccion : '—' %></div>
      </a>
    </div>

    <p style="margin: 0 0 8px 0; font-size: 12px; font-weight: 700; color: var(--gv-muted); text-transform: uppercase; letter-spacing: .04em;">Sincronización <span style="font-weight:600; text-transform:none;">(solo contactos que ya cumplen CIF + provincia)</span></p>
    <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(132px, 1fr)); gap: 12px; margin-bottom: 18px;">
      <a href="<%= segmentLink('sync_al_dia') %>" class="dash-stat gv-holded-kpi" data-variant="green" style="text-decoration:none; color:inherit; display:block; border-radius:12px;">
        <div class="dash-stat-label">Al día</div>
        <div class="dash-stat-value"><%= s.syncImportados != null ? s.syncImportados : '—' %></div>
      </a>
      <a href="<%= segmentLink('sync_pte_import') %>" class="dash-stat gv-holded-kpi" data-variant="yellow" style="text-decoration:none; color:inherit; display:block; border-radius:12px;">
        <div class="dash-stat-label">Pte. importar</div>
        <div class="dash-stat-value"><%= s.syncPteImportar != null ? s.syncPteImportar : '—' %></div>
      </a>
      <a href="<%= segmentLink('sync_pte_export') %>" class="dash-stat gv-holded-kpi" data-variant="blue" style="text-decoration:none; color:inherit; display:block; border-radius:12px;">
        <div class="dash-stat-label">Exportar → Holded</div>
        <div class="dash-stat-value"><%= s.syncPteExportar != null ? s.syncPteExportar : '—' %></div>
      </a>
      <a href="<%= segmentLink('sync_desinc') %>" class="dash-stat gv-holded-kpi" data-variant="blue" style="text-decoration:none; color:inherit; display:block; border-radius:12px;">
        <div class="dash-stat-label">Divergente / revisar</div>
        <div class="dash-stat-value"><%= s.syncDesincronizado != null ? s.syncDesincronizado : '—' %></div>
      </a>
      <div class="dash-stat" data-variant="navy" title="Suma de estados que requieren decisión de sync">
        <div class="dash-stat-label">Total atención sync</div>
        <div class="dash-stat-value"><%= s.syncRequierenAtencion != null ? s.syncRequierenAtencion : '—' %></div>
      </div>
    </div>
    <style>
      a.gv-holded-kpi:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12); }
    </style>

    <div style="display:flex; gap: 12px; flex-wrap: wrap; margin-bottom: 18px;">
      <form method="post" action="/cpanel/holded-clientes/import" style="display:inline;">
        <input type="hidden" name="dryRun" value="1" />
        <% sel.forEach(function(t) { %>
          <input type="hidden" name="tags" value="<%= t %>" />
        <% }) %>
        <% if (vp !== 'todos') { %>
          <input type="hidden" name="vista" value="<%= vp %>" />
        <% } %>
        <% if (seg) { %><input type="hidden" name="segment" value="<%= seg %>" /><% } %>
        <button type="submit" class="btn secondary">Simular importación</button>
      </form>
      <form method="post" action="/cpanel/holded-clientes/import" style="display:inline;">
        <% sel.forEach(function(t) { %>
          <input type="hidden" name="tags" value="<%= t %>" />
        <% }) %>
        <% if (vp !== 'todos') { %>
          <input type="hidden" name="vista" value="<%= vp %>" />
        <% } %>
        <% if (seg) { %><input type="hidden" name="segment" value="<%= seg %>" /><% } %>
        <button type="submit" class="btn">Importar ahora</button>
      </form>
      <a class="btn secondary" href="<%= vistaLink(vp) %>">Actualizar vista previa</a>
    </div>

    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin-bottom: 12px;">
      <h2 class="card-title" style="margin:0;">Vista previa</h2>
      <span style="font-size: 12px; font-weight: 700; color: var(--gv-muted);">Mostrar:</span>
      <a href="<%= vistaLink('todos') %>" class="badge <%= vp === 'todos' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;">Todos</a>
      <a href="<%= vistaLink('importables') %>" class="badge <%= vp === 'importables' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;" title="Nueva importación o reimportar desde Holded">Importar / reimportar</a>
      <a href="<%= vistaLink('importados') %>" class="badge <%= vp === 'importados' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;" title="Con la etiqueta elegida y ya existe fila en clientes (CRM)">Importados</a>
      <a href="<%= vistaLink('pendientes_importar') %>" class="badge <%= vp === 'pendientes_importar' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;" title="Con la etiqueta elegida y aún no hay cliente en la base">Pendientes de importar</a>
      <a href="<%= vistaLink('errores') %>" class="badge <%= vp === 'errores' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;" title="Tienen la etiqueta elegida pero no son importables (diferencia entre «con tag» e «importables»); motivo en la última columna">Errores</a>
      <a href="<%= vistaLink('omitidos') %>" class="badge <%= vp === 'omitidos' ? 'ok' : '' %>" style="text-decoration:none; cursor:pointer;">Solo omitidos</a>
    </div>
    <% const previewList = Array.isArray(previewRows) ? previewRows : rowsSafe; %>
    <% const motivoSinCif = typeof motivoSinCifHolded === 'string' ? motivoSinCifHolded : ''; %>
    <% const sinCifEnErrores = (vp === 'errores' && motivoSinCif) ? previewList.filter(function(r) { return String(r.motivo || '') === motivoSinCif; }) : []; %>
    <% const sinCifEnOmitidos = (vp === 'omitidos' && motivoSinCif) ? previewList.filter(function(r) { return String(r.motivo || '') === motivoSinCif; }) : []; %>
    <% const sinTagEnOmitidos = vp === 'omitidos' ? previewList.filter(function(r) { return r.coincideTag === false; }) : []; %>
    <p style="margin: 0 0 10px 0; font-size: 13px; color: var(--gv-muted);">
      Mostrando <strong><%= previewList.length %></strong> fila(s)<% if (vp !== 'todos' || seg) { %> (filtro activo; el total en Holded no cambia<% if (seg) { %>; segmento <code><%= seg %></code><% } %>)<% } %>.
    </p>
    <% if (vp === 'errores' && s.conTagSeleccionada != null && s.importables != null) { %>
    <p style="margin: -6px 0 12px 0; font-size: 12px; color: var(--gv-muted);">
      Lista = <strong>con tag elegida</strong> (<%= s.conTagSeleccionada %>) − <strong>importables</strong> (<%= s.importables %>) = contactos con etiqueta pero que no cumplen reglas de importación; el motivo está en la columna «Motivo».
    </p>
    <% } %>
    <% const tagsForLead = sel.length ? sel : (typeof tagScope === 'object' && tagScope && Array.isArray(tagScope.effectiveTagsDisplay) && tagScope.effectiveTagsDisplay.length ? tagScope.effectiveTagsDisplay : []); %>
    <% if (vp === 'errores' && sinCifEnErrores.length > 0 && tagsForLead.length) { %>
    <div style="margin-bottom: 14px; display: flex; flex-wrap: wrap; align-items: center; gap: 12px;">
      <form method="post" action="/cpanel/holded-clientes/alta-leads-sin-cif" style="display: inline;">
        <% tagsForLead.forEach(function(t) { %>
          <input type="hidden" name="tags" value="<%= t %>" />
        <% }) %>
        <input type="hidden" name="vista" value="errores" />
        <% if (seg) { %><input type="hidden" name="segment" value="<%= seg %>" /><% } %>
        <button type="submit" class="btn">Dar de alta como Lead (<%= sinCifEnErrores.length %> sin CIF en Holded)</button>
      </form>
      <span style="font-size: 12px; color: var(--gv-muted); max-width: 560px;">Crea clientes en estado Lead, CIF «Pendiente», vincula ID Holded y sincroniza tag <code>crm</code> en Holded si no la tenían.</span>
    </div>
    <% } %>
    <% if (vp === 'omitidos' && tagsForLead.length) { %>
    <div style="margin-bottom: 14px; display: flex; flex-wrap: wrap; align-items: flex-start; gap: 12px;">
      <% if (sinTagEnOmitidos.length > 0) { %>
      <a class="btn" href="<%= excelSinTagHref %>">Descargar Excel — revisión (<%= sinTagEnOmitidos.length %> sin etiqueta de filtro)</a>
      <% } %>
      <% if (sinCifEnOmitidos.length > 0) { %>
      <form method="post" action="/cpanel/holded-clientes/alta-leads-sin-cif" style="display: inline;">
        <% tagsForLead.forEach(function(t) { %>
          <input type="hidden" name="tags" value="<%= t %>" />
        <% }) %>
        <input type="hidden" name="vista" value="omitidos" />
        <% if (seg) { %><input type="hidden" name="segment" value="<%= seg %>" /><% } %>
        <button type="submit" class="btn secondary">Dar de alta como Lead (<%= sinCifEnOmitidos.length %> sin CIF en Holded)</button>
      </form>
      <% } %>
      <span style="font-size: 12px; color: var(--gv-muted); max-width: 560px;">Sin alcance de tags: descarga el Excel (faltan <code>crm</code> y el resto del alcance OR, p. ej. <code>sepa</code>). Omite filas sin ninguna etiqueta en Holded. Sin CIF: alta Lead. Resto de omitidos: <strong>bandera rosa</strong>.</span>
    </div>
    <% } else if (vp === 'omitidos') { %>
    <p style="margin: 0 0 12px 0; font-size: 12px; color: var(--gv-muted);">Las filas con <strong>bandera rosa</strong> a la izquierda son omitidas por un motivo distinto de «sin CIF» (p. ej. provincia no mapeada): revísalas en Holded o en el CRM.</p>
    <% } %>
    <div class="table-wrap" style="max-height: 70vh; overflow: auto;">
      <table class="dash-table">
        <thead>
          <tr>
            <th title="Nombre del estado del cliente en el CRM (estdoClientes) y estado de alineación Holded ↔ BD">Estado (BD / sync)</th>
            <th>ID Holded</th>
            <th>Nombre</th>
            <th>CIF</th>
            <th>Prov. Holded</th>
            <th>Prov. CRM</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th title="Solo se muestra la tag crm si el contacto la tiene">Tags (solo crm)</th>
            <th title="Fecha de última modificación en Holded (API) y en CRM si la columna existe">Últ. modificación</th>
            <th title="Campos comparables distintos entre Holded y CRM">Campos distintos</th>
            <th>Motivo</th>
            <th>Acción</th>
          </tr>
        </thead>
        <tbody>
          <% previewList.forEach((r) => { %>
            <% const isOmitRevisarPink = vp === 'omitidos' && !r.crmYaExisteEnCrm && (r.estadoBase === 'omitido' || r.estado === 'omitido') && motivoSinCif && String(r.motivo || '') !== motivoSinCif; %>
            <tr class="<%= isOmitRevisarPink ? 'gv-holded-omitidos-revisar' : '' %>">
              <td>
                <% if (r.crmYaExisteEnCrm && (r.estadoBase === 'omitido' || r.estado === 'omitido')) { %>
                  <span class="badge ok">En CRM</span>
                  <div style="font-size:11px; margin-top:6px; color: var(--gv-muted); line-height:1.35;">Ya hay cliente vinculado (ref/CIF). No cuenta como omitido operativo.</div>
                <% } else if (r.estadoBase === 'omitido' || r.estado === 'omitido') { %>
                  <span class="badge danger">omitido</span>
                <% } else { %>
                  <div style="font-weight:600; font-size:13px; color: var(--gv-text, #1a1a1a);">
                    <%= (r.crmEstadoClienteNombre && String(r.crmEstadoClienteNombre).trim()) ? String(r.crmEstadoClienteNombre).trim() : (r.crmVinculado ? '—' : 'Sin cliente en CRM') %>
                  </div>
                  <div style="font-size:11px; margin-top:5px; line-height:1.35;">
                    <% if (r.estado === 'importable') { %>
                      <span class="badge ok">Pendiente alta CRM</span>
                    <% } else if (r.estado === 'importado') { %>
                      <span class="badge ok">Al día (Holded ↔ BD)</span>
                    <% } else if (r.estado === 'pte_importar') { %>
                      <span class="badge warn">Pte. importar</span>
                    <% } else if (r.estado === 'pte_exportar') { %>
                      <span class="badge info">Sincronizar</span>
                    <% } else if (r.estado === 'desincronizado') { %>
                      <span class="badge danger">Desincronizado</span>
                    <% } else { %>
                      <span class="badge info"><%= r.estado || '—' %></span>
                    <% } %>
                  </div>
                <% } %>
              </td>
              <td style="font-size: 11px; font-family: monospace;"><%= r.holdedId || r.cli_Id_Holded || '—' %></td>
              <td><%= r.nombre || '—' %></td>
              <td><%= r.cif || '—' %></td>
              <td><%= r.provinciaHolded || '—' %></td>
              <td title="<%= r.estado === 'importado' ? 'Provincia CRM oculta: contacto ya importado' : '' %>"><% if (r.estado === 'importado') { %>—<% } else { %><%= r.provinciaCrm || '—' %><% } %></td>
              <td><%= r.email || '—' %></td>
              <td><%= r.telefono || r.movil || '—' %></td>
              <td style="max-width: 180px; word-break: break-word; font-size: 12px;"><%= r.tags || '—' %></td>
              <td style="font-size: 11px; line-height: 1.35; max-width: 160px;">
                <% if (r.estadoBase === 'omitido' || r.estado === 'omitido') { %>—<% } else { %>
                  <span style="color: var(--gv-muted);">Holded:</span> <%= r.holdedFechaModTexto || '—' %><br />
                  <span style="color: var(--gv-muted);">CRM:</span> <%= r.crmFechaModTexto || '—' %>
                <% } %>
              </td>
              <td style="font-size: 11px; max-width: 220px; line-height: 1.35;">
                <% if (r.estadoBase === 'omitido' || r.estado === 'omitido') { %>—<% } else if (Array.isArray(r.syncCamposDiferentes) && r.syncCamposDiferentes.length) { %>
                  <%= r.syncCamposDiferentes.join(', ') %>
                <% } else { %>—<% } %>
              </td>
              <td style="font-size: 12px;"><%= r.motivo || '—' %></td>
              <td style="font-size: 12px; white-space: nowrap;">
                <% if (r.estado === 'pte_exportar' && r.holdedId) { %>
                  <form method="post" action="/cpanel/holded-clientes/export-crm" style="display:inline;">
                    <input type="hidden" name="holdedId" value="<%= r.holdedId %>" />
                    <% if (vp !== 'todos') { %><input type="hidden" name="vista" value="<%= vp %>" /><% } %>
                    <% if (seg) { %><input type="hidden" name="segment" value="<%= seg %>" /><% } %>
                    <% sel.forEach(function(t) { %><input type="hidden" name="tags" value="<%= t %>" /><% }); %>
                    <button type="submit" class="btn secondary" style="font-size: 11px; padding: 4px 8px;">Volcar CRM → Holded</button>
                  </form>
                <% } else { %>—<% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
