        <section id="tab_<%= t.id %>" class="gv-tabpanel <%= idx === 0 ? 'is-active' : '' %>" role="tabpanel" data-tabpanel="<%= t.id %>">
          <% if (t.id === 'direccion') { %>
            <div class="gv-direccion-tab-hd" style="margin-bottom: 14px;">
              <% if (mode === 'edit' && cid) { %>
                <a class="btn gv-relaciones-add" href="/clientes/<%= cid %>/direcciones/new">Añadir dirección de envío</a>
                <p class="gv-relaciones-tab__sub" style="margin: 8px 0 0 0; font-size: 13px; color: var(--gv-muted);">Si el cliente tiene más de una dirección de envío, añádelas aquí.</p>
              <% } else { %>
                <p style="font-size: 13px; color: var(--gv-muted);">Guarda primero el cliente para poder añadir direcciones de envío adicionales.</p>
              <% } %>
            </div>
          <% } %>
          <% if (t.id === 'relaciones' && mode === 'edit' && cid) { %>
            <div class="gv-relaciones-tab">
              <div class="gv-relaciones-tab__hd">
                <h3 class="gv-relaciones-tab__title">Contactos relacionados</h3>
                <p class="gv-relaciones-tab__sub">Vincula este contacto con otros para ver relaciones cruzadas.</p>
                <button type="button" class="btn gv-relaciones-add" id="gvBtnAddRelaciones">Añadir contactos relacionados</button>
              </div>
              <div class="table-wrap gv-relaciones-table-wrap" <%= (!relaciones || relaciones.length === 0) ? 'style="display:none;"' : '' %>>
                <table class="gv-contactos-table gv-relaciones-table">
                  <colgroup>
                    <col class="gv-contactos-col-nombre" />
                    <col class="gv-contactos-col-tipo" />
                    <col class="gv-contactos-col-telefono" />
                    <col class="gv-contactos-col-email" />
                    <col class="gv-contactos-col-contacto" />
                    <col class="gv-contactos-col-provincia" />
                    <col class="gv-contactos-col-estado" />
                    <col class="gv-contactos-col-acciones" />
                  </colgroup>
                  <thead>
                    <tr>
                      <th class="gv-contactos-col-nombre">Nombre / Razón Social</th>
                      <th>Tipo</th>
                      <th class="gv-contactos-col-telefono">Teléfono</th>
                      <th class="gv-contactos-col-email">Email</th>
                      <th class="gv-contactos-col-contacto">Contacto</th>
                      <th>Provincia</th>
                      <th class="gv-contactos-col-estado">Estado</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody id="gvRelacionesList">
                    <% (relaciones || []).forEach((r) => { %>
                      <% const nom = r.relacionado_nombre || r.relacionado_nombre_cial || r.origen_nombre || r.origen_nombre_cial || 'Cliente'; %>
                      <% const tipo = r.relacionado_tipo || r.origen_tipo || '—'; %>
                      <% const tel = String(r.relacionado_telefono || r.relacionado_movil || r.origen_telefono || r.origen_movil || '').trim(); %>
                      <% const email = String(r.relacionado_email || r.origen_email || '').trim(); %>
                      <% const contacto = r.relacionado_nom_contacto || r.origen_nom_contacto || '—'; %>
                      <% const provincia = r.relacionado_provincia || r.origen_provincia || '—'; %>
                      <% const estado = r.relacionado_estado || r.origen_estado || '—'; %>
                      <% const relId = r.clirel_cli_relacionado_id || r.clirel_cli_origen_id; %>
                      <% const origenId = r.clirel_cli_origen_id; %>
                      <% const relacionadoId = r.clirel_cli_relacionado_id; %>
                      <tr class="gv-relacion-row" data-origen="<%= origenId %>" data-relacionado="<%= relacionadoId %>">
                        <td class="gv-contactos-col-nombre"><%= nom %></td>
                        <td><% const tipoClase = (String(tipo).toLowerCase() === 'empresa') ? 'empresa' : (String(tipo).toLowerCase() === 'persona') ? 'persona' : 'otros'; %><span class="gv-badge gv-badge--<%= tipoClase %>"><%= tipo %></span></td>
                        <td class="gv-contactos-col-telefono"><%- include('partials/telefono-display', { telefono: tel }) %></td>
                        <td class="gv-contactos-col-email"><% if (email) { %><a href="mailto:<%= email %>" class="gv-contactos-link"><%= email %></a><% } else { %>—<% } %></td>
                        <td class="gv-contactos-col-contacto"><%= contacto %></td>
                        <td><%= provincia %></td>
                        <td class="gv-contactos-col-estado"><%= estado %></td>
                        <td>
                          <div class="gv-actions">
                            <a class="btn secondary icon" href="/clientes/<%= relId %>" target="_blank" title="Ver" aria-label="Ver contacto <%= relId %>">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                              </svg>
                            </a>
                            <button type="button" class="btn secondary icon gv-remove-relacion" data-origen="<%= origenId %>" data-relacionado="<%= relacionadoId %>" title="Quitar relación" aria-label="Quitar relación">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                              </svg>
                            </button>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <p class="gv-relaciones-empty" id="gvRelacionesEmpty" <%= (relaciones && relaciones.length > 0) ? 'style="display:none;"' : '' %>>
                No hay contactos relacionados. Usa el botón superior para añadirlos.
              </p>
            </div>
          <% } else if (t.id === 'mayoristas' && !cid) { %>
            <div class="gv-relaciones-tab">
              <div class="gv-relaciones-tab__hd">
                <h3 class="gv-relaciones-tab__title">Mayoristas / Cooperativas</h3>
                <p class="gv-relaciones-tab__sub">Asocia los mayoristas con los que trabaja este cliente y su número de asociado.</p>
              </div>
              <p style="font-size: 13px; color: var(--gv-muted); margin: 0;">Guarda primero el cliente para poder vincular mayoristas y el número de asociado.</p>
            </div>
          <% } else if (t.id === 'mayoristas' && cid) { %>
            <div class="gv-relaciones-tab">
              <div class="gv-relaciones-tab__hd">
                <h3 class="gv-relaciones-tab__title">Mayoristas / Cooperativas</h3>
                <p class="gv-relaciones-tab__sub">Asocia los mayoristas con los que trabaja este cliente y su número de asociado.</p>
              </div>
              <% if (mode === 'edit') { %>
              <div style="display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap; margin-bottom:16px;">
                <label style="display:grid; gap:4px; flex:1; min-width:160px;">
                  <span style="font-weight:700; font-size:13px;">Mayorista</span>
                  <select id="gvCoopSelect" style="padding:8px 10px; border:1px solid var(--gv-border); border-radius:8px; font-size:14px;">
                    <option value="">— Seleccionar —</option>
                    <% (cooperativas || []).forEach((c) => { %>
                      <% const cid2 = Number(c.coop_id ?? c.id ?? c.Id ?? 0); %>
                      <option value="<%= cid2 %>"><%= c.coop_nombre ?? c.Nombre ?? c.nombre ?? ('Cooperativa ' + cid2) %></option>
                    <% }) %>
                  </select>
                </label>
                <label style="display:grid; gap:4px; flex:1; min-width:120px;">
                  <span style="font-weight:700; font-size:13px;">Nº Asociado</span>
                  <input type="text" id="gvCoopNumAsociado" placeholder="Código de asociado" style="padding:8px 10px; border:1px solid var(--gv-border); border-radius:8px; font-size:14px;" />
                </label>
                <button type="button" class="btn gv-relaciones-add" id="gvBtnAddCoop" style="white-space:nowrap;">Añadir</button>
              </div>
              <% } %>
              <div class="table-wrap" id="gvCoopTableWrap" <%= (!(cooperativasCliente || []).length) ? 'style="display:none;"' : '' %>>
                <table class="gv-contactos-table">
                  <thead>
                    <tr>
                      <th>Mayorista</th>
                      <th>Nº Asociado</th>
                      <% if (mode === 'edit') { %><th style="width:60px;">Acciones</th><% } %>
                    </tr>
                  </thead>
                  <tbody id="gvCoopList">
                    <% (cooperativasCliente || []).forEach((cc) => { %>
                      <tr data-rel-id="<%= cc.id || '' %>" data-coop-id="<%= cc.Id_Cooperativa %>">
                        <td style="font-weight:700;"><%= cc.Nombre || '—' %></td>
                        <td>
                          <span class="gv-coop-num-display"><%= cc.NumAsociado || '—' %></span>
                          <% if (mode === 'edit') { %>
                          <input type="text" class="gv-coop-num-input" value="<%= cc.NumAsociado || '' %>" style="display:none; padding:5px 8px; border:1px solid var(--gv-border); border-radius:6px; font-size:13px; width:100%;" />
                          <% } %>
                        </td>
                        <% if (mode === 'edit') { %>
                        <td>
                          <div class="gv-actions" style="display:flex; gap:4px;">
                            <button type="button" class="btn secondary icon gv-edit-coop" data-rel-id="<%= cc.id || '' %>" title="Editar nº asociado">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:15px;height:15px;">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                              </svg>
                            </button>
                            <button type="button" class="btn secondary icon gv-remove-coop" data-rel-id="<%= cc.id || '' %>" title="Quitar">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:15px;height:15px;">
                                <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
                              </svg>
                            </button>
                          </div>
                        </td>
                        <% } %>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <p id="gvCoopEmpty" <%= ((cooperativasCliente || []).length) ? 'style="display:none;"' : '' %> style="color:var(--gv-muted); font-size:14px; margin-top:8px;">
                No hay mayoristas asociados a este cliente.
              </p>
            </div>
          <% } else { %>
          <div class="grid cols-2 gv-form-grid<%= t.id === 'datos_banco' ? ' gv-datos-banco-stack' : '' %>" style="gap: 12px;">
              <% (t.fields || []).forEach((f) => { %>
                <% const name = f.name; %>
                <% const label = f.label; %>
                <% const required = !!f.required; %>
                <% const spec = f.spec || {}; %>
                <% if (spec.kind === 'relaciones' || spec.kind === 'mayoristas') return; %>
                <% if (spec.options === 'comerciales') return; %>
                <% const isMissing = missingFieldsList.indexOf(name) !== -1; %>
                <% const inputId = `gv_${String(name).replace(/[^a-zA-Z0-9_-]/g, '_')}`; %>
                <% const nl = String(name || '').toLowerCase(); %>
                <% let datBancoCls = ''; %>
                <% if (t.id === 'datos_banco') {
                  if (nl.includes('iban')) datBancoCls = ' gv-datbanco-iban';
                  else if (nl.includes('banco')) datBancoCls = ' gv-datbanco-banco';
                  else datBancoCls = ' gv-datbanco-rest';
                } %>

                <% const isTipoEspField = (spec.options === 'tipos_clientes' || spec.options === 'especialidades' || spec.options === 'tipos_clientes_nombre'); %>
                <% const isAdminOnly = !!f.adminOnly; %>
                <% const forceReadonly = isAdminOnly && !(typeof admin !== 'undefined' && admin); %>
                <% const fieldPlaceholder = (typeof f.placeholder === 'string' && f.placeholder.trim()) ? f.placeholder.trim() : ''; %>
                <label style="display:grid; gap: 6px;" class="<%= isMissing ? 'gv-field-error' : '' %><%= isTipoEspField ? ' gv-field-tipo-esp' : '' %><%= isAdminOnly ? ' gv-field-admin-only' : '' %><%= datBancoCls %>" <%= isTipoEspField ? ' data-visibility-tipo-contacto="persona"' : '' %>>
                  <span style="font-weight:800; color: var(--gv-ink); font-size: 13px;"><%= label %><%= required ? ' *' : '' %><% if (isAdminOnly) { %> <span class="gv-badge-admin" title="Solo puede editar un administrador">Solo admin</span><% } %></span>

                  <% if (forceReadonly) { %>
                    <div class="gv-readonly"><%= _pickVal(name) || '—' %></div>
                    <input type="hidden" name="<%= name %>" value="<%= _pickVal(name) %>" />
                  <% } else if (spec.kind === 'readonly') { %>
                    <div class="gv-readonly"><%= pickDisplayVal(name) %></div>
                  <% } else if (spec.kind === 'textarea') { %>
                    <textarea id="<%= inputId %>" name="<%= name %>" rows="4" <%= required ? 'required' : '' %> aria-invalid="<%= isMissing ? 'true' : 'false' %>"><%= _pickVal(name) %></textarea>
                  <% } else if (spec.kind === 'checkbox') { %>
                    <input type="hidden" name="<%= name %>" value="0" />
                    <div style="display:flex; align-items:center; gap:10px;">
                      <input id="<%= inputId %>" type="checkbox" name="<%= name %>" value="1" <%= (_pickVal(name) === '1' || _pickVal(name).toLowerCase() === 'true') ? 'checked' : '' %> />
                      <span style="color: var(--gv-muted); font-weight:700;">Sí</span>
                    </div>
                  <% } else if (spec.kind === 'select' && spec.options === 'ok_ko') { %>
                    <select id="gv-ok-ko" name="<%= name %>">
                      <option value="1" <%= _pickVal(name) === '1' ? 'selected' : '' %>>Activo</option>
                      <option value="0" <%= _pickVal(name) === '0' ? 'selected' : '' %>>Inactivo</option>
                    </select>
                    <small style="color: var(--gv-muted);">Solo se puede estar activo con DNI/CIF informado.</small>
                  <% } else if (spec.kind === 'select' && spec.options === 'estados_cliente') { %>
                    <% const curId = Number(_pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% (estadosCliente || []).forEach((r) => { %>
                        <% const rid = Number(r.estcli_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                        <% const rlabel = r.estcli_nombre ?? r.Nombre ?? r.nombre ?? r.Estado ?? r.estado ?? r.descripcion ?? r.Descripcion ?? ('Estado ' + rid); %>
                        <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                      <% }) %>
                    </select>
                    <small style="color: var(--gv-muted);">Si seleccionas Activo sin DNI/CIF válido, se guardará como Potencial.</small>
                  <% } else if (spec.kind === 'select' && spec.options === 'tipo_contacto') { %>
                    <% const curTipo = String(_pickVal(name) || '').trim(); %>
                    <select id="gv-tipo-contacto" name="<%= name %>" data-field="tipo_contacto">
                      <option value="">— Seleccionar —</option>
                      <option value="Empresa" <%= curTipo.toLowerCase() === 'empresa' ? 'selected' : '' %>>Empresa</option>
                      <option value="Persona" <%= curTipo.toLowerCase() === 'persona' ? 'selected' : '' %>>Persona</option>
                      <option value="Otros" <%= curTipo.toLowerCase() === 'otros' ? 'selected' : '' %>>Otros</option>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'comerciales') { %>
                    <% const cur = Number(_pickVal(name) || 0) || 0; %>
                    <% const canEditDelegado = (typeof canChangeComercial !== 'undefined' && canChangeComercial === true) || (typeof admin !== 'undefined' && admin === true); %>
                    <% if (canEditDelegado) { %>
                      <select id="<%= inputId %>" name="<%= name %>">
                        <option value="">(sin asignar)</option>
                        <% (comerciales || []).forEach((c) => { %>
                          <% const cid = Number(c.com_id ?? c.id ?? c.Id ?? 0) || 0; %>
                          <% const cnombre = c.com_nombre ?? c.Nombre ?? ''; %>
                          <% const cemail = c.com_email ?? c.Email ?? c.email ?? ''; %>
                          <option value="<%= cid %>" <%= cid === cur ? 'selected' : '' %>><%= cnombre %> (<%= cemail %>)</option>
                        <% }) %>
                      </select>
                    <% } else { %>
                      <% const comercialAsignado = (comerciales || []).find(function(c){ return Number(c.com_id ?? c.id ?? c.Id ?? 0) === cur; }); %>
                      <div class="gv-readonly"><%= comercialAsignado ? (comercialAsignado.com_nombre ?? comercialAsignado.Nombre ?? '') : 'Sin asignar' %></div>
                      <input type="hidden" name="<%= name %>" value="<%= _pickVal(name) %>" />
                    <% } %>
                  <% } else if (spec.kind === 'select' && spec.options === 'tarifas') { %>
                    <% const curTar = Number(_pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="0" <%= curTar === 0 ? 'selected' : '' %>>0 PVL</option>
                      <% (tarifas || []).forEach((t) => { %>
                        <% const tid = Number(t.tarcli_id ?? t.Id ?? t.id ?? 0) || 0; %>
                        <% const tlabel = t.tarcli_nombre ?? t.NombreTarifa ?? t.Nombre ?? t.nombre ?? ('Tarifa ' + tid); %>
                        <option value="<%= tid %>" <%= tid === curTar ? 'selected' : '' %>><%= tid %> · <%= tlabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'paises') { %>
                    <% const curId = Number(_pickVal(name) || 0) || 0; %>
                    <% const curPaisEnLista = (paises || []).some((p) => Number(p.pais_id ?? p.id ?? p.Id ?? 0) === curId); %>
                    <% const curPaisLabel = (item && (item.PaisNombre ?? item.Pais ?? item.cli_Pais)) ? String(item.PaisNombre ?? item.Pais ?? item.cli_Pais).trim() : (curId ? 'País ' + curId : ''); %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% if (curId && !curPaisEnLista && curPaisLabel) { %>
                        <option value="<%= curId %>" selected><%= curPaisLabel %></option>
                      <% } %>
                      <% (paises || []).forEach((p) => { %>
                        <% const pid = Number(p.pais_id ?? p.id ?? p.Id ?? p.ID ?? 0) || 0; %>
                        <% const plabel = p.pais_nombre ?? p.Nombre_pais ?? p.Nombre ?? p.nombre ?? p.Pais ?? ('País ' + pid); %>
                        <% const pCodigo = String(p.pais_codigo ?? p.Id_pais ?? p.id_pais ?? '').trim().toUpperCase(); %>
                        <option value="<%= pid %>" data-pais-codigo="<%= pCodigo %>" <%= pid === curId ? 'selected' : '' %>><%= plabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'provincias') { %>
                    <% const curId = Number(_pickVal(name) || 0) || 0; %>
                    <% const curProvEnLista = (provincias || []).some((p) => Number(p.prov_id ?? p.id ?? p.Id ?? p.ID ?? 0) === curId); %>
                    <% const curProvLabel = (item && (item.ProvinciaNombre ?? item.Provincia ?? item.provincia)) ? String(item.ProvinciaNombre ?? item.Provincia ?? item.provincia).trim() : (curId ? 'Provincia ' + curId : ''); %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% if (curId && !curProvEnLista && curProvLabel) { %>
                        <option value="<%= curId %>" selected><%= curProvLabel %></option>
                      <% } %>
                      <% (provincias || []).forEach((p) => { %>
                        <% const pid = Number(p.prov_id ?? p.id ?? p.Id ?? p.ID ?? 0) || 0; %>
                        <% const plabel = p.prov_nombre ?? p.Nombre_provincia ?? p.Nombre ?? p.nombre ?? p.Provincia ?? ('Provincia ' + pid); %>
                        <option value="<%= pid %>" <%= pid === curId ? 'selected' : '' %>><%= plabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'formas_pago') { %>
                    <% const curId = Number(_pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% (formasPago || []).forEach((r) => { %>
                        <% const rid = Number(r.formp_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                        <% const rlabel = r.formp_nombre ?? r.FormaPago ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? ('Forma pago ' + rid); %>
                        <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                      <% }) %>
                    </select>
                <% } else if (spec.kind === 'select' && spec.options === 'tipos_clientes') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (tiposClientes || []).forEach((r) => { %>
                      <% const rid = Number(r.tipc_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.tipc_nombre ?? r.tipc_tipo ?? r.Tipo ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? ('Tipo cliente ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'especialidades') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (especialidades || []).forEach((r) => { %>
                      <% const rid = Number(r.esp_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.esp_nombre ?? r.Nombre ?? r.nombre ?? r.Especialidad ?? r.descripcion ?? ('Especialidad ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'tipos_clientes_nombre') { %>
                  <% const cur = String(_pickVal(name) || '').trim().toLowerCase(); %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (tiposClientes || []).forEach((r) => { %>
                      <% const rlabel = String(r.Tipo ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? '').trim(); %>
                      <% const rval = rlabel; %>
                      <option value="<%= rval %>" <%= (rlabel && rlabel.trim().toLowerCase() === cur) ? 'selected' : '' %>><%= rlabel || '—' %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'idiomas') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (idiomas || []).forEach((r) => { %>
                      <% const rid = Number(r.idiom_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const code = (r.Codigo ?? r.codigo ?? r.idiom_codigo ?? '').toString().trim().toUpperCase(); %>
                      <% const rname = r.idiom_nombre ?? r.Nombre ?? r.Idioma ?? r.descripcion ?? r.Descripcion ?? ('Idioma ' + rid); %>
                      <% const rlabel = code ? (code + ' · ' + rname) : rname; %>
                      <option value="<%= rid %>" data-idiom-codigo="<%= code %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'monedas') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <% const curMonEnLista = (monedas || []).some((r) => Number(r.mon_id ?? r.id ?? r.Id ?? r.ID ?? 0) === curId); %>
                  <% const curMonLabel = (item && (item.MonedaNombre ?? item.Moneda ?? item.cli_Moneda)) ? String(item.MonedaNombre ?? item.Moneda ?? item.cli_Moneda).trim() : (curId ? 'Moneda ' + curId : ''); %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% if (curId && !curMonEnLista && curMonLabel) { %>
                      <option value="<%= curId %>" selected><%= curMonLabel %></option>
                    <% } %>
                    <% (monedas || []).forEach((r) => { %>
                      <% const rid = Number(r.mon_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const code = (r.Codigo ?? r.codigo ?? r.ISO ?? r.Iso ?? r.mon_codigo ?? '').toString().trim().toUpperCase(); %>
                      <% const rname = r.mon_nombre ?? r.Nombre ?? r.Moneda ?? r.descripcion ?? r.Descripcion ?? ('Moneda ' + rid); %>
                      <% const rlabel = code ? (code + ' · ' + rname) : rname; %>
                      <option value="<%= rid %>" data-mon-codigo="<%= code %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'cooperativas') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (cooperativas || []).forEach((r) => { %>
                      <% const rid = Number(r.coop_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.coop_nombre ?? r.Nombre ?? r.nombre ?? ('Cooperativa ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'grupos_compras') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (gruposCompras || []).forEach((r) => { %>
                      <% const rid = Number(r.grupcompr_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.grupcompr_nombre ?? r.Nombre ?? r.nombre ?? ('Grupo compras ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'input' && spec.pctDescuento) { %>
                  <% const displayVal = numVal(name); %>
                  <span class="gv-pct-descuento-wrap" style="display:inline-flex; align-items:center; gap:6px; max-width:100%;">
                    <input
                      id="<%= inputId %>"
                      name="<%= name %>"
                      type="text"
                      inputmode="decimal"
                      autocomplete="off"
                      class="gv-input-pct-descuento"
                      value="<%= displayVal %>"
                      placeholder="0"
                      aria-invalid="<%= isMissing ? 'true' : 'false' %>"
                      title="Solo números y separador decimal (porcentaje)"
                    />
                    <span style="font-weight:800; color:var(--gv-muted); font-size:14px;">%</span>
                  </span>
                <% } else { %>
                  <% const type = spec.type || 'text'; %>
                  <% const isNombreField = (label && String(label).indexOf('Nombre / Razón social') !== -1); %>
                  <% const isTelField = (spec.type === 'tel' || /telefono|movil/i.test(String(name))); %>
                  <% const displayVal = (type === 'number') ? numVal(name) : (isTelField && typeof fmtTelefono === 'function') ? fmtTelefono(_pickVal(name)) : _pickVal(name); %>
                  <% const gvBankData = (t.id === 'datos_banco' && !forceReadonly) ? (nl.includes('iban') ? ' data-gv-iban-field="1"' : nl.includes('banco') ? ' data-gv-banco-field="1"' : (nl.includes('swift') || nl.includes('bic') || nl.includes('swift_bic')) ? ' data-gv-swift-field="1"' : '') : ''; %>
                  <input
                    id="<%= inputId %>"
                    name="<%= name %>"
                    type="<%= type %>"
                    <%= required ? 'required' : '' %>
                    value="<%= displayVal %>"
                    <% if (fieldPlaceholder) { %>placeholder="<%= fieldPlaceholder %>"<% } %>
                    aria-invalid="<%= isMissing ? 'true' : 'false' %>"
                    <%= type === 'number' ? 'step="0.01"' : '' %>
                    <% if (isNombreField) { %>data-gv-nombre-field="1"<% } %>
                    <%= gvBankData %>
                  />
                <% } %>

                <% if (isMissing) { %><small class="gv-field-error-msg">Campo obligatorio</small><% } %>
              </label>
            <% }) %>
          </div>
          <% } %>
        </section>
