    <style nonce="<%= cspNonce %>">
    .gv-scroll-top {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 9999;
      width: 44px;
      height: 44px;
      border: none;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gv-primary, #008bd2), var(--gv-primary-2, #005f8f));
      color: #fff;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(0,0,0,.18);
      opacity: 0;
      visibility: hidden;
      transform: translateY(12px);
      transition: opacity .25s ease, visibility .25s ease, transform .25s ease, background .2s ease;
    }
    .gv-scroll-top.is-visible {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .gv-scroll-top:hover {
      background: var(--gv-ink, #0c143a);
      box-shadow: 0 6px 20px rgba(0,0,0,.25);
    }
    .gv-scroll-top:active { transform: scale(.92); }
    @media (max-width: 600px) {
      .gv-scroll-top { bottom: 18px; right: 18px; width: 40px; height: 40px; }
    }
    </style>
    <script nonce="<%= cspNonce %>">
    (function(){
      var btn = document.getElementById('gv-scroll-top');
      if (!btn) return;
      var threshold = 300;
      var ticking = false;
      function check() {
        if (window.scrollY > threshold) btn.classList.add('is-visible');
        else btn.classList.remove('is-visible');
        ticking = false;
      }
      window.addEventListener('scroll', function() {
        if (!ticking) { window.requestAnimationFrame(check); ticking = true; }
      }, { passive: true });
      btn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      check();
    })();
    </script>

