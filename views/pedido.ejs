<%- include('partials/header', { title: 'Pedido' }) %>

<%
  const pedidoId = item?.id ?? item?.Id ?? item?.ped_id ?? '';
  const numPedido = item?.NumPedido ?? item?.ped_numero ?? '';
  const fecha = fmtDateES(item.FechaPedido ?? item.Fecha ?? item?.ped_fecha ?? '');
  const entrega = item?.FechaEntrega ? fmtDateES(item.FechaEntrega) : '';
  const clienteNombre = (typeof clienteLabel !== 'undefined' && clienteLabel) ? clienteLabel : (cliente && (cliente.Nombre_Razon_Social || cliente.cli_nombre_razon_social || cliente.Nombre || cliente.nombre)) ? (cliente.Nombre_Razon_Social || cliente.cli_nombre_razon_social || cliente.Nombre || cliente.nombre) : '';
  const clienteCif = (cliente && (cliente.DNI_CIF || cliente.cli_dni_cif || cliente.DniCif)) ? (cliente.DNI_CIF || cliente.cli_dni_cif || cliente.DniCif) : '';
  const clienteDir = cliente?.Direccion || cliente?.cli_direccion || '';
  const clientePob = cliente?.Poblacion || cliente?.cli_poblacion || '';
  const clienteCp = cliente?.CodigoPostal || cliente?.cli_codigo_postal || '';
  const clienteEmail = cliente?.Email || cliente?.cli_email || '';
  const clienteTel = cliente?.Telefono || cliente?.cli_telefono || cliente?.Movil || cliente?.cli_movil || '';
  const dir = direccionEnvio || null;
  const dtoPedidoPct = Math.max(0, Math.min(100, toNum(item.ped_dto ?? item.Dto ?? item.Descuento ?? 0, 0)));
  const _regfisId = Number(item?.ped_regfis_id ?? cliente?.cli_regfis_id ?? 1) || 1;
  const _taxLabels = { 1: 'IVA', 2: 'IGIC', 3: 'IPSI' };
  const taxLabel = _taxLabels[_regfisId] || 'IVA';
  const serie = String(item?.Serie ?? item?.serie ?? 'P').trim();
  const idDireccionEnvio = Number(item?.Id_DireccionEnvio ?? item?.id_direccion_envio ?? item?.ped_direnv_id ?? 0) || 0;

  const idFormaPago = Number(item?.Id_FormaPago ?? item?.id_forma_pago ?? item?.ped_formp_id ?? 0) || 0;
  const formaPagoDisplay = (typeof formaPagoLabel !== 'undefined' && formaPagoLabel) ? formaPagoLabel : String(formaPago?.Nombre ?? formaPago?.FormaPago ?? formaPago?.nombre ?? formaPago?.forma_pago ?? '').trim() || (idFormaPago ? String(idFormaPago) : '');

  const idTipoPedido = Number(item?.Id_TipoPedido ?? item?.id_tipo_pedido ?? item?.ped_tipp_id ?? 0) || 0;
  const tipoPedidoDisplay = (typeof tipoPedidoLabel !== 'undefined' && tipoPedidoLabel) ? tipoPedidoLabel : String(tipoPedido?.Nombre ?? tipoPedido?.Tipo ?? tipoPedido?.nombre ?? tipoPedido?.tipo ?? '').trim() || (idTipoPedido ? String(idTipoPedido) : '');

  const idTarifa = Number(item?.Id_Tarifa ?? item?.id_tarifa ?? item?.ped_tarcli_id ?? 0) || 0;
  const tarifaDisplay = (typeof tarifaLabel !== 'undefined' && tarifaLabel) ? tarifaLabel : String(tarifa?.NombreTarifa ?? tarifa?.Nombre ?? tarifa?.nombre ?? tarifa?.tarcli_nombre ?? '').trim() || (idTarifa ? String(idTarifa) : '');

  const idEstadoPedido = Number(item?.Id_EstadoPedido ?? item?.id_estado_pedido ?? item?.ped_estped_id ?? 0) || 0;
  const estadoDisplay = (typeof estadoLabel !== 'undefined' && estadoLabel) ? estadoLabel : String(estadoPedido?.nombre ?? estadoPedido?.Nombre ?? estadoPedido?.estped_nombre ?? item?.EstadoPedido ?? item?.Estado ?? item?.ped_estado_txt ?? '').trim();
  const estadoColorRaw = String(estadoPedido?.color ?? estadoPedido?.Color ?? item?.EstadoColor ?? '').trim().toLowerCase();
  const st = (estadoDisplay || '').toLowerCase();
  const clsPalette = st.includes('deneg') ? 'danger' : (st.includes('pagad') || st.includes('aprob') ? 'ok' : (st.includes('pend') ? 'warn' : 'info'));
  const estadoCls = ['ok', 'danger', 'warn', 'info'].includes(estadoColorRaw) ? estadoColorRaw : clsPalette;

  const idComercial = Number(item?.Id_Cial ?? item?.id_cial ?? item?.ped_com_id ?? item?.ComercialId ?? item?.comercialId ?? 0) || 0;
  const comercialDisplay = (typeof comercialLabel !== 'undefined' && comercialLabel) ? comercialLabel : String(comercial?.Nombre ?? comercial?.com_nombre ?? comercial?.nombre ?? item?.ComercialNombre ?? '').trim() || (idComercial ? String(idComercial) : '');

  const observaciones = String(item?.Observaciones ?? item?.observaciones ?? item?.ped_observaciones ?? '').trim();
%>

<div class="gv-doc-page">
  <div class="gv-doc-top gv-no-print">
    <a class="btn secondary" href="/pedidos">Volver</a>
    <% if (typeof canEdit !== 'undefined' && canEdit) { %>
      <a class="btn secondary" href="/pedidos/<%= pedidoId %>/edit">Editar</a>
    <% } %>
    <% if (admin) { %>
      <form method="post" action="/pedidos/<%= pedidoId %>/delete" style="display:inline;" onsubmit="return confirm('¿Eliminar este pedido?');">
        <%- include('partials/csrf-field') %>
        <button class="btn secondary" style="border-color: rgba(255,186,0,.6);" type="submit">Borrar</button>
      </form>
    <% } %>
    <% if (typeof isTransfer !== 'undefined' && isTransfer) { %>
    <a class="btn secondary" href="/pedidos/<%= pedidoId %>/transfer.xlsx" style="display:inline-flex;align-items:center;gap:6px;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>Excel</a>
    <a class="btn secondary" href="/pedidos/<%= pedidoId %>/transfer-imprimir" target="_blank" rel="noopener">Imprimir Transfer</a>
    <% } else { %>
    <a class="btn secondary" href="/pedidos/<%= pedidoId %>.xlsx">Excel</a>
    <a class="btn secondary" href="/pedidos/<%= pedidoId %>?print=1" target="_blank" rel="noopener" title="Imprimir o guardar como PDF">Imprimir</a>
    <% } %>
    <% if (canShowHefame) { %>
    <span class="gv-hefame-wrap">
      <a class="btn secondary" href="/pedidos/<%= pedidoId %>/hefame.xlsx">HEFAME</a>
      <button type="button" class="gv-hefame-info-btn" onclick="document.getElementById('modal-hefame').showModal()" title="Información Hefame" aria-label="Información Hefame">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
      </button>
    </span>
    <% } %>
  </div>

  <% if (canShowHefame) { %>
  <dialog id="modal-hefame" class="gv-modal-hefame" aria-labelledby="modal-hefame-title" onclick="if (event.target === this) this.close()">
    <div class="gv-modal-hefame-inner">
      <h2 id="modal-hefame-title" class="gv-modal-hefame-title">Export Hefame</h2>
      <p class="gv-modal-hefame-text">El envío por email está temporalmente deshabilitado.</p>
      <p class="gv-modal-hefame-text">Puede descargar la plantilla Excel con los datos del pedido para Hefame usando el enlace siguiente.</p>
      <p class="gv-modal-hefame-actions">
        <a class="btn" href="/pedidos/<%= pedidoId %>/hefame.xlsx">Descargar plantilla Excel Hefame</a>
      </p>
      <button type="button" class="gv-modal-hefame-close" onclick="document.getElementById('modal-hefame').close()" aria-label="Cerrar">Cerrar</button>
    </div>
  </dialog>
  <% } %>
  <style nonce="<%= cspNonce %>">
    .gv-hefame-wrap { display: inline-flex; align-items: center; gap: 4px; }
    .gv-hefame-info-btn { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; padding: 0; border: 1px solid rgba(0,0,0,.15); border-radius: 6px; background: var(--gv-bg, #f8f9fa); color: var(--gv-muted, #6c757d); cursor: pointer; }
    .gv-hefame-info-btn:hover { background: var(--gv-bg-hover, #e9ecef); color: var(--gv-fg, #212529); }
    .gv-modal-hefame { border: none; border-radius: 8px; padding: 0; max-width: 90vw; width: 420px; box-shadow: 0 4px 20px rgba(0,0,0,.2); }
    .gv-modal-hefame::backdrop { background: rgba(0,0,0,.4); }
    .gv-modal-hefame-inner { padding: 20px 24px; }
    .gv-modal-hefame-title { margin: 0 0 12px; font-size: 1.15rem; color: var(--gv-fg, #212529); }
    .gv-modal-hefame-text { margin: 0 0 8px; font-size: 0.95rem; line-height: 1.45; color: var(--gv-muted, #495057); }
    .gv-modal-hefame-actions { margin: 16px 0 12px; }
    .gv-modal-hefame-close { display: block; margin-top: 8px; padding: 6px 12px; font-size: 0.9rem; background: transparent; border: 1px solid rgba(0,0,0,.2); border-radius: 6px; cursor: pointer; color: var(--gv-fg, #212529); }
    .gv-modal-hefame-close:hover { background: rgba(0,0,0,.06); }
  </style>

  <div class="gv-doc-head gv-print-header">
    <div class="gv-doc-company">
      GEMAVIP ESPAÑA SL.
      <small>B19427004</small>
      <small>CALLE DE LA SEÑA 2</small>
      <small>CARTAGENA (30201), Murcia, España</small>
      <small>pedidosespana@gemavip.com · +34 686 48 36 84</small>
    </div>
    <div class="gv-doc-meta">
      <div class="gv-doc-title">PEDIDO #<%- escapeHtml(String(numPedido || pedidoId || '')) %></div>
      <div class="gv-doc-kv">
        <div><span>Fecha</span><b><%- escapeHtml(String(fecha)) %></b></div>
        <% if (entrega) { %>
          <div><span>Entrega</span><b><%- escapeHtml(String(entrega)) %></b></div>
        <% } %>
        <% if (item.NumPedidoCliente || item.Num_Pedido_Cliente) { %>
          <div><span>Ref. cliente</span><b><%- escapeHtml(String(item.NumPedidoCliente ?? item.Num_Pedido_Cliente ?? '')) %></b></div>
        <% } %>
        <% if (mayoristaInfo && (mayoristaInfo.nombre || mayoristaInfo.codigoAsociado)) { %>
          <div><span>Cooperativa</span><b><%- escapeHtml(String(mayoristaInfo.nombre || '—')) %></b></div>
          <div><span>Nº asociado (<%- escapeHtml(String(mayoristaInfo.nombre || 'Mayorista')) %>)</span><b><%- escapeHtml(String(mayoristaInfo.codigoAsociado || (item.NumAsociadoHefame ?? item.num_asociado_hefame ?? '—'))) %></b></div>
        <% } else if (item.NumAsociadoHefame || item.num_asociado_hefame) { %>
          <% const _mNom = /transfer\s+(.+)/i.test(tipoPedidoDisplay || '') ? RegExp.$1.trim() : 'Mayorista'; %>
          <div><span>Nº asociado (<%- escapeHtml(String(_mNom)) %>)</span><b><%- escapeHtml(String(item.NumAsociadoHefame ?? item.num_asociado_hefame ?? '')) %></b></div>
        <% } %>
        <% if (Number(item.EsEspecial ?? item.es_especial ?? 0) === 1) { %>
          <% const est = String(item.EspecialEstado ?? item.especial_estado ?? 'pendiente').trim().toLowerCase() || 'pendiente'; %>
          <div><span>Especial</span><b><%= est === 'aprobado' ? 'Aprobado' : (est === 'rechazado' ? 'Rechazado' : 'Pendiente') %></b></div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="gv-print-body" id="gvPedidoTabs">
    <div class="gv-tabs gv-no-print" role="tablist" aria-label="Secciones del pedido" style="margin: 10px 0 14px 0;">
      <button type="button" class="gv-tab is-active" role="tab" aria-selected="true" aria-controls="tab_cabecera" data-tab="cabecera">Cabecera</button>
      <button type="button" class="gv-tab" role="tab" aria-selected="false" aria-controls="tab_envio" data-tab="envio">Envío</button>
      <button type="button" class="gv-tab" role="tab" aria-selected="false" aria-controls="tab_lineas" data-tab="lineas">Líneas y totales</button>
    </div>

    <section id="tab_cabecera" class="gv-tabpanel is-active" role="tabpanel" data-tabpanel="cabecera">
      <div class="gv-doc-parties" style="margin-top: 0;">
        <div class="gv-doc-box">
          <h3>Cliente</h3>
          <div class="gv-doc-lines">
            <div><%- escapeHtml(String(clienteNombre || (item.Id_Cliente ?? ''))) %></div>
            <% if (clienteCif) { %><small><%- escapeHtml(String(clienteCif)) %></small><% } %>
            <% if (clienteDir) { %><small><%- escapeHtml(String(clienteDir)) %></small><% } %>
            <% if (clienteCp || clientePob) { %><small><%- escapeHtml([clienteCp, clientePob].filter(Boolean).join(' ')) %></small><% } %>
            <% if (clienteEmail || clienteTel) { %><small><% if (clienteEmail) { %><a href="mailto:<%= encodeURIComponent(String(clienteEmail)) %>" class="gv-contactos-link"><%- escapeHtml(String(clienteEmail)) %></a><% } %><% if (clienteEmail && clienteTel) { %> · <% } %><% if (clienteTel) { %><%- include('partials/telefono-display', { telefono: clienteTel }) %><% } %></small><% } %>
          </div>
        </div>

        <div class="gv-doc-box">
          <h3>Cabecera</h3>
          <div class="gv-doc-kv" style="margin-top: 0;">
            <div><span>Serie</span><b><%- escapeHtml(String(serie || '—')) %></b></div>
            <div><span>Estado</span><b>
              <% if (estadoDisplay) { %>
                <span class="badge <%= estadoCls %>"><%- escapeHtml(String(estadoDisplay)) %></span>
              <% } else { %>
                —
              <% } %>
            </b></div>
            <div><span>Comercial</span><b><%- escapeHtml(String(comercialDisplay || '—')) %></b></div>
            <div><span>Tarifa</span><b><%- escapeHtml(String(tarifaDisplay || '—')) %></b></div>
            <div><span>Forma pago</span><b><%- escapeHtml(String(formaPagoDisplay || '—')) %></b></div>
            <div><span>Tipo pedido</span><b><%- escapeHtml(String(tipoPedidoDisplay || '—')) %></b></div>
            <div><span>Ref. cliente</span><b><%- escapeHtml(String((item.NumPedidoCliente ?? item.Num_Pedido_Cliente) || '—')) %></b></div>
            <div><span>Dto pedido</span><b><%= dtoPedidoPct ? `${fmtNumES(dtoPedidoPct, 2)}%` : '—' %></b></div>
            <div><span>Especial</span><b><%= Number(item.EsEspecial ?? item.es_especial ?? 0) === 1 ? 'Sí' : '—' %></b></div>
            <% if (Number(item.EsEspecial ?? item.es_especial ?? 0) === 1) { %>
              <% const est = String(item.EspecialEstado ?? item.especial_estado ?? 'pendiente').trim().toLowerCase() || 'pendiente'; %>
              <div><span>Estado esp.</span><b><%= est === 'aprobado' ? 'Aprobado' : (est === 'rechazado' ? 'Rechazado' : 'Pendiente') %></b></div>
            <% } %>
            <% if (mayoristaInfo && (mayoristaInfo.nombre || mayoristaInfo.codigoAsociado)) { %>
              <div><span>Cooperativa</span><b><%- escapeHtml(String(mayoristaInfo.nombre || '—')) %></b></div>
              <div><span>Nº asociado (<%- escapeHtml(String(mayoristaInfo.nombre || 'Mayorista')) %>)</span><b><%- escapeHtml(String(mayoristaInfo.codigoAsociado || (item.NumAsociadoHefame ?? item.num_asociado_hefame ?? '—'))) %></b></div>
            <% } else if ((item.NumAsociadoHefame ?? item.num_asociado_hefame)) { %>
              <% const _mNom2 = /transfer\s+(.+)/i.test(tipoPedidoDisplay || '') ? RegExp.$1.trim() : 'Mayorista'; %>
              <div><span>Nº asociado (<%- escapeHtml(String(_mNom2)) %>)</span><b><%- escapeHtml(String(item.NumAsociadoHefame ?? item.num_asociado_hefame ?? '')) %></b></div>
            <% } %>
          </div>
        </div>
      </div>

      <% if (observaciones) { %>
        <div class="grid" style="margin-top: 14px;">
          <div class="gv-doc-box">
            <h3>Observaciones</h3>
            <div class="gv-doc-lines" style="font-weight: 600; color: var(--gv-text);">
              <div style="white-space:pre-wrap;"><%- escapeHtml(observaciones) %></div>
            </div>
          </div>
        </div>
      <% } %>
    </section>

    <section id="tab_envio" class="gv-tabpanel" role="tabpanel" data-tabpanel="envio">
      <div class="grid" style="gap: 14px;">
        <div class="gv-doc-box">
          <h3>Datos de envío</h3>
          <div class="gv-doc-lines">
            <% if (dir) { %>
              <div><%- escapeHtml(String(dir.Alias || dir.Nombre_Destinatario || clienteNombre || '—')) %></div>
              <% if (idDireccionEnvio) { %><small>ID dirección: <%= idDireccionEnvio %></small><% } %>
              <% if (dir.Nombre_Destinatario && dir.Alias) { %><small><%- escapeHtml(String(dir.Nombre_Destinatario)) %></small><% } %>
              <% if (dir.Direccion) { %><small><%- escapeHtml(String(dir.Direccion)) %></small><% } %>
              <% if (dir.Direccion2) { %><small><%- escapeHtml(String(dir.Direccion2)) %></small><% } %>
              <% if (dir.CodigoPostal || dir.Poblacion) { %><small><%- escapeHtml([dir.CodigoPostal, dir.Poblacion].filter(Boolean).join(' ')) %></small><% } %>
              <% if (dir.Pais) { %><small><%- escapeHtml(String(dir.Pais)) %></small><% } %>
              <% if (dir.Email || dir.Telefono || dir.Movil) { %><small><% if (dir.Email) { %><a href="mailto:<%= encodeURIComponent(String(dir.Email)) %>" class="gv-contactos-link"><%- escapeHtml(String(dir.Email)) %></a><% } %><% const dirTel = dir.Telefono || dir.Movil || dir.direnv_telefono || dir.direnv_movil || ''; %><% if (dir.Email && dirTel) { %> · <% } %><% if (dirTel) { %><%- include('partials/telefono-display', { telefono: dirTel }) %><% } %></small><% } %>
              <% if (dir.Observaciones) { %><small><%- escapeHtml(String(dir.Observaciones)) %></small><% } %>
            <% } else { %>
              <div><%- escapeHtml(String(clienteNombre || '—')) %></div>
              <% if (idDireccionEnvio) { %><small>ID dirección: <%= idDireccionEnvio %></small><% } %>
              <small>(Sin dirección de envío asociada)</small>
            <% } %>
          </div>
        </div>
      </div>
    </section>

    <section id="tab_lineas" class="gv-tabpanel" role="tabpanel" data-tabpanel="lineas">
      <div class="gv-doc-table-wrap" style="margin-top: 0;">
        <table class="gv-doc-table">
          <colgroup>
            <col style="width:12%">
            <col style="width:38%">
            <col style="width:10%">
            <col style="width:8%">
            <col style="width:7%">
            <col style="width:10%">
            <col style="width:5%">
            <col style="width:10%">
          </colgroup>
          <thead>
            <tr>
              <th>CÓDIGO</th>
              <th>CONCEPTO</th>
              <th class="is-right">PVL</th>
              <th class="is-right">UNDS</th>
              <th class="is-right">DTO</th>
              <th class="is-right">SUBTOTAL</th>
              <th class="is-right"><%= taxLabel %></th>
              <th class="is-right">TOTAL</th>
            </tr>
          </thead>
          <tbody>
            <% let sumBase = 0, sumIva = 0, sumTotal = 0; const ivaByPct = {}; %>
            <% (lineas || []).forEach((l) => { %>
              <%
                const codigo = (l.art_codigo ?? l.art_sku ?? l.SKU ?? l.Codigo ?? l.pedart_art_id ?? l.Id_Articulo ?? l.id_articulo ?? '').toString();
                const concepto = (l.art_nombre ?? l.Nombre ?? l.Descripcion ?? l.pedart_articulo_txt ?? l.Articulo ?? l.nombre ?? '').toString();
                const qty = Math.max(0, toNum(l.pedart_cantidad ?? l.Cantidad ?? l.Unidades ?? 0, 0));
                const pvl = Math.max(
                  0,
                  toNum(l.Linea_PVP ?? l.pedart_pvp ?? l.PVP ?? l.pvp ?? l.PrecioUnitario ?? l.PVL ?? l.Precio ?? l.pvl ?? l.art_pvl ?? 0, 0)
                );
                const dto = Math.max(
                  0,
                  Math.min(
                    100,
                    toNum(l.Linea_Dto ?? l.pedart_dto ?? l.DtoLinea ?? l.dto_linea ?? l.Dto ?? l.dto ?? l.Descuento ?? l.descuento ?? 0, 0)
                  )
                );

                // Base por línea (sin dto pedido), igual que en el formulario de edición
                const baseStored = toNum(l.pedart_subtotal ?? l.Base ?? l.BaseImponible ?? l.Subtotal ?? l.Importe ?? NaN, NaN);
                const baseCalc = round2(qty * pvl * (1 - dto / 100));
                const base = Number.isFinite(baseStored) ? round2(baseStored) : baseCalc;

                const ivaImpStored = toNum(l.ImporteIVA ?? l.TotalIVA ?? l.importe_iva ?? NaN, NaN);
                let ivaPct = toNum(l.Linea_IVA ?? l.pedart_iva ?? l.IVA ?? l.PorcIVA ?? l.PorcentajeIVA ?? l.TipoIVA ?? l.art_iva ?? 0, 0);
                if (ivaPct > 100) ivaPct = 0;
                const ivaImpCalc = round2(base * ivaPct / 100);
                const ivaImp = Number.isFinite(ivaImpStored) ? round2(ivaImpStored) : ivaImpCalc;

                const totalStored = toNum(l.pedart_total ?? l.Total ?? l.TotalLinea ?? l.ImporteTotal ?? l.total_linea ?? NaN, NaN);
                const totalCalc = round2(base + ivaImp);
                const total = Number.isFinite(totalStored) ? round2(totalStored) : totalCalc;

                sumBase += base;
                sumIva += ivaImp;
                sumTotal += total;
                if (ivaPct > 0) {
                  const pctKey = String(round2(ivaPct));
                  if (!ivaByPct[pctKey]) ivaByPct[pctKey] = { pct: ivaPct, sum: 0 };
                  ivaByPct[pctKey].sum += ivaImp;
                }
              %>
              <tr>
                <td><%- escapeHtml(String(codigo)) %></td>
                <td class="is-wrap">
                  <div class="gv-doc-concept"><%- escapeHtml(String(concepto || (codigo ? `Artículo ${codigo}` : '—'))) %></div>
                </td>
                <td class="is-right"><%= fmtEurES(pvl) %></td>
                <td class="is-right"><%= qty ? fmtNumES(qty, 0) : '' %></td>
                <td class="is-right"><%= `${fmtNumES(dto, 2)}%` %></td>
                <td class="is-right"><%= fmtEurES(base) %></td>
                <td class="is-right"><%= ivaPct ? `${fmtNumES(ivaPct, 2)}%` : '—' %></td>
                <td class="is-right"><%= fmtEurES(total) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="gv-doc-summary">
        <%
          const importeDtoPedido = dtoPedidoPct ? round2(round2(sumBase) * dtoPedidoPct / 100) : 0;
          const baseAfterDto = round2(round2(sumBase) - importeDtoPedido);
          const factorDto = dtoPedidoPct ? (1 - dtoPedidoPct / 100) : 1;
          const ivaAfterDto = round2(round2(sumIva) * factorDto);
          const totalCalculado = round2(baseAfterDto + ivaAfterDto);
          const totalGuardado = toNum(item.ped_total ?? item.TotalPedido ?? item.Total ?? NaN, NaN);
          const totalAntesRetenciones = (Number.isFinite(totalGuardado) && totalGuardado > 0)
            ? round2(totalGuardado)
            : totalCalculado;
        %>
        <table>
          <tr>
            <td>SUBTOTAL</td>
            <td class="is-right"><%= fmtEurES(round2(sumBase)) %></td>
          </tr>
          <% if (dtoPedidoPct) { %>
            <tr>
              <td>DTO PEDIDO (<%= fmtNumES(dtoPedidoPct, 2) %>%)</td>
              <td class="is-right">−<%= fmtEurES(importeDtoPedido) %></td>
            </tr>
          <% } %>
          <tr>
            <td>BASE IMPONIBLE</td>
            <td class="is-right"><%= fmtEurES(baseAfterDto) %></td>
          </tr>
          <% Object.keys(ivaByPct || {}).sort((a, b) => Number(a) - Number(b)).forEach((key) => { %>
            <% const iva = ivaByPct[key]; if (iva && iva.sum) { %>
              <tr>
                <td><%= taxLabel %> (<%= fmtNumES(iva.pct, 2) %>%)</td>
                <td class="is-right"><%= fmtEurES(round2(round2(iva.sum) * factorDto)) %></td>
              </tr>
            <% } %>
          <% }) %>
          <%
            const retencionPct = cliente && (Number(cliente.IRPF ?? cliente.Retencion ?? cliente.retencion ?? '') || 0);
            const importeRetencion = toNum(item.ImporteRetencion ?? item.importe_retencion ?? NaN, NaN);
            const retenciones = [];
            if (retencionPct > 0) {
              const imp = Number.isFinite(importeRetencion) ? round2(importeRetencion) : round2(baseAfterDto * retencionPct / 100);
              retenciones.push({ pct: retencionPct, importe: imp });
            }
            if (cliente && Array.isArray(cliente.Retenciones) && cliente.Retenciones.length) {
              cliente.Retenciones.forEach((r) => {
                const p = toNum(r.porcentaje ?? r.Porcentaje ?? r.pct ?? 0, 0);
                if (p > 0) retenciones.push({ pct: p, importe: round2((r.importe != null ? toNum(r.importe, NaN) : baseAfterDto * p / 100)) });
              });
            }
          %>
          <% retenciones.forEach((r) => { %>
            <tr>
              <td>RETENCIÓN (<%= fmtNumES(r.pct, 2) %>%)</td>
              <td class="is-right">−<%= fmtEurES(r.importe) %></td>
            </tr>
          <% }) %>
          <tr>
            <td class="gv-doc-grand">TOTAL</td>
            <td class="gv-doc-grand is-right"><%= fmtEurES(round2(totalAntesRetenciones - retenciones.reduce((s, r) => s + r.importe, 0))) %></td>
          </tr>
        </table>
      </div>
    </section>
  </div>
</div>

<script nonce="<%= cspNonce %>">
(function () {
  var root = document.getElementById('gvPedidoTabs');
  if (!root) return;
  var tabButtons = Array.prototype.slice.call(root.querySelectorAll('.gv-tab[data-tab]'));
  var panels = Array.prototype.slice.call(root.querySelectorAll('.gv-tabpanel[data-tabpanel]'));
  function setTab(id) {
    tabButtons.forEach(function (b) {
      var active = b.getAttribute('data-tab') === id;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      var active = p.getAttribute('data-tabpanel') === id;
      p.classList.toggle('is-active', active);
    });
  }
  tabButtons.forEach(function (b) {
    b.addEventListener('click', function () {
      setTab(b.getAttribute('data-tab'));
    });
  });
  var hash = String(window.location.hash || '').replace('#', '').trim().toLowerCase();
  if (hash === 'cabecera' || hash === 'envio' || hash === 'lineas') setTab(hash);

  // Abrir diálogo de impresión cuando se carga con ?print=1
  if (window.location.search.indexOf('print=1') !== -1) {
    function doPrint() {
      try { window.print(); } catch (e) { alert('No se pudo abrir el cuadro de impresión. Prueba Ctrl+P.'); }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', doPrint);
    } else {
      setTimeout(doPrint, 300);
    }
  }
})();
</script>

<%- include('partials/footer') %>

