<%- include('partials/header', { title: 'Cliente' }) %>

<% const cid = (item && (item.cli_id ?? item.clienteId ?? item.Id ?? item.id)) ? (item.cli_id ?? item.clienteId ?? item.Id ?? item.id) : ''; %>

<section class="card gv-cliente-form" style="max-width: 1080px; margin: 0 auto;">
  <div class="card-hd">
    <h1 class="card-title">Cliente #<%= cid %></h1>
    <p class="card-subtitle" style="font-weight: 700;"><%= item?.cli_nombre_razon_social ?? item?.Nombre_Razon_Social ?? item?.cli_nombre_cial ?? item?.Nombre_Cial ?? item?.Nombre ?? 'Detalle de cliente' %></p>
  </div>
  <div class="card-bd">
    <% if (typeof solicitud !== 'undefined' && solicitud === 'ok') { %>
      <div class="gv-alert gv-alert--success" style="margin-bottom:12px;">
        Solicitud enviada. Un administrador la revisará y te asignará el contacto si la aprueba.
      </div>
    <% } %>

    <div class="gv-form-actions-sticky">
      <div class="gv-form-actions-sticky__inner">
        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <a class="btn secondary" href="/clientes">Volver</a>
          <% if (canEdit) { %>
            <a class="btn" href="/clientes/<%= cid %>/edit">Editar</a>
          <% } %>
          <% if (typeof tieneRelaciones !== 'undefined' && tieneRelaciones) { %>
            <button type="button" class="btn secondary" id="gvBtnRelaciones" title="Ver clientes relacionados" style="display:inline-flex; align-items:center; gap:6px;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              Relaciones
            </button>
          <% } %>
          <% if (typeof puedeSolicitarAsignacion !== 'undefined' && puedeSolicitarAsignacion) { %>
            <form method="post" action="/clientes/<%= cid %>/solicitar-asignacion" style="display:inline;">
              <button class="btn secondary" type="submit">Solicitar que me asignen este contacto</button>
            </form>
          <% } %>
          <% if (admin) { %>
            <form method="post" action="/clientes/<%= cid %>/delete" style="display:inline;" onsubmit="return confirm('¿Mover este contacto a la papelera?');">
              <button class="btn secondary" style="border-color: rgba(255,186,0,.6);" type="submit">Papelera</button>
            </form>
          <% } %>
        </div>
        <div style="color: var(--gv-muted); font-weight:800;">
          Estado: <% const estVal = item?.EstadoClienteNombre ?? (item?.OK_KO === 1 ? 'Activo' : item?.OK_KO === 0 ? 'Inactivo' : (item?.OK_KO ?? item?.cli_ok_ko ?? '')); %><%= (estVal === 'OK' || estVal === 'ok') ? 'Activo' : (estVal || '—') %>
        </div>
      </div>
    </div>

    <div class="gv-tabs" role="tablist" aria-label="Secciones del contacto" style="margin-top: 8px;">
      <% (tabs || []).forEach((t, idx) => { %>
        <button
          type="button"
          class="gv-tab <%= idx === 0 ? 'is-active' : '' %>"
          role="tab"
          aria-selected="<%= idx === 0 ? 'true' : 'false' %>"
          aria-controls="tab_<%= t.id %>"
          data-tab="<%= t.id %>"
        ><%= t.label %></button>
      <% }) %>
    </div>

    <%
      const fieldAliases = { cli_com_id: ['Id_Cial', 'id_cial'], id_cial: ['cli_com_id', 'Id_Cial'], cli_idiom_id: ['Id_Idioma', 'id_idioma'], id_idioma: ['cli_idiom_id', 'Id_Idioma'], cli_mon_id: ['Id_Moneda', 'id_moneda'], id_moneda: ['cli_mon_id', 'Id_Moneda'], cli_formp_id: ['Id_FormaPago', 'id_formapago'], cli_tarcli_id: ['cli_tarifa_legacy', 'Tarifa'], cli_tarifa_legacy: ['cli_tarcli_id', 'Tarifa'], cli_esp_id: ['Id_Especialidad', 'id_especialidad'], id_especialidad: ['cli_esp_id', 'Id_Especialidad'], cli_re: ['cli_RE'], cli_motivo_baja: ['cli_MotivoBaja', 'cli_motivobaja'], cli_motivobaja: ['cli_motivo_baja', 'cli_MotivoBaja'], cli_fecha_baja: ['cli_FechaBaja', 'cli_fechabaja'], cli_fechabaja: ['cli_fecha_baja', 'cli_FechaBaja'] };
      const pickVal = (name) => {
        if (!item) return '';
        const keys = [name, ...(fieldAliases[String(name).toLowerCase()] || [])];
        for (const k of keys) {
          const v = item[k];
          if (v !== undefined && v !== null) return String(v);
        }
        return '';
      };
      const findById = (rows, id) => {
        const cur = Number(id ?? 0) || 0;
        if (!cur) return null;
        const pkKeys = ['id', 'Id', 'ID', 'com_id', 'pais_id', 'formp_id', 'idi_id', 'idiom_id', 'mon_id', 'tipc_id', 'esp_id', 'prov_id'];
        return (rows || []).find((r) => {
          for (const k of pkKeys) {
            if (r[k] !== undefined && r[k] !== null && Number(r[k]) === cur) return true;
          }
          return false;
        }) || null;
      };
      const displayForField = (f) => {
        const name = f?.name;
        const spec = f?.spec || {};
        const raw = pickVal(name);
        const rawStr = (raw === null || raw === undefined) ? '' : String(raw);
        if (spec.kind === 'checkbox') {
          const s = rawStr.trim().toLowerCase();
          if (s === '1' || s === 'true' || s === 'si') return 'Sí';
          if (s === '0' || s === 'false' || s === 'no') return 'No';
        }
        if (spec.kind === 'select' && spec.options === 'estados_cliente') return item?.EstadoClienteNombre ?? (rawStr || '—');
        if (spec.kind === 'select' && spec.options === 'comerciales') {
          const row = (comerciales || []).find((r) => Number(r.com_id ?? r.id ?? r.Id ?? 0) === Number(raw));
          return item?.ComercialNombre ?? row?.com_nombre ?? row?.Nombre ?? (rawStr || '—');
        }
        if (spec.kind === 'select' && spec.options === 'tipos_clientes') return item?.TipoClienteNombre ?? (rawStr || '—');
        if (spec.kind === 'select' && spec.options === 'especialidades') {
          if (item?.EspecialidadNombre) return item.EspecialidadNombre;
          const row = findById(especialidades, raw);
          return row?.esp_nombre ?? row?.Nombre ?? row?.nombre ?? (rawStr || '—');
        }
        if (spec.kind === 'select' && spec.options === 'provincias') {
          const row = findById(provincias, raw);
          return item?.ProvinciaNombre ?? row?.prov_nombre ?? row?.Nombre ?? row?.nombre ?? (rawStr || '—');
        }
        if (spec.kind === 'select' && spec.options === 'paises') {
          const row = findById(paises, raw);
          return row?.Nombre_pais ?? row?.pais_nombre ?? row?.Nombre ?? row?.nombre ?? item?.PaisNombre ?? item?.Pais ?? (rawStr || '—');
        }
        if (spec.kind === 'select' && spec.options === 'formas_pago') {
          const row = findById(formasPago, raw);
          return (row?.FormaPago ?? row?.Nombre ?? row?.nombre) ?? (rawStr || '—');
        }
        if (spec.kind === 'select' && spec.options === 'idiomas') {
          if (item?.IdiomaNombre) return item.IdiomaNombre;
          const row = findById(idiomas, raw);
          const code = String(row?.Codigo ?? row?.codigo ?? row?.ISO ?? '').trim();
          const lbl = row?.Nombre ?? row?.nombre ?? row?.idiom_nombre ?? row?.Idioma ?? '';
          return (code && lbl) ? `${code} · ${lbl}` : (lbl || rawStr || '—');
        }
        if (spec.kind === 'select' && spec.options === 'monedas') {
          if (item?.MonedaNombre) return item.MonedaNombre;
          const row = findById(monedas, raw);
          const code = String(row?.Codigo ?? row?.codigo ?? row?.ISO ?? '').trim();
          const lbl = row?.Nombre ?? row?.nombre ?? row?.mon_nombre ?? row?.Moneda ?? '';
          return (code && lbl) ? `${code} · ${lbl}` : (lbl || rawStr || '—');
        }
        if (spec.kind === 'select' && spec.options === 'tarifas') {
          const row = (tarifas || []).find((r) => Number(r.tarcli_id ?? r.Id ?? r.id ?? 0) === Number(raw));
          return row ? String(row.tarcli_nombre ?? row.NombreTarifa ?? row.Nombre ?? row.nombre ?? '').trim() : (rawStr || '—');
        }
        if (spec.kind === 'select' && spec.options === 'tipos_clientes_nombre') return rawStr || '—';
        if (spec.type === 'date') return (typeof fmtDateES === 'function') ? (fmtDateES(raw) || '—') : (rawStr || '—');
        if (spec.pctDescuento) {
          const t = rawStr.trim();
          if (!t) return '—';
          const n = parseFloat(String(t).replace(',', '.'));
          return (Number.isFinite(n) ? String(n) : t) + ' %';
        }
        const out = rawStr.trim();
        return out ? out : '—';
      };
    %>

    <% (tabs || []).forEach((t, idx) => { %>
      <section id="tab_<%= t.id %>" class="gv-tabpanel <%= idx === 0 ? 'is-active' : '' %>" role="tabpanel" data-tabpanel="<%= t.id %>">
        <% if (t.id === 'mayoristas') { %>
          <div style="margin-bottom:8px;">
            <h3 style="font-weight:900; font-size:15px; color:var(--gv-ink); margin:0 0 4px;">Mayoristas / Cooperativas</h3>
            <p style="font-size:13px; color:var(--gv-muted); margin:0 0 12px;">Mayoristas asociados a este cliente.</p>
          </div>
          <% if ((cooperativasCliente || []).length) { %>
          <div class="table-wrap">
            <table class="gv-contactos-table">
              <thead><tr><th>Mayorista</th><th>Nº Asociado</th></tr></thead>
              <tbody>
                <% (cooperativasCliente || []).forEach((cc) => { %>
                  <tr>
                    <td style="font-weight:700;"><%= cc.Nombre || '—' %></td>
                    <td><%= cc.NumAsociado || '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } else { %>
          <p style="color:var(--gv-muted); font-size:14px;">No hay mayoristas asociados.</p>
          <% } %>
        <% } else { %>
        <div class="grid cols-2" style="gap: 12px;">
            <% (t.fields || []).forEach((f) => { %>
              <% if (f.spec && f.spec.kind === 'mayoristas') return; %>
              <% const isAdminOnly = !!f.adminOnly; %>
              <% const showSoloAdmin = isAdminOnly && (typeof admin === 'undefined' || !admin); %>
              <div class="<%= showSoloAdmin ? 'gv-field-admin-only' : '' %>" style="display:grid; gap: 6px;">
                <span style="font-weight:800; color: var(--gv-ink); font-size: 13px;"><%= f.label %><% if (showSoloAdmin) { %> <span class="gv-badge-admin" title="Solo puede editar un administrador">Solo admin</span><% } %></span>
                <div class="gv-readonly" style="<%= (f.spec && f.spec.kind === 'textarea') ? 'white-space:pre-wrap;' : '' %>">
                  <% const isTelField = (f.spec && (f.spec.type === 'tel' || ['telefono','movil','cli_telefono','cli_movil'].includes(String(f.name || '').toLowerCase()))); %>
                  <% if (isTelField) { %>
                    <%- include('partials/telefono-display', { telefono: pickVal(f.name) }) %>
                  <% } else { %>
                    <%= displayForField(f) %>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% }) %>

    <% if (typeof tieneRelaciones !== 'undefined' && tieneRelaciones && Array.isArray(relaciones) && relaciones.length > 0) { %>
      <div class="gv-modal-backdrop" id="gvRelacionesBackdrop" hidden></div>
      <div class="gv-modal" id="gvRelacionesModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvRelacionesTitle">
        <div class="gv-modal-card" style="max-width: 560px;">
          <div class="gv-modal-hd">
            <div class="gv-modal-title" id="gvRelacionesTitle">Clientes relacionados</div>
            <div class="gv-modal-subtitle">Clientes vinculados con este contacto.</div>
          </div>
          <div class="gv-modal-bd" style="padding: 0 16px 10px 16px;">
            <div id="gvRelacionesList" style="display:grid; gap: 10px;">
              <% (relaciones || []).forEach((r) => { %>
                <% const nom = r.relacionado_nombre || r.relacionado_nombre_cial || r.origen_nombre || r.origen_nombre_cial || 'Cliente'; %>
                <% const desc = r.clirel_descripcion || ''; %>
                <div style="display:flex; gap:10px; align-items:center; justify-content:space-between; border:1px solid var(--gv-border); border-radius:12px; padding:12px; background: rgba(255,255,255,.85);">
                  <div>
                    <div style="font-weight:900; color:var(--gv-ink);"><%= nom %></div>
                    <% if (desc) { %><div style="margin-top:4px; color:var(--gv-muted); font-size:13px;"><%= desc %></div><% } %>
                  </div>
                  <a class="btn secondary" href="/clientes/<%= r.clirel_cli_relacionado_id || r.clirel_cli_origen_id %>">Ver</a>
                </div>
              <% }) %>
            </div>
          </div>
          <div class="gv-modal-actions">
            <button type="button" class="btn secondary" id="gvRelacionesCerrar">Cerrar</button>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

<style>
.gv-field-admin-only {
  border-left: 3px solid var(--gv-danger, #e53e3e);
  padding-left: 8px;
}
.gv-badge-admin {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  color: #fff;
  background: var(--gv-danger, #e53e3e);
  border-radius: 4px;
  padding: 1px 5px;
  margin-left: 5px;
  vertical-align: middle;
  letter-spacing: 0.03em;
}
</style>

<script>
(function () {
  var tabButtons = Array.prototype.slice.call(document.querySelectorAll('.gv-tab[data-tab]'));
  var panels = Array.prototype.slice.call(document.querySelectorAll('.gv-tabpanel[data-tabpanel]'));
  function setTab(id) {
    tabButtons.forEach(function (b) {
      var active = b.getAttribute('data-tab') === id;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      var active = p.getAttribute('data-tabpanel') === id;
      p.classList.toggle('is-active', active);
    });
  }
  tabButtons.forEach(function (b) {
    b.addEventListener('click', function () {
      setTab(b.getAttribute('data-tab'));
    });
  });

  // Modal relaciones
  var btnRelaciones = document.getElementById('gvBtnRelaciones');
  var backdropRel = document.getElementById('gvRelacionesBackdrop');
  var modalRel = document.getElementById('gvRelacionesModal');
  var cerrarRel = document.getElementById('gvRelacionesCerrar');
  if (btnRelaciones && modalRel) {
    function showRelModal() {
      if (backdropRel) backdropRel.hidden = false;
      if (modalRel) modalRel.hidden = false;
      if (cerrarRel) cerrarRel.focus();
    }
    function hideRelModal() {
      if (backdropRel) backdropRel.hidden = true;
      if (modalRel) modalRel.hidden = true;
    }
    btnRelaciones.addEventListener('click', showRelModal);
    if (backdropRel) backdropRel.addEventListener('click', hideRelModal);
    if (cerrarRel) cerrarRel.addEventListener('click', hideRelModal);
  }
})();
</script>

<%- include('partials/footer') %>

