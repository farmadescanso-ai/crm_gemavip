<%- include('partials/header', { title: 'Pedidos' }) %>

<style>
  /* Spinner de carga (uso puntual en modales) */
  .gv-spinner{
    width: 16px;
    height: 16px;
    display: inline-block;
    border-radius: 999px;
    border: 2px solid rgba(255,255,255,.35);
    border-top-color: #fff;
    animation: gvSpin 0.9s linear infinite;
  }
  @keyframes gvSpin{ to{ transform: rotate(360deg); } }
  .gv-btn-loading{
    display:inline-flex;
    align-items:center;
    gap: 8px;
  }
</style>

<section class="card">
  <div class="card-hd">
    <h1 class="card-title">Pedidos</h1>
    <p class="card-subtitle">
      <% const _anioCab = (typeof pedidosAnioEtiqueta !== 'undefined') ? pedidosAnioEtiqueta : (selectedYear ?? new Date().getFullYear()); %>
      Año <strong><%= _anioCab %></strong><% if (typeof selectedPeriodo === 'string' && selectedPeriodo === 'anio_anterior') { %> <span class="badge info" style="font-size:11px; vertical-align:middle;">01/01–31/12 (año anterior)</span><% } else if (typeof selectedPeriodo === 'string' && selectedPeriodo === 'anio_actual') { %> <span class="badge ok" style="font-size:11px; vertical-align:middle;">01/01–31/12 (año actual)</span><% } %> · <%= items.length %> en esta página
      <% const hasPaging = (typeof paging !== 'undefined' && paging && typeof paging.total !== 'undefined'); %>
      <% if (hasPaging && paging.total) { %>
        · Total <%= paging.total %> · Página <%= paging.page || 1 %>
      <% } %>
      (vista ligera).
    </p>
  </div>
  <div class="card-bd">
    <%
      const toNum = (v, dflt = 0) => {
        if (v === null || v === undefined) return dflt;
        const s = String(v).trim();
        if (!s) return dflt;
        const n = Number(String(s).replace(',', '.'));
        return Number.isFinite(n) ? n : dflt;
      };
      const round2 = (n) => Math.round((Number(n) + Number.EPSILON) * 100) / 100;
      const itemsArr = Array.isArray(items) ? items : [];
      const estadoNorm = (p) => String(p?.EstadoPedidoNombre ?? p?.EstadoPedido ?? p?.Estado ?? p?.ped_estado_txt ?? p?.estado ?? '').trim().toLowerCase() || 'pendiente';
      const isPendiente = (p) => estadoNorm(p).includes('pend');
      const isEspecial = (p) => {
        const v = p?.EsEspecial ?? p?.es_especial ?? p?.especial ?? 0;
        return Number(v) === 1 || String(v).trim().toLowerCase() === 'true';
      };
      const especialEstado = (p) => String(p?.EspecialEstado ?? p?.especial_estado ?? '').trim().toLowerCase();
      const totalPedidoNum = (p) => toNum(p?.TotalPedido ?? p?.ped_total ?? p?.Total ?? p?.ImporteTotal ?? 0, 0);
      const ventasTotal = round2(itemsArr.reduce((s, p) => s + totalPedidoNum(p), 0));

      const incompletos = itemsArr.filter((p) => {
        const idDir = Number(p?.Id_DireccionEnvio ?? p?.id_direccion_envio ?? p?.ped_direnv_id ?? 0) || 0;
        const ref = String(p?.NumPedidoCliente ?? p?.Num_Pedido_Cliente ?? p?.ped_num_pedido_cliente ?? '').trim();
        const fp = Number(p?.Id_FormaPago ?? p?.id_forma_pago ?? p?.ped_formp_id ?? 0) || 0;
        const tp = Number(p?.Id_TipoPedido ?? p?.id_tipo_pedido ?? p?.ped_tipp_id ?? 0) || 0;
        return (!idDir) || (!ref) || (!fp) || (!tp);
      });
      const especialesPend = itemsArr.filter((p) => isEspecial(p) && (especialEstado(p) === 'pendiente' || especialEstado(p) === '' || especialEstado(p) === 'pending'));

      const _seguimientoEstados = [
        { key: 'pendiente',  label: 'Pendiente',  badge: 'warn',   icon: '⏳' },
        { key: 'revisando',  label: 'Revisando',  badge: 'info',   icon: '🔍' },
        { key: 'aprobado',   label: 'Aprobado',   badge: 'ok',     icon: '✅' },
        { key: 'entregado',  label: 'Entregado',  badge: 'info',   icon: '📦' },
        { key: 'pagado',     label: 'Pagado',     badge: 'ok',     icon: '💰' },
        { key: 'denegado',   label: 'Denegado',   badge: 'danger', icon: '❌' },
      ];
      const _byEstadoSeg = {};
      _seguimientoEstados.forEach((e) => {
        _byEstadoSeg[e.key] = itemsArr.filter((p) => estadoNorm(p) === e.key);
      });
    %>

    <div id="gvPedidosTabs">
      <div class="gv-form-actions-sticky gv-no-print" style="margin-bottom: 10px;">
        <div class="gv-form-actions-sticky__inner" style="flex-direction: column; align-items: stretch; gap: 10px;">
          <div style="display:flex; align-items:center; justify-content:space-between; gap: 10px; flex-wrap:wrap;">
            <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
              <a class="btn" href="/pedidos/new">Nuevo pedido</a>
              <a class="btn secondary" href="/pedidos<%= selectedMarcaId ? `?marca=${encodeURIComponent(String(selectedMarcaId))}` : '' %>">Limpiar búsqueda</a>
            </div>
            <div style="color: var(--gv-muted); font-weight:800;">
              Total: <%= (typeof fmtEurES === 'function') ? fmtEurES(ventasTotal) : ventasTotal %>
            </div>
          </div>

          <form method="get" action="/pedidos" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin: 0;">
            <input type="hidden" name="limit" value="<%= (typeof paging !== 'undefined' && paging && paging.limit) ? paging.limit : 10 %>" />
            <input type="hidden" name="periodo" id="gv-periodo-hidden" value="<%= typeof selectedPeriodo === 'string' ? selectedPeriodo : '' %>" />
            <label for="marca" style="font-weight:700; color: var(--gv-ink);">Marca</label>
            <select id="marca" name="marca" class="gv-client-picker__q" style="width:auto; min-width: 220px;">
              <option value="" <%= !selectedMarcaId ? 'selected' : '' %>>Todas</option>
              <% (marcas || []).forEach((m) => { %>
                <option value="<%= m.id %>" <%= Number(selectedMarcaId) === Number(m.id) ? 'selected' : '' %>><%= m.nombre ?? m.Nombre ?? m.marca ?? m.Marca ?? m.id %></option>
              <% }) %>
            </select>
            <label for="q" style="font-weight:700; color: var(--gv-ink);">Buscar</label>
            <input
              id="q"
              name="q"
              type="search"
              class="gv-client-picker__q"
              style="min-width: 260px; flex: 1 1 340px;"
              placeholder="Ej: provincia:Murcia comercial:Paco estado:pendiente · o texto libre"
              value="<%= typeof q === 'string' ? q : '' %>"
            />
            <button class="btn secondary" type="submit">Ver</button>
            <% if ((typeof q === 'string' && q) || selectedMarcaId || (typeof selectedPeriodo === 'string' && selectedPeriodo) || (typeof selectedDesde === 'string' && selectedDesde) || (typeof selectedHasta === 'string' && selectedHasta) || (typeof selectedEstadoId !== 'undefined' && selectedEstadoId) || (typeof selectedComercialId !== 'undefined' && selectedComercialId)) { %><a class="btn secondary" href="/pedidos" title="Limpiar filtros">✕</a><% } %>
          </form>

          <%
            const _periodoActual = typeof selectedPeriodo === 'string' ? selectedPeriodo : '';
            const _selectedDesde = typeof selectedDesde === 'string' ? selectedDesde : '';
            const _selectedHasta = typeof selectedHasta === 'string' ? selectedHasta : '';
            const _hasCustomRange = !!(_selectedDesde || _selectedHasta);
            const _limPed = (typeof paging !== 'undefined' && paging && paging.limit) ? paging.limit : 10;
            const _periodoBase = '/pedidos?limit=' + _limPed + (selectedMarcaId ? `&marca=${encodeURIComponent(String(selectedMarcaId))}` : '') + (typeof q === 'string' && q ? `&q=${encodeURIComponent(q)}` : '');
            const _hrefAnioActual = '/pedidos?periodo=anio_actual&limit=' + _limPed;
            const _anioActualActivo = !_hasCustomRange && (
              _periodoActual === 'anio_actual'
              || (!_periodoActual && !selectedMarcaId && !(typeof q === 'string' && q && String(q).trim()))
            );
            const _anioAnteriorActivo = !_hasCustomRange && _periodoActual === 'anio_anterior';
            const _periodos = [
              { key: 'hoy',       label: 'Hoy' },
              { key: '7d',        label: 'Últimos 7 días' },
              { key: '30d',       label: 'Últimos 30 días' },
              { key: '90d',       label: 'Últimos 90 días' },
              { key: 'mes',       label: 'Mes actual' },
              { key: 'trimestre', label: 'Trimestre actual' },
            ];
          %>
          <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
            <span style="font-weight:700; color:var(--gv-ink); font-size:12px;">Desde</span>
            <input type="date" id="gv-fecha-desde" value="<%= _selectedDesde %>"
              class="gv-client-picker__q"
              style="width:auto; min-width:140px; padding:5px 10px; font-size:12px; border-radius:8px;<%= _hasCustomRange ? ' border-color:rgba(143,174,27,.6); box-shadow:0 0 0 2px rgba(143,174,27,.12);' : '' %>"
            />
            <span style="font-weight:700; color:var(--gv-ink); font-size:12px;">Hasta</span>
            <input type="date" id="gv-fecha-hasta" value="<%= _selectedHasta %>"
              class="gv-client-picker__q"
              style="width:auto; min-width:140px; padding:5px 10px; font-size:12px; border-radius:8px;<%= _hasCustomRange ? ' border-color:rgba(143,174,27,.6); box-shadow:0 0 0 2px rgba(143,174,27,.12);' : '' %>"
            />
            <button type="button" id="gv-fecha-apply" class="badge ok" style="border:none; cursor:pointer; font-size:11px; padding:5px 12px; font-weight:800;">Aplicar</button>
            <% if (_hasCustomRange) { %>
              <a href="<%= _periodoBase %>" class="badge danger" style="text-decoration:none; font-size:11px; padding:4px 10px; cursor:pointer;">✕</a>
            <% } %>
          </div>

          <div style="display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
            <span style="font-weight:700; color:var(--gv-ink); font-size:12px; margin-right:2px;">Periodo:</span>
            <a href="<%= _hrefAnioActual %>"
              class="badge <%= _anioActualActivo ? 'ok' : '' %>"
              style="text-decoration:none; font-size:11px; padding:4px 10px; cursor:pointer;<%= _anioActualActivo ? ' font-weight:900;' : '' %>"
              title="Quita marca y búsqueda; 1 ene – 31 dic del año en curso"
            >Año actual</a>
            <a href="<%= _periodoBase %>&periodo=anio_anterior"
              class="badge <%= _anioAnteriorActivo ? 'ok' : '' %>"
              style="text-decoration:none; font-size:11px; padding:4px 10px; cursor:pointer;<%= _anioAnteriorActivo ? ' font-weight:900;' : '' %>"
              title="1 ene – 31 dic del año anterior"
            >Año anterior</a>
            <% _periodos.forEach((pr) => { %>
              <% const isActive = !_hasCustomRange && String(_periodoActual) === String(pr.key); %>
              <a href="<%= _periodoBase %>&periodo=<%= encodeURIComponent(pr.key) %>"
                class="badge <%= isActive ? 'ok' : '' %>"
                style="text-decoration:none; font-size:11px; padding:4px 10px; cursor:pointer;<%= isActive ? ' font-weight:900;' : '' %>"
              ><%= pr.label %></a>
            <% }) %>
          </div>
          <script>
          (function(){
            var btnApply = document.getElementById('gv-fecha-apply');
            var inputDesde = document.getElementById('gv-fecha-desde');
            var inputHasta = document.getElementById('gv-fecha-hasta');
            if (!btnApply || !inputDesde || !inputHasta) return;
            function applyDateRange() {
              var d = inputDesde.value || '';
              var h = inputHasta.value || '';
              if (!d && !h) return;
              var base = '<%= _periodoBase %>';
              if (d) base += '&desde=' + encodeURIComponent(d);
              if (h) base += '&hasta=' + encodeURIComponent(h);
              window.location.href = base;
            }
            btnApply.addEventListener('click', applyDateRange);
            inputDesde.addEventListener('change', function(){ if (inputHasta.value) applyDateRange(); });
            inputHasta.addEventListener('change', function(){ if (inputDesde.value) applyDateRange(); });
          })();
          </script>

          <% if (typeof admin !== 'undefined' && admin) { %>
            <%
              const _selEstadoId = typeof selectedEstadoId !== 'undefined' ? Number(selectedEstadoId) : null;
              const _selComercialId = typeof selectedComercialId !== 'undefined' ? Number(selectedComercialId) : null;
              const _estadosArr = (typeof estadosPedido !== 'undefined' && Array.isArray(estadosPedido)) ? estadosPedido : [];
              const _comercialesArr = (typeof comercialesList !== 'undefined' && Array.isArray(comercialesList)) ? comercialesList : [];
              const _filtroBase = '/pedidos?limit=' + ((typeof paging !== 'undefined' && paging && paging.limit) ? paging.limit : 10)
                + (selectedMarcaId ? `&marca=${encodeURIComponent(String(selectedMarcaId))}` : '')
                + (typeof q === 'string' && q ? `&q=${encodeURIComponent(q)}` : '')
                + (_periodoActual ? `&periodo=${encodeURIComponent(_periodoActual)}` : '')
                + (_selectedDesde ? `&desde=${encodeURIComponent(_selectedDesde)}` : '')
                + (_selectedHasta ? `&hasta=${encodeURIComponent(_selectedHasta)}` : '');
            %>
            <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
              <label style="font-weight:700; color:var(--gv-ink); font-size:12px; display:flex; align-items:center; gap:5px;">
                Estado
                <select id="gv-filter-estado" style="font-size:12px; padding:4px 8px; min-width:140px;" onchange="window.location.href='<%= _filtroBase %>' + (this.value ? '&estado=' + this.value : '') + '<%= _selComercialId ? '&comercial=' + _selComercialId : '' %>'">
                  <option value="">Todos</option>
                  <% _estadosArr.forEach((e) => { %>
                    <option value="<%= e.estped_id ?? e.id %>" <%= _selEstadoId === Number(e.estped_id ?? e.id) ? 'selected' : '' %>><%= e.estped_nombre ?? e.nombre ?? e.Nombre %></option>
                  <% }) %>
                </select>
              </label>
              <label style="font-weight:700; color:var(--gv-ink); font-size:12px; display:flex; align-items:center; gap:5px;">
                Comercial
                <select id="gv-filter-comercial" style="font-size:12px; padding:4px 8px; min-width:180px;" onchange="window.location.href='<%= _filtroBase %>' + '<%= _selEstadoId ? '&estado=' + _selEstadoId : '' %>' + (this.value ? '&comercial=' + this.value : '')">
                  <option value="">Todos</option>
                  <% _comercialesArr.forEach((c) => { %>
                    <option value="<%= c.com_id ?? c.id ?? c.Id %>" <%= _selComercialId === Number(c.com_id ?? c.id ?? c.Id) ? 'selected' : '' %>><%= c.com_nombre ?? c.nombre ?? c.Nombre ?? c.com_email ?? '' %></option>
                  <% }) %>
                </select>
              </label>
              <% if (_selEstadoId || _selComercialId) { %>
                <a class="badge danger" href="<%= _filtroBase %>" style="text-decoration:none; font-size:11px; padding:4px 10px; cursor:pointer;">Limpiar filtros avanzados</a>
              <% } %>
            </div>
          <% } %>

          <% if (typeof paging !== 'undefined' && paging && paging.total && paging.total > (paging.limit || 10)) { %>
            <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 12px;">
              <% const prev = (paging.page || 1) > 1 ? (paging.page || 1) - 1 : null; %>
              <% const next = ((paging.page || 1) * (paging.limit || 10)) < paging.total ? (paging.page || 1) + 1 : null; %>
              <% const base = `/pedidos?limit=${paging.limit || 10}` + (selectedMarcaId ? `&marca=${encodeURIComponent(String(selectedMarcaId))}` : '') + (typeof q === 'string' && q ? `&q=${encodeURIComponent(q)}` : '') + (_periodoActual ? `&periodo=${encodeURIComponent(_periodoActual)}` : '') + (_selectedDesde ? `&desde=${encodeURIComponent(_selectedDesde)}` : '') + (_selectedHasta ? `&hasta=${encodeURIComponent(_selectedHasta)}` : '') + ((typeof selectedEstadoId !== 'undefined' && selectedEstadoId) ? `&estado=${selectedEstadoId}` : '') + ((typeof selectedComercialId !== 'undefined' && selectedComercialId) ? `&comercial=${selectedComercialId}` : ''); %>
              <% if (prev) { %>
                <a class="btn secondary" href="<%= base %>&page=<%= prev %>">Anterior</a>
              <% } %>
              <% if (next) { %>
                <a class="btn secondary" href="<%= base %>&page=<%= next %>">Siguiente</a>
              <% } %>
            </div>
          <% } %>

          <div class="gv-tabs" role="tablist" aria-label="Vistas de pedidos">
            <button type="button" class="gv-tab is-active" role="tab" aria-selected="true" aria-controls="tab_listado" data-tab="listado">Listado</button>
            <button type="button" class="gv-tab" role="tab" aria-selected="false" aria-controls="tab_seguimiento" data-tab="seguimiento">Seguimiento</button>
          </div>
        </div>
      </div>

      <section id="tab_listado" class="gv-tabpanel is-active" role="tabpanel" data-tabpanel="listado">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Acciones</th>
                <th>Estado</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Tipo cliente</th>
                <th>Total</th>
                <th>PEDIDO</th>
                <th>Nº Asociado</th>
                <th>REF. CLIENTE</th>
                <th>Comercial</th>
                <th>Provincia</th>
              </tr>
            </thead>
            <tbody>
              <% itemsArr.forEach((p) => { %>
                <% const pid = p.Id ?? p.id ?? p.ped_id; %>
                <% const owner = Number(p.ped_com_id ?? p.Id_Cial ?? p.id_cial ?? p.ComercialId ?? p.comercialId ?? 0) || 0; %>
                <% const currentUserId = Number(userId ?? user?.id ?? 0) || 0; %>
                <% const isOwner = currentUserId && owner && currentUserId === owner; %>
                <% const canEdit = admin || (isOwner && isPendiente(p)); %>
                <tr>
                  <td>
                    <div class="gv-actions">
                      <a class="btn secondary icon" href="/pedidos/<%= pid %>" title="Ver" aria-label="Ver pedido <%= pid %>">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                          <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                      </a>
                      <% if (canEdit) { %>
                        <a class="btn secondary icon" href="/pedidos/<%= pid %>/edit" title="Editar" aria-label="Editar pedido <%= pid %>">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 20h9"></path>
                            <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
                          </svg>
                        </a>
                      <% } %>
                      <% if (admin) { %>
                        <form method="post" action="/pedidos/<%= pid %>/delete" onsubmit="return confirm('¿Eliminar este pedido?');">
                          <button class="btn secondary icon danger" type="submit" title="Borrar" aria-label="Borrar pedido <%= pid %>">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path d="M3 6h18"></path>
                              <path d="M8 6V4h8v2"></path>
                              <path d="M19 6l-1 14H6L5 6"></path>
                              <path d="M10 11v6"></path>
                              <path d="M14 11v6"></path>
                            </svg>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                  <td>
                    <% const estadoLabel = String(p.EstadoPedidoNombre ?? p.EstadoPedido ?? p.Estado ?? p.ped_estado_txt ?? '').trim(); %>
                    <% const estadoColor = String(p.EstadoColor ?? '').trim().toLowerCase(); %>
                    <% const st = estadoLabel.toLowerCase(); %>
                    <% const cls = estadoColor || (st.includes('deneg') ? 'danger' : (st.includes('pagad') || st.includes('aprob') ? 'ok' : (st.includes('pend') ? 'warn' : 'info'))); %>
                    <% const estadoId = Number(p.Id_EstadoPedido ?? p.id_estado_pedido ?? p.ped_estped_id ?? 0) || 0; %>
                    <% if (admin) { %>
                      <button
                        type="button"
                        id="gvEstadoBadge_<%= pid %>"
                        class="badge <%= estadoLabel ? cls : 'info' %> gv-pedido-estado-badge"
                        data-pid="<%= pid %>"
                        data-num="<%= (p.NumPedido ?? p.ped_numero ?? p.Numero_Pedido ?? pid) %>"
                        data-estado-id="<%= estadoId %>"
                        data-estado-label="<%= estadoLabel %>"
                        title="Hacer clic para modificar el estado del pedido"
                        style="appearance:none; border:0; cursor:pointer;"
                      ><%= estadoLabel || '—' %></button>
                    <% } else if (st.includes('pend')) { %>
                      <button
                        type="button"
                        class="badge <%= cls %> gv-pedido-estado-comercial"
                        data-pid="<%= pid %>"
                        data-num="<%= (p.NumPedido ?? p.ped_numero ?? p.Numero_Pedido ?? pid) %>"
                        title="Clic para pasar a Revisando"
                        style="appearance:none; border:0; cursor:pointer;"
                      ><%= estadoLabel || 'Pendiente' %></button>
                    <% } else { %>
                      <% if (estadoLabel) { %>
                        <span class="badge <%= cls %>"><%= estadoLabel %></span>
                      <% } else { %>
                        —
                      <% } %>
                    <% } %>
                  </td>
                  <td><%= fmtDateES(p.FechaPedido ?? p.ped_fecha ?? p.Fecha ?? '') %></td>
                  <td><%= p.ClienteNombre ?? p.ClienteNombreCial ?? p.Nombre_Razon_Social ?? p.cli_nombre_razon_social ?? p.Nombre ?? (p.Id_Cliente ?? p.ClienteId ?? '') %></td>
                  <td><%= p.TipoClienteNombre ?? '—' %></td>
                  <td><%= fmtEurES(p.TotalPedido ?? p.ped_total ?? p.Total ?? 0) %></td>
                  <td><%= p.NumPedido ?? p.ped_numero ?? p.Numero_Pedido ?? '' %></td>
                  <td><%= p.NumAsociadoMayorista ? (p.NumAsociadoMayorista + (p.NombreMayorista ? ' · ' + p.NombreMayorista : '')) : '—' %></td>
                  <td><%= p.NumPedidoCliente ?? p.Num_Pedido_Cliente ?? p.ped_num_pedido_cliente ?? '' %></td>
                  <td><%= p.ComercialNombre ?? (p.Id_Cial ?? p.id_cial ?? p.ped_com_id ?? '—') %></td>
                  <td><%= p.ProvinciaNombre ?? '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section id="tab_seguimiento" class="gv-tabpanel" role="tabpanel" data-tabpanel="seguimiento">

        <%/* ── Resumen rápido de estados ── */%>
        <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:14px;">
          <% _seguimientoEstados.forEach((e) => { %>
            <span class="badge <%= e.badge %>" style="font-size:13px; padding:7px 14px; cursor:default;">
              <%= e.icon %> <%= e.label %>: <strong><%= (_byEstadoSeg[e.key] || []).length %></strong>
            </span>
          <% }) %>
          <% if (especialesPend.length) { %>
            <span class="badge warn" style="font-size:13px; padding:7px 14px; cursor:default;">⚡ Especiales pend.: <strong><%= especialesPend.length %></strong></span>
          <% } %>
          <% if (incompletos.length) { %>
            <span class="badge danger" style="font-size:13px; padding:7px 14px; cursor:default;">⚠ Incompletos: <strong><%= incompletos.length %></strong></span>
          <% } %>
        </div>

        <%/* ── Tarjetas por cada estado ── */%>
        <div class="grid cols-2" style="gap: 12px;">
          <% _seguimientoEstados.forEach((e) => { %>
            <% const _estItems = _byEstadoSeg[e.key] || []; %>
            <section class="card">
              <div class="card-hd" style="display:flex; align-items:center; gap:8px;">
                <h2 class="card-title" style="display:flex; align-items:center; gap:6px;">
                  <span class="badge <%= e.badge %>" style="font-size:11px; padding:3px 8px;"><%= e.icon %> <%= e.label %></span>
                </h2>
                <p class="card-subtitle" style="margin:0;"><%= _estItems.length %> pedido<%= _estItems.length !== 1 ? 's' : '' %></p>
              </div>
              <div class="card-bd">
                <% if (_estItems.length) { %>
                  <div class="table-wrap">
                    <table>
                      <thead><tr><th>Fecha</th><th>Pedido</th><th>Cliente</th><th>Total</th></tr></thead>
                      <tbody>
                        <% _estItems.slice(0, 20).forEach((p) => { %>
                          <% const pid = p.Id ?? p.id ?? p.ped_id; %>
                          <tr>
                            <td><%= fmtDateES(p.FechaPedido ?? p.ped_fecha ?? p.Fecha ?? '') %></td>
                            <td><a href="/pedidos/<%= pid %>"><%= p.NumPedido ?? p.ped_numero ?? p.Numero_Pedido ?? pid %></a></td>
                            <td><%= p.ClienteNombre ?? p.ClienteNombreCial ?? p.Nombre_Razon_Social ?? p.cli_nombre_razon_social ?? p.Nombre ?? (p.Id_Cliente ?? p.ClienteId ?? '') %></td>
                            <td><%= fmtEurES(p.TotalPedido ?? p.ped_total ?? p.Total ?? 0) %></td>
                          </tr>
                        <% }) %>
                        <% if (_estItems.length > 20) { %>
                          <tr><td colspan="4" style="color:var(--gv-muted); font-weight:700; text-align:center;">… y <%= _estItems.length - 20 %> más</td></tr>
                        <% } %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <p style="color: var(--gv-muted); font-weight:800; margin:0;">Sin pedidos en este estado.</p>
                <% } %>
              </div>
            </section>
          <% }) %>
        </div>

        <%/* ── Especiales pendientes ── */%>
        <% if (especialesPend.length) { %>
          <section class="card" style="margin-top: 12px;">
            <div class="card-hd">
              <h2 class="card-title">⚡ Especiales (pendientes)</h2>
              <p class="card-subtitle"><%= especialesPend.length %> pedidos</p>
            </div>
            <div class="card-bd">
              <div class="table-wrap">
                <table>
                  <thead><tr><th>Fecha</th><th>Pedido</th><th>Cliente</th><th>Estado especial</th></tr></thead>
                  <tbody>
                    <% especialesPend.slice(0, 20).forEach((p) => { %>
                      <% const pid = p.Id ?? p.id ?? p.ped_id; %>
                      <tr>
                        <td><%= fmtDateES(p.FechaPedido ?? p.ped_fecha ?? p.Fecha ?? '') %></td>
                        <td><a href="/pedidos/<%= pid %>"><%= p.NumPedido ?? p.ped_numero ?? p.Numero_Pedido ?? pid %></a></td>
                        <td><%= p.ClienteNombre ?? p.ClienteNombreCial ?? p.Nombre_Razon_Social ?? p.cli_nombre_razon_social ?? p.Nombre ?? (p.Id_Cliente ?? p.ClienteId ?? '') %></td>
                        <td><%= (p.EspecialEstado ?? p.especial_estado ?? 'pendiente') %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </section>
        <% } %>

        <%/* ── Incompletos ── */%>
        <section class="card" style="margin-top: 12px;">
          <div class="card-hd">
            <h2 class="card-title">⚠ Incompletos</h2>
            <p class="card-subtitle">Faltan datos clave (dirección, referencia cliente, forma de pago o tipo)</p>
          </div>
          <div class="card-bd">
            <div class="table-wrap">
              <table>
                <thead><tr><th>Fecha</th><th>Pedido</th><th>Cliente</th><th>Faltan</th></tr></thead>
                <tbody>
                  <% (incompletos || []).slice(0, 30).forEach((p) => { %>
                    <%
                      const pid = p.Id ?? p.id ?? p.ped_id;
                      const idDir = Number(p?.Id_DireccionEnvio ?? p?.id_direccion_envio ?? 0) || 0;
                      const ref = String(p?.NumPedidoCliente ?? p?.Num_Pedido_Cliente ?? '').trim();
                      const fp = Number(p?.Id_FormaPago ?? p?.id_forma_pago ?? 0) || 0;
                      const tp = Number(p?.Id_TipoPedido ?? p?.id_tipo_pedido ?? 0) || 0;
                      const faltan = [];
                      if (!idDir) faltan.push('Dirección envío');
                      if (!ref) faltan.push('Ref. cliente');
                      if (!fp) faltan.push('Forma pago');
                      if (!tp) faltan.push('Tipo pedido');
                    %>
                    <tr>
                      <td><%= fmtDateES(p.FechaPedido ?? p.ped_fecha ?? p.Fecha ?? '') %></td>
                      <td><a href="/pedidos/<%= pid %>"><%= p.NumPedido ?? p.ped_numero ?? p.Numero_Pedido ?? pid %></a></td>
                      <td><%= p.ClienteNombre ?? p.ClienteNombreCial ?? p.Nombre_Razon_Social ?? p.cli_nombre_razon_social ?? p.Nombre ?? (p.Id_Cliente ?? p.ClienteId ?? '') %></td>
                      <td><%= faltan.join(' · ') || '—' %></td>
                    </tr>
                  <% }) %>
                  <% if (!incompletos.length) { %>
                    <tr><td colspan="4" style="color: var(--gv-muted); font-weight:800;">Sin incompletos.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </section>

      <% if (admin && Array.isArray(estadosPedido) && estadosPedido.length) { %>
        <!-- Modal admin: seleccionar estado -->
        <div id="gv-estado-backdrop" class="gv-modal-backdrop" hidden></div>
        <div id="gv-estado-modal" class="gv-modal" hidden role="dialog" aria-modal="true" aria-labelledby="gv-estado-title">
          <div class="gv-modal-card">
            <div class="gv-modal-hd">
              <div class="gv-modal-title" id="gv-estado-title">Cambiar estado del pedido</div>
              <div class="gv-modal-subtitle">Selecciona el nuevo estado para el pedido <span id="gv-estado-pedido-num">—</span>.</div>
            </div>
            <div style="padding: 14px 16px; display:grid; gap: 10px;">
              <label style="display:grid; gap: 6px;">
                <span style="font-weight:800; color: var(--gv-ink); font-size: 13px;">Nuevo estado</span>
                <select id="gv-estado-select" class="gv-client-picker__q">
                  <% (estadosPedido || []).forEach((e) => { %>
                    <option value="<%= e.id %>" data-color="<%= e.color %>"><%= e.nombre %></option>
                  <% }) %>
                </select>
              </label>
              <div id="gv-estado-error" class="gv-alert gv-alert--warn" style="display:none;"></div>
            </div>
            <div class="gv-modal-actions">
              <button type="button" class="btn secondary" id="gv-estado-cancel">Cerrar</button>
              <button type="button" class="btn" id="gv-estado-next">Guardar</button>
            </div>
          </div>
        </div>

        <!-- Modal admin: confirmación -->
        <div id="gv-estado-confirm-backdrop" class="gv-modal-backdrop" hidden></div>
        <div id="gv-estado-confirm-modal" class="gv-modal" hidden role="dialog" aria-modal="true" aria-labelledby="gv-estado-confirm-title">
          <div class="gv-modal-card">
            <div class="gv-modal-hd">
              <div class="gv-modal-title" id="gv-estado-confirm-title">Confirmar cambio</div>
              <div class="gv-modal-subtitle">¿Seguro que quieres cambiar el estado del pedido <span id="gv-estado-confirm-pedido-num">—</span> a <b id="gv-estado-confirm-nombre">—</b>?</div>
            </div>
            <div class="gv-modal-actions">
              <button type="button" class="btn secondary" id="gv-estado-confirm-cancel">Cerrar</button>
              <button type="button" class="btn" id="gv-estado-confirm-accept">
                <span class="gv-btn-loading">
                  <span class="gv-spinner" id="gv-estado-spinner" style="display:none;" aria-hidden="true"></span>
                  <span id="gv-estado-accept-label">Aceptar</span>
                </span>
              </button>
            </div>
          </div>
        </div>

        <script>
        (function () {
          var root = document.getElementById('gvPedidosTabs');
          if (!root) return;

          var modal = document.getElementById('gv-estado-modal');
          var backdrop = document.getElementById('gv-estado-backdrop');
          var select = document.getElementById('gv-estado-select');
          var errBox = document.getElementById('gv-estado-error');
          var pedidoNumSpan = document.getElementById('gv-estado-pedido-num');
          var btnCancel = document.getElementById('gv-estado-cancel');
          var btnNext = document.getElementById('gv-estado-next');

          var cModal = document.getElementById('gv-estado-confirm-modal');
          var cBackdrop = document.getElementById('gv-estado-confirm-backdrop');
          var cPedidoNum = document.getElementById('gv-estado-confirm-pedido-num');
          var cNombre = document.getElementById('gv-estado-confirm-nombre');
          var cCancel = document.getElementById('gv-estado-confirm-cancel');
          var cAccept = document.getElementById('gv-estado-confirm-accept');
          var cSpinner = document.getElementById('gv-estado-spinner');
          var cAcceptLabel = document.getElementById('gv-estado-accept-label');

          if (!modal || !backdrop || !select || !btnCancel || !btnNext || !cModal || !cBackdrop || !cCancel || !cAccept) return;

          var currentPid = null;
          var currentPedidoNum = '';
          var currentBadge = null;
          var isSaving = false;

          function setSaving(on) {
            isSaving = !!on;
            cAccept.disabled = isSaving;
            cCancel.disabled = isSaving;
            if (cSpinner) cSpinner.style.display = isSaving ? 'inline-block' : 'none';
            if (cAcceptLabel) cAcceptLabel.textContent = isSaving ? 'Guardando...' : 'Aceptar';
          }

          function openSelectModal(pid, pedidoNum, curEstadoId) {
            currentPid = pid;
            currentPedidoNum = pedidoNum || String(pid);
            pedidoNumSpan.textContent = currentPedidoNum;
            if (errBox) { errBox.style.display = 'none'; errBox.textContent = ''; }
            if (curEstadoId) {
              select.value = String(curEstadoId);
            } else if (select.options && select.options.length) {
              select.selectedIndex = 0;
            }
            backdrop.hidden = false;
            modal.hidden = false;
          }
          function closeSelectModal(resetState) {
            modal.hidden = true;
            backdrop.hidden = true;
            if (resetState) {
              currentPid = null;
              currentPedidoNum = '';
              currentBadge = null;
            }
          }

          function openConfirmModal(pedidoNum, estadoNombre) {
            cPedidoNum.textContent = pedidoNum || '—';
            cNombre.textContent = estadoNombre || '—';
            cBackdrop.hidden = false;
            cModal.hidden = false;
          }
          function closeConfirmModal() {
            cModal.hidden = true;
            cBackdrop.hidden = true;
          }

          btnCancel.addEventListener('click', function () { closeSelectModal(true); });
          backdrop.addEventListener('click', function () { closeSelectModal(true); });
          btnNext.addEventListener('click', function () {
            if (!currentPid) return;
            var opt = select.options[select.selectedIndex];
            var estadoNombre = opt ? (opt.textContent || '').trim() : '';
            var pedidoNum = currentPedidoNum || (pedidoNumSpan ? pedidoNumSpan.textContent : String(currentPid));
            closeSelectModal(false);
            openConfirmModal(pedidoNum, estadoNombre);
          });

          cCancel.addEventListener('click', function () {
            if (isSaving) return;
            closeConfirmModal();
            currentPid = null; currentPedidoNum = ''; currentBadge = null;
          });
          cBackdrop.addEventListener('click', function () {
            if (isSaving) return;
            closeConfirmModal();
            currentPid = null; currentPedidoNum = ''; currentBadge = null;
          });

          cAccept.addEventListener('click', async function () {
            if (!currentBadge) { closeConfirmModal(); return; }
            var pid = currentBadge.getAttribute('data-pid');
            var estadoId = select.value;
            var opt = select.options[select.selectedIndex];
            var estadoNombre = opt ? (opt.textContent || '').trim() : '';

            try {
              setSaving(true);
              var r = await fetch('/pedidos/' + encodeURIComponent(pid) + '/estado', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ estadoId: estadoId })
              });
              var json = await r.json().catch(function () { return null; });
              if (!r.ok || !json || !json.ok) {
                throw new Error((json && json.error) ? json.error : ('HTTP ' + r.status));
              }
              var color = (json.estado && json.estado.color) ? String(json.estado.color) : 'info';
              var nombre = (json.estado && json.estado.nombre) ? String(json.estado.nombre) : (estadoNombre || '—');

              currentBadge.textContent = nombre;
              currentBadge.setAttribute('data-estado-id', String(json.estado.id || estadoId || ''));
              currentBadge.setAttribute('data-estado-label', nombre);
              currentBadge.classList.remove('ok', 'info', 'warn', 'danger');
              currentBadge.classList.add(color || 'info');

              closeConfirmModal();
              currentPid = null; currentPedidoNum = ''; currentBadge = null;
            } catch (e) {
              closeConfirmModal();
              if (errBox) {
                errBox.textContent = 'No se pudo cambiar el estado. ' + (e && e.message ? e.message : '');
                errBox.style.display = 'block';
              }
              backdrop.hidden = false;
              modal.hidden = false;
              if (pedidoNumSpan) pedidoNumSpan.textContent = currentPedidoNum || (pid || '—');
            } finally {
              setSaving(false);
            }
          });

          root.addEventListener('click', function (ev) {
            var btn = ev.target && ev.target.closest ? ev.target.closest('button.gv-pedido-estado-badge[data-pid]') : null;
            if (!btn) return;
            currentBadge = btn;
            var pid = btn.getAttribute('data-pid');
            var pedidoNum = btn.getAttribute('data-num') || '';
            var curEstadoId = Number(btn.getAttribute('data-estado-id') || 0) || 0;
            openSelectModal(pid, pedidoNum, curEstadoId);
          });
        })();
        </script>
      <% } %>

      <%
        const revisandoEstado = (estadosPedido || []).find(function (e) {
          return String(e.codigo || e.nombre || '').toLowerCase().includes('revis');
        });
      %>
      <% if (!admin && revisandoEstado) { %>
        <!-- Comercial: clic en Pendiente → confirmar → Revisando -->
        <div id="gv-comercial-confirm-backdrop" class="gv-modal-backdrop" hidden></div>
        <div id="gv-comercial-confirm-modal" class="gv-modal" hidden role="dialog" aria-modal="true">
          <div class="gv-modal-card">
            <div style="padding: 24px 24px 0; text-align: center;">
              <div style="display:inline-flex; align-items:center; justify-content:center; width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%); margin-bottom:16px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#e65100" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                  <line x1="12" y1="9" x2="12" y2="13"></line>
                  <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
              </div>
              <div class="gv-modal-title" style="font-size:18px; margin-bottom:8px;">Enviar pedido a revisión</div>
              <div style="color:var(--gv-ink); font-size:14px; line-height:1.5;">
                Vas a pasar el pedido <b id="gv-comercial-confirm-num" style="color:var(--gv-brand, #1a73e8);">—</b> al estado <span class="badge info" style="font-size:12px; vertical-align:middle;">Revisando</span>
              </div>
            </div>
            <div style="margin: 16px 24px; padding: 12px 14px; background: #fff8e1; border-left: 4px solid #f9a825; border-radius: 8px; font-size: 13px; color: #5d4037; line-height: 1.5;">
              <b>Esta acción no se puede deshacer.</b><br>
              Una vez confirmado, ya no podrás editar ni modificar este pedido.
            </div>
            <div class="gv-modal-actions" style="padding: 16px 24px;">
              <button type="button" class="btn secondary" id="gv-comercial-cancel">Cancelar</button>
              <button type="button" class="btn" id="gv-comercial-accept" style="background: linear-gradient(135deg, #e65100 0%, #f57c00 100%); border:none;">
                <span class="gv-btn-loading">
                  <span class="gv-spinner" id="gv-comercial-spinner" style="display:none;" aria-hidden="true"></span>
                  <span id="gv-comercial-accept-label">Sí, enviar a revisión</span>
                </span>
              </button>
            </div>
          </div>
        </div>

        <script>
        (function () {
          var root = document.getElementById('gvPedidosTabs');
          if (!root) return;
          var revisandoId = '<%= revisandoEstado.id %>';
          var cModal = document.getElementById('gv-comercial-confirm-modal');
          var cBackdrop = document.getElementById('gv-comercial-confirm-backdrop');
          var cNum = document.getElementById('gv-comercial-confirm-num');
          var cCancel = document.getElementById('gv-comercial-cancel');
          var cAccept = document.getElementById('gv-comercial-accept');
          var cSpinner = document.getElementById('gv-comercial-spinner');
          var cLabel = document.getElementById('gv-comercial-accept-label');
          if (!cModal || !cBackdrop || !cCancel || !cAccept) return;

          var activeBadge = null;
          var saving = false;

          function setSaving(on) {
            saving = !!on;
            cAccept.disabled = saving;
            cCancel.disabled = saving;
            if (cSpinner) cSpinner.style.display = saving ? 'inline-block' : 'none';
            if (cLabel) cLabel.textContent = saving ? 'Enviando...' : 'Sí, enviar a revisión';
          }

          cCancel.addEventListener('click', function () { if (!saving) { cModal.hidden = true; cBackdrop.hidden = true; activeBadge = null; } });
          cBackdrop.addEventListener('click', function () { if (!saving) { cModal.hidden = true; cBackdrop.hidden = true; activeBadge = null; } });

          cAccept.addEventListener('click', async function () {
            if (!activeBadge || saving) return;
            var pid = activeBadge.getAttribute('data-pid');
            try {
              setSaving(true);
              var r = await fetch('/pedidos/' + encodeURIComponent(pid) + '/estado', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ estadoId: revisandoId })
              });
              var json = await r.json().catch(function () { return null; });
              if (!r.ok || !json || !json.ok) {
                throw new Error((json && json.error) ? json.error : ('HTTP ' + r.status));
              }
              var color = (json.estado && json.estado.color) ? String(json.estado.color) : 'info';
              var nombre = (json.estado && json.estado.nombre) ? String(json.estado.nombre) : 'Revisando';
              activeBadge.textContent = nombre;
              activeBadge.classList.remove('ok', 'info', 'warn', 'danger');
              activeBadge.classList.add(color || 'info');
              activeBadge.disabled = true;
              activeBadge.style.cursor = 'default';
              activeBadge.title = '';

              var tr = activeBadge.closest('tr');
              if (tr) {
                var editBtn = tr.querySelector('a[href*="/edit"]');
                if (editBtn) editBtn.remove();
              }

              cModal.hidden = true;
              cBackdrop.hidden = true;
              activeBadge = null;

              var wh = json.webhook;
              if (wh && !wh.ok) {
                alert('Estado actualizado, pero hubo un error al notificar (webhook): ' + (wh.error || 'HTTP ' + wh.status));
              }
            } catch (e) {
              cModal.hidden = true;
              cBackdrop.hidden = true;
              alert('No se pudo cambiar el estado: ' + (e && e.message ? e.message : 'Error desconocido'));
            } finally {
              setSaving(false);
            }
          });

          root.addEventListener('click', function (ev) {
            var btn = ev.target && ev.target.closest ? ev.target.closest('button.gv-pedido-estado-comercial[data-pid]') : null;
            if (!btn) return;
            activeBadge = btn;
            var num = btn.getAttribute('data-num') || btn.getAttribute('data-pid') || '—';
            if (cNum) cNum.textContent = num;
            cBackdrop.hidden = false;
            cModal.hidden = false;
          });
        })();
        </script>
      <% } %>
    </div>
  </div>
</section>

<script>
(function () {
  var root = document.getElementById('gvPedidosTabs');
  if (!root) return;
  var tabButtons = Array.prototype.slice.call(root.querySelectorAll('.gv-tab[data-tab]'));
  var panels = Array.prototype.slice.call(root.querySelectorAll('.gv-tabpanel[data-tabpanel]'));
  if (!tabButtons.length || !panels.length) return;
  function setTab(id) {
    tabButtons.forEach(function (b) {
      var active = b.getAttribute('data-tab') === id;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      var active = p.getAttribute('data-tabpanel') === id;
      p.classList.toggle('is-active', active);
    });
  }
  tabButtons.forEach(function (b) {
    b.addEventListener('click', function () {
      setTab(b.getAttribute('data-tab'));
    });
  });
  var hash = String(window.location.hash || '').replace('#', '').trim().toLowerCase();
  if (hash === 'resumen') hash = 'listado';
  if (hash === 'listado' || hash === 'seguimiento') setTab(hash);
})();
</script>

<%- include('partials/footer') %>

