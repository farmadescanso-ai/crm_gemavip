<%- include('partials/header', { title: title || 'Comparación CRM Holded' }) %>

<% const d = typeof detail === 'object' && detail ? detail : {}; %>
<% const cli = d.cliente && typeof d.cliente === 'object' ? d.cliente : null; %>
<% const nom = cli ? (cli.cli_nombre_razon_social || cli.Nombre_Razon_Social || '') : ''; %>
<% const comparable = Array.isArray(d.comparableRows) ? d.comparableRows : []; %>
<% const crmAll = Array.isArray(d.crmAllColumnas) ? d.crmAllColumnas : (Array.isArray(d.restoColumnas) ? d.restoColumnas : []); %>
<% const holdedJson = typeof d.holdedJsonPretty === 'string' && d.holdedJsonPretty ? d.holdedJsonPretty : ''; %>
<% const holdedFlat = Array.isArray(d.holdedFieldRows) ? d.holdedFieldRows : []; %>
<% const crmOpts = Array.isArray(d.crmColumnOptions) ? d.crmColumnOptions : []; %>
<% const savedMap = (d.savedFieldMap && typeof d.savedFieldMap === 'object') ? d.savedFieldMap : {}; %>
<% const fmMeta = (d.fieldMapMeta && typeof d.fieldMapMeta === 'object') ? d.fieldMapMeta : {}; %>
<% const crmPick = Array.isArray(d.crmPickerRows) ? d.crmPickerRows : []; %>
<% const pathOpts = Array.isArray(d.holdedPathOptions) ? d.holdedPathOptions : []; %>
<% const pathLabels = d.holdedPathLabels && typeof d.holdedPathLabels === 'object' ? d.holdedPathLabels : {}; %>
<% const colLab = d.crmColumnLabelsEs && typeof d.crmColumnLabelsEs === 'object' ? d.crmColumnLabelsEs : {}; %>
<% const canSync = !d.missingHoldedLink && d.holdedId; %>
<% const syncPend = cli && (cli.cli_holded_sync_pendiente === 1 || cli.cli_holded_sync_pendiente === true); %>

<section class="card gv-vista gv-cpanel gv-holded-comparar-ficha">
  <div class="card-hd gv-vista-hd">
    <div class="gv-cpanel-kicker">
      <span class="gv-cpanel-badge">Superadmin</span>
      <span class="gv-cpanel-kicker__user"><%= user?.nombre ?? user?.email ?? '—' %></span>
    </div>
    <h1 class="card-title gv-vista-hd__title">Comparación CRM ↔ Holded</h1>
    <p class="gv-vista-hd__sub" style="margin-top: 8px;">
      <% if (cli && typeof cli.cli_id !== 'undefined') { %>
        <strong><%= nom || 'Cliente' %></strong>
        <span style="color: var(--gv-muted);"> · CRM <code>cli_id</code>=<%= cli.cli_id %></span>
        <% if (d.holdedId) { %>
          <span style="color: var(--gv-muted);"> · Holded <code><%= d.holdedId %></code></span>
        <% } %>
      <% } %>
    </p>
    <p style="margin-top: 12px; display: flex; flex-wrap: wrap; gap: 10px;">
      <a class="btn secondary" href="/cpanel/holded-comparar">← Listado</a>
      <% if (cli && cli.cli_id) { %>
        <a class="btn secondary" href="/clientes/<%= cli.cli_id %>">Ficha CRM</a>
      <% } %>
      <a class="btn secondary" href="/cpanel">CPanel</a>
    </p>
  </div>
  <div class="card-bd">
    <% if (typeof success === 'string' && success) { %>
      <div class="gv-alert success" role="status" style="margin-bottom: 16px;">
        <strong>Completado</strong>
        <p style="margin: 8px 0 0 0;"><%= success %></p>
      </div>
    <% } %>
    <% if (typeof error === 'string' && error) { %>
      <div class="gv-alert error" role="alert" style="margin-bottom: 16px;">
        <strong>Error</strong>
        <p style="margin: 8px 0 0 0;"><%- escapeHtml(error) %></p>
      </div>
    <% } %>

    <% if (!d.ok && d.error) { %>
      <div class="gv-alert error" role="alert">
        <strong>No se pudo cargar</strong>
        <p style="margin: 8px 0 0 0;"><%= d.error %></p>
      </div>
    <% } else if (cli) { %>

      <% if (d.holdedError) { %>
        <div class="gv-alert error" role="alert" style="margin-bottom: 16px;">
          <strong>Holded</strong>
          <p style="margin: 8px 0 0 0;"><%= d.holdedError %></p>
        </div>
      <% } %>

      <% if (canSync && typeof cli.cli_holded_sync_pendiente !== 'undefined') { %>
        <p class="gv-holded-sync-status" style="margin: 0 0 14px 0; font-size: 14px;">
          <% if (syncPend) { %>
            <span class="badge warning" title="Hash CRM distinto del contacto Holded">Sincronización pendiente</span>
            <span style="color: var(--gv-muted); margin-left: 8px;">Usa «Traer» o «Enviar» para alinear.</span>
          <% } else { %>
            <span class="badge ok" title="Datos comparables alineados">Sin divergencias en campos del hash</span>
          <% } %>
        </p>
      <% } %>

      <div class="gv-holded-comparar-actions" style="display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 22px; padding: 16px; border-radius: 12px; border: 1px solid rgba(0, 139, 210, 0.25); background: linear-gradient(135deg, rgba(0, 139, 210, 0.06) 0%, rgba(248, 250, 252, 0.95) 100%);">
        <% if (canSync) { %>
          <form method="post" action="/cpanel/holded-comparar/<%= cliId %>/export" style="display: inline;">
            <%- include('partials/csrf-field') %>
            <button type="submit" class="btn">Enviar CRM → Holded</button>
          </form>
          <form method="post" action="/cpanel/holded-comparar/<%= cliId %>/import" style="display: inline;">
            <%- include('partials/csrf-field') %>
            <button type="submit" class="btn secondary">Traer Holded → CRM</button>
          </form>
        <% } else { %>
          <p style="margin: 0; font-size: 13px; color: var(--gv-muted);">Sin <code>cli_Id_Holded</code> no se puede sincronizar con la API Holded. Vincula el cliente o importa desde Holded.</p>
        <% } %>
      </div>

      <h2 class="gv-holded-comparar-h2">Qué se sincroniza (hash)</h2>
      <p class="gv-holded-comparar-hint" style="margin: 0 0 12px 0; font-size: 13px; color: var(--gv-muted); max-width: 920px;">
        La tabla siguiente son los campos que entran en <code>cli_holded_sync_hash</code> y en los botones Traer / Enviar (misma lógica).
        <span class="gv-sync-dot gv-sync-dot--ok" aria-hidden="true"></span> igual ·
        <span class="gv-sync-dot gv-sync-dot--bad" aria-hidden="true"></span> distinto
      </p>
      <div class="table-wrap" style="margin-bottom: 28px;">
        <table class="dash-table gv-holded-comparar-diff-table">
          <thead>
            <tr>
              <th style="width: 36px;"></th>
              <th>Campo</th>
              <th>CRM</th>
              <th>Holded (equivalente)</th>
            </tr>
          </thead>
          <tbody>
            <% comparable.forEach(function (row) { %>
              <tr>
                <td class="gv-holded-comparar-dot-cell">
                  <span class="gv-sync-dot <%= row.match ? 'gv-sync-dot--ok' : 'gv-sync-dot--bad' %>" title="<%= row.match ? 'Coincide' : 'No coincide' %>" aria-label="<%= row.match ? 'Coincide' : 'No coincide' %>"></span>
                </td>
                <td style="font-weight: 600;"><%= row.label %></td>
                <td style="font-size: 13px; word-break: break-word;"><%= row.crmDisplay %></td>
                <td style="font-size: 13px; word-break: break-word;"><%= row.holdedDisplay %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <details class="gv-holded-comparar-details" style="margin-bottom: 24px;">
        <summary style="cursor: pointer; font-weight: 700; font-size: 15px; color: var(--gv-ink);">CRM — todos los campos de la fila (auditoría)</summary>
        <p style="margin: 10px 0 12px 0; font-size: 13px; color: var(--gv-muted);">Columnas de <code>clientes</code> y nombres resueltos por la consulta (provincia, país, etc.). No es la vista principal de sync.</p>
        <div class="table-wrap">
          <table class="dash-table gv-holded-comparar-rest-table">
            <thead>
              <tr>
                <th style="min-width: 200px;">Campo</th>
                <th>Valor</th>
              </tr>
            </thead>
            <tbody>
              <% crmAll.forEach(function (row) { %>
                <tr>
                  <td>
                    <div class="gv-holded-field-label-es"><%= row.labelEs || row.key %></div>
                    <div class="gv-holded-field-key-tech"><code><%= row.key %></code></div>
                  </td>
                  <td style="font-size: 12px; word-break: break-word; white-space: pre-wrap;"><%= row.value %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </details>

      <details class="gv-holded-comparar-details gv-holded-map-advanced-wrap">
        <summary style="cursor: pointer; font-weight: 700; font-size: 15px; color: var(--gv-ink);">Mapeo avanzado (opcional)</summary>
        <p style="margin: 10px 0 12px 0; font-size: 13px; color: var(--gv-muted); max-width: 920px;">
          Solo necesario si un campo Holded no está cubierto por la tabla «Qué se sincroniza».
          Enlaza rutas JSON (<code>GET /contacts/:id</code>) a columnas <code>clientes</code>. <strong>Guardar mapeo global</strong> persiste en MySQL.
          <% if (fmMeta.updatedAt) { %>
            <span style="display: block; margin-top: 8px;">Último guardado: <code><%= fmMeta.updatedAt %></code><% if (fmMeta.updatedBy) { %> · <%= fmMeta.updatedBy %><% } %></span>
          <% } %>
        </p>
        <% if (holdedFlat.length) { %>
          <div class="gv-holded-map-savebar">
            <button type="button" class="btn gv-holded-map-save">Guardar mapeo global en servidor</button>
            <button type="button" class="btn secondary gv-holded-map-clear" style="font-size: 13px;">Restablecer a sugerencias automáticas (solo pantalla)</button>
            <span class="gv-holded-map-saved" style="font-size: 13px; color: var(--gv-muted);" aria-live="polite"></span>
          </div>
          <div class="gv-holded-map-grid">
            <div>
              <h3 class="gv-holded-map-col-hd">Holded (API) — rutas y valores</h3>
              <p class="gv-holded-map-col-sub">Desplegable: columna CRM destino. Badge «Guardado» = override persistido en BD.</p>
              <div class="table-wrap gv-holded-flat-wrap">
                <table class="dash-table gv-holded-flat-table">
                  <thead>
                    <tr>
                      <th style="min-width: 180px;">Campo Holded</th>
                      <th>Valor</th>
                      <th style="min-width: 200px;">→ Columna CRM</th>
                      <th style="width: 72px;">Prio.</th>
                      <th style="width: 72px;">Hash</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% holdedFlat.forEach(function (row) {
                         var tierLabel = row.tier === 1 ? '1' : (row.tier === 2 ? '2' : '3');
                         var tierClass = 'gv-holded-tier--' + (row.tier === 1 ? '1' : (row.tier === 2 ? '2' : '3'));
                         var eff = row.effectiveCrmColumn != null ? String(row.effectiveCrmColumn) : '';
                    %>
                      <tr class="gv-holded-flat-row <%= tierClass %>">
                        <td>
                          <div class="gv-holded-field-label-es"><%= row.pathLabelEs || row.path %></div>
                          <div class="gv-holded-field-key-tech" title="Ruta técnica en la API"><code><%= row.path %></code></div>
                        </td>
                        <td style="font-size: 11px; word-break: break-word; max-width: 220px;" title="<%= row.valueDisplay %>"><%= row.valueDisplay %></td>
                        <td>
                          <select
                            class="input gv-holded-map-select gv-holded-map-select--left"
                            data-holded-path="<%= String(row.path).replace(/"/g, '&quot;') %>"
                            data-suggested="<%= row.suggestedCrmColumn ? String(row.suggestedCrmColumn).replace(/"/g, '&quot;') : '' %>"
                            data-crm-col=""
                            aria-label="Enlazar <%= row.path %> a columna CRM"
                            style="font-size: 11px; max-width: 100%;"
                          >
                            <option value="">— (sin elegir)</option>
                            <% crmOpts.forEach(function (col) { %>
                              <option value="<%= col %>" <%= eff === col ? 'selected' : '' %>><%= colLab[col] ? colLab[col] + ' — ' + col : col %></option>
                            <% }); %>
                          </select>
                          <% if (row.hasSavedOverride) { %><span class="gv-holded-map-badge-saved" title="En BD">Guardado</span><% } %>
                        </td>
                        <td style="font-size: 11px; text-align: center;"><%= tierLabel %></td>
                        <td style="text-align: center; font-size: 11px;">
                          <% if (row.inComparableHash) { %>
                            <span class="gv-holded-hash-badge" title="Hash sync">Sí</span>
                          <% } else { %>—<% } %>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
            <div>
              <h3 class="gv-holded-map-col-hd">CRM — columnas <code>clientes</code> (BD)</h3>
              <p class="gv-holded-map-col-sub">Valor actual del cliente y origen Holded (ruta). Cambiar aquí o en la columna izquierda; ambos se sincronizan al guardar.</p>
              <div class="table-wrap">
                <table class="dash-table gv-holded-flat-table">
                  <thead>
                    <tr>
                      <th style="min-width: 200px;">Columna CRM</th>
                      <th>Valor en ficha</th>
                      <th style="min-width: 220px;">Origen Holded</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% crmPick.forEach(function (r) { %>
                      <tr>
                        <td>
                          <div class="gv-holded-field-label-es"><%= r.colLabelEs || r.col %></div>
                          <div class="gv-holded-field-key-tech"><code><%= r.col %></code></div>
                        </td>
                        <td style="font-size: 11px; word-break: break-word; max-width: 240px;"><%= r.valueDisplay %></td>
                        <td>
                          <select
                            class="input gv-holded-map-select gv-holded-map-select--right"
                            data-crm-col="<%= String(r.col).replace(/"/g, '&quot;') %>"
                            style="font-size: 11px; max-width: 100%;"
                            aria-label="Origen Holded para <%= r.col %>"
                          >
                            <option value="">— (ninguna)</option>
                            <% pathOpts.forEach(function (p) { %>
                              <% var pDisp = pathLabels[p] ? pathLabels[p] + ' — ' + p : p; %>
                              <option value="<%= String(p).replace(/"/g, '&quot;') %>" <%= r.selectedHoldedPath === p ? 'selected' : '' %>><%= pDisp %></option>
                            <% }); %>
                          </select>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% } else if (holdedJson) { %>
          <p style="color: var(--gv-muted); font-size: 13px;">No se pudo generar la tabla de rutas (contacto vacío o error).</p>
        <% } else { %>
          <p style="color: var(--gv-muted); font-size: 13px;">No hay datos Holded para mapear (sin API key, sin vínculo o error al cargar el contacto).</p>
        <% } %>
      </details>

      <% if (holdedJson) { %>
        <details class="gv-holded-json-details gv-holded-comparar-details" style="margin-top: 16px;">
          <summary style="cursor: pointer; font-weight: 700; font-size: 14px; color: var(--gv-ink);">JSON crudo (respuesta completa Holded)</summary>
          <pre class="gv-holded-formas-pago-sql gv-holded-raw-json" style="max-height: 50vh; overflow: auto; margin-top: 10px;"><%= holdedJson %></pre>
        </details>
      <% } %>
    <% } %>
  </div>
</section>

<% if (cli && cli.cli_id && holdedFlat.length) { %>
<script nonce="<%= cspNonce %>">
(function () {
  var statusEl = document.querySelector('.gv-holded-map-saved');
  var serverMap = <%- safeJsonInline(savedMap || {}) %>;

  function collectMapFromLeft() {
    var m = {};
    document.querySelectorAll('.gv-holded-map-select--left').forEach(function (sel) {
      var path = sel.getAttribute('data-holded-path');
      if (!path) return;
      if (sel.value) m[path] = sel.value;
    });
    return m;
  }

  function syncRightFromMap(m) {
    document.querySelectorAll('.gv-holded-map-select--right').forEach(function (sel) {
      var col = sel.getAttribute('data-crm-col');
      if (!col) return;
      var found = '';
      for (var p in m) {
        if (m[p] === col) {
          found = p;
          break;
        }
      }
      sel.value = found || '';
    });
  }

  function syncLeftFromMap(m) {
    document.querySelectorAll('.gv-holded-map-select--left').forEach(function (sel) {
      var path = sel.getAttribute('data-holded-path');
      if (!path) return;
      if (m[path]) sel.value = m[path];
      else {
        var sug = sel.getAttribute('data-suggested') || '';
        sel.value = sug || '';
      }
    });
  }

  var map = Object.assign({}, serverMap);
  if (Object.keys(map).length === 0) map = collectMapFromLeft();
  syncRightFromMap(map);

  document.querySelectorAll('.gv-holded-map-select--left').forEach(function (sel) {
    sel.addEventListener('change', function () {
      map = collectMapFromLeft();
      syncRightFromMap(map);
      if (statusEl) statusEl.textContent = 'Cambios sin guardar (pulsa «Guardar mapeo global»).';
    });
  });

  document.querySelectorAll('.gv-holded-map-select--right').forEach(function (sel) {
    sel.addEventListener('change', function () {
      var col = sel.getAttribute('data-crm-col');
      var newPath = sel.value || '';
      if (newPath) delete map[newPath];
      for (var p in map) {
        if (map[p] === col) delete map[p];
      }
      if (newPath) map[newPath] = col;
      syncLeftFromMap(map);
      syncRightFromMap(map);
      if (statusEl) statusEl.textContent = 'Cambios sin guardar (pulsa «Guardar mapeo global»).';
    });
  });

  var saveBtn = document.querySelector('.gv-holded-map-save');
  if (saveBtn) saveBtn.addEventListener('click', function () {
    map = collectMapFromLeft();
    saveBtn.disabled = true;
    fetch('/cpanel/holded-comparar/field-map', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ map: map })
    })
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function () {
        if (statusEl) statusEl.textContent = 'Mapeo guardado en servidor. Import/export usarán estos enlaces.';
        serverMap = Object.assign({}, map);
      })
      .catch(function (e) {
        if (statusEl) statusEl.textContent = 'Error al guardar: ' + (e && e.message ? e.message : String(e));
      })
      .finally(function () {
        saveBtn.disabled = false;
      });
  });

  var clr = document.querySelector('.gv-holded-map-clear');
  if (clr) clr.addEventListener('click', function () {
    document.querySelectorAll('.gv-holded-map-select--left').forEach(function (sel) {
      var sug = sel.getAttribute('data-suggested') || '';
      sel.value = sug || '';
    });
    map = collectMapFromLeft();
    syncRightFromMap(map);
    if (statusEl) statusEl.textContent = 'Restablecido a sugerencias (solo pantalla; no sobrescribe el servidor hasta que guardes).';
  });
})();
</script>
<% } %>

<%- include('partials/footer') %>
