<%- include('partials/header', { title: title || 'Centros prescriptores' }) %>
<% 
/** Solo número romano + zona, p. ej. "Área de Salud IV (Noroeste)" → "IV (Noroeste)" */
function areaSaludCorta(raw) {
  if (raw == null || raw === '') return null;
  const s = String(raw).trim();
  if (!s) return null;
  const m = s.match(/([IVXLCDM]+)\s*(\([^)]+\))\s*$/i);
  if (m) return (m[1] + ' ' + m[2]).trim();
  const sinPrefijo = s.replace(/^área\s+de\s+salud\s+/iu, '').trim();
  return sinPrefijo || s;
}

/**
 * Nombres tipo "Centro de Salud Calasparra / PAC- Punto de Atención…"
 * → primera línea hasta el tramo principal; segunda línea desde "PAC-" (salto en ` / `).
 */
function nombreCentroHtml(raw) {
  if (raw == null || raw === '') return null;
  const s = String(raw).trim();
  if (!s) return null;
  const sep = ' / ';
  const idx = s.indexOf(sep);
  if (idx === -1) return escapeHtml(s);
  const a = s.slice(0, idx).trimEnd();
  const b = s.slice(idx + sep.length).trimStart();
  if (!b) return escapeHtml(s);
  return escapeHtml(a) + '<br />' + escapeHtml(b);
}
%>
<style>
  .admin-centros-pre-wrap .admin-centros-pre-table {
    table-layout: fixed;
    width: 100%;
  }
  .admin-centros-pre-wrap .admin-centros-pre-table th,
  .admin-centros-pre-wrap .admin-centros-pre-table td {
    vertical-align: top;
    white-space: normal;
    overflow-wrap: break-word;
    word-break: break-word;
    line-height: 1.35;
    padding: 10px 8px;
  }
</style>

<section class="card admin-centros-pre-wrap" style="max-width: 1200px; margin: 0 auto;">
  <div class="card-hd">
    <h1 class="card-title">Centros prescriptores</h1>
    <% if (typeof subtitle === 'string' && subtitle) { %>
      <p class="card-subtitle"><%= subtitle %></p>
    <% } %>
  </div>
  <div class="card-bd">
    <% if (typeof error === 'string' && error) { %>
      <div class="gv-alert gv-alert--warn"><%- escapeHtml(error) %></div>
      <div style="height: 12px;"></div>
    <% } %>

    <form method="get" action="/admin/sql-centro-murciasalud" class="gv-stack" style="margin-bottom: 16px; display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;">
      <div style="flex: 1; min-width: 200px;">
        <label for="q" class="gv-label">Buscar</label>
        <input
          class="gv-input"
          type="search"
          id="q"
          name="q"
          value="<%- escapeHtml(typeof q === 'string' ? String(q) : '') %>"
          placeholder="Nombre, población, municipio o código…"
          autocomplete="off"
          maxlength="120"
        />
      </div>
      <div class="gv-actions" style="padding-bottom: 2px;">
        <button class="btn" type="submit">Filtrar</button>
        <% if (typeof q === 'string' && q) { %>
          <a class="btn secondary" href="/admin/sql-centro-murciasalud">Limpiar</a>
        <% } %>
      </div>
    </form>

    <% const list = Array.isArray(rows) ? rows : []; %>
    <p class="gv-muted" style="font-size: 13px; margin: 0 0 12px 0;">
      <%= list.length %> <%= list.length === 1 ? 'centro' : 'centros' %>
      <% if (typeof q === 'string' && q) { %> (filtro activo)<% } %>
    </p>

    <div class="table-wrap">
      <table class="admin-centros-pre-table">
        <colgroup>
          <col style="width: 6%;" />
          <col style="width: 15%;" />
          <col style="width: 16%;" />
          <col style="width: 5%;" />
          <col style="width: 8%;" />
          <col style="width: 8%;" />
          <col style="width: 9%;" />
          <col style="width: 11%;" />
          <col style="width: 10%;" />
          <col style="width: 8%;" />
          <col style="width: 4%;" />
        </colgroup>
        <thead>
          <tr>
            <th style="text-align:left;">Código</th>
            <th style="text-align:left;">Nombre</th>
            <th style="text-align:left;">Dirección</th>
            <th style="text-align:left;">CP</th>
            <th style="text-align:left;">Población</th>
            <th style="text-align:left;">Municipio</th>
            <th style="text-align:left;">Teléfono</th>
            <th style="text-align:left;">Email</th>
            <th style="text-align:left;">Coordinador</th>
            <th style="text-align:left;">Área de salud</th>
            <th style="text-align:left;">Ruta</th>
          </tr>
        </thead>
        <tbody>
          <% if (!list.length) { %>
            <tr>
              <td colspan="11" style="color: var(--gv-muted); padding: 16px;">
                No hay centros que mostrar. Si la tabla existe pero está vacía, importa datos con los scripts SQL del repositorio.
              </td>
            </tr>
          <% } %>
          <% list.forEach((row) => { %>
            <% const areaTxt = areaSaludCorta(row.cent_Area_Salud); %>
            <% const nomHtml = nombreCentroHtml(row.cent_Nombre_Centro); %>
            <tr>
              <td><%= row.cent_codigo != null && row.cent_codigo !== '' ? escapeHtml(String(row.cent_codigo)) : '—' %></td>
              <td style="font-weight: 600;"><%- nomHtml != null ? nomHtml : '—' %></td>
              <td><%= row.cent_Direccion ? escapeHtml(String(row.cent_Direccion)) : '—' %></td>
              <td><%= row.cent_Cod_Postal ? escapeHtml(String(row.cent_Cod_Postal)) : '—' %></td>
              <td><%= row.cent_Poblacion ? escapeHtml(String(row.cent_Poblacion)) : '—' %></td>
              <td><%= row.cent_Municipio ? escapeHtml(String(row.cent_Municipio)) : '—' %></td>
              <td><%= row.cent_Telefono ? escapeHtml(String(row.cent_Telefono)) : '—' %></td>
              <td><%= row.cent_Email ? escapeHtml(String(row.cent_Email)) : '—' %></td>
              <td><%= row.cent_Coordinador ? escapeHtml(String(row.cent_Coordinador)) : '—' %></td>
              <td><%= areaTxt ? escapeHtml(areaTxt) : '—' %></td>
              <td><%= row.cent_Id_Ruta != null && row.cent_Id_Ruta !== '' ? escapeHtml(String(row.cent_Id_Ruta)) : '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
