<%- include('partials/header', { title: title || 'Importar Holded' }) %>
<style nonce="<%= cspNonce %>">.gv-holded-tab:hover{color:var(--gv-accent,#0d7377)!important;}</style>

<section class="card">
  <div class="card-hd">
    <nav class="gv-holded-tabs" role="tablist" style="display: flex; gap: 0; margin-bottom: 16px; border-bottom: 1px solid var(--gv-border, #ddd);">
      <a href="/admin/importar-holded" role="tab" aria-selected="true" class="gv-holded-tab gv-holded-tab--active" style="padding: 10px 16px; font-weight: 600; color: var(--gv-accent, #0d7377); border-bottom: 2px solid var(--gv-accent, #0d7377); margin-bottom: -1px; text-decoration: none;">Importar</a>
      <a href="/admin/importar-holded?tab=json-holded&start=2026-01-01&end=2026-12-31" role="tab" class="gv-holded-tab" style="padding: 10px 16px; color: var(--gv-muted, #666); text-decoration: none;">JSON</a>
      <a href="/admin/importar-holded?tab=preview&start=2026-01-01&end=2026-12-31" role="tab" class="gv-holded-tab" style="padding: 10px 16px; color: var(--gv-muted, #666); text-decoration: none;">Vista previa</a>
      <a href="/admin/importar-holded?tab=relacion-codigos&start=2026-01-01&end=2026-01-31" role="tab" class="gv-holded-tab" style="padding: 10px 16px; color: var(--gv-muted, #666); text-decoration: none;">Relación códigos</a>
    </nav>
    <h1 class="card-title"><%= title || 'Importar pedidos Holded' %></h1>
    <% if (subtitle) { %>
      <p class="card-subtitle"><%= subtitle %></p>
    <% } %>
    <p class="card-subtitle" style="margin-top: 8px; font-size: 13px; color: var(--gv-muted, #666);">
      Acceso exclusivo administrador del sistema. No aparece en menús.
    </p>
  </div>
  <div class="card-bd">
    <% if (!hasApiKey) { %>
      <div class="gv-alert warn" role="alert">
        <strong>HOLDED_API_KEY no configurada</strong>
        <p style="margin: 8px 0 0 0;">Añade la variable HOLDED_API_KEY en las variables de entorno (Vercel o .env local) para poder importar pedidos.</p>
      </div>
    <% } %>

    <% if (typeof error === 'string' && error) { %>
      <div class="gv-alert error" role="alert" style="margin-bottom: 16px;">
        <strong>Error</strong>
        <p style="margin: 8px 0 0 0;"><%= error %></p>
      </div>
    <% } %>
    <% if (typeof success === 'string' && success) { %>
      <div class="gv-alert success" role="status" style="margin-bottom: 16px;">
        <strong>Completado</strong>
        <p style="margin: 8px 0 0 0;"><%= success %></p>
      </div>
    <% } %>

    <% if (hasApiKey && needsMigration) { %>
      <div class="gv-alert warn" role="alert" style="margin-bottom: 16px;">
        <strong>Migración pendiente</strong>
        <p style="margin: 8px 0 12px 0;">Es necesario ejecutar la migración para añadir la columna <code>ped_id_holded</code> en la tabla pedidos.</p>
        <form method="post" action="/admin/importar-holded/run-migration" style="display: inline;">
          <%- include('partials/csrf-field') %>
          <button type="submit" class="btn primary">Ejecutar migración</button>
        </form>
      </div>
    <% } %>

    <% if (hasApiKey && !needsMigration) { %>
      <form id="gv-holded-sync-form" method="post" action="/admin/importar-holded/sync" style="max-width: 480px;">
        <%- include('partials/csrf-field') %>
        <div class="form-group" style="margin-bottom: 16px;">
          <label for="gv-holded-start">Fecha inicio</label>
          <input type="date" id="gv-holded-start" name="start" value="2026-01-01" required />
        </div>
        <div class="form-group" style="margin-bottom: 16px;">
          <label for="gv-holded-end">Fecha fin</label>
          <input type="date" id="gv-holded-end" name="end" value="2026-12-31" required />
        </div>
        <div class="form-group" style="margin-bottom: 16px;">
          <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
            <input type="checkbox" name="dryRun" value="1" id="gv-holded-dry" />
            <span>Simular (no guardar en BD)</span>
          </label>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <button type="submit" class="btn primary" id="gv-holded-btn">
            Importar pedidos
          </button>
          <span id="gv-holded-status" style="align-self: center; font-weight: 600;"></span>
        </div>
      </form>

      <script nonce="<%= cspNonce %>">
        (() => {
          const form = document.getElementById('gv-holded-sync-form');
          const btn = document.getElementById('gv-holded-btn');
          const status = document.getElementById('gv-holded-status');
          if (!form || !btn) return;

          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            status.textContent = 'Importando...';
            status.style.color = '';

            const fd = new FormData(form);
            const dryRun = form.querySelector('#gv-holded-dry')?.checked;

            try {
              const r = await fetch('/admin/importar-holded/sync', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
                body: new URLSearchParams({
                  start: fd.get('start') || '2026-01-01',
                  end: fd.get('end') || '2026-12-31',
                  dryRun: dryRun ? '1' : '0'
                })
              });
              const data = await r.json();

              if (data.ok) {
                status.textContent = '✓ ' + (dryRun ? 'Simulación: ' + data.inserted + ' pedidos' : data.inserted + ' pedidos importados');
                status.style.color = 'var(--gv-success, green)';
              } else {
                status.textContent = '✗ ' + (data.error || 'Error');
                status.style.color = 'var(--gv-error, #b91c1c)';
              }
            } catch (err) {
              status.textContent = '✗ Error: ' + err.message;
              status.style.color = 'var(--gv-error, #b91c1c)';
            }
            btn.disabled = false;
          });
        })();
      </script>
      <p style="margin-top: 20px; color: var(--gv-muted, #666); font-size: 14px;">
        Solo se importan pedidos de clientes en la <strong>Provincia de Murcia</strong>. Los clientes que no existan se crearán automáticamente.
      </p>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
