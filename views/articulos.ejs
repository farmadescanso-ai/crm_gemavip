<%- include('partials/header', { title: 'Artículos' }) %>

<% if (typeof loadError === 'string' && loadError) { %>
  <div class="card" style="border-color: var(--gv-danger, #c00); margin-bottom: 1rem;">
    <p style="color: var(--gv-danger, #c00); font-weight: 700;">Error al cargar artículos: <%- escapeHtml(String(loadError)) %></p>
  </div>
<% } %>
<% if (articuloMsg === 'deactivated') { %>
  <div class="gv-alert gv-alert--success" style="margin-bottom: 1rem;">El artículo está en pedidos; se ha desactivado en lugar de eliminarlo.</div>
<% } %>
<section class="card gv-vista">
  <div class="card-hd gv-vista-hd">
    <div class="gv-vista-hd__title-row">
      <h1 class="card-title gv-vista-hd__title">Artículos</h1>
      <button type="button" class="gv-vista-hd__info" aria-label="Información" title="Información">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
      </button>
      <span class="gv-vista-hd__tooltip" role="tooltip">Catálogo de artículos: busca por C.N., nombre o código interno. El filtro por marca puede estar desactivado según configuración.</span>
    </div>
    <div class="gv-vista-hd__bar">
      <nav class="gv-vista-tabs" aria-label="Vista">
        <a class="gv-vista-tab is-active" href="/articulos">Catálogo</a>
      </nav>
      <div class="gv-vista-hd__actions">
        <form method="get" action="/articulos" class="gv-vista-search" style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
          <input type="hidden" name="page" value="1" />
          <% if (!filtroMarcaFijo) { %>
            <label for="marca-art" style="font-weight: 700; color: var(--gv-ink);">Marca</label>
            <select id="marca-art" name="marca" class="gv-client-picker__q" style="width: auto; min-width: 200px;">
              <option value="" <%= !selectedMarcaId ? 'selected' : '' %>>Todas</option>
              <% (marcas || []).forEach((m) => { %>
                <option value="<%= m.id ?? m.mar_id %>" <%= Number(selectedMarcaId) === Number(m.id ?? m.mar_id) ? 'selected' : '' %>><%- escapeHtml(String(m.nombre ?? m.mar_nombre ?? m.id ?? m.mar_id ?? '')) %></option>
              <% }) %>
            </select>
          <% } %>
          <label for="q-art" class="visually-hidden">Buscar artículos</label>
          <input type="search" id="q-art" name="q" class="gv-vista-search__input" placeholder="C.N., nombre, código interno…" value="<%- escapeHtml(String(typeof searchQuery === 'string' ? searchQuery : '')) %>" style="min-width: 220px;" />
          <button class="btn secondary" type="submit">Buscar</button>
          <% if (typeof searchQuery === 'string' && searchQuery) { %>
            <a class="btn secondary" href="/articulos<%= selectedMarcaId ? '?marca=' + selectedMarcaId : '' %>" title="Limpiar búsqueda">✕</a>
          <% } %>
        </form>
        <% if (admin) { %>
          <a class="btn" href="/articulos/new">Nuevo artículo</a>
        <% } %>
      </div>
    </div>
    <p class="gv-vista-hd__sub">
      <% if (typeof total === 'number' && total > 0) { %>
        <% const from = (page - 1) * limit + 1; %>
        <% const to = Math.min(page * limit, total); %>
        Mostrando <%= from %>–<%= to %> de <%= total %> artículos
      <% } else { %>
        <%= typeof total === 'number' ? total : (items || []).length %> artículos
      <% } %>
      <% if (filtroMarcaFijo) { %> · Marca: todas<% } else if (selectedMarcaId) { %> · Marca filtrada<% } %>
      <% if (typeof searchQuery === 'string' && searchQuery) { %> · Buscando: &ldquo;<%- escapeHtml(String(searchQuery)) %>&rdquo;<% } %>
    </p>
  </div>
  <div class="card-bd">
    <% const qsArt = []; if (selectedMarcaId) qsArt.push('marca=' + selectedMarcaId); if (typeof searchQuery === 'string' && searchQuery) qsArt.push('q=' + encodeURIComponent(searchQuery)); const qsArtStr = qsArt.join('&'); %>
    <div class="gv-vista-pagination">
      <% if (page > 1) { %>
        <a class="btn secondary" href="/articulos?page=<%= page - 1 %><%= qsArtStr ? '&' + qsArtStr : '' %>">← Anterior</a>
      <% } %>
      <span class="gv-vista-pagination__info">
        Página
        <form method="get" action="/articulos" class="gv-vista-pagination__goto" style="display: inline;">
          <% if (selectedMarcaId) { %><input type="hidden" name="marca" value="<%= selectedMarcaId %>" /><% } %>
          <% if (typeof searchQuery === 'string' && searchQuery) { %><input type="hidden" name="q" value="<%- escapeHtml(String(searchQuery)) %>" /><% } %>
          <input type="number" name="page" min="1" max="<%= totalPages || 1 %>" value="<%= page %>" class="gv-vista-pagination__input" aria-label="Ir a página" title="Ir a página" />
          <button type="submit" class="btn secondary icon gv-vista-pagination__btn">Ir</button>
        </form>
        de <%= totalPages || 1 %>
      </span>
      <% if (page < totalPages) { %>
        <a class="btn secondary" href="/articulos?page=<%= page + 1 %><%= qsArtStr ? '&' + qsArtStr : '' %>">Siguiente →</a>
      <% } %>
    </div>

    <div class="table-wrap gv-articulos-table-wrap">
      <table class="gv-articulos-table">
        <colgroup>
          <col class="gv-articulos-col-cn">
          <col class="gv-articulos-col-nombre">
          <col class="gv-articulos-col-unid">
          <col class="gv-articulos-col-pvl">
          <col class="gv-articulos-col-iva">
          <col class="gv-articulos-col-activo">
          <col class="gv-articulos-col-acciones">
        </colgroup>
        <thead>
          <tr>
            <th>C.N.</th>
            <th>Nombre</th>
            <th>Unid. Caja</th>
            <th>PVL</th>
            <th>IVA</th>
            <th>Activo</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% (items || []).forEach((a) => { const aid = a.Id ?? a.id ?? a.art_id; %>
            <tr>
              <td><%- escapeHtml(String(a.SKU ?? a.art_sku ?? '')) %></td>
              <td class="gv-articulos-td-nombre"><%- escapeHtml(String(a.Nombre ?? a.art_nombre ?? '')) %></td>
              <td><%- escapeHtml(String(a.Unidades_Caja ?? a.art_unidades_caja ?? '')) %></td>
              <td><%- escapeHtml(String(a.PVL ?? a.art_pvl ?? '')) %></td>
              <td><%- escapeHtml(String(a.IVA ?? a.art_iva ?? '')) %></td>
              <td><%= (a.Activo ?? a.art_activo ?? 1) ? 'Sí' : 'No' %></td>
              <td>
                <div class="gv-actions">
                  <a class="btn secondary icon" href="/articulos/<%= aid %>" title="Ver ficha" aria-label="Ver ficha">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                  </a>
                  <% if (admin) { %>
                    <a class="btn secondary icon" href="/articulos/<%= aid %>/edit" title="Editar" aria-label="Editar">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"></path><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path></svg>
                    </a>
                    <form method="post" action="/articulos/<%= aid %>/delete" onsubmit="return confirm('¿Eliminar este artículo?');">
                      <%- include('partials/csrf-field') %>
                      <button class="btn secondary icon danger" type="submit" title="Eliminar" aria-label="Eliminar">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18"></path><path d="M8 6V4h8v2"></path><path d="M19 6l-1 14H6L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path></svg>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
          <% if (!items || items.length === 0) { %>
            <tr>
              <td colspan="7" style="color: var(--gv-muted); font-weight:700;">No hay artículos.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
