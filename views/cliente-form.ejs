<%- include('partials/header', { title: mode === 'edit' ? 'Editar cliente' : 'Nuevo cliente' }) %>

<% const missingFieldsList = (typeof missingFields !== 'undefined' && Array.isArray(missingFields)) ? missingFields : []; %>
<% const cid = (typeof clienteId !== 'undefined' && clienteId != null && clienteId !== '') ? clienteId : (item && (item.Id ?? item.id ?? item.cli_id ?? (typeof meta !== 'undefined' && meta && meta.pk ? item[meta.pk] : null))); %>
<% const formAction = (mode === 'edit' && cid) ? ('/clientes/' + cid + '/edit') : '/clientes/new'; %>
<% const cancelHref = (mode === 'edit' && cid) ? ('/clientes/' + cid) : '/clientes'; %>

<section class="card gv-cliente-form" style="max-width: 1080px; margin: 0 auto;">
  <div class="card-hd">
    <h1 class="card-title"><%= mode === 'edit' ? 'Editar cliente' : 'Nuevo cliente' %></h1>
    <p class="card-subtitle">Revisa y completa la ficha del cliente. Puedes moverte por pestañas sin perder cambios.</p>
  </div>
  <div class="card-bd">
    <% if (error) { %>
      <div class="gv-alert gv-alert--warn" style="margin-bottom:12px;"><%= error %></div>
    <% } %>
    <% if (typeof dupDniMatches !== 'undefined' && Array.isArray(dupDniMatches) && dupDniMatches.length) { %>
      <div class="gv-alert gv-alert--warn" style="margin-bottom:12px;">
        <strong>Mismo DNI/CIF en otro contacto:</strong>
        <ul style="margin:8px 0 0 18px; padding:0;">
          <% dupDniMatches.slice(0, 8).forEach(function (m) { %>
            <li>#<%= m.Id %> — <%= (m.Nombre_Razon_Social || m.cli_nombre_razon_social || '—') %> <% var dc = m.DNI_CIF || m.cli_dni_cif || ''; if (dc) { %>(<%= dc %>)<% } %></li>
          <% }); %>
        </ul>
      </div>
    <% } %>
    <div id="gvDupDniClient" class="gv-alert gv-alert--warn" style="display:none; margin-bottom:12px;" role="alert" aria-live="polite"></div>

    <form id="gvClienteForm" method="post" action="<%= formAction %>" class="gv-form" style="display:grid; gap: 12px;" data-dni-blocked="0">
      <% if (mode === 'create') { %>
        <input type="hidden" name="dup_confirmed" id="gvDupConfirmed" value="0" />
      <% } %>
      <div class="gv-form-actions-sticky">
        <div class="gv-form-actions-sticky__inner">
          <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <a class="btn secondary" href="<%= cancelHref %>" id="gvCancelBtn">Cancelar</a>
            <button class="btn" type="submit" id="gvSaveBtn"><%= mode === 'edit' ? 'Guardar' : 'Crear' %></button>
          </div>
          <div id="gvDirtyHint" class="gv-dirty-hint" style="display:none;">Tienes cambios sin guardar.</div>
        </div>
      </div>

      <div class="gv-cliente-name-bar" id="gvClienteNameBar">
        <span class="gv-cliente-name-bar__label">Contacto:</span>
        <span class="gv-cliente-name-bar__name" id="gvClienteNameDisplay"><%= mode === 'edit' && item ? (item.cli_nombre_razon_social || item.Nombre_Razon_Social || item.Nombre_Cial || item.cli_nombre_cial || '—') : '—' %></span>
      </div>

      <% const curComId = Number(item?.cli_com_id ?? item?.Id_Cial ?? 0) || 0; %>
      <% const isAdminDelegado = !!(admin || canChangeComercial); %>
      <div class="gv-delegado-block" style="margin-bottom:16px; padding:12px; background:var(--gv-bg-subtle, #f5f5f5); border-radius:8px;">
        <label for="gv_delegado" style="font-weight:800; font-size:13px; color:var(--gv-ink); display:block; margin-bottom:6px;">Delegado</label>
        <% if (isAdminDelegado) { %>
          <select name="cli_com_id" id="gv_delegado" style="min-width:220px;">
            <option value="">(sin asignar)</option>
            <% (comerciales || []).forEach((c) => { %>
              <% const cid = Number(c.com_id ?? c.id ?? c.Id ?? 0) || 0; %>
              <% const cnombre = (c.com_nombre ?? c.Nombre ?? '').trim() || '—'; %>
              <option value="<%= cid %>" <%= cid === curComId ? 'selected' : '' %>><%= cnombre %></option>
            <% }) %>
          </select>
        <% } else { %>
          <% const asignado = (comerciales || []).find(c => Number(c.com_id ?? c.id ?? c.Id ?? 0) === curComId); %>
          <div class="gv-readonly"><%= asignado ? (asignado.com_nombre ?? asignado.Nombre ?? '') : 'Sin asignar' %></div>
          <input type="hidden" name="cli_com_id" value="<%= curComId %>" />
        <% } %>
      </div>

      <div class="gv-tabs" role="tablist" aria-label="Secciones del contacto">
        <% (tabs || []).forEach((t, idx) => { %>
          <button
            type="button"
            class="gv-tab <%= idx === 0 ? 'is-active' : '' %>"
            role="tab"
            aria-selected="<%= idx === 0 ? 'true' : 'false' %>"
            aria-controls="tab_<%= t.id %>"
            data-tab="<%= t.id %>"
          ><%= t.label %></button>
        <% }) %>
      </div>

      <% const _pickVal = (typeof pickVal === 'function' ? pickVal : (name) => { const v = (item && item[name] !== undefined) ? item[name] : ''; return (v === null || v === undefined) ? '' : String(v); }); %>
      <% const numVal = (name) => { const v = _pickVal(name); return v === '' ? '' : v; }; %>
      <% const pickDisplayVal = (name) => { const fn = typeof resolveDisplayValue === 'function' ? resolveDisplayValue : null; const val = fn ? fn(name, item) : _pickVal(name); return (val && String(val).trim()) ? String(val).trim() : '—'; }; %>

      <% (tabs || []).forEach((t, idx) => { %>
        <section id="tab_<%= t.id %>" class="gv-tabpanel <%= idx === 0 ? 'is-active' : '' %>" role="tabpanel" data-tabpanel="<%= t.id %>">
          <% if (t.id === 'direccion') { %>
            <div class="gv-direccion-tab-hd" style="margin-bottom: 14px;">
              <% if (mode === 'edit' && cid) { %>
                <a class="btn gv-relaciones-add" href="/clientes/<%= cid %>/direcciones/new">Añadir dirección de envío</a>
                <p class="gv-relaciones-tab__sub" style="margin: 8px 0 0 0; font-size: 13px; color: var(--gv-muted);">Si el cliente tiene más de una dirección de envío, añádelas aquí.</p>
              <% } else { %>
                <p style="font-size: 13px; color: var(--gv-muted);">Guarda primero el cliente para poder añadir direcciones de envío adicionales.</p>
              <% } %>
            </div>
          <% } %>
          <% if (t.id === 'relaciones' && mode === 'edit' && cid) { %>
            <div class="gv-relaciones-tab">
              <div class="gv-relaciones-tab__hd">
                <h3 class="gv-relaciones-tab__title">Contactos relacionados</h3>
                <p class="gv-relaciones-tab__sub">Vincula este contacto con otros para ver relaciones cruzadas.</p>
                <button type="button" class="btn gv-relaciones-add" id="gvBtnAddRelaciones">Añadir contactos relacionados</button>
              </div>
              <div class="table-wrap gv-relaciones-table-wrap" <%= (!relaciones || relaciones.length === 0) ? 'style="display:none;"' : '' %>>
                <table class="gv-contactos-table gv-relaciones-table">
                  <colgroup>
                    <col class="gv-contactos-col-nombre" />
                    <col class="gv-contactos-col-tipo" />
                    <col class="gv-contactos-col-telefono" />
                    <col class="gv-contactos-col-email" />
                    <col class="gv-contactos-col-contacto" />
                    <col class="gv-contactos-col-provincia" />
                    <col class="gv-contactos-col-estado" />
                    <col class="gv-contactos-col-acciones" />
                  </colgroup>
                  <thead>
                    <tr>
                      <th class="gv-contactos-col-nombre">Nombre / Razón Social</th>
                      <th>Tipo</th>
                      <th class="gv-contactos-col-telefono">Teléfono</th>
                      <th class="gv-contactos-col-email">Email</th>
                      <th class="gv-contactos-col-contacto">Contacto</th>
                      <th>Provincia</th>
                      <th class="gv-contactos-col-estado">Estado</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody id="gvRelacionesList">
                    <% (relaciones || []).forEach((r) => { %>
                      <% const nom = r.relacionado_nombre || r.relacionado_nombre_cial || r.origen_nombre || r.origen_nombre_cial || 'Cliente'; %>
                      <% const tipo = r.relacionado_tipo || r.origen_tipo || '—'; %>
                      <% const tel = String(r.relacionado_telefono || r.relacionado_movil || r.origen_telefono || r.origen_movil || '').trim(); %>
                      <% const email = String(r.relacionado_email || r.origen_email || '').trim(); %>
                      <% const contacto = r.relacionado_nom_contacto || r.origen_nom_contacto || '—'; %>
                      <% const provincia = r.relacionado_provincia || r.origen_provincia || '—'; %>
                      <% const estado = r.relacionado_estado || r.origen_estado || '—'; %>
                      <% const relId = r.clirel_cli_relacionado_id || r.clirel_cli_origen_id; %>
                      <% const origenId = r.clirel_cli_origen_id; %>
                      <% const relacionadoId = r.clirel_cli_relacionado_id; %>
                      <tr class="gv-relacion-row" data-origen="<%= origenId %>" data-relacionado="<%= relacionadoId %>">
                        <td class="gv-contactos-col-nombre"><%= nom %></td>
                        <td><% const tipoClase = (String(tipo).toLowerCase() === 'empresa') ? 'empresa' : (String(tipo).toLowerCase() === 'persona') ? 'persona' : 'otros'; %><span class="gv-badge gv-badge--<%= tipoClase %>"><%= tipo %></span></td>
                        <td class="gv-contactos-col-telefono"><%- include('partials/telefono-display', { telefono: tel }) %></td>
                        <td class="gv-contactos-col-email"><% if (email) { %><a href="mailto:<%= email %>" class="gv-contactos-link"><%= email %></a><% } else { %>—<% } %></td>
                        <td class="gv-contactos-col-contacto"><%= contacto %></td>
                        <td><%= provincia %></td>
                        <td class="gv-contactos-col-estado"><%= estado %></td>
                        <td>
                          <div class="gv-actions">
                            <a class="btn secondary icon" href="/clientes/<%= relId %>" target="_blank" title="Ver" aria-label="Ver contacto <%= relId %>">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                              </svg>
                            </a>
                            <button type="button" class="btn secondary icon gv-remove-relacion" data-origen="<%= origenId %>" data-relacionado="<%= relacionadoId %>" title="Quitar relación" aria-label="Quitar relación">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                              </svg>
                            </button>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <p class="gv-relaciones-empty" id="gvRelacionesEmpty" <%= (relaciones && relaciones.length > 0) ? 'style="display:none;"' : '' %>>
                No hay contactos relacionados. Usa el botón superior para añadirlos.
              </p>
            </div>
          <% } else if (t.id === 'mayoristas' && cid) { %>
            <div class="gv-relaciones-tab">
              <div class="gv-relaciones-tab__hd">
                <h3 class="gv-relaciones-tab__title">Mayoristas / Cooperativas</h3>
                <p class="gv-relaciones-tab__sub">Asocia los mayoristas con los que trabaja este cliente y su número de asociado.</p>
              </div>
              <% if (mode === 'edit') { %>
              <div style="display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap; margin-bottom:16px;">
                <label style="display:grid; gap:4px; flex:1; min-width:160px;">
                  <span style="font-weight:700; font-size:13px;">Mayorista</span>
                  <select id="gvCoopSelect" style="padding:8px 10px; border:1px solid var(--gv-border); border-radius:8px; font-size:14px;">
                    <option value="">— Seleccionar —</option>
                    <% (cooperativas || []).forEach((c) => { %>
                      <% const cid2 = Number(c.coop_id ?? c.id ?? c.Id ?? 0); %>
                      <option value="<%= cid2 %>"><%= c.coop_nombre ?? c.Nombre ?? c.nombre ?? ('Cooperativa ' + cid2) %></option>
                    <% }) %>
                  </select>
                </label>
                <label style="display:grid; gap:4px; flex:1; min-width:120px;">
                  <span style="font-weight:700; font-size:13px;">Nº Asociado</span>
                  <input type="text" id="gvCoopNumAsociado" placeholder="Código de asociado" style="padding:8px 10px; border:1px solid var(--gv-border); border-radius:8px; font-size:14px;" />
                </label>
                <button type="button" class="btn gv-relaciones-add" id="gvBtnAddCoop" style="white-space:nowrap;">Añadir</button>
              </div>
              <% } %>
              <div class="table-wrap" id="gvCoopTableWrap" <%= (!(cooperativasCliente || []).length) ? 'style="display:none;"' : '' %>>
                <table class="gv-contactos-table">
                  <thead>
                    <tr>
                      <th>Mayorista</th>
                      <th>Nº Asociado</th>
                      <% if (mode === 'edit') { %><th style="width:60px;">Acciones</th><% } %>
                    </tr>
                  </thead>
                  <tbody id="gvCoopList">
                    <% (cooperativasCliente || []).forEach((cc) => { %>
                      <tr data-rel-id="<%= cc.id || '' %>" data-coop-id="<%= cc.Id_Cooperativa %>">
                        <td style="font-weight:700;"><%= cc.Nombre || '—' %></td>
                        <td>
                          <span class="gv-coop-num-display"><%= cc.NumAsociado || '—' %></span>
                          <% if (mode === 'edit') { %>
                          <input type="text" class="gv-coop-num-input" value="<%= cc.NumAsociado || '' %>" style="display:none; padding:5px 8px; border:1px solid var(--gv-border); border-radius:6px; font-size:13px; width:100%;" />
                          <% } %>
                        </td>
                        <% if (mode === 'edit') { %>
                        <td>
                          <div class="gv-actions" style="display:flex; gap:4px;">
                            <button type="button" class="btn secondary icon gv-edit-coop" data-rel-id="<%= cc.id || '' %>" title="Editar nº asociado">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:15px;height:15px;">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                              </svg>
                            </button>
                            <button type="button" class="btn secondary icon gv-remove-coop" data-rel-id="<%= cc.id || '' %>" title="Quitar">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:15px;height:15px;">
                                <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
                              </svg>
                            </button>
                          </div>
                        </td>
                        <% } %>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <p id="gvCoopEmpty" <%= ((cooperativasCliente || []).length) ? 'style="display:none;"' : '' %> style="color:var(--gv-muted); font-size:14px; margin-top:8px;">
                No hay mayoristas asociados a este cliente.
              </p>
            </div>
          <% } else { %>
          <div class="grid cols-2 gv-form-grid<%= t.id === 'datos_banco' ? ' gv-datos-banco-stack' : '' %>" style="gap: 12px;">
              <% (t.fields || []).forEach((f) => { %>
                <% const name = f.name; %>
                <% const label = f.label; %>
                <% const required = !!f.required; %>
                <% const spec = f.spec || {}; %>
                <% if (spec.kind === 'relaciones' || spec.kind === 'mayoristas') return; %>
                <% if (spec.options === 'comerciales') return; %>
                <% const isMissing = missingFieldsList.indexOf(name) !== -1; %>
                <% const inputId = `gv_${String(name).replace(/[^a-zA-Z0-9_-]/g, '_')}`; %>
                <% const nl = String(name || '').toLowerCase(); %>
                <% let datBancoCls = ''; %>
                <% if (t.id === 'datos_banco') {
                  if (nl.includes('iban')) datBancoCls = ' gv-datbanco-iban';
                  else if (nl.includes('banco')) datBancoCls = ' gv-datbanco-banco';
                  else datBancoCls = ' gv-datbanco-rest';
                } %>

                <% const isTipoEspField = (spec.options === 'tipos_clientes' || spec.options === 'especialidades' || spec.options === 'tipos_clientes_nombre'); %>
                <% const isAdminOnly = !!f.adminOnly; %>
                <% const forceReadonly = isAdminOnly && !(typeof admin !== 'undefined' && admin); %>
                <label style="display:grid; gap: 6px;" class="<%= isMissing ? 'gv-field-error' : '' %><%= isTipoEspField ? ' gv-field-tipo-esp' : '' %><%= isAdminOnly ? ' gv-field-admin-only' : '' %><%= datBancoCls %>" <%= isTipoEspField ? ' data-visibility-tipo-contacto="persona"' : '' %>>
                  <span style="font-weight:800; color: var(--gv-ink); font-size: 13px;"><%= label %><%= required ? ' *' : '' %><% if (isAdminOnly) { %> <span class="gv-badge-admin" title="Solo puede editar un administrador">Solo admin</span><% } %></span>

                  <% if (forceReadonly) { %>
                    <div class="gv-readonly"><%= _pickVal(name) || '—' %></div>
                    <input type="hidden" name="<%= name %>" value="<%= _pickVal(name) %>" />
                  <% } else if (spec.kind === 'readonly') { %>
                    <div class="gv-readonly"><%= pickDisplayVal(name) %></div>
                  <% } else if (spec.kind === 'textarea') { %>
                    <textarea id="<%= inputId %>" name="<%= name %>" rows="4" <%= required ? 'required' : '' %> aria-invalid="<%= isMissing ? 'true' : 'false' %>"><%= _pickVal(name) %></textarea>
                  <% } else if (spec.kind === 'checkbox') { %>
                    <input type="hidden" name="<%= name %>" value="0" />
                    <div style="display:flex; align-items:center; gap:10px;">
                      <input id="<%= inputId %>" type="checkbox" name="<%= name %>" value="1" <%= (_pickVal(name) === '1' || _pickVal(name).toLowerCase() === 'true') ? 'checked' : '' %> />
                      <span style="color: var(--gv-muted); font-weight:700;">Sí</span>
                    </div>
                  <% } else if (spec.kind === 'select' && spec.options === 'ok_ko') { %>
                    <select id="gv-ok-ko" name="<%= name %>">
                      <option value="1" <%= _pickVal(name) === '1' ? 'selected' : '' %>>Activo</option>
                      <option value="0" <%= _pickVal(name) === '0' ? 'selected' : '' %>>Inactivo</option>
                    </select>
                    <small style="color: var(--gv-muted);">Solo se puede estar activo con DNI/CIF informado.</small>
                  <% } else if (spec.kind === 'select' && spec.options === 'estados_cliente') { %>
                    <% const curId = Number(_pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% (estadosCliente || []).forEach((r) => { %>
                        <% const rid = Number(r.estcli_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                        <% const rlabel = r.estcli_nombre ?? r.Nombre ?? r.nombre ?? r.Estado ?? r.estado ?? r.descripcion ?? r.Descripcion ?? ('Estado ' + rid); %>
                        <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                      <% }) %>
                    </select>
                    <small style="color: var(--gv-muted);">Si seleccionas Activo sin DNI/CIF válido, se guardará como Potencial.</small>
                  <% } else if (spec.kind === 'select' && spec.options === 'tipo_contacto') { %>
                    <% const curTipo = String(_pickVal(name) || '').trim(); %>
                    <select id="gv-tipo-contacto" name="<%= name %>" data-field="tipo_contacto">
                      <option value="">— Seleccionar —</option>
                      <option value="Empresa" <%= curTipo.toLowerCase() === 'empresa' ? 'selected' : '' %>>Empresa</option>
                      <option value="Persona" <%= curTipo.toLowerCase() === 'persona' ? 'selected' : '' %>>Persona</option>
                      <option value="Otros" <%= curTipo.toLowerCase() === 'otros' ? 'selected' : '' %>>Otros</option>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'comerciales') { %>
                    <% const cur = Number(_pickVal(name) || 0) || 0; %>
                    <% const canEditDelegado = (typeof canChangeComercial !== 'undefined' && canChangeComercial === true) || (typeof admin !== 'undefined' && admin === true); %>
                    <% if (canEditDelegado) { %>
                      <select id="<%= inputId %>" name="<%= name %>">
                        <option value="">(sin asignar)</option>
                        <% (comerciales || []).forEach((c) => { %>
                          <% const cid = Number(c.com_id ?? c.id ?? c.Id ?? 0) || 0; %>
                          <% const cnombre = c.com_nombre ?? c.Nombre ?? ''; %>
                          <% const cemail = c.com_email ?? c.Email ?? c.email ?? ''; %>
                          <option value="<%= cid %>" <%= cid === cur ? 'selected' : '' %>><%= cnombre %> (<%= cemail %>)</option>
                        <% }) %>
                      </select>
                    <% } else { %>
                      <% const comercialAsignado = (comerciales || []).find(function(c){ return Number(c.com_id ?? c.id ?? c.Id ?? 0) === cur; }); %>
                      <div class="gv-readonly"><%= comercialAsignado ? (comercialAsignado.com_nombre ?? comercialAsignado.Nombre ?? '') : 'Sin asignar' %></div>
                      <input type="hidden" name="<%= name %>" value="<%= _pickVal(name) %>" />
                    <% } %>
                  <% } else if (spec.kind === 'select' && spec.options === 'tarifas') { %>
                    <% const curTar = Number(_pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="0" <%= curTar === 0 ? 'selected' : '' %>>0 PVL</option>
                      <% (tarifas || []).forEach((t) => { %>
                        <% const tid = Number(t.tarcli_id ?? t.Id ?? t.id ?? 0) || 0; %>
                        <% const tlabel = t.tarcli_nombre ?? t.NombreTarifa ?? t.Nombre ?? t.nombre ?? ('Tarifa ' + tid); %>
                        <option value="<%= tid %>" <%= tid === curTar ? 'selected' : '' %>><%= tid %> · <%= tlabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'paises') { %>
                    <% const curId = Number(_pickVal(name) || 0) || 0; %>
                    <% const curPaisEnLista = (paises || []).some((p) => Number(p.pais_id ?? p.id ?? p.Id ?? 0) === curId); %>
                    <% const curPaisLabel = (item && (item.PaisNombre ?? item.Pais ?? item.cli_Pais)) ? String(item.PaisNombre ?? item.Pais ?? item.cli_Pais).trim() : (curId ? 'País ' + curId : ''); %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% if (curId && !curPaisEnLista && curPaisLabel) { %>
                        <option value="<%= curId %>" selected><%= curPaisLabel %></option>
                      <% } %>
                      <% (paises || []).forEach((p) => { %>
                        <% const pid = Number(p.pais_id ?? p.id ?? p.Id ?? p.ID ?? 0) || 0; %>
                        <% const plabel = p.pais_nombre ?? p.Nombre_pais ?? p.Nombre ?? p.nombre ?? p.Pais ?? ('País ' + pid); %>
                        <% const pCodigo = String(p.pais_codigo ?? p.Id_pais ?? p.id_pais ?? '').trim().toUpperCase(); %>
                        <option value="<%= pid %>" data-pais-codigo="<%= pCodigo %>" <%= pid === curId ? 'selected' : '' %>><%= plabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'provincias') { %>
                    <% const curId = Number(_pickVal(name) || 0) || 0; %>
                    <% const curProvEnLista = (provincias || []).some((p) => Number(p.prov_id ?? p.id ?? p.Id ?? p.ID ?? 0) === curId); %>
                    <% const curProvLabel = (item && (item.ProvinciaNombre ?? item.Provincia ?? item.provincia)) ? String(item.ProvinciaNombre ?? item.Provincia ?? item.provincia).trim() : (curId ? 'Provincia ' + curId : ''); %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% if (curId && !curProvEnLista && curProvLabel) { %>
                        <option value="<%= curId %>" selected><%= curProvLabel %></option>
                      <% } %>
                      <% (provincias || []).forEach((p) => { %>
                        <% const pid = Number(p.prov_id ?? p.id ?? p.Id ?? p.ID ?? 0) || 0; %>
                        <% const plabel = p.prov_nombre ?? p.Nombre_provincia ?? p.Nombre ?? p.nombre ?? p.Provincia ?? ('Provincia ' + pid); %>
                        <option value="<%= pid %>" <%= pid === curId ? 'selected' : '' %>><%= plabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'formas_pago') { %>
                    <% const curId = Number(_pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% (formasPago || []).forEach((r) => { %>
                        <% const rid = Number(r.formp_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                        <% const rlabel = r.formp_nombre ?? r.FormaPago ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? ('Forma pago ' + rid); %>
                        <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                      <% }) %>
                    </select>
                <% } else if (spec.kind === 'select' && spec.options === 'tipos_clientes') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (tiposClientes || []).forEach((r) => { %>
                      <% const rid = Number(r.tipc_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.tipc_nombre ?? r.tipc_tipo ?? r.Tipo ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? ('Tipo cliente ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'especialidades') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (especialidades || []).forEach((r) => { %>
                      <% const rid = Number(r.esp_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.esp_nombre ?? r.Nombre ?? r.nombre ?? r.Especialidad ?? r.descripcion ?? ('Especialidad ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'tipos_clientes_nombre') { %>
                  <% const cur = String(_pickVal(name) || '').trim().toLowerCase(); %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (tiposClientes || []).forEach((r) => { %>
                      <% const rlabel = String(r.Tipo ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? '').trim(); %>
                      <% const rval = rlabel; %>
                      <option value="<%= rval %>" <%= (rlabel && rlabel.trim().toLowerCase() === cur) ? 'selected' : '' %>><%= rlabel || '—' %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'idiomas') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (idiomas || []).forEach((r) => { %>
                      <% const rid = Number(r.idiom_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const code = (r.Codigo ?? r.codigo ?? r.idiom_codigo ?? '').toString().trim().toUpperCase(); %>
                      <% const rname = r.idiom_nombre ?? r.Nombre ?? r.Idioma ?? r.descripcion ?? r.Descripcion ?? ('Idioma ' + rid); %>
                      <% const rlabel = code ? (code + ' · ' + rname) : rname; %>
                      <option value="<%= rid %>" data-idiom-codigo="<%= code %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'monedas') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <% const curMonEnLista = (monedas || []).some((r) => Number(r.mon_id ?? r.id ?? r.Id ?? r.ID ?? 0) === curId); %>
                  <% const curMonLabel = (item && (item.MonedaNombre ?? item.Moneda ?? item.cli_Moneda)) ? String(item.MonedaNombre ?? item.Moneda ?? item.cli_Moneda).trim() : (curId ? 'Moneda ' + curId : ''); %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% if (curId && !curMonEnLista && curMonLabel) { %>
                      <option value="<%= curId %>" selected><%= curMonLabel %></option>
                    <% } %>
                    <% (monedas || []).forEach((r) => { %>
                      <% const rid = Number(r.mon_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const code = (r.Codigo ?? r.codigo ?? r.ISO ?? r.Iso ?? r.mon_codigo ?? '').toString().trim().toUpperCase(); %>
                      <% const rname = r.mon_nombre ?? r.Nombre ?? r.Moneda ?? r.descripcion ?? r.Descripcion ?? ('Moneda ' + rid); %>
                      <% const rlabel = code ? (code + ' · ' + rname) : rname; %>
                      <option value="<%= rid %>" data-mon-codigo="<%= code %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'cooperativas') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (cooperativas || []).forEach((r) => { %>
                      <% const rid = Number(r.coop_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.coop_nombre ?? r.Nombre ?? r.nombre ?? ('Cooperativa ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'grupos_compras') { %>
                  <% const curId = Number(_pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (gruposCompras || []).forEach((r) => { %>
                      <% const rid = Number(r.grupcompr_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.grupcompr_nombre ?? r.Nombre ?? r.nombre ?? ('Grupo compras ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'input' && spec.pctDescuento) { %>
                  <% const displayVal = numVal(name); %>
                  <span class="gv-pct-descuento-wrap" style="display:inline-flex; align-items:center; gap:6px; max-width:100%;">
                    <input
                      id="<%= inputId %>"
                      name="<%= name %>"
                      type="text"
                      inputmode="decimal"
                      autocomplete="off"
                      class="gv-input-pct-descuento"
                      value="<%= displayVal %>"
                      placeholder="0"
                      aria-invalid="<%= isMissing ? 'true' : 'false' %>"
                      title="Solo números y separador decimal (porcentaje)"
                    />
                    <span style="font-weight:800; color:var(--gv-muted); font-size:14px;">%</span>
                  </span>
                <% } else { %>
                  <% const type = spec.type || 'text'; %>
                  <% const isNombreField = (label && String(label).indexOf('Nombre / Razón social') !== -1); %>
                  <% const isTelField = (spec.type === 'tel' || /telefono|movil/i.test(String(name))); %>
                  <% const displayVal = (type === 'number') ? numVal(name) : (isTelField && typeof fmtTelefono === 'function') ? fmtTelefono(_pickVal(name)) : _pickVal(name); %>
                  <% const gvBankData = (t.id === 'datos_banco' && !forceReadonly) ? (nl.includes('iban') ? ' data-gv-iban-field="1"' : nl.includes('banco') ? ' data-gv-banco-field="1"' : (nl.includes('swift') || nl.includes('bic') || nl.includes('swift_bic')) ? ' data-gv-swift-field="1"' : '') : ''; %>
                  <input
                    id="<%= inputId %>"
                    name="<%= name %>"
                    type="<%= type %>"
                    <%= required ? 'required' : '' %>
                    value="<%= displayVal %>"
                    aria-invalid="<%= isMissing ? 'true' : 'false' %>"
                    <%= type === 'number' ? 'step="0.01"' : '' %>
                    <% if (isNombreField) { %>data-gv-nombre-field="1"<% } %>
                    <%= gvBankData %>
                  />
                <% } %>

                <% if (isMissing) { %><small class="gv-field-error-msg">Campo obligatorio</small><% } %>
              </label>
            <% }) %>
          </div>
          <% } %>
        </section>
      <% }) %>
    </form>

    <div class="gv-modal-backdrop" id="gvUnsavedBackdrop" hidden></div>
    <div class="gv-modal" id="gvUnsavedModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvUnsavedTitle">
      <div class="gv-modal-card">
        <div class="gv-modal-hd">
          <div class="gv-modal-title" id="gvUnsavedTitle">Salir sin guardar</div>
          <div class="gv-modal-subtitle">Has modificado campos. Si sales ahora, perderás los cambios.</div>
        </div>
        <div class="gv-modal-actions">
          <button type="button" class="btn secondary" id="gvUnsavedStay">Seguir editando</button>
          <a class="btn" href="<%= cancelHref %>" id="gvUnsavedLeave">Salir sin guardar</a>
        </div>
      </div>
    </div>

    <div class="gv-modal-backdrop" id="gvFormatBackdrop" hidden></div>
    <div class="gv-modal" id="gvFormatModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvFormatTitle">
      <div class="gv-modal-card gv-modal-card--format">
        <div class="gv-modal-hd">
          <div class="gv-modal-title" id="gvFormatTitle">¿Es correcto el formato?</div>
          <div class="gv-modal-subtitle" id="gvFormatSubtitle">Para personas se recomienda: Apellido1 Apellido2, Nombre. Para empresas: Nombre de la empresa.</div>
        </div>
        <div class="gv-modal-actions">
          <button type="button" class="btn secondary" id="gvFormatNo">Corregir</button>
          <button type="button" class="btn" id="gvFormatYes">Sí, es correcto</button>
        </div>
      </div>
    </div>

    <% if (mode === 'edit' && cid) { %>
      <div class="gv-modal-backdrop" id="gvRelacionesModalBackdrop" hidden></div>
      <div class="gv-modal" id="gvRelacionesModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvRelacionesModalTitle">
        <div class="gv-modal-card" style="max-width: 640px;">
          <div class="gv-modal-hd">
            <div class="gv-modal-title" id="gvRelacionesModalTitle">Buscar y añadir contactos relacionados</div>
            <div class="gv-modal-subtitle">Escribe para buscar. Selecciona varios y guarda.</div>
          </div>
          <div class="gv-modal-bd" style="padding: 16px;">
            <input type="search" id="gvRelacionesSearch" placeholder="Buscar por nombre, DNI, email..." style="width:100%; padding:10px 14px; margin-bottom:12px; border:1px solid var(--gv-border); border-radius:8px;" />
            <div id="gvRelacionesResults" style="max-height: 280px; overflow-y: auto; display:grid; gap: 8px;"></div>
            <div id="gvRelacionesSelected" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--gv-border);"></div>
          </div>
          <div class="gv-modal-actions" style="display:flex; gap:10px; justify-content:flex-end;">
            <button type="button" class="btn secondary" id="gvRelacionesModalCerrar">Cancelar</button>
            <button type="button" class="btn" id="gvRelacionesModalGuardar">Guardar seleccionados</button>
          </div>
        </div>
      </div>
    <% } %>

    <% if (mode === 'create') { %>
      <div class="gv-modal-backdrop" id="gvDupBackdrop" hidden></div>
      <div class="gv-modal" id="gvDupModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvDupTitle">
        <div class="gv-modal-card" style="max-width: 760px;">
          <div class="gv-modal-hd">
            <div class="gv-modal-title" id="gvDupTitle">Posible duplicado por nombre</div>
            <div class="gv-modal-subtitle">Hay contactos con un nombre parecido (el DNI/CIF no coincide). Revisa si ya existe antes de crear otro registro.</div>
          </div>
          <div class="gv-modal-bd" style="padding: 0 16px 10px 16px;">
            <div id="gvDupList" style="display:grid; gap: 10px;"></div>
            <% if (typeof admin !== 'undefined' && admin) { %>
              <p style="font-size:13px; color:var(--gv-muted); margin: 12px 0 0 0;">
                Para <strong>unificar</strong> varios registros en un solo ID (sincronizar datos), usa
                <a href="/clientes/duplicados">Clientes → Duplicados</a> y fusiona los contactos.
              </p>
            <% } else { %>
              <p style="font-size:13px; color:var(--gv-muted); margin: 12px 0 0 0;">
                Si se trata del mismo cliente con dos fichas, un administrador puede unificarlos en <strong>Clientes → Duplicados</strong> para dejar un solo ID.
              </p>
            <% } %>
          </div>
          <div class="gv-modal-actions" style="display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end;">
            <button type="button" class="btn secondary" id="gvDupContinue">Seguir creando igualmente</button>
            <a class="btn" href="/clientes" id="gvDupCancel">Volver al listado</a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

<style>
.gv-field-admin-only {
  border-left: 3px solid var(--gv-danger, #e53e3e);
  padding-left: 8px;
}
.gv-badge-admin {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  color: #fff;
  background: var(--gv-danger, #e53e3e);
  border-radius: 4px;
  padding: 1px 5px;
  margin-left: 5px;
  vertical-align: middle;
  letter-spacing: 0.03em;
}
</style>

<script>
(function () {
  var form = document.getElementById('gvClienteForm');
  if (!form) return;
  var mode = "<%= mode %>";

  // Tabs
  var tabButtons = Array.prototype.slice.call(document.querySelectorAll('.gv-tab[data-tab]'));
  var panels = Array.prototype.slice.call(document.querySelectorAll('.gv-tabpanel[data-tabpanel]'));
  function setTab(id) {
    tabButtons.forEach(function (b) {
      var active = b.getAttribute('data-tab') === id;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      var active = p.getAttribute('data-tabpanel') === id;
      p.classList.toggle('is-active', active);
    });
  }
  tabButtons.forEach(function (b) {
    b.addEventListener('click', function () {
      setTab(b.getAttribute('data-tab'));
    });
  });
  var hashTab = (window.location.hash || '').replace('#tab_', '');
  var qsTab = (function(){ var m = (window.location.search || '').match(/[?&]tab=([^&]+)/); return m ? m[1] : ''; })();
  var tabToOpen = hashTab || qsTab;
  if (tabToOpen && tabButtons.some(function(b){ return b.getAttribute('data-tab') === tabToOpen; })) {
    setTab(tabToOpen);
  }

  // Tipo Cliente y Especialidad: solo visibles cuando Tipo de contacto = Persona
  var tipoContactoSelect = document.getElementById('gv-tipo-contacto');
  var tipoEspFields = form.querySelectorAll('.gv-field-tipo-esp');
  function toggleTipoEspVisibility() {
    var val = tipoContactoSelect ? String((tipoContactoSelect.options[tipoContactoSelect.selectedIndex] || {}).value || '').trim().toLowerCase() : '';
    var show = val === 'persona';
    tipoEspFields.forEach(function (el) {
      el.style.display = show ? '' : 'none';
    });
  }
  if (tipoContactoSelect) {
    tipoContactoSelect.addEventListener('change', toggleTipoEspVisibility);
    toggleTipoEspVisibility();
  } else if (tipoEspFields.length) {
    tipoEspFields.forEach(function (el) { el.style.display = ''; });
  }

  // Descuento %: solo dígitos y un separador decimal (no letras)
  function sanitizePctDescuento(raw) {
    var s = String(raw || '').replace(/\s/g, '');
    var out = '';
    var hasSep = false;
    for (var i = 0; i < s.length; i++) {
      var ch = s[i];
      if (ch >= '0' && ch <= '9') out += ch;
      else if ((ch === '.' || ch === ',') && !hasSep) {
        hasSep = true;
        out += '.';
      }
    }
    if (out === '.') return '0.';
    return out;
  }
  form.querySelectorAll('.gv-input-pct-descuento').forEach(function (el) {
    el.addEventListener('input', function () {
      var before = el.value;
      var next = sanitizePctDescuento(before);
      if (next !== before) el.value = next;
    });
    el.addEventListener('paste', function (e) {
      e.preventDefault();
      var t = (e.clipboardData || window.clipboardData).getData('text');
      el.value = sanitizePctDescuento(t);
    });
  });

  // Barra de nombre del cliente (encima de pestañas)
  var nameBar = document.getElementById('gvClienteNameBar');
  var nameDisplay = document.getElementById('gvClienteNameDisplay');
  var nameInput = form.querySelector('input[data-gv-nombre-field="1"]') || form.querySelector('input[name="cli_nombre_razon_social"]') || form.querySelector('input[name="Nombre_Razon_Social"]');
  var dniInput = form.querySelector('input[name="cli_dni_cif"]') || form.querySelector('input[name="DNI_CIF"]');
  function isPersonByDniCif(val) {
    var v = String(val || '').trim().toUpperCase().replace(/\s+/g, '').replace(/-/g, '');
    if (!v) return true;
    var cif = /^[ABCDEFGHJNPQRSUVW][0-9]{7}[0-9A-J]$/;
    var dni = /^[0-9]{8}[A-Z]$/;
    var nie = /^[XYZ][0-9]{7}[A-Z]$/;
    if (cif.test(v)) return false;
    return dni.test(v) || nie.test(v);
  }
  function updateNameBar() {
    if (!nameDisplay) return;
    var nom = nameInput ? String(nameInput.value || '').trim() : '';
    nameDisplay.textContent = nom || '—';
  }
  function updateNombrePlaceholder() {
    if (!nameInput) return;
    var isPerson = isPersonByDniCif(dniInput ? dniInput.value : '');
    nameInput.placeholder = isPerson ? 'Apellido1 Apellido2, Nombre' : 'Nombre de la empresa';
  }
  if (nameInput) {
    nameInput.addEventListener('input', updateNameBar);
    nameInput.addEventListener('change', updateNameBar);
  }
  if (dniInput) {
    dniInput.addEventListener('input', updateNombrePlaceholder);
    dniInput.addEventListener('change', updateNombrePlaceholder);
  }
  updateNameBar();
  updateNombrePlaceholder();

  // Modal formato nombre: si no cumple regla, preguntar
  var formatBackdrop = document.getElementById('gvFormatBackdrop');
  var formatModal = document.getElementById('gvFormatModal');
  var formatNo = document.getElementById('gvFormatNo');
  var formatYes = document.getElementById('gvFormatYes');
  var formatPendingBlur = null;
  function looksLikeCorrectFormat(nom, isPerson) {
    var n = String(nom || '').trim();
    if (!n || n.length < 3) return true;
    if (isPerson) return n.indexOf(',') !== -1;
    return true;
  }
  function checkNombreFormat(el) {
    if (!nameInput || !el || el !== nameInput) return;
    var nom = String(nameInput.value || '').trim();
    if (!nom || nom.length < 4) return;
    var isPerson = isPersonByDniCif(dniInput ? dniInput.value : '');
    if (looksLikeCorrectFormat(nom, isPerson)) return;
    formatPendingBlur = el;
    if (formatBackdrop) formatBackdrop.hidden = false;
    if (formatModal) formatModal.hidden = false;
    if (formatNo) formatNo.focus();
  }
  function hideFormatModal() {
    if (formatBackdrop) formatBackdrop.hidden = true;
    if (formatModal) formatModal.hidden = true;
    formatPendingBlur = null;
  }
  if (nameInput) {
    nameInput.addEventListener('blur', function () { checkNombreFormat(this); });
  }
  if (formatBackdrop) formatBackdrop.addEventListener('click', hideFormatModal);
  if (formatNo) formatNo.addEventListener('click', function () { hideFormatModal(); if (nameInput) nameInput.focus(); });
  if (formatYes) formatYes.addEventListener('click', hideFormatModal);

  // Auto-rellenar Población, Provincia, Código País y País al blur en código postal (una sola declaración de elementos)
  var cpInput = form.querySelector('input[name="cli_codigo_postal"], input[name="CodigoPostal"], input[name="codigo_postal"]');
  var poblacionInput = form.querySelector('input[name="cli_poblacion"], input[name="Poblacion"], input[name="poblacion"]');
  var codPaisInput = form.querySelector('input[name="cli_CodPais"], input[name="CodPais"], input[name="codigo_pais"]');
  var provSelect = form.querySelector('select[name="cli_prov_id"], select[name="Id_Provincia"], select[name="id_provincia"]');
  var paisSelect = form.querySelector('select[name="cli_pais_id"], select[name="Id_Pais"], select[name="id_pais"]');
  if (cpInput) {
    var cpTimeout = null;
    function tryProvinciaPaisFromCp() {
      var cp = String(cpInput.value || '').trim().replace(/\s+/g, '');
      if (cp.length < 2) return;
      fetch('/api/provincia-by-cp?cp=' + encodeURIComponent(cp), {
        credentials: 'include',
        headers: { Accept: 'application/json' }
      })
        .then(function (r) {
          if (!r.ok) return null;
          var ct = (r.headers.get('Content-Type') || '').toLowerCase();
          if (ct.indexOf('application/json') === -1) return null;
          return r.json();
        })
        .then(function (json) {
          if (!json || !json.ok) return;
