              var o = document.createElement('option');
              o.value = String(json.provinciaId);
              o.textContent = json.provinciaNombre;
              provSelect.appendChild(o);
              provSelect.value = String(json.provinciaId);
            }
          }
          if (json.paisId && paisSelect) {
            var optPais = paisSelect.querySelector('option[value="' + String(json.paisId) + '"]');
            if (optPais) {
              paisSelect.value = String(json.paisId);
