<%- include('partials/header', { title: mode === 'edit' ? 'Editar cliente' : 'Nuevo cliente' }) %>

<% const missingFieldsList = (typeof missingFields !== 'undefined' && Array.isArray(missingFields)) ? missingFields : []; %>
<% const cid = (typeof clienteId !== 'undefined' && clienteId != null && clienteId !== '') ? clienteId : (item && (item.Id ?? item.id ?? item.cli_id ?? (typeof meta !== 'undefined' && meta && meta.pk ? item[meta.pk] : null))); %>
<% const formAction = (mode === 'edit' && cid) ? ('/clientes/' + cid + '/edit') : '/clientes/new'; %>
<% const cancelHref = (mode === 'edit' && cid) ? ('/clientes/' + cid) : '/clientes'; %>

<section class="card gv-cliente-form" style="max-width: 1080px; margin: 0 auto;">
  <div class="card-hd">
    <h1 class="card-title"><%= mode === 'edit' ? 'Editar cliente' : 'Nuevo cliente' %></h1>
    <p class="card-subtitle">Revisa y completa la ficha del cliente. Puedes moverte por pestañas sin perder cambios.</p>
  </div>
  <div class="card-bd">
    <% if (error) { %>
      <div class="gv-alert gv-alert--warn" style="margin-bottom:12px;"><%= error %></div>
    <% } %>

    <form id="gvClienteForm" method="post" action="<%= formAction %>" class="gv-form" style="display:grid; gap: 12px;">
      <% if (mode === 'create') { %>
        <input type="hidden" name="dup_confirmed" id="gvDupConfirmed" value="0" />
      <% } %>
      <div class="gv-form-actions-sticky">
        <div class="gv-form-actions-sticky__inner">
          <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <a class="btn secondary" href="<%= cancelHref %>" id="gvCancelBtn">Cancelar</a>
            <button class="btn" type="submit" id="gvSaveBtn"><%= mode === 'edit' ? 'Guardar' : 'Crear' %></button>
          </div>
          <div id="gvDirtyHint" class="gv-dirty-hint" style="display:none;">Tienes cambios sin guardar.</div>
        </div>
      </div>

      <div class="gv-cliente-name-bar" id="gvClienteNameBar">
        <span class="gv-cliente-name-bar__label">Contacto:</span>
        <span class="gv-cliente-name-bar__name" id="gvClienteNameDisplay"><%= mode === 'edit' && item ? (item.cli_nombre_razon_social || item.Nombre_Razon_Social || item.Nombre_Cial || item.cli_nombre_cial || '—') : '—' %></span>
      </div>

      <div class="gv-tabs" role="tablist" aria-label="Secciones del contacto">
        <% (tabs || []).forEach((t, idx) => { %>
          <button
            type="button"
            class="gv-tab <%= idx === 0 ? 'is-active' : '' %>"
            role="tab"
            aria-selected="<%= idx === 0 ? 'true' : 'false' %>"
            aria-controls="tab_<%= t.id %>"
            data-tab="<%= t.id %>"
          ><%= t.label %></button>
        <% }) %>
      </div>

      <% const pickVal = (name) => { const v = (item && item[name] !== undefined) ? item[name] : ''; return (v === null || v === undefined) ? '' : String(v); }; %>
      <% const numVal = (name) => { const v = pickVal(name); return v === '' ? '' : v; }; %>
      <% const pickDisplayVal = (name) => { const fn = typeof resolveDisplayValue === 'function' ? resolveDisplayValue : null; const val = fn ? fn(name, item) : pickVal(name); return (val && String(val).trim()) ? String(val).trim() : '—'; }; %>

      <% (tabs || []).forEach((t, idx) => { %>
        <section id="tab_<%= t.id %>" class="gv-tabpanel <%= idx === 0 ? 'is-active' : '' %>" role="tabpanel" data-tabpanel="<%= t.id %>">
          <% if (t.id === 'relaciones' && mode === 'edit' && cid) { %>
            <div class="gv-relaciones-tab">
              <div class="gv-relaciones-tab__hd">
                <h3 class="gv-relaciones-tab__title">Contactos relacionados</h3>
                <p class="gv-relaciones-tab__sub">Vincula este contacto con otros para ver relaciones cruzadas.</p>
                <button type="button" class="btn gv-relaciones-add" id="gvBtnAddRelaciones">Añadir contactos relacionados</button>
              </div>
              <div class="table-wrap gv-relaciones-table-wrap" <%= (!relaciones || relaciones.length === 0) ? 'style="display:none;"' : '' %>>
                <table class="gv-contactos-table gv-relaciones-table">
                  <colgroup>
                    <col class="gv-contactos-col-nombre" />
                    <col class="gv-contactos-col-tipo" />
                    <col class="gv-contactos-col-telefono" />
                    <col class="gv-contactos-col-email" />
                    <col class="gv-contactos-col-contacto" />
                    <col class="gv-contactos-col-provincia" />
                    <col class="gv-contactos-col-estado" />
                    <col class="gv-contactos-col-acciones" />
                  </colgroup>
                  <thead>
                    <tr>
                      <th class="gv-contactos-col-nombre">Nombre / Razón Social</th>
                      <th>Tipo</th>
                      <th class="gv-contactos-col-telefono">Teléfono</th>
                      <th class="gv-contactos-col-email">Email</th>
                      <th class="gv-contactos-col-contacto">Contacto</th>
                      <th>Provincia</th>
                      <th class="gv-contactos-col-estado">Estado</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody id="gvRelacionesList">
                    <% (relaciones || []).forEach((r) => { %>
                      <% const nom = r.relacionado_nombre || r.relacionado_nombre_cial || r.origen_nombre || r.origen_nombre_cial || 'Cliente'; %>
                      <% const tipo = r.relacionado_tipo || r.origen_tipo || '—'; %>
                      <% const tel = String(r.relacionado_telefono || r.relacionado_movil || r.origen_telefono || r.origen_movil || '').trim(); %>
                      <% const email = String(r.relacionado_email || r.origen_email || '').trim(); %>
                      <% const contacto = r.relacionado_nom_contacto || r.origen_nom_contacto || '—'; %>
                      <% const provincia = r.relacionado_provincia || r.origen_provincia || '—'; %>
                      <% const estado = r.relacionado_estado || r.origen_estado || '—'; %>
                      <% const relId = r.clirel_cli_relacionado_id || r.clirel_cli_origen_id; %>
                      <% const origenId = r.clirel_cli_origen_id; %>
                      <% const relacionadoId = r.clirel_cli_relacionado_id; %>
                      <tr class="gv-relacion-row" data-origen="<%= origenId %>" data-relacionado="<%= relacionadoId %>">
                        <td class="gv-contactos-col-nombre"><%= nom %></td>
                        <td><% const tipoClase = (String(tipo).toLowerCase() === 'empresa') ? 'empresa' : (String(tipo).toLowerCase() === 'persona') ? 'persona' : 'otros'; %><span class="gv-badge gv-badge--<%= tipoClase %>"><%= tipo %></span></td>
                        <td class="gv-contactos-col-telefono"><%- include('partials/telefono-display', { telefono: tel }) %></td>
                        <td class="gv-contactos-col-email"><% if (email) { %><a href="mailto:<%= email %>" class="gv-contactos-link"><%= email %></a><% } else { %>—<% } %></td>
                        <td class="gv-contactos-col-contacto"><%= contacto %></td>
                        <td><%= provincia %></td>
                        <td class="gv-contactos-col-estado"><%= estado %></td>
                        <td>
                          <div class="gv-actions">
                            <a class="btn secondary icon" href="/clientes/<%= relId %>" target="_blank" title="Ver" aria-label="Ver contacto <%= relId %>">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                              </svg>
                            </a>
                            <button type="button" class="btn secondary icon gv-remove-relacion" data-origen="<%= origenId %>" data-relacionado="<%= relacionadoId %>" title="Quitar relación" aria-label="Quitar relación">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                              </svg>
                            </button>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <p class="gv-relaciones-empty" id="gvRelacionesEmpty" <%= (relaciones && relaciones.length > 0) ? 'style="display:none;"' : '' %>>
                No hay contactos relacionados. Usa el botón superior para añadirlos.
              </p>
            </div>
          <% } else { %>
          <div class="grid cols-2 gv-form-grid" style="gap: 12px;">
              <% (t.fields || []).forEach((f) => { %>
                <% const name = f.name; %>
                <% const label = f.label; %>
                <% const required = !!f.required; %>
                <% const spec = f.spec || {}; %>
                <% if (spec.kind === 'relaciones') return; %>
                <% const isMissing = missingFieldsList.indexOf(name) !== -1; %>
                <% const inputId = `gv_${String(name).replace(/[^a-zA-Z0-9_-]/g, '_')}`; %>

                <label style="display:grid; gap: 6px;" class="<%= isMissing ? 'gv-field-error' : '' %>">
                  <span style="font-weight:800; color: var(--gv-ink); font-size: 13px;"><%= label %><%= required ? ' *' : '' %></span>

                  <% if (spec.kind === 'readonly') { %>
                    <div class="gv-readonly"><%= pickDisplayVal(name) %></div>
                  <% } else if (spec.kind === 'textarea') { %>
                    <textarea id="<%= inputId %>" name="<%= name %>" rows="4" <%= required ? 'required' : '' %> aria-invalid="<%= isMissing ? 'true' : 'false' %>"><%= pickVal(name) %></textarea>
                  <% } else if (spec.kind === 'checkbox') { %>
                    <input type="hidden" name="<%= name %>" value="0" />
                    <div style="display:flex; align-items:center; gap:10px;">
                      <input id="<%= inputId %>" type="checkbox" name="<%= name %>" value="1" <%= (pickVal(name) === '1' || pickVal(name).toLowerCase() === 'true') ? 'checked' : '' %> />
                      <span style="color: var(--gv-muted); font-weight:700;">Sí</span>
                    </div>
                  <% } else if (spec.kind === 'select' && spec.options === 'ok_ko') { %>
                    <select id="gv-ok-ko" name="<%= name %>">
                      <option value="1" <%= pickVal(name) === '1' ? 'selected' : '' %>>Activo</option>
                      <option value="0" <%= pickVal(name) === '0' ? 'selected' : '' %>>Inactivo</option>
                    </select>
                    <small style="color: var(--gv-muted);">Solo se puede estar activo con DNI/CIF informado.</small>
                  <% } else if (spec.kind === 'select' && spec.options === 'estados_cliente') { %>
                    <% const curId = Number(pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% (estadosCliente || []).forEach((r) => { %>
                        <% const rid = Number(r.estcli_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                        <% const rlabel = r.estcli_nombre ?? r.Nombre ?? r.nombre ?? ('Estado ' + rid); %>
                        <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                      <% }) %>
                    </select>
                    <small style="color: var(--gv-muted);">Si seleccionas Activo sin DNI/CIF válido, se guardará como Potencial.</small>
                  <% } else if (spec.kind === 'select' && spec.options === 'tipo_contacto') { %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">— Seleccionar —</option>
                      <option value="Empresa" <%= pickVal(name) === 'Empresa' ? 'selected' : '' %>>Empresa</option>
                      <option value="Persona" <%= pickVal(name) === 'Persona' ? 'selected' : '' %>>Persona</option>
                      <option value="Otros" <%= pickVal(name) === 'Otros' ? 'selected' : '' %>>Otros</option>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'comerciales') { %>
                    <% const cur = Number(pickVal(name) || 0) || 0; %>
                    <% if (canChangeComercial) { %>
                      <select id="<%= inputId %>" name="<%= name %>">
                        <option value="">(sin asignar)</option>
                        <% (comerciales || []).forEach((c) => { %>
                          <% const cid = Number(c.com_id ?? c.id ?? c.Id ?? 0) || 0; %>
                          <% const cnombre = c.com_nombre ?? c.Nombre ?? ''; %>
                          <% const cemail = c.com_email ?? c.Email ?? c.email ?? ''; %>
                          <option value="<%= cid %>" <%= cid === cur ? 'selected' : '' %>><%= cnombre %> (<%= cemail %>)</option>
                        <% }) %>
                      </select>
                    <% } else { %>
                      <% const comercialAsignado = (comerciales || []).find(function(c){ return Number(c.com_id ?? c.id ?? c.Id ?? 0) === cur; }); %>
                      <div class="gv-readonly"><%= comercialAsignado ? (comercialAsignado.com_nombre ?? comercialAsignado.Nombre ?? '') : 'Sin asignar' %></div>
                      <input type="hidden" name="<%= name %>" value="<%= pickVal(name) %>" />
                    <% } %>
                  <% } else if (spec.kind === 'select' && spec.options === 'tarifas') { %>
                    <% const curTar = Number(pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <% (tarifas || []).forEach((t) => { %>
                        <% const tid = Number(t.tarcli_id ?? t.Id ?? t.id ?? 0) || 0; %>
                        <% const tlabel = t.tarcli_nombre ?? t.NombreTarifa ?? t.Nombre ?? t.nombre ?? ('Tarifa ' + tid); %>
                        <option value="<%= tid %>" <%= tid === curTar ? 'selected' : '' %>><%= tid %> · <%= tlabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'paises') { %>
                    <% const curId = Number(pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% (paises || []).forEach((p) => { %>
                        <% const pid = Number(p.pais_id ?? p.id ?? p.Id ?? p.ID ?? 0) || 0; %>
                        <% const plabel = p.pais_nombre ?? p.Nombre_pais ?? p.Nombre ?? p.nombre ?? p.Pais ?? ('País ' + pid); %>
                        <option value="<%= pid %>" <%= pid === curId ? 'selected' : '' %>><%= plabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'provincias') { %>
                    <% const curId = Number(pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% (provincias || []).forEach((p) => { %>
                        <% const pid = Number(p.prov_id ?? p.id ?? p.Id ?? p.ID ?? 0) || 0; %>
                        <% const plabel = p.prov_nombre ?? p.Nombre_provincia ?? p.Nombre ?? p.nombre ?? p.Provincia ?? ('Provincia ' + pid); %>
                        <option value="<%= pid %>" <%= pid === curId ? 'selected' : '' %>><%= plabel %></option>
                      <% }) %>
                    </select>
                  <% } else if (spec.kind === 'select' && spec.options === 'formas_pago') { %>
                    <% const curId = Number(pickVal(name) || 0) || 0; %>
                    <select id="<%= inputId %>" name="<%= name %>">
                      <option value="">—</option>
                      <% (formasPago || []).forEach((r) => { %>
                        <% const rid = Number(r.formp_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                        <% const rlabel = r.formp_nombre ?? r.FormaPago ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? ('Forma pago ' + rid); %>
                        <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                      <% }) %>
                    </select>
                <% } else if (spec.kind === 'select' && spec.options === 'tipos_clientes') { %>
                  <% const curId = Number(pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (tiposClientes || []).forEach((r) => { %>
                      <% const rid = Number(r.tipc_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.tipc_tipo ?? r.Tipo ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? ('Tipo cliente ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'tipos_clientes_nombre') { %>
                  <% const cur = String(pickVal(name) || '').trim().toLowerCase(); %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (tiposClientes || []).forEach((r) => { %>
                      <% const rlabel = String(r.Tipo ?? r.Nombre ?? r.nombre ?? r.descripcion ?? r.Descripcion ?? '').trim(); %>
                      <% const rval = rlabel; %>
                      <option value="<%= rval %>" <%= (rlabel && rlabel.trim().toLowerCase() === cur) ? 'selected' : '' %>><%= rlabel || '—' %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'idiomas') { %>
                  <% const curId = Number(pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (idiomas || []).forEach((r) => { %>
                      <% const rid = Number(r.idiom_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const code = (r.Codigo ?? r.codigo ?? '').toString().trim(); %>
                      <% const rname = r.idiom_nombre ?? r.Nombre ?? r.Idioma ?? r.descripcion ?? r.Descripcion ?? ('Idioma ' + rid); %>
                      <% const rlabel = code ? (code + ' · ' + rname) : rname; %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'monedas') { %>
                  <% const curId = Number(pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (monedas || []).forEach((r) => { %>
                      <% const rid = Number(r.mon_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const code = (r.Codigo ?? r.codigo ?? r.ISO ?? r.Iso ?? '').toString().trim(); %>
                      <% const rname = r.mon_nombre ?? r.Nombre ?? r.Moneda ?? r.descripcion ?? r.Descripcion ?? ('Moneda ' + rid); %>
                      <% const rlabel = code ? (code + ' · ' + rname) : rname; %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'cooperativas') { %>
                  <% const curId = Number(pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (cooperativas || []).forEach((r) => { %>
                      <% const rid = Number(r.coop_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.coop_nombre ?? r.Nombre ?? r.nombre ?? ('Cooperativa ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else if (spec.kind === 'select' && spec.options === 'grupos_compras') { %>
                  <% const curId = Number(pickVal(name) || 0) || 0; %>
                  <select id="<%= inputId %>" name="<%= name %>">
                    <option value="">—</option>
                    <% (gruposCompras || []).forEach((r) => { %>
                      <% const rid = Number(r.grupcompr_id ?? r.id ?? r.Id ?? r.ID ?? 0) || 0; %>
                      <% const rlabel = r.grupcompr_nombre ?? r.Nombre ?? r.nombre ?? ('Grupo compras ' + rid); %>
                      <option value="<%= rid %>" <%= rid === curId ? 'selected' : '' %>><%= rlabel %></option>
                    <% }) %>
                  </select>
                <% } else { %>
                  <% const type = spec.type || 'text'; %>
                  <% const isNombreField = (label && String(label).indexOf('Nombre / Razón social') !== -1); %>
                  <% const isTelField = (spec.type === 'tel' || /telefono|movil/i.test(String(name))); %>
                  <% const displayVal = (type === 'number') ? numVal(name) : (isTelField && typeof fmtTelefono === 'function') ? fmtTelefono(pickVal(name)) : pickVal(name); %>
                  <input
                    id="<%= inputId %>"
                    name="<%= name %>"
                    type="<%= type %>"
                    <%= required ? 'required' : '' %>
                    value="<%= displayVal %>"
                    aria-invalid="<%= isMissing ? 'true' : 'false' %>"
                    <%= type === 'number' ? 'step="0.01"' : '' %>
                    <%= isNombreField ? 'data-gv-nombre-field="1"' : '' %>
                  />
                <% } %>

                <% if (isMissing) { %><small class="gv-field-error-msg">Campo obligatorio</small><% } %>
              </label>
            <% }) %>
          </div>
          <% } %>
        </section>
      <% }) %>
    </form>

    <div class="gv-modal-backdrop" id="gvUnsavedBackdrop" hidden></div>
    <div class="gv-modal" id="gvUnsavedModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvUnsavedTitle">
      <div class="gv-modal-card">
        <div class="gv-modal-hd">
          <div class="gv-modal-title" id="gvUnsavedTitle">Salir sin guardar</div>
          <div class="gv-modal-subtitle">Has modificado campos. Si sales ahora, perderás los cambios.</div>
        </div>
        <div class="gv-modal-actions">
          <button type="button" class="btn secondary" id="gvUnsavedStay">Seguir editando</button>
          <a class="btn" href="<%= cancelHref %>" id="gvUnsavedLeave">Salir sin guardar</a>
        </div>
      </div>
    </div>

    <div class="gv-modal-backdrop" id="gvFormatBackdrop" hidden></div>
    <div class="gv-modal" id="gvFormatModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvFormatTitle">
      <div class="gv-modal-card gv-modal-card--format">
        <div class="gv-modal-hd">
          <div class="gv-modal-title" id="gvFormatTitle">¿Es correcto el formato?</div>
          <div class="gv-modal-subtitle" id="gvFormatSubtitle">Para personas se recomienda: Apellido1 Apellido2, Nombre. Para empresas: Nombre de la empresa.</div>
        </div>
        <div class="gv-modal-actions">
          <button type="button" class="btn secondary" id="gvFormatNo">Corregir</button>
          <button type="button" class="btn" id="gvFormatYes">Sí, es correcto</button>
        </div>
      </div>
    </div>

    <% if (mode === 'edit' && cid) { %>
      <div class="gv-modal-backdrop" id="gvRelacionesModalBackdrop" hidden></div>
      <div class="gv-modal" id="gvRelacionesModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvRelacionesModalTitle">
        <div class="gv-modal-card" style="max-width: 640px;">
          <div class="gv-modal-hd">
            <div class="gv-modal-title" id="gvRelacionesModalTitle">Buscar y añadir contactos relacionados</div>
            <div class="gv-modal-subtitle">Escribe para buscar. Selecciona varios y guarda.</div>
          </div>
          <div class="gv-modal-bd" style="padding: 16px;">
            <input type="search" id="gvRelacionesSearch" placeholder="Buscar por nombre, DNI, email..." style="width:100%; padding:10px 14px; margin-bottom:12px; border:1px solid var(--gv-border); border-radius:8px;" />
            <div id="gvRelacionesResults" style="max-height: 280px; overflow-y: auto; display:grid; gap: 8px;"></div>
            <div id="gvRelacionesSelected" style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--gv-border);"></div>
          </div>
          <div class="gv-modal-actions" style="display:flex; gap:10px; justify-content:flex-end;">
            <button type="button" class="btn secondary" id="gvRelacionesModalCerrar">Cancelar</button>
            <button type="button" class="btn" id="gvRelacionesModalGuardar">Guardar seleccionados</button>
          </div>
        </div>
      </div>
    <% } %>

    <% if (mode === 'create') { %>
      <div class="gv-modal-backdrop" id="gvDupBackdrop" hidden></div>
      <div class="gv-modal" id="gvDupModal" hidden role="dialog" aria-modal="true" aria-labelledby="gvDupTitle">
        <div class="gv-modal-card" style="max-width: 760px;">
          <div class="gv-modal-hd">
            <div class="gv-modal-title" id="gvDupTitle">Este contacto puede estar ya dado de alta</div>
            <div class="gv-modal-subtitle">Hemos encontrado coincidencias por CIF/NIF o por nombre. Revisa antes de crear un duplicado.</div>
          </div>
          <div class="gv-modal-bd" style="padding: 0 16px 10px 16px;">
            <div id="gvDupList" style="display:grid; gap: 10px;"></div>
          </div>
          <div class="gv-modal-actions" style="display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end;">
            <button type="button" class="btn secondary" id="gvDupContinue">Seguir creando</button>
            <a class="btn" href="/clientes" id="gvDupCancel">Cancelar alta</a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

<script>
(function () {
  var form = document.getElementById('gvClienteForm');
  if (!form) return;
  var mode = "<%= mode %>";

  // Tabs
  var tabButtons = Array.prototype.slice.call(document.querySelectorAll('.gv-tab[data-tab]'));
  var panels = Array.prototype.slice.call(document.querySelectorAll('.gv-tabpanel[data-tabpanel]'));
  function setTab(id) {
    tabButtons.forEach(function (b) {
      var active = b.getAttribute('data-tab') === id;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      var active = p.getAttribute('data-tabpanel') === id;
      p.classList.toggle('is-active', active);
    });
  }
  tabButtons.forEach(function (b) {
    b.addEventListener('click', function () {
      setTab(b.getAttribute('data-tab'));
    });
  });
  var hashTab = (window.location.hash || '').replace('#tab_', '');
  if (hashTab && tabButtons.some(function(b){ return b.getAttribute('data-tab') === hashTab; })) {
    setTab(hashTab);
  }

  // Barra de nombre del cliente (encima de pestañas)
  var nameBar = document.getElementById('gvClienteNameBar');
  var nameDisplay = document.getElementById('gvClienteNameDisplay');
  var nameInput = form.querySelector('input[data-gv-nombre-field="1"]') || form.querySelector('input[name="cli_nombre_razon_social"]') || form.querySelector('input[name="Nombre_Razon_Social"]');
  var dniInput = form.querySelector('input[name="cli_dni_cif"]') || form.querySelector('input[name="DNI_CIF"]');
  function isPersonByDniCif(val) {
    var v = String(val || '').trim().toUpperCase().replace(/\s+/g, '').replace(/-/g, '');
    if (!v) return true;
    var cif = /^[ABCDEFGHJNPQRSUVW][0-9]{7}[0-9A-J]$/;
    var dni = /^[0-9]{8}[A-Z]$/;
    var nie = /^[XYZ][0-9]{7}[A-Z]$/;
    if (cif.test(v)) return false;
    return dni.test(v) || nie.test(v);
  }
  function updateNameBar() {
    if (!nameDisplay) return;
    var nom = nameInput ? String(nameInput.value || '').trim() : '';
    nameDisplay.textContent = nom || '—';
  }
  function updateNombrePlaceholder() {
    if (!nameInput) return;
    var isPerson = isPersonByDniCif(dniInput ? dniInput.value : '');
    nameInput.placeholder = isPerson ? 'Apellido1 Apellido2, Nombre' : 'Nombre de la empresa';
  }
  if (nameInput) {
    nameInput.addEventListener('input', updateNameBar);
    nameInput.addEventListener('change', updateNameBar);
  }
  if (dniInput) {
    dniInput.addEventListener('input', updateNombrePlaceholder);
    dniInput.addEventListener('change', updateNombrePlaceholder);
  }
  updateNameBar();
  updateNombrePlaceholder();

  // Modal formato nombre: si no cumple regla, preguntar
  var formatBackdrop = document.getElementById('gvFormatBackdrop');
  var formatModal = document.getElementById('gvFormatModal');
  var formatNo = document.getElementById('gvFormatNo');
  var formatYes = document.getElementById('gvFormatYes');
  var formatPendingBlur = null;
  function looksLikeCorrectFormat(nom, isPerson) {
    var n = String(nom || '').trim();
    if (!n || n.length < 3) return true;
    if (isPerson) return n.indexOf(',') !== -1;
    return true;
  }
  function checkNombreFormat(el) {
    if (!nameInput || !el || el !== nameInput) return;
    var nom = String(nameInput.value || '').trim();
    if (!nom || nom.length < 4) return;
    var isPerson = isPersonByDniCif(dniInput ? dniInput.value : '');
    if (looksLikeCorrectFormat(nom, isPerson)) return;
    formatPendingBlur = el;
    if (formatBackdrop) formatBackdrop.hidden = false;
    if (formatModal) formatModal.hidden = false;
    if (formatNo) formatNo.focus();
  }
  function hideFormatModal() {
    if (formatBackdrop) formatBackdrop.hidden = true;
    if (formatModal) formatModal.hidden = true;
    formatPendingBlur = null;
  }
  if (nameInput) {
    nameInput.addEventListener('blur', function () { checkNombreFormat(this); });
  }
  if (formatBackdrop) formatBackdrop.addEventListener('click', hideFormatModal);
  if (formatNo) formatNo.addEventListener('click', function () { hideFormatModal(); if (nameInput) nameInput.focus(); });
  if (formatYes) formatYes.addEventListener('click', hideFormatModal);

  // Auto-rellenar provincia al cambiar código postal
  var cpInput = form.querySelector('input[name="cli_codigo_postal"], input[name="CodigoPostal"], input[name="codigo_postal"]');
  var provSelect = form.querySelector('select[name="cli_prov_id"], select[name="Id_Provincia"], select[name="id_provincia"]');
  if (cpInput && provSelect) {
    var cpTimeout = null;
    function tryProvinciaFromCp() {
      var cp = String(cpInput.value || '').trim().replace(/\s+/g, '');
      if (cp.length < 2) return;
      fetch('/api/provincia-by-cp?cp=' + encodeURIComponent(cp), { headers: { Accept: 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (json) {
          if (json && json.ok && json.provinciaId && provSelect) {
            var opt = provSelect.querySelector('option[value="' + String(json.provinciaId) + '"]');
            if (opt) {
              provSelect.value = String(json.provinciaId);
              if (typeof form.dispatchEvent === 'function') {
                form.dispatchEvent(new Event('change', { bubbles: true }));
              }
            }
          }
        })
        .catch(function () {});
    }
    cpInput.addEventListener('blur', tryProvinciaFromCp);
    cpInput.addEventListener('input', function () {
      if (cpTimeout) clearTimeout(cpTimeout);
      cpTimeout = setTimeout(tryProvinciaFromCp, 600);
    });
  }

  // Dirty tracking
  var dirtyHint = document.getElementById('gvDirtyHint');
  var initial = null;
  function snapshot() {
    var fd = new FormData(form);
    var obj = {};
    fd.forEach(function (v, k) {
      // Si hay múltiples entradas con mismo nombre (ej hidden+checkbox), quedarnos con la última
      obj[k] = String(v);
    });
    return obj;
  }
  initial = snapshot();
  function isDirty() {
    var cur = snapshot();
    var keys = Object.keys(initial);
    for (var i = 0; i < keys.length; i++) {
      var k = keys[i];
      if (String(cur[k] || '') !== String(initial[k] || '')) return true;
    }
    // nuevos campos
    var curKeys = Object.keys(cur);
    for (var j = 0; j < curKeys.length; j++) {
      var kk = curKeys[j];
      if (initial[kk] === undefined && String(cur[kk] || '') !== '') return true;
    }
    return false;
  }
  function updateDirtyUi() {
    var d = isDirty();
    if (dirtyHint) dirtyHint.style.display = d ? 'block' : 'none';
  }
  form.addEventListener('input', updateDirtyUi);
  form.addEventListener('change', updateDirtyUi);
  updateDirtyUi();

  // Cancel confirm modal
  var cancelBtn = document.getElementById('gvCancelBtn');
  var backdrop = document.getElementById('gvUnsavedBackdrop');
  var modal = document.getElementById('gvUnsavedModal');
  var stay = document.getElementById('gvUnsavedStay');

  function showModal() {
    if (backdrop) backdrop.hidden = false;
    if (modal) modal.hidden = false;
    if (stay) stay.focus();
  }
  function hideModal() {
    if (backdrop) backdrop.hidden = true;
    if (modal) modal.hidden = true;
  }

  if (cancelBtn) {
    cancelBtn.addEventListener('click', function (e) {
      if (!isDirty()) return;
      e.preventDefault();
      showModal();
    });
  }
  if (backdrop) backdrop.addEventListener('click', hideModal);
  if (stay) stay.addEventListener('click', hideModal);

  // Modal clientes relacionados (solo edit)
  var clienteId = "<%= typeof clienteId !== 'undefined' ? clienteId : '' %>";
  if (mode === 'edit' && clienteId) {
    var searchInput = document.getElementById('gvRelacionesSearch');
    var resultsDiv = document.getElementById('gvRelacionesResults');
    var selectedDiv = document.getElementById('gvRelacionesSelected');
    var btnAdd = document.getElementById('gvBtnAddRelaciones');
    var modalBackdrop = document.getElementById('gvRelacionesModalBackdrop');
    var modal = document.getElementById('gvRelacionesModal');
    var btnCerrar = document.getElementById('gvRelacionesModalCerrar');
    var btnGuardar = document.getElementById('gvRelacionesModalGuardar');
    var selectedIds = {};
    var searchTimeout = null;

    function hideRelModal() {
      if (modalBackdrop) modalBackdrop.hidden = true;
      if (modal) modal.hidden = true;
    }
    function showRelModal() {
      selectedIds = {};
      if (searchInput) searchInput.value = '';
      if (resultsDiv) resultsDiv.innerHTML = '';
      renderSelected();
      if (modalBackdrop) modalBackdrop.hidden = false;
      if (modal) modal.hidden = false;
      if (searchInput) { searchInput.focus(); searchInput.dispatchEvent(new Event('input')); }
    }
    function renderSelected() {
      if (!selectedDiv) return;
      var ids = Object.keys(selectedIds).filter(function(k){ return selectedIds[k]; });
      if (ids.length === 0) { selectedDiv.innerHTML = ''; return; }
      selectedDiv.innerHTML = '<div style="font-weight:800; margin-bottom:8px;">Seleccionados: ' + ids.length + '</div>';
    }
    function renderResults(items) {
      if (!resultsDiv) return;
      if (!items || !items.length) { resultsDiv.innerHTML = '<div style="color:var(--gv-muted); padding:12px;">Sin resultados. Escribe al menos 2 caracteres.</div>'; return; }
      resultsDiv.innerHTML = items.map(function(c) {
        var id = c.cli_id || c.Id || c.id;
        var nom = c.cli_nombre_razon_social || c.Nombre_Razon_Social || c.Nombre_Cial || '';
        var dni = c.cli_dni_cif || c.DNI_CIF || '';
        var email = c.cli_email || c.Email || '';
        var checked = selectedIds[id] ? 'checked' : '';
        return '<label style="display:flex; align-items:center; gap:10px; padding:10px; border:1px solid var(--gv-border); border-radius:8px; cursor:pointer;">' +
          '<input type="checkbox" class="gv-rel-check" data-id="' + id + '" ' + checked + ' />' +
          '<div><div style="font-weight:800;">' + (nom || 'Cliente ' + id) + '</div>' +
          (dni || email ? '<div style="font-size:12px; color:var(--gv-muted);">' + [dni, email].filter(Boolean).join(' · ') + '</div>' : '') + '</div></label>';
      }).join('');
      resultsDiv.querySelectorAll('.gv-rel-check').forEach(function(cb) {
        cb.addEventListener('change', function() {
          selectedIds[this.getAttribute('data-id')] = this.checked;
          renderSelected();
        });
      });
    }
    function doSearch() {
      var q = searchInput ? String(searchInput.value || '').trim() : '';
      if (q.length < 2) { renderResults([]); return; }
      var url = '/api/clientes/buscar?q=' + encodeURIComponent(q) + '&limit=20&exclude=' + encodeURIComponent(clienteId) + '&scope=all';
      fetch(url, { headers: { Accept: 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(json) {
          if (json && json.ok && json.items) renderResults(json.items);
          else renderResults([]);
        })
        .catch(function() { renderResults([]); });
    }
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        if (searchTimeout) clearTimeout(searchTimeout);
        searchTimeout = setTimeout(doSearch, 300);
      });
    }
    if (btnAdd) btnAdd.addEventListener('click', showRelModal);
    if (modalBackdrop) modalBackdrop.addEventListener('click', hideRelModal);
    if (btnCerrar) btnCerrar.addEventListener('click', hideRelModal);
    if (btnGuardar) btnGuardar.addEventListener('click', function() {
      var ids = Object.keys(selectedIds).filter(function(k){ return selectedIds[k]; });
      if (ids.length === 0) { hideRelModal(); return; }
      var items = ids.map(function(id){ return { cliRelacionadoId: Number(id) }; });
      fetch('/api/clientes/' + clienteId + '/relaciones/batch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ items: items })
      })
        .then(function(r) { return r.json().catch(function() { return { ok: false, error: 'Respuesta no válida' }; }); })
        .then(function(json) {
          if (json && json.ok) window.location.reload();
          else alert((json && json.error) ? json.error : 'Error al guardar.');
        })
        .catch(function() { alert('Error de conexión.'); });
    });

    // Quitar relación (DELETE /clientes/:origenId/relaciones/:relacionadoId)
    document.querySelectorAll('.gv-remove-relacion').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var origenId = this.getAttribute('data-origen');
        var relacionadoId = this.getAttribute('data-relacionado');
        if (!origenId || !relacionadoId || !confirm('¿Quitar esta relación?')) return;
        fetch('/api/clientes/' + origenId + '/relaciones/' + relacionadoId, { method: 'DELETE', headers: { Accept: 'application/json' } })
          .then(function(r) { return r.json(); })
          .then(function(json) { if (json && json.ok) window.location.reload(); })
          .catch(function() {});
      });
    });
  }

  // DNI/CIF -> no permitir OK si vacío
  var dni = document.getElementById('gv_DNI_CIF') || document.getElementById('gv-dni-cif');
  var okKo = document.getElementById('gv-ok-ko');
  if (dni && okKo) {
    function sync() {
      var vacio = !String(dni.value || '').trim();
      var opt = okKo.querySelector('option[value=\"1\"]');
      if (opt) opt.disabled = vacio;
      if (vacio && okKo.value === '1') okKo.value = '0';
    }
    dni.addEventListener('input', sync);
    dni.addEventListener('change', sync);
    sync();
  }

  // Duplicados (solo alta)
  if (mode === 'create') {
    var dupBackdrop = document.getElementById('gvDupBackdrop');
    var dupModal = document.getElementById('gvDupModal');
    var dupList = document.getElementById('gvDupList');
    var dupContinue = document.getElementById('gvDupContinue');
    var dupConfirmed = document.getElementById('gvDupConfirmed');

    var lastKeyShown = '';
    var aborter = null;

    function showDupModal() {
      if (dupBackdrop) dupBackdrop.hidden = false;
      if (dupModal) dupModal.hidden = false;
      if (dupContinue) dupContinue.focus();
    }
    function hideDupModal() {
      if (dupBackdrop) dupBackdrop.hidden = true;
      if (dupModal) dupModal.hidden = true;
    }
    if (dupBackdrop) dupBackdrop.addEventListener('click', hideDupModal);
    if (dupContinue) dupContinue.addEventListener('click', function () {
      if (dupConfirmed) dupConfirmed.value = '1';
      hideDupModal();
      // si el usuario estaba intentando guardar, reenviar submit
      try { form.requestSubmit ? form.requestSubmit() : form.submit(); } catch (_) {}
    });

    function debounce(fn, wait) {
      var t = null;
      return function () {
        var args = arguments;
        if (t) window.clearTimeout(t);
        t = window.setTimeout(function () { fn.apply(null, args); }, wait);
      };
    }
    function escapeHtml(s) {
      return String(s || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }
    function normDni(s) {
      return String(s || '')
        .trim()
        .toUpperCase()
        .replace(/\s+/g, '')
        .replace(/-/g, '');
    }
    function normName(s) {
      try {
        return String(s || '')
          .trim()
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .replace(/\s+/g, ' ');
      } catch (_) {
        return String(s || '').trim().toLowerCase().replace(/\s+/g, ' ');
      }
    }
    async function duplicates(dni, nombre, nombreCial) {
      var url = "/api/clientes/duplicates?limit=6"
        + "&dni=" + encodeURIComponent(String(dni || ''))
        + "&nombre=" + encodeURIComponent(String(nombre || ''))
        + "&nombreCial=" + encodeURIComponent(String(nombreCial || ''));
      var opts = { headers: { Accept: 'application/json' } };
      if (aborter) aborter.abort();
      aborter = new AbortController();
      opts.signal = aborter.signal;
      var r = await fetch(url, opts);
      if (!r.ok) throw new Error("HTTP " + r.status);
      var json = await r.json();
      if (!json || json.ok !== true) return [];
      return {
        matches: Array.isArray(json.matches) ? json.matches : [],
        otherCount: Number(json.otherCount || 0) || 0
      };
    }
    function renderMatches(items, otherCount) {
      if (!dupList) return;
      if ((!items || !items.length) && !otherCount) {
        dupList.innerHTML = '<div class="gv-alert gv-alert--warn" style="margin:0;">No se han encontrado coincidencias.</div>';
        return;
      }
      var html = '';
      if (otherCount && (!items || !items.length)) {
        html += '<div class="gv-alert gv-alert--warn" style="margin:0;">Se han detectado coincidencias en otros contactos a los que no tienes acceso (' + escapeHtml(otherCount) + '). Contacta con un administrador.</div>';
      }
      html += (items || []).map(function (it) {
        var id = it.Id || it.id || '';
        var rs = it.Nombre_Razon_Social || it.Nombre || '';
        var nc = it.Nombre_Cial || '';
        var cif = it.DNI_CIF || '';
        var cp = it.CodigoPostal || '';
        var pob = it.Poblacion || '';
        var title = [rs, nc].filter(Boolean).join(' / ') || ('Contacto ' + id);
        var meta = [cif, [cp, pob].filter(Boolean).join(' ')].filter(Boolean).join(' · ');
        return (
          '<div style="display:flex; gap:10px; align-items:flex-start; justify-content:space-between; border:1px solid var(--gv-border); border-radius:12px; padding:12px; background: rgba(255,255,255,.85);">' +
            '<div style="min-width:0;">' +
              '<div style="font-weight:900; color:var(--gv-ink);">' + escapeHtml(id) + ' · ' + escapeHtml(title) + '</div>' +
              (meta ? ('<div style="margin-top:4px; color:var(--gv-muted); font-weight:700;">' + escapeHtml(meta) + '</div>') : '') +
            '</div>' +
            '<div style="display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end;">' +
              '<a class="btn secondary" href="/clientes/' + encodeURIComponent(String(id)) + '">Ver</a>' +
              '<a class="btn" href="/clientes/' + encodeURIComponent(String(id)) + '/edit">Modificar</a>' +
            '</div>' +
          '</div>'
        );
      }).join('');
      dupList.innerHTML = html || '<div class="gv-alert gv-alert--warn" style="margin:0;">No se han encontrado coincidencias.</div>';
    }

    var dniInput = document.getElementById('gv_DNI_CIF');
    var nameInput = document.getElementById('gv_Nombre_Razon_Social');
    var comercialNameInput = document.getElementById('gv_Nombre_Cial');

    var run = debounce(async function () {
      try {
        var dniVal = normDni(dniInput ? dniInput.value : '');
        var nameVal = normName(nameInput ? nameInput.value : '');
        var cialVal = normName(comercialNameInput ? comercialNameInput.value : '');

        var key = [dniVal, nameVal, cialVal].join('|');
        // no re-lanzar si no cambió nada desde que ya lo mostramos
        if (key && key === lastKeyShown) return;

        // Solo lanzar cuando haya señales suficientes
        if (!(dniVal && dniVal.length >= 8) && !(nameVal && nameVal.length >= 6) && !(cialVal && cialVal.length >= 6)) return;

        var result = await duplicates(dniVal, nameVal, cialVal);
        var matches = result.matches || [];
        var otherCount = Number(result.otherCount || 0) || 0;
        if (!matches.length && !otherCount) return;

        lastKeyShown = key;
        renderMatches(matches.slice(0, 6), otherCount);
        showDupModal();
      } catch (_e) {
        // silencioso: no bloquear el alta si falla el lookup
      }
    }, 350);

    [dniInput, nameInput, comercialNameInput].filter(Boolean).forEach(function (el) {
      el.addEventListener('input', run);
      el.addEventListener('change', run);
    });

    // Bloquear submit si hay duplicados y no se ha confirmado aún
    form.addEventListener('submit', async function (e) {
      try {
        if (dupConfirmed && String(dupConfirmed.value) === '1') return;
        var dniVal = normDni(dniInput ? dniInput.value : '');
        var nameVal = normName(nameInput ? nameInput.value : '');
        var cialVal = normName(comercialNameInput ? comercialNameInput.value : '');
        if (!(dniVal && dniVal.length >= 8) && !(nameVal && nameVal.length >= 6) && !(cialVal && cialVal.length >= 6)) return;
        e.preventDefault();
        var result = await duplicates(dniVal, nameVal, cialVal);
        var matches = result.matches || [];
        var otherCount = Number(result.otherCount || 0) || 0;
        if (!matches.length && !otherCount) {
          if (dupConfirmed) dupConfirmed.value = '1'; // no hay duplicados: permitir crear
          try { form.requestSubmit ? form.requestSubmit() : form.submit(); } catch (_) {}
          return;
        }
        renderMatches(matches.slice(0, 6), otherCount);
        showDupModal();
      } catch (_err) {
        // si falla, no bloquear el alta (fallback a validación servidor)
      }
    });

    // Si el servidor re-renderiza con coincidencias, mostrarlas al cargar
    try {
      var serverMatches = <%- JSON.stringify(typeof dupMatches !== 'undefined' ? dupMatches : []) %>;
      var serverOther = <%- JSON.stringify(typeof dupOtherCount !== 'undefined' ? dupOtherCount : 0) %>;
      if ((serverMatches && serverMatches.length) || (serverOther && Number(serverOther) > 0)) {
        renderMatches((serverMatches || []).slice(0, 6), Number(serverOther || 0) || 0);
        showDupModal();
      }
    } catch (_) {}
  }
})();
</script>

<%- include('partials/footer') %>

