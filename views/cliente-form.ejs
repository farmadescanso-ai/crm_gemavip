  function renderDniConflictHtml(matches) {
    if (!matches || !matches.length) return '';
    var rows = matches.slice(0, 8).map(function (it) {
      var id = it.Id || it.id || '';
      var rs = it.Nombre_Razon_Social || it.cli_nombre_razon_social || '';
      var cif = it.DNI_CIF || it.cli_dni_cif || '';
      return '<li><strong>#' + escapeHtml(String(id)) + '</strong> — ' + escapeHtml(rs) + (cif ? ' (' + escapeHtml(cif) + ')' : '') + '</li>';
    }).join('');
    return '<strong>Este DNI/CIF ya está registrado en otro contacto.</strong> No se puede guardar mientras coincida con otro cliente. Corrige el identificador o abre el registro existente.' +
      '<ul style="margin:8px 0 0 18px;">' + rows + '</ul>';
