  // IBAN ES → nombre del banco y SWIFT/BIC (código de entidad = 4 dígitos tras ES + DC IBAN)
  function gvFindBankInputs() {
    var iban =
      form.querySelector('[data-gv-iban-field="1"]') ||
      form.querySelector('.gv-datbanco-iban input') ||
      form.querySelector('input[name="cli_iban"], input[name="cli_IBAN"], input[name="IBAN"], input[name="Cli_Iban"], input[name="Cli_IBAN"]');
    var banco =
      form.querySelector('[data-gv-banco-field="1"]') ||
      form.querySelector('.gv-datbanco-banco input') ||
      form.querySelector('input[name="cli_banco"], input[name="cli_Banco"], input[name="Banco"], input[name="Cli_Banco"]');
    var swift =
      form.querySelector('[data-gv-swift-field="1"]') ||
      (function () {
        var rest = form.querySelectorAll('.gv-datbanco-rest input');
        if (rest.length === 1) return rest[0];
        for (var i = 0; i < rest.length; i++) {
          var nm = String(rest[i].getAttribute('name') || '').toLowerCase();
          if (nm.indexOf('swift') !== -1 || nm.indexOf('bic') !== -1) return rest[i];
        }
        return rest[0] || null;
      })() ||
      form.querySelector('input[name="cli_swift"], input[name="cli_Swift"], input[name="SWIFT"], input[name="SWIFT_BIC"], input[name="Cli_Swift"]');
    return { iban: iban, banco: banco, swift: swift };
  }
  var _gvBank = gvFindBankInputs();
  var ibanInput = _gvBank.iban;
  var bancoInput = _gvBank.banco;
  var swiftInput = _gvBank.swift;
  if (ibanInput) {
    function normIbanStr(s) {
      return String(s || '').replace(/\s+/g, '').toUpperCase();
    }
    function extractEntidadDesdeIbanEs(ibanNorm) {
      if (!/^ES[0-9]{2}/.test(ibanNorm) || ibanNorm.length < 8) return null;
      return ibanNorm.substring(4, 8);
    }
    var ibanBancoTimeout = null;
    function tryBancoSwiftDesdeIban() {
      var bank = gvFindBankInputs();
      var ib = bank.iban;
      if (!ib) return;
      var raw = normIbanStr(ib.value);
      if (raw.length < 8) return;
      var ent = extractEntidadDesdeIbanEs(raw);
      if (!ent || !/^[0-9]{4}$/.test(ent)) return;
      fetch('/api/banco-por-entidad?entidad=' + encodeURIComponent(ent), {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' }
      })
        .then(function (r) {
          if (r.status === 401) return null;
          if (!r.ok) return null;
          var ct = (r.headers.get('Content-Type') || '').toLowerCase();
          if (ct.indexOf('application/json') === -1) return null;
          return r.json();
        })
        .then(function (json) {
          if (!json || !json.ok) return;
          var bank2 = gvFindBankInputs();
          if (json.bancoNombre && bank2.banco) {
            bank2.banco.value = json.bancoNombre;
          }
          if (json.swiftBic && bank2.swift) {
            bank2.swift.value = json.swiftBic;
          }
        })
        .catch(function () {});
    }
    function onIbanBlurOrChange() {
      setTimeout(tryBancoSwiftDesdeIban, 0);
    }
    ibanInput.addEventListener('blur', onIbanBlurOrChange);
    ibanInput.addEventListener('change', onIbanBlurOrChange);
    ibanInput.addEventListener('paste', function () {
      setTimeout(tryBancoSwiftDesdeIban, 10);
    });
    ibanInput.addEventListener('input', function () {
      if (ibanBancoTimeout) clearTimeout(ibanBancoTimeout);
      var rawQuick = normIbanStr(ibanInput.value);
      if (rawQuick.length === 24 && /^ES[0-9]/.test(rawQuick)) {
        tryBancoSwiftDesdeIban();
        return;
      }
      ibanBancoTimeout = setTimeout(tryBancoSwiftDesdeIban, 400);
    });
    // Intro en un input de formulario suele enviar el formulario antes del blur; evitar y rellenar banco/SWIFT
    ibanInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        tryBancoSwiftDesdeIban();
      }
    });
  }

