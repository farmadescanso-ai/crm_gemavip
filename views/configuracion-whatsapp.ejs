<%- include('partials/header', { title: 'Configuración WhatsApp' }) %>

<section class="card">
  <div class="card-hd">
    <h1 class="card-title">Notificaciones por WhatsApp</h1>
    <p class="card-subtitle">Configuración Twilio para enviar avisos cuando lleguen nuevas notificaciones (solicitudes de asignación, pedidos especiales).</p>
  </div>
  <div class="card-bd">
    <p>Las variables se configuran en <strong>Vercel → Settings → Environment Variables</strong> o en Admin → Variables sistema:</p>
    <ul style="margin: 12px 0; padding-left: 24px;">
      <li><code>TWILIO_ACCOUNT_SID</code></li>
      <li><code>TWILIO_AUTH_TOKEN</code></li>
      <li><code>TWILIO_WHATSAPP_FROM</code> (ej. <code>whatsapp:+14155238886</code> en sandbox)</li>
      <li><code>NOTIFY_WHATSAPP_TO</code> (ej. <code>+34610721369</code>)</li>
    </ul>

    <div class="gv-alert info" style="margin: 16px 0;">
      <strong>Estado</strong>
      <div id="gv-wa-status" style="margin-top: 8px;">Cargando...</div>
      <div style="margin-top: 12px; display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
        <button type="button" id="gv-wa-test-btn" class="btn secondary">Enviar mensaje de prueba</button>
        <span id="gv-wa-test-result" style="font-weight: 700;"></span>
      </div>
    </div>

    <p style="margin-top: 16px; color: var(--gv-muted); font-size: 13px;">
      En sandbox de Twilio, el número destinatario debe haber enviado antes un mensaje de activación al número de Twilio.
    </p>
  </div>
</section>

<script>
(function() {
  const statusEl = document.getElementById('gv-wa-status');
  const testBtn = document.getElementById('gv-wa-test-btn');
  const resultEl = document.getElementById('gv-wa-test-result');

  async function loadStatus() {
    try {
      const r = await fetch('/api/whatsapp-status');
      const data = await r.json();
      if (data.configured) {
        statusEl.innerHTML = '✓ Configurado correctamente. Los avisos se enviarán al número configurado en NOTIFY_WHATSAPP_TO.';
      } else {
        const missing = [];
        if (!data.hasAccountSid) missing.push('TWILIO_ACCOUNT_SID');
        if (!data.hasAuthToken) missing.push('TWILIO_AUTH_TOKEN');
        if (!data.hasFrom) missing.push('TWILIO_WHATSAPP_FROM');
        if (!data.hasTo) missing.push('NOTIFY_WHATSAPP_TO');
        statusEl.innerHTML = '✗ No configurado. Faltan: ' + (missing.join(', ') || 'credenciales');
      }
    } catch (e) {
      statusEl.textContent = 'Error: ' + e.message;
    }
  }

  if (testBtn && resultEl) {
    testBtn.addEventListener('click', async () => {
      testBtn.disabled = true;
      resultEl.textContent = 'Enviando...';
      resultEl.style.color = '';
      try {
        const r = await fetch('/api/whatsapp-test');
        const data = await r.json();
        if (data.sent) {
          resultEl.textContent = '✓ Mensaje enviado. Revisa tu WhatsApp.';
          resultEl.style.color = 'var(--gv-success, green)';
        } else {
          resultEl.textContent = '✗ ' + (data.error || 'Error');
          resultEl.style.color = 'var(--gv-error, #b91c1c)';
        }
      } catch (e) {
        resultEl.textContent = '✗ ' + e.message;
        resultEl.style.color = 'var(--gv-error, #b91c1c)';
      }
      testBtn.disabled = false;
    });
  }

  loadStatus();
})();
</script>

<%- include('partials/footer') %>
