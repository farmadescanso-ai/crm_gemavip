<%- include('partials/header', { title: title || 'CPanel' }) %>

<section class="card gv-vista gv-cpanel">
  <div class="card-hd gv-vista-hd">
    <div class="gv-cpanel-kicker">
      <span class="gv-cpanel-badge">Superadmin</span>
      <span class="gv-cpanel-kicker__user"><%= user?.nombre ?? user?.email ?? '—' %></span>
    </div>
    <h1 class="card-title gv-vista-hd__title">CPanel</h1>
    <p class="gv-vista-hd__sub gv-cpanel-sub">
      Herramientas exclusivas del CRM Gemavip: sincronización con Holded y utilidades reservadas.
    </p>
  </div>
  <div class="card-bd">
    <p class="gv-cpanel-intro">
      El acceso a esta zona está limitado al <strong>usuario con id 1</strong>. Desde aquí puedes abrir las herramientas de importación y cruce de datos con Holded.
    </p>
    <div class="gv-cpanel-tools">
      <a href="/cpanel/holded-clientes" class="gv-cpanel-tool">
        <span class="gv-cpanel-tool__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
            <path d="M3 3v5h5" />
            <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
            <path d="M16 16h5v5" />
          </svg>
        </span>
        <span class="gv-cpanel-tool__title">Importar clientes Holded</span>
        <span class="gv-cpanel-tool__desc">Vista previa por tags, provincia mapeada a España (BD), import masivo y export CRM → Holded.</span>
        <span class="gv-cpanel-tool__cta">Abrir herramienta</span>
      </a>
      <a href="/cpanel/holded-comparar" class="gv-cpanel-tool">
        <span class="gv-cpanel-tool__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <line x1="4" y1="8" x2="20" y2="8" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="16" x2="14" y2="16" />
            <circle cx="18" cy="16" r="3" />
          </svg>
        </span>
        <span class="gv-cpanel-tool__title">Comparar CRM ↔ Holded</span>
        <span class="gv-cpanel-tool__desc">Todos los campos del cliente en BD frente a Holded, diff por campo sincronizable y sincronización en ambas direcciones.</span>
        <span class="gv-cpanel-tool__cta">Abrir comparación</span>
      </a>
      <a href="/cpanel/holded-formas-pago" class="gv-cpanel-tool">
        <span class="gv-cpanel-tool__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <rect x="2" y="5" width="20" height="14" rx="2" />
            <line x1="2" y1="10" x2="22" y2="10" />
          </svg>
        </span>
        <span class="gv-cpanel-tool__title">Formas de pago Holded</span>
        <span class="gv-cpanel-tool__desc">Listado desde la API, tabla CRM y SQL sugerido para sincronizar con formas_pago.</span>
        <span class="gv-cpanel-tool__cta">Abrir</span>
      </a>
      <a href="/cpanel/holded-articulos" class="gv-cpanel-tool">
        <span class="gv-cpanel-tool__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
            <path d="M3 6h18" />
            <path d="M16 10a4 4 0 0 1-8 0" />
          </svg>
        </span>
        <span class="gv-cpanel-tool__title">Artículos Holded → CRM</span>
        <span class="gv-cpanel-tool__desc">Catálogo de venta desde Holded: filtra por etiquetas (farmacia, mayorista, etc.) e importa filas seleccionadas a articulos.</span>
        <span class="gv-cpanel-tool__cta">Abrir</span>
      </a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
