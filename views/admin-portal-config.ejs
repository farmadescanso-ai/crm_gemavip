<%- include('partials/header', { title: title || 'Portal' }) %>

<section class="card" style="max-width: 720px; margin: 0 auto;">
  <div class="card-hd">
    <h1 class="card-title">Portal del cliente</h1>
    <p class="card-subtitle">Activa el acceso de clientes y qué áreas del portal pueden verse por defecto. Los datos viven en el CRM Gemavip (sin conectar con CRM externos).</p>
  </div>
  <div class="card-bd">
    <% if (typeof saved !== 'undefined' && saved) { %>
      <div class="gv-alert gv-alert--success" style="margin-bottom:12px;">Guardado.</div>
    <% } %>
    <form method="post" action="/admin/portal-config">
      <%- include('partials/csrf-field') %>
      <label style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
        <input type="checkbox" name="portcfg_activo" value="1" <%= cfg && Number(cfg.portcfg_activo) === 1 ? 'checked' : '' %> />
        <span style="font-weight:700;">Portal activo</span>
      </label>
      <p style="font-weight:800; margin:16px 0 8px;">Visibilidad por defecto</p>
      <label style="display:flex; align-items:center; gap:8px;"><input type="checkbox" name="portcfg_ver_facturas" value="1" <%= !cfg || Number(cfg.portcfg_ver_facturas) !== 0 ? 'checked' : '' %> /> Facturas</label>
      <label style="display:flex; align-items:center; gap:8px;"><input type="checkbox" name="portcfg_ver_pedidos" value="1" <%= !cfg || Number(cfg.portcfg_ver_pedidos) !== 0 ? 'checked' : '' %> /> Pedidos</label>
      <label style="display:flex; align-items:center; gap:8px;"><input type="checkbox" name="portcfg_ver_presupuestos" value="1" <%= !cfg || Number(cfg.portcfg_ver_presupuestos) !== 0 ? 'checked' : '' %> /> Presupuestos</label>
      <label style="display:flex; align-items:center; gap:8px;"><input type="checkbox" name="portcfg_ver_albaranes" value="1" <%= !cfg || Number(cfg.portcfg_ver_albaranes) !== 0 ? 'checked' : '' %> /> Albaranes</label>
      <label style="display:flex; align-items:center; gap:8px;"><input type="checkbox" name="portcfg_ver_catalogo" value="1" <%= cfg && Number(cfg.portcfg_ver_catalogo) === 1 ? 'checked' : '' %> /> Catálogo B2B (cuando exista)</label>
      <label style="display:flex; align-items:center; gap:8px; margin-top:10px;"><input type="checkbox" name="portcfg_stripe_activo" value="1" <%= cfg && Number(cfg.portcfg_stripe_activo) === 1 ? 'checked' : '' %> /> Permitir pago Stripe (cuando esté integrado)</label>
      <div style="margin-top:16px;">
        <button class="btn" type="submit">Guardar</button>
        <a class="btn secondary" href="/dashboard" style="margin-left:8px;">Volver</a>
      </div>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
