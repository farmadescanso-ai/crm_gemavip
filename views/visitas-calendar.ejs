<%- include('partials/header', { title: 'Visitas' }) %>

<% const safeMonth = (typeof month !== 'undefined' && month) ? String(month) : ''; %>
<% const safeInitialDate = (typeof initialDate !== 'undefined' && initialDate) ? initialDate : ''; %>
<% const safeTotalMes = (typeof totalMes !== 'undefined' && totalMes !== null) ? Number(totalMes) : 0; %>
<% const calTabHref = '/visitas?view=calendar' + (safeMonth ? '&month=' + encodeURIComponent(safeMonth) : ''); %>

<section class="card gv-vista dash-card-visitas">
  <div class="card-hd gv-vista-hd">
    <div class="gv-vista-hd__title-row">
      <h1 class="card-title gv-vista-hd__title">Visitas</h1>
      <button type="button" class="gv-vista-hd__info" aria-label="Información" title="Información" data-tooltip="Vista mensual con todas las visitas del mes. Usa Lista para filtrar por fecha o ID y paginar resultados.">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
      </button>
      <span class="gv-vista-hd__tooltip" role="tooltip" id="visitas-cal-tooltip">Vista mensual con todas las visitas del mes. Usa Lista para filtrar por fecha o ID y paginar resultados.</span>
    </div>
    <div class="gv-vista-hd__bar">
      <nav class="gv-vista-tabs" role="tablist" aria-label="Vista de visitas">
        <a class="gv-vista-tab" href="/visitas?view=list" role="tab" aria-selected="false">Lista</a>
        <a class="gv-vista-tab is-active" href="<%= calTabHref %>" role="tab" aria-selected="true">Calendario</a>
      </nav>
      <div class="gv-vista-hd__actions">
        <a class="btn" href="/visitas/new">Nueva visita</a>
      </div>
    </div>
    <p class="gv-vista-hd__sub">
      Calendario · <span class="badge info"><%= safeMonth %></span>
      · Total visitas (mes): <strong style="color: var(--gv-ink);"><%= safeTotalMes %></strong>
    </p>
  </div>
  <div class="card-bd">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" />
    <div id="gv-visitas-calendar" class="gv-visitas-calendar-host" data-initial-date="<%= fmtDateISO(safeInitialDate) %>" style="min-height: 560px;"></div>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script defer src="/assets/scripts/visitas-calendar.js"></script>
  </div>
</section>

<%- include('partials/footer') %>
