<%- include('partials/header', { title: 'Visitas' }) %>

<% const safeMonth = (typeof month !== 'undefined' && month) ? String(month) : ''; %>
<% const safeInitialDate = (typeof initialDate !== 'undefined' && initialDate) ? initialDate : ''; %>
<% const safeTotalMes = (typeof totalMes !== 'undefined' && totalMes !== null) ? Number(totalMes) : 0; %>

<section class="card dash-card-visitas">
  <div class="card-hd">
    <h1 class="card-title">Visitas</h1>
    <p class="card-subtitle" style="color: var(--gv-muted); font-weight: 700;">
      Calendario · <span class="badge info"><%= safeMonth %></span>
      · Total visitas (mes): <strong style="color: var(--gv-ink);"><%= safeTotalMes %></strong>
    </p>
  </div>
  <div class="card-bd">
    <div class="gv-form-actions-sticky gv-no-print" style="margin-bottom: 12px;">
      <div class="gv-form-actions-sticky__inner" style="flex-direction: column; align-items: stretch; gap: 12px;">
        <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 10px;">
          <nav class="gv-tabs" role="tablist" aria-label="Vista de visitas">
            <a class="gv-tab" href="/visitas?view=list" role="tab" aria-selected="false">Lista</a>
            <a class="gv-tab is-active" href="/visitas?view=calendar&month=<%= encodeURIComponent(safeMonth) %>" role="tab" aria-selected="true">Calendario</a>
          </nav>
          <a class="btn" href="/visitas/new">Nueva visita</a>
        </div>
      </div>
    </div>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" />
    <div id="gv-visitas-calendar" class="gv-visitas-calendar-host" data-initial-date="<%= fmtDateISO(safeInitialDate) %>" style="min-height: 560px;"></div>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script defer src="/assets/scripts/visitas-calendar.js"></script>
  </div>
</section>

<%- include('partials/footer') %>
