<%- include('../partials/header', { title: title || 'Facturas', headerVariant: 'portal' }) %>

<section class="card" style="max-width: 960px; margin: 0 auto;">
  <div class="card-hd">
    <h1 class="card-title">Facturas</h1>
    <p class="card-subtitle" style="font-size: 13px; color: var(--gv-muted);">Documentos de facturación disponibles para tu cuenta.</p>
  </div>
  <div class="card-bd">
    <% if (sinHolded) { %>
      <div class="gv-alert gv-alert--warn">No hay facturas disponibles hasta que tu ficha tenga completada la información de facturación en Gemavip. Si crees que falta algo, contacta con tu comercial.</div>
    <% } else if (sinApi) { %>
      <div class="gv-alert gv-alert--warn">El listado de facturas no está disponible en este momento. Inténtalo más tarde o contacta con Gemavip.</div>
    <% } else if (!(docs || []).length) { %>
      <p style="color:var(--gv-muted);">No hay facturas en el periodo consultado.</p>
    <% } else { %>
      <div class="table-wrap">
        <table class="gv-contactos-table">
          <thead><tr><th>Nº</th><th>Fecha</th><th>Total</th><th>PDF</th></tr></thead>
          <tbody>
            <% (docs || []).forEach((d) => { %>
              <tr>
                <td><%- escapeHtml(String(d.docNumber || d.num || d.id || '—')) %></td>
                <td><%= d.date ? (typeof fmtDateES === 'function' ? fmtDateES(new Date(d.date * 1000)) : '') : '—' %></td>
                <td><%- escapeHtml(String(d.total != null ? d.total : '—')) %></td>
                <td><a href="/portal/doc/invoice/<%= d.id %>/pdf" target="_blank" rel="noopener">Descargar</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <div style="margin-top:20px; padding-top:16px; border-top:1px solid rgba(0,0,0,.08);">
      <h3 style="font-size:15px; font-weight:800;">Comentario sobre una factura</h3>
      <p style="font-size:13px; color:var(--gv-muted); margin:4px 0 8px;">Indica el mismo número o referencia que aparece en la tabla.</p>
      <form method="post" action="/portal/comentario" style="display:grid; gap:8px; max-width:480px; margin-top:8px;">
        <%- include('../partials/csrf-field') %>
        <input type="hidden" name="tipo_doc" value="invoice" />
        <input type="hidden" name="redirect" value="/portal/facturas" />
        <label>Nº o referencia del documento <input name="ref_externa" required placeholder="Ej. según la lista" /></label>
        <label>Mensaje <textarea name="mensaje" rows="3" required></textarea></label>
        <button class="btn secondary" type="submit">Enviar comentario</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
