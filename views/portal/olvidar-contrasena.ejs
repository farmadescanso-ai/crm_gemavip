<%- include('../partials/header', { title: title || 'Recuperar', headerVariant: 'login' }) %>

<section class="card login-card" style="max-width: 480px; margin: 2rem auto;">
  <div class="card-hd">
    <h2 class="card-title">Recuperar contraseña</h2>
  </div>
  <div class="card-bd">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="gv-alert gv-alert--warn"><%- escapeHtml(error) %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="gv-alert gv-alert--success"><%- escapeHtml(success) %></div>
    <% } %>
    <form method="post" action="/login-cliente/olvidar-contrasena" style="margin-top:12px;">
      <%- include('../partials/csrf-field') %>
      <label style="display:grid; gap:6px;">
        <span style="font-weight:700; font-size:13px;">Email</span>
        <input type="email" name="email" required />
      </label>
      <button class="btn" type="submit" style="margin-top:12px;">Enviar enlace</button>
    </form>
    <p style="margin-top:14px;"><a href="/login-cliente">Volver al login</a></p>
  </div>
</section>

<%- include('../partials/footer') %>
