<%- include('../partials/header', { title: title || 'Pedido', headerVariant: 'portal' }) %>

<section class="card" style="max-width: 960px; margin: 0 auto;">
  <div class="card-hd" style="display:flex; flex-wrap:wrap; justify-content:space-between; gap:12px; align-items:flex-start;">
    <div>
      <h1 class="card-title" style="margin:0;">Pedido <%- escapeHtml(String(pedido.ped_numero || pedido.NumPedido || pedido.ped_id || '')) %></h1>
      <p class="card-subtitle" style="margin:6px 0 0;"><a href="/portal/pedidos">← Volver</a></p>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <a class="btn secondary" href="/portal/pedidos/<%= pedido.ped_id || pedido.Id %>/print" target="_blank" rel="noopener">Descargar / imprimir</a>
    </div>
  </div>
  <div class="card-bd">
    <% if (typeof portalPedidoEditable !== 'undefined' && !portalPedidoEditable) { %>
      <div class="gv-alert" style="margin-bottom:14px; background:rgba(0,139,210,.08); border:1px solid rgba(0,139,210,.25); color:var(--gv-ink); font-size:14px;">
        Este pedido ya no está en estado <strong>Pendiente</strong>. Solo puedes consultarlo y descargarlo; las modificaciones las realiza Gemavip desde el CRM.
      </div>
    <% } %>
    <p><strong>Fecha:</strong> <%= typeof fmtDateES === 'function' ? fmtDateES(pedido.ped_fecha || pedido.FechaPedido) : '' %></p>
    <p><strong>Estado:</strong> <%- escapeHtml(String(pedido.ped_estado_txt || pedido.Estado || '—')) %></p>
    <% const obs = pedido.ped_observaciones ?? pedido.Observaciones; %>
    <% if (obs && String(obs).trim()) { %>
      <p style="margin-top: 12px;"><strong>Observaciones:</strong><br /><span style="white-space: pre-wrap;"><%- escapeHtml(String(obs)) %></span></p>
    <% } %>
    <% if (lineas && lineas.length) { %>
      <h3 style="font-size:15px; margin:16px 0 8px;">Líneas</h3>
      <div class="table-wrap">
        <table class="gv-contactos-table">
          <thead><tr><th>Artículo</th><th>Cant.</th><th>Precio</th></tr></thead>
          <tbody>
            <% lineas.forEach((l) => { %>
              <tr>
                <td><%- escapeHtml(String(l.art_nombre || l.Descripcion || l.articulo_nombre || '—')) %></td>
                <td><%- escapeHtml(String(l.cantidad ?? l.Cantidad ?? l.pedart_cantidad ?? '—')) %></td>
                <td><%- escapeHtml(String(l.precio ?? l.Precio ?? '—')) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
