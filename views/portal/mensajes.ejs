<%- include('../partials/header', { title: title || 'Mensajes', headerVariant: 'portal' }) %>

<section class="card" style="max-width: 640px; margin: 0 auto;">
  <div class="card-hd">
    <h1 class="card-title">Mensajes a Gemavip</h1>
    <p class="card-subtitle">Tu mensaje llega al equipo interno (cola de notificaciones). Para pedidos o documentos concretos indica referencias si las tienes.</p>
  </div>
  <div class="card-bd">
    <% if (typeof sent !== 'undefined' && sent) { %>
      <div class="gv-alert gv-alert--success" style="margin-bottom: 12px;">Mensaje enviado. Te contactaremos si hace falta.</div>
    <% } %>
    <% if (typeof err !== 'undefined' && err === 'short') { %>
      <div class="gv-alert gv-alert--warn" style="margin-bottom: 12px;">Escribe al menos unas palabras (mínimo 3 caracteres).</div>
    <% } %>
    <% if (typeof err !== 'undefined' && err === 'long') { %>
      <div class="gv-alert gv-alert--warn" style="margin-bottom: 12px;">El mensaje es demasiado largo. Acorta el texto.</div>
    <% } %>
    <% if (typeof err !== 'undefined' && err === 'save') { %>
      <div class="gv-alert gv-alert--warn" style="margin-bottom: 12px;">No se pudo guardar el mensaje. Inténtalo más tarde.</div>
    <% } %>

    <form method="post" action="/portal/mensajes" style="display: grid; gap: 12px;">
      <%- include('../partials/csrf-field') %>
      <label style="display: grid; gap: 6px;">
        <span style="font-weight: 700; font-size: 13px;">Tu mensaje</span>
        <textarea name="mensaje" rows="8" required minlength="3" maxlength="2000" style="width: 100%; padding: 10px; border-radius: 10px; border: 1px solid var(--gv-border); font-size: 14px;" placeholder="Consulta, incidencia o solicitud…"></textarea>
      </label>
      <button class="btn" type="submit" style="justify-content: center;">Enviar</button>
    </form>
    <p style="margin-top: 16px; font-size: 13px; color: var(--gv-muted);">
      <a href="/portal">← Volver al inicio del portal</a>
    </p>
  </div>
</section>

<%- include('../partials/footer') %>
