<%- include('../partials/header', { title: title || 'Portal cliente', headerVariant: 'login' }) %>

<section class="login-hero">
  <div class="login-hero-inner">
    <h1 class="login-title">Portal del cliente</h1>
    <p class="login-subtitle">Consulta pedidos, facturas y documentos de tu cuenta.</p>
  </div>
</section>

<section class="card login-card">
  <div class="card-hd">
    <h2 class="card-title" style="font-size: 20px;">Iniciar sesión</h2>
    <p class="card-subtitle">Email y contraseña de acceso al portal.</p>
  </div>
  <div class="card-bd">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="gv-alert gv-alert--warn"><%- escapeHtml(error) %></div>
      <div style="height: 10px;"></div>
    <% } %>
    <% if (typeof restablecido !== 'undefined' && restablecido) { %>
      <div class="gv-alert gv-alert--success">Contraseña actualizada. Ya puedes entrar.</div>
      <div style="height: 10px;"></div>
    <% } %>

    <form method="post" action="/login-cliente" class="login-form">
      <%- include('../partials/csrf-field') %>
      <% if (typeof returnTo === 'string' && returnTo) { %>
        <input type="hidden" name="returnTo" value="<%- escapeHtml(returnTo) %>" />
      <% } %>
      <label style="display:grid; gap: 6px;">
        <span style="font-weight:700; color: var(--gv-ink); font-size: 13px;">Email</span>
        <input name="email" type="email" autocomplete="username" required />
      </label>
      <label style="display:grid; gap: 6px;">
        <span style="font-weight:700; color: var(--gv-ink); font-size: 13px;">Contraseña</span>
        <input name="password" type="password" autocomplete="current-password" required />
      </label>
      <button class="btn" type="submit" style="width:100%; justify-content:center;">Entrar</button>
    </form>
    <p style="margin-top:14px; font-size:13px;">
      <a href="/login-cliente/olvidar-contrasena">¿Olvidaste tu contraseña?</a>
      · <a href="/login">Acceso comerciales</a>
    </p>
  </div>
</section>

<%- include('../partials/footer') %>
