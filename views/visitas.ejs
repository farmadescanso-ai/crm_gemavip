<%- include('partials/header', { title: 'Visitas' }) %>

<% /* fmtDateES y fmtTimeHM vienen de res.locals (helpers globales) */ %>
<% const hasPaging = (typeof paging !== 'undefined' && paging && typeof paging.total !== 'undefined'); %>
<% const lim = hasPaging && paging.limit ? Number(paging.limit) : 10; %>
<% const tot = hasPaging ? Number(paging.total) : 0; %>
<% const totalPages = hasPaging && lim > 0 ? Math.max(1, Math.ceil(tot / lim)) : 1; %>
<% const pg = hasPaging ? Number(paging.page) || 1 : 1; %>
<% const baseQs = 'view=list&limit=' + encodeURIComponent(String(lim)) + (selectedDate ? '&date=' + encodeURIComponent(selectedDate) : '') + ((typeof id !== 'undefined' && id) ? '&id=' + encodeURIComponent(String(id)) : ''); %>

<section class="card gv-vista dash-card-visitas">
  <div class="card-hd gv-vista-hd">
    <div class="gv-vista-hd__title-row">
      <h1 class="card-title gv-vista-hd__title">Visitas</h1>
      <button type="button" class="gv-vista-hd__info" aria-label="Información" title="Información" data-tooltip="Filtra por fecha o por ID de visita. La lista está paginada; usa el calendario para ver el mes completo.">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
      </button>
      <span class="gv-vista-hd__tooltip" role="tooltip" id="visitas-tooltip">Filtra por fecha o por ID de visita. La lista está paginada; usa el calendario para ver el mes completo.</span>
    </div>
    <div class="gv-vista-hd__bar">
      <nav class="gv-vista-tabs" role="tablist" aria-label="Vista de visitas">
        <a class="gv-vista-tab is-active" href="/visitas?view=list" role="tab" aria-selected="true">Lista</a>
        <a class="gv-vista-tab" href="/visitas?view=calendar" role="tab" aria-selected="false">Calendario</a>
      </nav>
      <div class="gv-vista-hd__actions gv-vista-hd__actions--visitas">
        <form method="get" action="/visitas" class="gv-vista-visitas-filter-form">
          <input type="hidden" name="view" value="list" />
          <input type="hidden" name="limit" value="<%= lim %>" />
          <label for="gv-vis-date" class="gv-vista-visitas-filter-form__label">Fecha</label>
          <input
            id="gv-vis-date"
            type="date"
            name="date"
            value="<%= selectedDate ? selectedDate : '' %>"
            class="gv-client-picker__q gv-vista-visitas-filter-form__input"
          />
          <label for="gv-vis-id" class="gv-vista-visitas-filter-form__label">ID visita</label>
          <input
            id="gv-vis-id"
            type="number"
            name="id"
            min="1"
            placeholder="Ej. 1234"
            value="<%= (typeof id !== 'undefined' && id) ? id : '' %>"
            class="gv-client-picker__q gv-vista-visitas-filter-form__input"
          />
          <button class="btn secondary" type="submit">Filtrar</button>
          <a class="btn secondary" href="/visitas?view=list">Limpiar</a>
        </form>
        <a class="btn" href="/visitas/new">Nueva visita</a>
      </div>
    </div>
    <p class="gv-vista-hd__sub">
      Vista lista
      <% if (hasPaging) { %>
        · Página <%= pg %> de <%= totalPages %> · <%= items.length %> en esta página · Total <%= tot %>
      <% } else { %>
        · <%= items.length %> resultados
      <% } %>
      <% if (selectedDate) { %> · <span class="badge info"><%= selectedDate %></span><% } %>
    </p>
  </div>
  <div class="card-bd">
    <% if (hasPaging && tot > 0) { %>
    <div class="gv-vista-pagination">
      <% if (pg > 1) { %>
        <a class="btn secondary" href="/visitas?<%= baseQs %>&page=<%= pg - 1 %>">← Anterior</a>
      <% } %>
      <span class="gv-vista-pagination__info">
        Página
        <form method="get" action="/visitas" class="gv-vista-pagination__goto" style="display:inline;">
          <input type="hidden" name="view" value="list" />
          <input type="hidden" name="limit" value="<%= lim %>" />
          <% if (selectedDate) { %><input type="hidden" name="date" value="<%= selectedDate %>" /><% } %>
          <% if (typeof id !== 'undefined' && id) { %><input type="hidden" name="id" value="<%= id %>" /><% } %>
          <input type="number" name="page" min="1" max="<%= totalPages %>" value="<%= pg %>" class="gv-vista-pagination__input" aria-label="Ir a página" title="Ir a página" />
          <button type="submit" class="btn secondary icon gv-vista-pagination__btn">Ir</button>
        </form>
        de <%= totalPages %>
      </span>
      <% if ((pg * lim) < tot) { %>
        <a class="btn secondary" href="/visitas?<%= baseQs %>&page=<%= pg + 1 %>">Siguiente →</a>
      <% } %>
    </div>
    <% } %>

    <div class="table-wrap">
      <table class="dash-table">
        <thead>
          <tr>
            <th class="dash-th-actions">Acciones</th>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Hora fin</th>
            <th>Tipo</th>
            <th>Cliente</th>
            <% if (admin) { %><th>Comercial</th><% } %>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          <% if (!items.length) { %>
            <tr>
              <td colspan="<%= admin ? 8 : 7 %>" style="text-align: center; padding: 28px 16px; color: var(--gv-muted); font-weight: 800;">
                No hay visitas con los filtros actuales.
              </td>
            </tr>
          <% } %>
          <% items.forEach((v) => { %>
            <% const vid = v.Id ?? v.vis_id ?? v.id; %>
            <% const est = String(v.Estado ?? v.vis_estado ?? '').trim(); %>
            <% const sl = est.toLowerCase(); %>
            <% const bcls = sl.includes('cancel') || sl.includes('anul') ? 'danger' : (sl.includes('pend') ? 'warn' : (sl.includes('realiz') || sl.includes('complet') || sl.includes('final') || sl.includes('confirm') ? 'ok' : (est ? 'info' : 'info'))); %>
            <tr>
              <td class="dash-td-actions">
                <div class="gv-actions">
                  <a class="btn secondary icon" href="/visitas/<%= vid %>" title="Ver" aria-label="Ver visita <%= vid %>">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </a>
                  <a class="btn secondary icon" href="/visitas/<%= vid %>/edit" title="Editar" aria-label="Editar visita <%= vid %>">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 20h9"></path>
                      <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
                    </svg>
                  </a>
                  <form method="post" action="/visitas/<%= vid %>/delete" onsubmit="return confirm('¿Eliminar esta visita?');">
                    <button class="btn secondary icon danger" type="submit" title="Borrar" aria-label="Borrar visita <%= vid %>">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 6h18"></path>
                        <path d="M8 6V4h8v2"></path>
                        <path d="M19 6l-1 14H6L5 6"></path>
                        <path d="M10 11v6"></path>
                        <path d="M14 11v6"></path>
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
              <td><%= fmtDateES(v.Fecha ?? v.vis_fecha ?? '') %></td>
              <td><%= fmtTimeHM(v.Hora ?? v.vis_hora ?? '') %></td>
              <td><%= fmtTimeHM(v.HoraFinal ?? v.vis_hora_final ?? v.Hora_Final ?? '') %></td>
              <td><%= v.TipoVisita ?? v.vis_tipo ?? '' %></td>
              <td><%= (v.ClienteRazonSocial || v.ClienteNombre || v.cli_nombre_razon_social) ? (v.ClienteRazonSocial || v.ClienteNombre || v.cli_nombre_razon_social) : (v.ClienteId ?? v.vis_cli_id ?? '') %></td>
              <% if (admin) { %>
                <td><%= v.ComercialNombre ?? v.com_nombre ?? (v.ComercialId ?? v.vis_com_id ?? '') %></td>
              <% } %>
              <td>
                <% if (est) { %>
                  <span class="badge <%= bcls %>" style="font-size: 11px; padding: 3px 8px;"><%= est %></span>
                <% } else { %>
                  —
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
