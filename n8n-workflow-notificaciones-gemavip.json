        "jsCode": "const item = $input.first().json;\nconst body = item.body || item;\n\nconst {\n  clienteNombre = '',\n  cli_dni_cif = '',\n  cli_direccion = '',\n  cli_codigo_postal = '',\n  cli_poblacion = '',\n  cli_prov_id_nombre = '',\n  cli_tipc_id_nombre = '',\n  cli_telefono = '',\n  cli_estcli_id_nombre = '',\n  userEmail = ''\n} = body;\n\nconst titulo = '✗ Asignación denegada';\nconst mensaje = 'Se ha denegado tu solicitud de asignación del siguiente cliente.';\nconst colorBorde = '#dc2626';\n\nconst html = `\n<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>${titulo}</title>\n</head>\n<body style=\"margin: 0; padding: 0; font-family: Poppins, Catamaran, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f8f8; color: #1f2a44; line-height: 1.6;\">\n  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 14px; box-shadow: 0 10px 30px rgba(12,20,58,0.10); border: 1px solid #e5e5e5;\">\n    <tr>\n      <td style=\"padding: 32px 40px;\">\n        <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"border-left: 4px solid ${colorBorde}; margin-bottom: 24px;\">\n          <tr>\n            <td style=\"padding-left: 16px;\">\n              <h1 style=\"margin: 0; font-size: 20px; font-weight: 600; color: #0c143a;\">${titulo}</h1>\n              <p style=\"margin: 8px 0 0 0; font-size: 14px; color: #5b667a;\">CRM Gemavip</p>\n            </td>\n          </tr>\n        </table>\n        <p style=\"margin: 0 0 24px 0; font-size: 15px; color: #1f2a44;\">${mensaje}</p>\n        <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"border: 1px solid #e5e5e5; border-radius: 14px; margin-bottom: 24px;\">\n          <tr>\n            <td style=\"padding: 20px; background: linear-gradient(135deg, rgba(239,68,68,0.06) 0%, rgba(220,38,38,0.04) 100%);\">\n              <h2 style=\"margin: 0 0 16px 0; font-size: 17px; font-weight: 600; color: #0c143a;\">${clienteNombre}</h2>\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"font-size: 14px; color: #1f2a44;\">\n                <tr><td style=\"padding: 6px 0; width: 140px; color: #5b667a;\">CIF/NIF</td><td style=\"padding: 6px 0;\">${cli_dni_cif || '—'}</td></tr>\n                <tr><td style=\"padding: 6px 0; color: #5b667a;\">Dirección</td><td style=\"padding: 6px 0;\">${cli_direccion || '—'}</td></tr>\n                <tr><td style=\"padding: 6px 0; color: #5b667a;\">CP / Población</td><td style=\"padding: 6px 0;\">${cli_codigo_postal || ''} ${cli_poblacion || '—'}</td></tr>\n                <tr><td style=\"padding: 6px 0; color: #5b667a;\">Provincia</td><td style=\"padding: 6px 0;\">${cli_prov_id_nombre || '—'}</td></tr>\n                <tr><td style=\"padding: 6px 0; color: #5b667a;\">Tipo</td><td style=\"padding: 6px 0;\">${cli_tipc_id_nombre || '—'}</td></tr>\n                <tr><td style=\"padding: 6px 0; color: #5b667a;\">Teléfono</td><td style=\"padding: 6px 0;\">${cli_telefono || '—'}</td></tr>\n                <tr><td style=\"padding: 6px 0; color: #5b667a;\">Estado</td><td style=\"padding: 6px 0;\">${cli_estcli_id_nombre || '—'}</td></tr>\n              </table>\n            </td>\n          </tr>\n        </table>\n        <p style=\"margin: 0; font-size: 12px; color: #5b667a;\">Correo generado automáticamente por CRM Gemavip.</p>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>\n`;\n\nreturn [{\n  json: {\n    html,\n    subject: titulo,\n    to: userEmail\n  }\n}];"
